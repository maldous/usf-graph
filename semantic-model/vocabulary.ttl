<urn:usf:namingrule:eightdigitfamilyslug> a usf:NamingRule;
    usf:canonicalName "eightdigitfamilyslug";
    usf:filenamePattern "^[0-9]{8}-[a-z0-9]+(?:-[a-z0-9]+)*(?:\\.[a-z0-9]+)+$".
<urn:usf:namingrule:languagenative> a usf:NamingRule;
    usf:canonicalName "languagenative";
    usf:filenamePattern "^[A-Za-z0-9._-]+$".
<urn:usf:namingrule:digestidentity> a usf:NamingRule;
    usf:canonicalName "digestidentity";
    usf:filenamePattern "^sha256:[0-9a-f]{64}$".
<urn:usf:namingrule:canonicalfixed> a usf:NamingRule;
    usf:canonicalName "canonicalfixed";
    usf:filenamePattern "^[A-Za-z0-9._-]+$".
<urn:usf:namingrule:providernative> a usf:NamingRule;
    usf:canonicalName "providernative";
    usf:filenamePattern "^[^\\x00]+$".
