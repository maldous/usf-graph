rung:discovery a usf:ProofRung;
    usf:canonicalName "discovery";
    usf:rungOrder 0.
rung:executable a usf:ProofRung;
    usf:canonicalName "executable";
    usf:rungOrder 1;
    usf:higherRungThan rung:discovery.
rung:contract a usf:ProofRung;
    usf:canonicalName "contract";
    usf:rungOrder 2;
    usf:higherRungThan rung:executable.
rung:behaviour a usf:ProofRung;
    usf:canonicalName "behaviour";
    usf:rungOrder 3;
    usf:higherRungThan rung:contract.
rung:substrate a usf:ProofRung;
    usf:canonicalName "substrate";
    usf:rungOrder 4;
    usf:higherRungThan rung:behaviour.
rung:resilience a usf:ProofRung;
    usf:canonicalName "resilience";
    usf:rungOrder 5;
    usf:higherRungThan rung:substrate.
rung:foundation a usf:ProofRung;
    usf:canonicalName "foundation";
    usf:rungOrder 6;
    usf:higherRungThan rung:resilience.
<urn:usf:ontology> usf:deliveredMinimumRung rung:behaviour;
    usf:liveMinimumRung rung:substrate.
pmode:deterministictestsubstitute a usf:ProviderMode;
    usf:canonicalName "deterministictestsubstitute";
    usf:definition "A repository-local, contract-faithful provider substitute whose inputs, time, randomness, persistence, failure injection and reset behaviour are explicit and deterministic for development and test; it never establishes staging or live-provider readiness.".
pmode:repositorylocalservice a usf:ProviderMode;
    usf:canonicalName "repositorylocalservice";
    usf:definition "A production-shaped provider implementation whose complete source, configuration, persistence and recovery behaviour are repository-local and exercised without a live external dependency.".
pmode:externalsandbox a usf:ProviderMode;
    usf:canonicalName "externalsandbox";
    usf:definition "A real external provider in a non-production sandbox tenant.".
pmode:liveexternal a usf:ProviderMode;
    usf:canonicalName "liveexternal";
    usf:definition "A real external provider in production.".
pmode:liveauthoritycontrol a usf:ProviderMode;
    usf:canonicalName "liveauthoritycontrol";
    usf:definition "The live external semantic control plane; its use proves authority operations only and makes no product-production claim.".
