ars:reachable a usf:ActionReachabilityState; usf:canonicalName "reachable"; usf:definition "An exact unconditional authority path reaches the action.".
ars:conditionallyreachable a usf:ActionReachabilityState; usf:canonicalName "conditionallyreachable"; usf:definition "The action is reachable only while its finite condition profile is satisfied.".
ars:delegatedonly a usf:ActionReachabilityState; usf:canonicalName "delegatedonly"; usf:definition "Only an explicit bounded delegation reaches the action.".
ars:serviceidentityonly a usf:ActionReachabilityState; usf:canonicalName "serviceidentityonly"; usf:definition "Only a declared service identity reaches the action.".
ars:breakglassonly a usf:ActionReachabilityState; usf:canonicalName "breakglassonly"; usf:definition "Only the controlled break-glass path reaches the action.".
ars:forbidden a usf:ActionReachabilityState; usf:canonicalName "forbidden"; usf:definition "Current authority explicitly forbids every path to the action.".
ars:notapplicable a usf:ActionReachabilityState; usf:canonicalName "notapplicable"; usf:definition "The action is semantically inapplicable to the role and capability under an explicit proof.".
ars:unresolved a usf:ActionReachabilityState; usf:canonicalName "unresolved"; usf:definition "Current authority does not yet warrant a positive, negative or inapplicable reachability result.".

ftc:tenantowned a usf:FieldTenancyClassification; usf:canonicalName "tenantowned"; usf:definition "The field value is owned within one tenant boundary.".
ftc:platformowned a usf:FieldTenancyClassification; usf:canonicalName "platformowned"; usf:definition "The field value is owned by the platform control boundary.".
ftc:sharedreference a usf:FieldTenancyClassification; usf:canonicalName "sharedreference"; usf:definition "The field is a controlled shared reference and carries no tenant-owned payload.".
fm:immutable a usf:FieldMutability; usf:canonicalName "immutable"; usf:definition "The field is immutable after creation.".
fm:mutable a usf:FieldMutability; usf:canonicalName "mutable"; usf:definition "The field may change through explicitly authorised operations.".
fm:appendonly a usf:FieldMutability; usf:canonicalName "appendonly"; usf:definition "The field may only be appended under the owning transaction semantics.".

stk:fixedinstant a usf:ScheduleTriggerKind; usf:canonicalName "fixedinstant"; usf:definition "One scheduled execution at an explicit instant.".
stk:recurringcalendar a usf:ScheduleTriggerKind; usf:canonicalName "recurringcalendar"; usf:definition "Recurring scheduled execution selected by a finite calendar expression.".
stk:recurringinterval a usf:ScheduleTriggerKind; usf:canonicalName "recurringinterval"; usf:definition "Recurring scheduled execution selected by a bounded interval.".
stk:conditionaldueinstant a usf:ScheduleTriggerKind; usf:canonicalName "conditionaldueinstant"; usf:definition "A workflow request is immediately executable unless it carries an explicit due instant, in which case durable scheduled execution is required.".

pc:public a usf:PrivacyClassification; usf:canonicalName "public"; usf:definition "Information intentionally exposed to unauthenticated or public recipients.".
pc:internal a usf:PrivacyClassification; usf:canonicalName "internal"; usf:definition "Information limited to authenticated foundation participants.".
pc:confidential a usf:PrivacyClassification; usf:canonicalName "confidential"; usf:definition "Information requiring explicit permission and bounded disclosure.".
pc:secret a usf:PrivacyClassification; usf:canonicalName "secret"; usf:definition "Secret material that must never be returned through ordinary read, list, search or export surfaces.".
pc:personal a usf:PrivacyClassification; usf:canonicalName "personal"; usf:definition "Personal information identifying or describing an individual.".
pc:sensitivepersonal a usf:PrivacyClassification; usf:canonicalName "sensitivepersonal"; usf:definition "Sensitive personal information requiring stronger access, audit and retention controls.".
pc:authenticationsecret a usf:PrivacyClassification; usf:canonicalName "authenticationsecret"; usf:definition "Credential or authentication secret material.".
pc:financial a usf:PrivacyClassification; usf:canonicalName "financial"; usf:definition "Financial or payment-related information.".
pc:audit a usf:PrivacyClassification; usf:canonicalName "audit"; usf:definition "Audit evidence whose integrity and bounded access must be preserved.".

