@prefix usf: <urn:usf:ontology:>.
@prefix pcd: <urn:usf:permutationclosuredisposition:>.
@prefix frd: <urn:usf:familyreviewdisposition:>.
@prefix rpdk: <urn:usf:rolepermissiondispositionkind:>.
@prefix pk: <urn:usf:principalkind:>.
@prefix rsk: <urn:usf:resourceselectorkind:>.
@prefix osc: <urn:usf:operationalsurfaceclassification:>.
@prefix pdr: <urn:usf:permutationdispositionreason:>.
@prefix pcr: <urn:usf:permutationclosurerepresentation:>.
@prefix dvss: <urn:usf:dimensionvaluesourcescope:>.
@prefix ppc: <urn:usf:permutationparticipationclassification:>.
@prefix pabc: <urn:usf:permutationaxisbindingclassification:>.
@prefix pfcc: <urn:usf:permutationfamilycandidateclassification:>.
@prefix pfmrd: <urn:usf:permutationfamilymodelreviewdisposition:>.
@prefix acp: <urn:usf:authorisationconditionprofile:>.
@prefix acc: <urn:usf:authorisationconditionclause:>.
@prefix acpred: <urn:usf:authorisationconditionpredicate:>.
@prefix acop: <urn:usf:authorisationconditionoperator:>.
@prefix accomp: <urn:usf:authorisationconditioncomposition:>.
@prefix ars: <urn:usf:actionreachabilitystate:>.
@prefix ftc: <urn:usf:fieldtenancyclassification:>.
@prefix fm: <urn:usf:fieldmutability:>.
@prefix pc: <urn:usf:privacyclassification:>.
@prefix tpt: <urn:usf:tokenprofiletemplate:>.
@prefix tcct: <urn:usf:tokenclaimconstrainttemplate:>.
@prefix stk: <urn:usf:scheduletriggerkind:>.
@prefix pfp: <urn:usf:permutationfamilyplane:>.
@prefix pao: <urn:usf:permutationapplicabilityoperator:>.
@prefix ppd: <urn:usf:permutationpathdirection:>.
@prefix psa: <urn:usf:permutationsignalaggregation:>.
@prefix par: <urn:usf:permutationapplicabilityreason:>.
@prefix ta: <urn:usf:tokenaudience:>.
@prefix tic: <urn:usf:tokenissuerclass:>.
@prefix asr: <urn:usf:authenticationstrengthrequirement:>.
@prefix popr: <urn:usf:proofofpossessionrequirement:>.
@prefix tlp: <urn:usf:tokenlifetimepolicy:>.
@prefix rvp: <urn:usf:revocationpolicy:>.
@prefix dc: <urn:usf:delegationconstraint:>.
@prefix tptsb: <urn:usf:tokenprofiletemplatesecuritybinding:>.
@prefix ccp: <urn:usf:classclosurepolicy:>.

<urn:usf:graph:permutation-vocabulary> {
ccp:exactdeclaredclass a usf:PermutationClassClosurePolicy;
    usf:canonicalName "exactdeclaredclass";
    usf:definition "The closure contains only its explicitly named root class. This policy is selected explicitly and is never an omitted-policy default.".
ccp:declaredtransitivesubclass a usf:PermutationClassClosurePolicy;
    usf:canonicalName "declaredtransitivesubclass";
    usf:definition "The closure contains its root and every named class reachable downwards through one or more declared rdfs:subClassOf edges. Blank-node expressions, upward supertype inference and cycles are prohibited.".

pcr:sparsesymbolic a usf:PermutationClosureRepresentation;
    usf:canonicalName "sparsesymbolic";
    usf:definition "The complete raw Cartesian universe remains a reproducible digest-bound external projection; required and allowed operational points may be RDF cells, forbidden and not-applicable regions require authority-backed symbolic rules, and deferred or unresolved regions remain explicit non-authorising digest commitments.".

pfp:runtimebehaviour a usf:PermutationFamilyPlane;
    usf:canonicalName "runtimebehaviour";
    usf:definition "Product, operator or control-plane behaviour that must have an executing runtime owner.".
pfp:assuranceobligation a usf:PermutationFamilyPlane;
    usf:canonicalName "assuranceobligation";
    usf:definition "Evidence, proof, validation or readiness behaviour whose owner validates rather than executes product runtime.".

pao:true a usf:PermutationApplicabilityOperator; usf:canonicalName "true"; usf:definition "The registered subject class is always applicable.".
pao:allof a usf:PermutationApplicabilityOperator; usf:canonicalName "allof"; usf:definition "Every ordered operand clause must hold.".
pao:anyof a usf:PermutationApplicabilityOperator; usf:canonicalName "anyof"; usf:definition "At least one ordered operand clause must hold.".
pao:not a usf:PermutationApplicabilityOperator; usf:canonicalName "not"; usf:definition "The single operand clause must not hold.".
pao:countatleast a usf:PermutationApplicabilityOperator; usf:canonicalName "countatleast"; usf:definition "The registered selector must yield at least the non-negative threshold.".
pao:countexactly a usf:PermutationApplicabilityOperator; usf:canonicalName "countexactly"; usf:definition "The registered selector must yield exactly the non-negative threshold.".
pao:valueequals a usf:PermutationApplicabilityOperator; usf:canonicalName "valueequals"; usf:definition "The selector result must equal the single declared value.".
pao:valueindeclaredset a usf:PermutationApplicabilityOperator; usf:canonicalName "valueindeclaredset"; usf:definition "At least one selector result must belong to the finite declared value set.".

ppd:outbound a usf:PermutationPathDirection; usf:canonicalName "outbound".
ppd:inbound a usf:PermutationPathDirection; usf:canonicalName "inbound".
psa:distinctvalues a usf:PermutationSignalAggregation; usf:canonicalName "distinctvalues".
psa:countdistinct a usf:PermutationSignalAggregation; usf:canonicalName "countdistinct".

par:subjectclassmismatch a usf:PermutationApplicabilityReason; usf:canonicalName "subjectclassmismatch"; usf:definition "The resource is not an instance of the family's registered subject class.".
par:nointerfacesdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "nointerfacesdeclared".
par:nooperationsdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "nooperationsdeclared".
par:nopermissionatomsdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "nopermissionatomsdeclared".
par:nostatesdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "nostatesdeclared".
par:notransitionsdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "notransitionsdeclared".
par:noportsdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noportsdeclared".
par:noexternaldependenciesdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noexternaldependenciesdeclared"; usf:definition "The capability has no explicit ExternalDependency reachable through its contract ports; port presence alone does not activate the family.".
par:noeventsdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noeventsdeclared".
par:nodatamodelsdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "nodatamodelsdeclared".
par:noconfigurationkeysdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noconfigurationkeysdeclared".
par:nosecretconfigurationkeysdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "nosecretconfigurationkeysdeclared".
par:nouisurfacesdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "nouisurfacesdeclared".
par:noformsdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noformsdeclared".
par:noworkflowsdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noworkflowsdeclared".
par:noprotocolsurfacesdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noprotocolsurfacesdeclared".
par:componentoptionabsent a usf:PermutationApplicabilityReason;
    usf:canonicalName "componentoptionabsent";
    usf:definition "The option component has no owning composed realisation option and therefore cannot participate in composition coverage.".

ta:foundationapi a usf:TokenAudience; usf:canonicalName "foundationapi"; usf:definition "A first-party foundation API surface.".
ta:tenantservice a usf:TokenAudience; usf:canonicalName "tenantservice"; usf:definition "A named tenant-scoped service audience.".
ta:externalcallback a usf:TokenAudience; usf:canonicalName "externalcallback"; usf:definition "A bounded external callback audience selected by an admitted provider binding.".
tic:platformidentityauthority a usf:TokenIssuerClass; usf:canonicalName "platformidentityauthority"; usf:definition "The platform's selected identity-authority class.".
tic:workloadidentityauthority a usf:TokenIssuerClass; usf:canonicalName "workloadidentityauthority"; usf:definition "An issuer class dedicated to non-human workload identities.".
tic:externalfederatedauthority a usf:TokenIssuerClass; usf:canonicalName "externalfederatedauthority"; usf:definition "An explicitly trusted federated issuer class.".
asr:authenticated a usf:AuthenticationStrengthRequirement; usf:canonicalName "authenticated"; usf:definition "A currently authenticated principal is required.".
asr:strongauthentication a usf:AuthenticationStrengthRequirement; usf:canonicalName "strongauthentication"; usf:definition "A phishing-resistant or equivalently strong authentication method is required.".
asr:multifactor a usf:AuthenticationStrengthRequirement; usf:canonicalName "multifactor"; usf:definition "Two independently controlled authentication factors are required.".
popr:bearerpermitted a usf:ProofOfPossessionRequirement; usf:canonicalName "bearerpermitted"; usf:definition "Bearer presentation is permitted only where the selected profile and risk policy allow it.".
popr:confirmationkeyrequired a usf:ProofOfPossessionRequirement; usf:canonicalName "confirmationkeyrequired"; usf:definition "The token must be cryptographically bound to a confirmation key presented by the caller.".
tlp:boundedaccess a usf:TokenLifetimePolicy; usf:canonicalName "boundedaccess"; usf:definition "A bounded access-token lifetime with refresh governed separately."; usf:maximumLifetimeSeconds 3600; usf:refreshable true.
tlp:boundedservice a usf:TokenLifetimePolicy; usf:canonicalName "boundedservice"; usf:definition "A bounded workload-token lifetime requiring periodic re-issuance."; usf:maximumLifetimeSeconds 900; usf:refreshable false.
tlp:shortlivedoperator a usf:TokenLifetimePolicy; usf:canonicalName "shortlivedoperator"; usf:definition "A short-lived non-refreshable operator-token lifetime."; usf:maximumLifetimeSeconds 600; usf:refreshable false.
tlp:shortlivedbreakglass a usf:TokenLifetimePolicy; usf:canonicalName "shortlivedbreakglass"; usf:definition "A short-lived non-refreshable emergency-token lifetime."; usf:maximumLifetimeSeconds 300; usf:refreshable false.
rvp:revocablebeforeexpiry a usf:RevocationPolicy; usf:canonicalName "revocablebeforeexpiry"; usf:definition "The issuer can revoke the token before its bounded expiry.".
rvp:boundedexpirynorefresh a usf:RevocationPolicy; usf:canonicalName "boundedexpirynorefresh"; usf:definition "The token cannot be refreshed and expires within its bounded lifetime.".
dc:delegationprohibited a usf:DelegationConstraint; usf:canonicalName "delegationprohibited"; usf:definition "No actor may exchange or delegate the token.".
dc:boundeddelegation a usf:DelegationConstraint; usf:canonicalName "boundeddelegation"; usf:definition "Delegation is permitted only through a bounded, auditable delegation chain.".
<urn:usf:eventdeliveryform:messageenvelope> a usf:EventDeliveryForm; usf:canonicalName "messageenvelope"; usf:definition "The event is carried in one explicitly modelled Message envelope.".
<urn:usf:eventdeliveryform:directnotification> a usf:EventDeliveryForm; usf:canonicalName "directnotification"; usf:definition "The event is delivered directly without a separately modelled Message envelope.".
par:eventdirectnotification a usf:PermutationApplicabilityReason; usf:canonicalName "eventdirectnotification"; usf:definition "The event explicitly uses direct-notification delivery, so a Message-envelope family is not applicable.".
par:nocomponentproviderbindingdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "nocomponentproviderbindingdeclared"; usf:definition "The option component has no explicit provider binding; absence does not create provider semantics.".
par:noeventpermissionsdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noeventpermissionsdeclared"; usf:definition "The event declares no permission profile; absence does not invent an event permission requirement.".
par:noauditeventsdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noauditeventsdeclared"; usf:definition "The operation declares no emitted audit event; absence does not create an audit-event relationship.".
par:nocomponentdependencydeclared a usf:PermutationApplicabilityReason; usf:canonicalName "nocomponentdependencydeclared"; usf:definition "The option component has no explicit dependency edge; absence does not create a dependency permutation.".
par:mappingtargetkindmismatch a usf:PermutationApplicabilityReason; usf:canonicalName "mappingtargetkindmismatch"; usf:definition "The concrete mapping selects another controlled target kind, so this target-specific mapping family is not applicable.".
par:noprocessserviceidentitydeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noprocessserviceidentitydeclared"; usf:definition "The deployable process has no explicit service-identity binding; absence does not invent an execution identity.".
par:noreachabilityroledeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noreachabilityroledeclared"; usf:definition "The action-reachability record is expressed for another principal form and has no explicit role binding.".
par:noreachabilityprincipalkinddeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noreachabilityprincipalkinddeclared"; usf:definition "The action-reachability record is expressed for another principal form and has no explicit principal-kind binding.".
par:noreachabilitypermissionatomdeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noreachabilitypermissionatomdeclared"; usf:definition "The reachability state has no admitted permission-atom path; absence must not create a grant.".
par:noreachabilityconditionprofiledeclared a usf:PermutationApplicabilityReason; usf:canonicalName "noreachabilityconditionprofiledeclared"; usf:definition "The reachability state has no explicit conditional-authorisation profile.".
tptsb:accesstoken a usf:TokenProfileTemplateSecurityBinding; usf:canonicalName "accesstoken"; usf:securityBindingForTokenProfileTemplate tpt:accesstoken; usf:securityBindingIssuerClass tic:platformidentityauthority; usf:securityBindingAudience ta:foundationapi; usf:securityBindingLifetimePolicy tlp:boundedaccess; usf:securityBindingAuthenticationStrength asr:authenticated; usf:securityBindingProofOfPossession popr:bearerpermitted; usf:securityBindingRevocationPolicy rvp:revocablebeforeexpiry; usf:securityBindingDelegationConstraint dc:delegationprohibited; usf:tokenProfileTemplateSecurityBindingDigest "sha256:861cb1189cd7964448af7664a616a954048daf917868fc2755f9b69414b3963e".
tptsb:servicetoken a usf:TokenProfileTemplateSecurityBinding; usf:canonicalName "servicetoken"; usf:securityBindingForTokenProfileTemplate tpt:servicetoken; usf:securityBindingIssuerClass tic:workloadidentityauthority; usf:securityBindingAudience ta:tenantservice; usf:securityBindingLifetimePolicy tlp:boundedservice; usf:securityBindingAuthenticationStrength asr:strongauthentication; usf:securityBindingProofOfPossession popr:confirmationkeyrequired; usf:securityBindingRevocationPolicy rvp:boundedexpirynorefresh; usf:securityBindingDelegationConstraint dc:delegationprohibited; usf:tokenProfileTemplateSecurityBindingDigest "sha256:6ba252ff82ccf99e4190337692728525de4db2311d405adc3012e6dc87e130fa".
tptsb:delegatedtoken a usf:TokenProfileTemplateSecurityBinding; usf:canonicalName "delegatedtoken"; usf:securityBindingForTokenProfileTemplate tpt:delegatedtoken; usf:securityBindingIssuerClass tic:platformidentityauthority; usf:securityBindingAudience ta:tenantservice; usf:securityBindingLifetimePolicy tlp:boundedaccess; usf:securityBindingAuthenticationStrength asr:strongauthentication; usf:securityBindingProofOfPossession popr:confirmationkeyrequired; usf:securityBindingRevocationPolicy rvp:revocablebeforeexpiry; usf:securityBindingDelegationConstraint dc:boundeddelegation; usf:tokenProfileTemplateSecurityBindingDigest "sha256:ff83482a5e9dc80fdfce58ccfdc7f06a41c454f15dd869020646ee91544ae3c1".
tptsb:shortlivedoperatortoken a usf:TokenProfileTemplateSecurityBinding; usf:canonicalName "shortlivedoperatortoken"; usf:securityBindingForTokenProfileTemplate tpt:shortlivedoperatortoken; usf:securityBindingIssuerClass tic:platformidentityauthority; usf:securityBindingAudience ta:foundationapi; usf:securityBindingLifetimePolicy tlp:shortlivedoperator; usf:securityBindingAuthenticationStrength asr:multifactor; usf:securityBindingProofOfPossession popr:confirmationkeyrequired; usf:securityBindingRevocationPolicy rvp:revocablebeforeexpiry; usf:securityBindingDelegationConstraint dc:delegationprohibited; usf:tokenProfileTemplateSecurityBindingDigest "sha256:dc8cea11a857e982db38176b13a1f0a90d3127c214cb3a0131fad42370849eb4".
tptsb:breakglasstoken a usf:TokenProfileTemplateSecurityBinding; usf:canonicalName "breakglasstoken"; usf:securityBindingForTokenProfileTemplate tpt:breakglasstoken; usf:securityBindingIssuerClass tic:platformidentityauthority; usf:securityBindingAudience ta:foundationapi; usf:securityBindingLifetimePolicy tlp:shortlivedbreakglass; usf:securityBindingAuthenticationStrength asr:multifactor; usf:securityBindingProofOfPossession popr:confirmationkeyrequired; usf:securityBindingRevocationPolicy rvp:boundedexpirynorefresh; usf:securityBindingDelegationConstraint dc:delegationprohibited; usf:tokenProfileTemplateSecurityBindingDigest "sha256:f18f5f92efa4ad18d5160686ba64e6d051584604f6dcf799b6cf954eaa3f6a92".

pcd:required a usf:PermutationClosureDisposition;
    usf:canonicalName "required";
    usf:definition "The combination must exist and behave; it requires executable behaviour, a permission atom, a satisfiable principal path, coverage, evidence and proof.".
pcd:allowed a usf:PermutationClosureDisposition;
    usf:canonicalName "allowed";
    usf:definition "The combination is permitted when invoked; it requires executable behaviour, a permission atom, a satisfiable principal path and positive coverage.".
pcd:forbidden a usf:PermutationClosureDisposition;
    usf:canonicalName "forbidden";
    usf:definition "The combination must be impossible to authorise or encode into a valid token; it requires denial rules, token denial and negative coverage.".
pcd:notapplicable a usf:PermutationClosureDisposition;
    usf:canonicalName "notapplicable";
    usf:definition "The combination is semantically meaningless for its subject; it requires a controlled reason code, rationale, provenance and applicability proof.".
pcd:deferred a usf:PermutationClosureDisposition;
    usf:canonicalName "deferred";
    usf:definition "The combination is explicitly deferred by current authority; prohibited unless the capability or contract is authority-deferred.".
pcd:unresolved a usf:PermutationClosureDisposition;
    usf:canonicalName "unresolved";
    usf:definition "The combination lacks a warranted semantic decision; active unresolved cells must return to zero before closure.".

frd:matrixrequired a usf:PermutationFamilyReviewDisposition;
    usf:canonicalName "matrixrequired";
    usf:definition "The subject exhibits the family's multi-axis operational behaviour and its candidate cells must be generated and dispositioned.".
frd:matrixnotapplicable a usf:PermutationFamilyReviewDisposition;
    usf:canonicalName "matrixnotapplicable";
    usf:definition "The subject provably has no independently meaningful behaviour on this family's axes; requires a controlled reason and signal proof.".

rpdk:granted a usf:RolePermissionDispositionKind;
    usf:canonicalName "granted";
    usf:definition "The role holds the permission atom unconditionally within its boundary.".
rpdk:conditionallygranted a usf:RolePermissionDispositionKind;
    usf:canonicalName "conditionallygranted";
    usf:definition "The role holds the permission atom only while a finite named authorisation condition profile is satisfied.".
rpdk:denied a usf:RolePermissionDispositionKind;
    usf:canonicalName "denied";
    usf:definition "The role explicitly does not hold the permission atom and no composition may reintroduce it.".
rpdk:notapplicable a usf:RolePermissionDispositionKind;
    usf:canonicalName "notapplicable";
    usf:definition "The permission atom is semantically meaningless for the role's boundary or principal kind.".
rpdk:delegatedonly a usf:RolePermissionDispositionKind;
    usf:canonicalName "delegatedonly";
    usf:definition "The role can exercise the permission atom only through an explicit bounded delegation.".
rpdk:serviceidentityonly a usf:RolePermissionDispositionKind;
    usf:canonicalName "serviceidentityonly";
    usf:definition "Only a service identity may exercise the permission atom; human roles are excluded.".
rpdk:breakglassonly a usf:RolePermissionDispositionKind;
    usf:canonicalName "breakglassonly";
    usf:definition "The permission atom is reachable only through the controlled break-glass path with audit and review.".

pk:humanuser a usf:PrincipalKind;
    usf:canonicalName "humanuser";
    usf:definition "An authenticated human acting through tenant or platform roles.".
pk:serviceidentity a usf:PrincipalKind;
    usf:canonicalName "serviceidentity";
    usf:definition "A non-human workload identity executing declared service behaviour.".
pk:automationagent a usf:PrincipalKind;
    usf:canonicalName "automationagent";
    usf:definition "An autonomous or assisted agent executing authorised programme or platform automation.".
pk:externalservice a usf:PrincipalKind;
    usf:canonicalName "externalservice";
    usf:definition "An external system interacting through declared integration surfaces such as webhooks.".
pk:anonymous a usf:PrincipalKind;
    usf:canonicalName "anonymous";
    usf:definition "An unauthenticated caller; permitted only where an explicit public permission atom exists.".
pk:platformoperator a usf:PrincipalKind;
    usf:canonicalName "platformoperator";
    usf:definition "A privileged human operating platform-scope control planes under audit.".
pk:coordinator a usf:PrincipalKind;
    usf:canonicalName "coordinator";
    usf:definition "The single authorised control-plane principal permitted to mutate semantic authority and integrate programme changes.".

rsk:exactresourceid a usf:ResourceSelectorKind; usf:canonicalName "exactresourceid"; usf:definition "Selects exactly one resource by stable identifier.".
rsk:ownerrelationship a usf:ResourceSelectorKind; usf:canonicalName "ownerrelationship"; usf:definition "Selects resources owned by the requesting principal.".
rsk:tenantscope a usf:ResourceSelectorKind; usf:canonicalName "tenantscope"; usf:definition "Selects resources within the principal's tenant boundary.".
rsk:organisationscope a usf:ResourceSelectorKind; usf:canonicalName "organisationscope"; usf:definition "Selects resources within an organisation or suborganisation.".
rsk:tagclassification a usf:ResourceSelectorKind; usf:canonicalName "tagclassification"; usf:definition "Selects resources carrying a validated tag or classification.".
rsk:boundedpathprefix a usf:ResourceSelectorKind; usf:canonicalName "boundedpathprefix"; usf:definition "Selects resources under a bounded, validated path prefix.".
rsk:approvedpredicate a usf:ResourceSelectorKind; usf:canonicalName "approvedpredicate"; usf:definition "Selects resources satisfying an approved finite predicate.".
rsk:timewindow a usf:ResourceSelectorKind; usf:canonicalName "timewindow"; usf:definition "Restricts selection to a bounded time window.".
rsk:environmentscope a usf:ResourceSelectorKind; usf:canonicalName "environmentscope"; usf:definition "Restricts selection to declared environments or environment classes.".
rsk:sessionscope a usf:ResourceSelectorKind; usf:canonicalName "sessionscope"; usf:definition "Restricts selection to the requesting session's state.".
rsk:delegationchain a usf:ResourceSelectorKind; usf:canonicalName "delegationchain"; usf:definition "Restricts selection through an explicit bounded delegation chain.".

osc:callableinterface a usf:OperationalSurfaceClassification; usf:canonicalName "callableinterface"; usf:definition "Exposes callable command and query operations.".
osc:gatewaycontrolplane a usf:OperationalSurfaceClassification; usf:canonicalName "gatewaycontrolplane"; usf:definition "Exposes coordinator or operator control-plane gateway operations.".
osc:eventdriven a usf:OperationalSurfaceClassification; usf:canonicalName "eventdriven"; usf:definition "Publishes or consumes events or messages.".
osc:scheduledautomation a usf:OperationalSurfaceClassification; usf:canonicalName "scheduledautomation"; usf:definition "Executes scheduled or policy-driven automation.".
osc:workflowdriven a usf:OperationalSurfaceClassification; usf:canonicalName "workflowdriven"; usf:definition "Owns stateful workflows with declared transitions.".
osc:datapersistence a usf:OperationalSurfaceClassification; usf:canonicalName "datapersistence"; usf:definition "Owns persisted data models with tenancy, migration and recovery obligations.".
osc:configurationsurface a usf:OperationalSurfaceClassification; usf:canonicalName "configurationsurface"; usf:definition "Owns configuration keys or secret slots across environments.".
osc:uisurface a usf:OperationalSurfaceClassification; usf:canonicalName "uisurface"; usf:definition "Exposes user-facing surfaces, routes, forms or views.".
osc:assuranceverification a usf:OperationalSurfaceClassification; usf:canonicalName "assuranceverification"; usf:definition "Provides assurance, validation or proof behaviour rather than product runtime.".
osc:internalprocessonly a usf:OperationalSurfaceClassification; usf:canonicalName "internalprocessonly"; usf:definition "Operates only through internal process calls with no external surface.".

pdr:requiredbycontractobligation a usf:PermutationDispositionReason; usf:canonicalName "requiredbycontractobligation"; usf:definition "Current contract claims or obligations require this combination to behave.".
pdr:allowedbyexplicitauthorisation a usf:PermutationDispositionReason; usf:canonicalName "allowedbyexplicitauthorisation"; usf:definition "Current authority explicitly permits this combination without requiring it.".
pdr:forbiddenbydenybydefault a usf:PermutationDispositionReason; usf:canonicalName "forbiddenbydenybydefault"; usf:definition "No grant exists and deny-by-default forbids the combination.".
pdr:forbiddenbytenantboundary a usf:PermutationDispositionReason; usf:canonicalName "forbiddenbytenantboundary"; usf:definition "The combination would cross a tenant or platform boundary without an explicit proven exception.".
pdr:forbiddenbyleastprivilege a usf:PermutationDispositionReason; usf:canonicalName "forbiddenbyleastprivilege"; usf:definition "Least privilege forbids granting this combination to the principal or role.".
pdr:forbiddenbycoordinatoronly a usf:PermutationDispositionReason; usf:canonicalName "forbiddenbycoordinatoronly"; usf:definition "Only the coordinator principal may exercise this combination; all other paths are forbidden.".
pdr:notapplicablebysubjectabsence a usf:PermutationDispositionReason; usf:canonicalName "notapplicablebysubjectabsence"; usf:definition "The subject declares none of the facets this combination ranges over.".
pdr:notapplicablebyapplicabilityrule a usf:PermutationDispositionReason; usf:canonicalName "notapplicablebyapplicabilityrule"; usf:definition "An explicit proved applicability rule excludes the combination.".
pdr:notapplicablebytransportabsence a usf:PermutationDispositionReason; usf:canonicalName "notapplicablebytransportabsence"; usf:definition "The subject exposes no surface on the combination's transport or interaction pattern.".
pdr:notapplicablebyuinonexposure a usf:PermutationDispositionReason; usf:canonicalName "notapplicablebyuinonexposure"; usf:definition "The capability is explicitly internal and authorises no UI exposure.".
pdr:deferredbyauthoritydecision a usf:PermutationDispositionReason; usf:canonicalName "deferredbyauthoritydecision"; usf:definition "Current authority explicitly defers the capability or contract scope.".
pdr:unresolvedpendingsemanticdecision a usf:PermutationDispositionReason; usf:canonicalName "unresolvedpendingsemanticdecision"; usf:definition "A missing semantic decision has been identified and must be resolved through evidence and publication.".

dvss:foundationcatalogue a usf:DimensionValueSourceScope;
    usf:canonicalName "foundationcatalogue";
    usf:definition "A finite reusable foundation taxonomy independent of current capability instances.".
dvss:authorityinstanceset a usf:DimensionValueSourceScope;
    usf:canonicalName "authorityinstanceset";
    usf:definition "A finite exact set of current authority instances; conformance-only fixtures never enter operational generation.".
dvss:capabilityrelationship a usf:DimensionValueSourceScope;
    usf:canonicalName "capabilityrelationship";
    usf:definition "Values derived only through declared relationships within the reviewed capability boundary.".
dvss:downstreamclosure a usf:DimensionValueSourceScope;
    usf:canonicalName "downstreamclosure";
    usf:definition "Values derived from an earlier digest-bound closure result rather than invented as an input vocabulary.".
dvss:registeredsubjectrelationship a usf:DimensionValueSourceScope;
    usf:canonicalName "registeredsubjectrelationship";
    usf:definition "Values are derived only by an ordered registered selector from the current registered family subject.".

ppc:operationalaxis a usf:PermutationParticipationClassification; usf:canonicalName "operationalaxis"; usf:definition "The reviewed term supplies an independently varying operational dimension when a warranted family binds it.".
ppc:assuranceaxis a usf:PermutationParticipationClassification; usf:canonicalName "assuranceaxis"; usf:definition "The reviewed term supplies an independently varying evidence, proof or validation dimension when a warranted family binds it.".
ppc:structuralselector a usf:PermutationParticipationClassification; usf:canonicalName "structuralselector"; usf:definition "The reviewed term selects subjects or values for a family without independently becoming a permutation axis.".
ppc:lifecyclederivationinput a usf:PermutationParticipationClassification; usf:canonicalName "lifecyclederivationinput"; usf:definition "The reviewed term influences lifecycle applicability or derivation without independently becoming an axis.".
ppc:metadataprovenancenonaxis a usf:PermutationParticipationClassification; usf:canonicalName "metadataprovenancenonaxis"; usf:definition "The reviewed term records metadata or provenance and has no independent behavioural cross-product.".
ppc:authoritydecisionrequired a usf:PermutationParticipationClassification; usf:canonicalName "authoritydecisionrequired"; usf:definition "Current semantic evidence cannot yet prove whether the reviewed term warrants a new axis or family.".

pabc:existingaxis a usf:PermutationAxisBindingClassification; usf:canonicalName "existingaxis"; usf:definition "The reviewed term is already represented by a registered finite dimension or its declared selector.".
pabc:unregisteredcontrolledaxis a usf:PermutationAxisBindingClassification; usf:canonicalName "unregisteredcontrolledaxis"; usf:definition "The reviewed controlled domain may vary independently but has no accepted registered axis decision.".
pabc:notanaxis a usf:PermutationAxisBindingClassification; usf:canonicalName "notanaxis"; usf:definition "The reviewed term is structurally or semantically relevant but does not independently vary as a permutation axis.".

pfcc:notafamilycandidate a usf:PermutationFamilyCandidateClassification; usf:canonicalName "notafamilycandidate"; usf:definition "The reviewed term cannot independently warrant a permutation family under the current participation rules.".
pfcc:authorityreviewrequired a usf:PermutationFamilyCandidateClassification; usf:canonicalName "authorityreviewrequired"; usf:definition "A bounded semantic decision must determine whether this candidate represents a genuinely independent behavioural cross-product.".
pfcc:warranted a usf:PermutationFamilyCandidateClassification; usf:canonicalName "warranted"; usf:definition "Current accepted semantic authority warrants a distinct permutation family.".
pfcc:rejected a usf:PermutationFamilyCandidateClassification; usf:canonicalName "rejected"; usf:definition "Current accepted semantic authority proves that the candidate is covered, dependent, non-behavioural or otherwise not a distinct family.".

pfmrd:warranted a usf:PermutationFamilyModelReviewDisposition;
    usf:canonicalName "warranted";
    usf:definition "Independent review accepts the exact leaf signature of an already-authored registered family; this classification creates no family, behaviour, permission, evidence admission, proof or contract activation.".

accomp:all a usf:AuthorisationConditionComposition; usf:canonicalName "all"; usf:definition "Every ordered clause must be satisfied.".
accomp:any a usf:AuthorisationConditionComposition; usf:canonicalName "any"; usf:definition "At least one ordered clause must be satisfied; each alternative remains explicit.".
acop:present a usf:AuthorisationConditionOperator; usf:canonicalName "present"; usf:definition "The bounded context claim or state must be present.".
acop:equals a usf:AuthorisationConditionOperator; usf:canonicalName "equals"; usf:definition "The bounded context value must equal the declared value IRI.".
acop:memberof a usf:AuthorisationConditionOperator; usf:canonicalName "memberof"; usf:definition "The principal or resource must be a member of the declared finite set.".
acop:atleast a usf:AuthorisationConditionOperator; usf:canonicalName "atleast"; usf:definition "The ordered assurance or authentication value must meet the declared minimum.".
acop:withinscope a usf:AuthorisationConditionOperator; usf:canonicalName "withinscope"; usf:definition "The value must remain within a declared tenant, environment, network or delegation scope.".
acop:before a usf:AuthorisationConditionOperator; usf:canonicalName "before"; usf:definition "The evaluated instant must precede a bounded declared instant.".
acop:after a usf:AuthorisationConditionOperator; usf:canonicalName "after"; usf:definition "The evaluated instant must follow a bounded declared instant.".

acpred:tenantmembership a usf:AuthorisationConditionPredicate; usf:canonicalName "tenantmembership"; usf:definition "The principal has current membership in the bounded tenant.".
acpred:tenantadministrator a usf:AuthorisationConditionPredicate; usf:canonicalName "tenantadministrator"; usf:definition "The principal holds current tenant-administrator authority within the bounded tenant.".
acpred:resourceownership a usf:AuthorisationConditionPredicate; usf:canonicalName "resourceownership"; usf:definition "The principal owns or is explicitly related to the selected resource.".
acpred:serviceidentity a usf:AuthorisationConditionPredicate; usf:canonicalName "serviceidentity"; usf:definition "The principal is a declared service identity rather than a human role.".
acpred:authenticationstrength a usf:AuthorisationConditionPredicate; usf:canonicalName "authenticationstrength"; usf:definition "Authentication meets the required finite strength classification.".
acpred:platformscope a usf:AuthorisationConditionPredicate; usf:canonicalName "platformscope"; usf:definition "The operation is confined to the declared platform control boundary.".
acpred:productionenvironment a usf:AuthorisationConditionPredicate; usf:canonicalName "productionenvironment"; usf:definition "The execution environment is production-class and subject to production controls.".
acpred:coordinatorprincipal a usf:AuthorisationConditionPredicate; usf:canonicalName "coordinatorprincipal"; usf:definition "The principal is the single declared semantic-authority coordinator.".
acpred:boundeddelegation a usf:AuthorisationConditionPredicate; usf:canonicalName "boundeddelegation"; usf:definition "An explicit finite delegation chain authorises the operation and selector.".
acpred:breakglassapproval a usf:AuthorisationConditionPredicate; usf:canonicalName "breakglassapproval"; usf:definition "A current break-glass approval exists.".
acpred:breakglassreason a usf:AuthorisationConditionPredicate; usf:canonicalName "breakglassreason"; usf:definition "A bounded auditable break-glass reason is present.".
acpred:legalholdapproval a usf:AuthorisationConditionPredicate; usf:canonicalName "legalholdapproval"; usf:definition "The required legal-hold approval is current.".
acpred:environmentbinding a usf:AuthorisationConditionPredicate; usf:canonicalName "environmentbinding"; usf:definition "The authorisation is bound to the declared environment class.".
acpred:trustedexecution a usf:AuthorisationConditionPredicate; usf:canonicalName "trustedexecution"; usf:definition "Execution occurs in a declared trusted execution boundary.".
acpred:requestorigin a usf:AuthorisationConditionPredicate; usf:canonicalName "requestorigin"; usf:definition "The request originates within an allowed finite network or transport boundary.".
acpred:lifecyclestate a usf:AuthorisationConditionPredicate; usf:canonicalName "lifecyclestate"; usf:definition "The governed resource is in an allowed lifecycle state.".
acpred:resourceclassification a usf:AuthorisationConditionPredicate; usf:canonicalName "resourceclassification"; usf:definition "The selected resource has an allowed finite classification.".
acpred:consent a usf:AuthorisationConditionPredicate; usf:canonicalName "consent"; usf:definition "Required consent is present and current.".
acpred:entitlement a usf:AuthorisationConditionPredicate; usf:canonicalName "entitlement"; usf:definition "The principal has the required current entitlement.".
acpred:approval a usf:AuthorisationConditionPredicate; usf:canonicalName "approval"; usf:definition "The required bounded approval is present.".
acpred:quotawithinlimit a usf:AuthorisationConditionPredicate; usf:canonicalName "quotawithinlimit"; usf:definition "The applicable quota remains within its declared limit.".
acpred:timewindow a usf:AuthorisationConditionPredicate; usf:canonicalName "timewindow"; usf:definition "Execution occurs inside a declared bounded time window.".

