    usf:valueSourceKind "derivedselector";
    usf:definition "Providers explicitly bound to the subject capability's external dependencies.".
dvs:externaldependencyfailuremode a usf:DimensionValueSource;
    usf:canonicalName "externaldependencyfailuremode";
