dvs:ackmode a usf:DimensionValueSource;
    usf:canonicalName "ackmode";
    usf:valueSourceKind "controlledlist".
dvs:action a usf:DimensionValueSource;
    usf:canonicalName "action";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:ActionKind"^^xsd:anyURI.
dvs:actionreachability a usf:DimensionValueSource;
    usf:canonicalName "actionreachability";
    usf:valueSourceKind "derivedselector";
    usf:definition "Values derived per subject by the generator as the reachability of each usf:ActionKind for the role and capability pair through granted permission atoms.".
dvs:apicommand a usf:DimensionValueSource;
    usf:canonicalName "apicommand";
    usf:valueSourceKind "derivedselector";
    usf:definition "Values derived per subject by the generator as the union of usf:Query, usf:Command and usf:GatewayOperation instances exposed as API or command surfaces of the subject capability.".
dvs:apiprotocolsurface a usf:DimensionValueSource;
    usf:canonicalName "apiprotocolsurface";
    usf:valueSourceKind "derivedselector";
    usf:definition "Values derived per subject by the generator as the union of usf:Interface instances and routed usf:Route surfaces declared for the subject.".
dvs:auditevent a usf:DimensionValueSource;
    usf:canonicalName "auditevent";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:AuditEvent"^^xsd:anyURI.
dvs:auditoutcome a usf:DimensionValueSource;
    usf:canonicalName "auditoutcome";
    usf:valueSourceKind "controlledlist".
dvs:authenticationmode a usf:DimensionValueSource;
    usf:canonicalName "authenticationmode";
    usf:valueSourceKind "controlledlist".
dvs:authenticationstrength a usf:DimensionValueSource;
    usf:canonicalName "authenticationstrength";
    usf:valueSourceKind "controlledlist".
dvs:capability a usf:DimensionValueSource;
    usf:canonicalName "capability";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:Capability"^^xsd:anyURI.
dvs:claimconstraint a usf:DimensionValueSource;
    usf:canonicalName "claimconstraint";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:TokenClaimConstraint"^^xsd:anyURI.
dvs:conditionprofile a usf:DimensionValueSource;
    usf:canonicalName "conditionprofile";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:AuthorisationConditionProfile"^^xsd:anyURI.
dvs:configurationkey a usf:DimensionValueSource;
    usf:canonicalName "configurationkey";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:ConfigurationKey"^^xsd:anyURI.
dvs:consumepermission a usf:DimensionValueSource;
    usf:canonicalName "consumepermission";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:PermissionAtom"^^xsd:anyURI.
dvs:consumer a usf:DimensionValueSource;
    usf:canonicalName "consumer";
    usf:valueSourceKind "derivedselector";
    usf:definition "Values derived per subject by the generator from declared usf:requiredConsumer values on the subject's events.".
dvs:datafield a usf:DimensionValueSource;
    usf:canonicalName "datafield";
    usf:valueSourceKind "derivedselector";
    usf:definition "Values derived per subject by the generator as bounded field selectors over the subject's data models; individual fields are not enumerated per instance.".
dvs:datamodel a usf:DimensionValueSource;
    usf:canonicalName "datamodel";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:DataModel"^^xsd:anyURI.
dvs:deadlettermode a usf:DimensionValueSource;
    usf:canonicalName "deadlettermode";
    usf:valueSourceKind "controlledlist".
dvs:delegationmode a usf:DimensionValueSource;
    usf:canonicalName "delegationmode";
    usf:valueSourceKind "controlledlist".
dvs:deliverysemantics a usf:DimensionValueSource;
    usf:canonicalName "deliverysemantics";
    usf:valueSourceKind "controlledlist".
dvs:direction a usf:DimensionValueSource;
    usf:canonicalName "direction";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:InteractionDirection"^^xsd:anyURI.
