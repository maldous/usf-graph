# Complete predicate summaries for the declarative value-derivation roots.
# These summaries are checked against the expression trees and are never used
# as an implementation dispatch table.
dvs:apicommand usf:valueSourceDerivationPredicate usf:hasContract, usf:interfaceForContract, usf:gatewayOperationForCapability.
dvs:apiprotocolsurface usf:valueSourceDerivationPredicate usf:hasContract, usf:hasUISemanticModel, usf:hasSurface.
dvs:externaldependency usf:valueSourceDerivationPredicate usf:hasContract.
dvs:externaldependencyprovider usf:valueSourceDerivationPredicate usf:hasContract.
dvs:externaldependencyfailuremode usf:valueSourceDerivationPredicate usf:hasContract.
dvs:externaldependencyrecoveryaction usf:valueSourceDerivationPredicate usf:hasContract.
dvs:formview usf:valueSourceDerivationPredicate usf:hasUISemanticModel.
dvs:operation usf:valueSourceDerivationPredicate usf:hasContract, usf:interfaceForContract.
dvs:resource usf:valueSourceDerivationPredicate usf:hasContract, usf:interfaceForContract, usf:hasOperation, usf:gatewayOperationForCapability, usf:requiresPermission.
dvs:scheduledjob usf:valueSourceDerivationPredicate usf:hasContract.
dvs:trigger usf:valueSourceDerivationPredicate usf:hasContract, usf:workflowForContract, usf:hasTransition.

# Exact family-to-subject and structured applicability registry. The current
# capability census remains explicit while runtime and assurance counts are
# separated by the registered plane.
pf:capabilityresourceaction usf:familySubjectRegistration psr:capabilityruntime; usf:familyApplicabilityRule prule:always.
