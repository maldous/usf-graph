# Heterogeneous family subjects are registered explicitly. Their selectors are
# rooted at the registered subject and never reinterpret a capability as a
# component or a concrete runtime binding.
psr:optioncomponentassurance a usf:PermutationSubjectRegistration;
    usf:canonicalName "optioncomponentassurance";
    usf:registeredSubjectClass usf:OptionComponent;
    usf:registeredFamilyPlane pfp:assuranceobligation.
psr:bindingruntime a usf:PermutationSubjectRegistration;
    usf:canonicalName "bindingruntime";
    usf:registeredSubjectClass usf:Binding;
    usf:registeredFamilyPlane pfp:runtimebehaviour.
psr:bindingassurance a usf:PermutationSubjectRegistration;
    usf:canonicalName "bindingassurance";
    usf:registeredSubjectClass usf:Binding;
    usf:registeredFamilyPlane pfp:assuranceobligation.

