    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:ProviderMode"^^xsd:anyURI.
dvs:quotastate a usf:DimensionValueSource;
    usf:canonicalName "quotastate";
    usf:valueSourceKind "controlledlist".
