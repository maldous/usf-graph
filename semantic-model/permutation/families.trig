    usf:canonicalName "ratelimitpolicy";
    usf:valueSourceKind "controlledlist".
dvs:replaymode a usf:DimensionValueSource;
    usf:canonicalName "replaymode";
    usf:valueSourceKind "controlledlist".
dvs:resource a usf:DimensionValueSource;
    usf:canonicalName "resource";
    usf:valueSourceKind "derivedselector";
    usf:definition "Values derived from the bounded semantic resource classes of the subject capability: exact usf:atomResourceClass relationships of its permission atoms united with the data models backing the capability.".
dvs:resourceselectorkind a usf:DimensionValueSource;
    usf:canonicalName "resourceselectorkind";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:ResourceSelectorKind"^^xsd:anyURI.
dvs:retentionstate a usf:DimensionValueSource;
    usf:canonicalName "retentionstate";
    usf:valueSourceKind "controlledlist".
dvs:retrymode a usf:DimensionValueSource;
    usf:canonicalName "retrymode";
    usf:valueSourceKind "controlledlist".
dvs:role a usf:DimensionValueSource;
    usf:canonicalName "role";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:Role"^^xsd:anyURI.
dvs:roleserviceidentity a usf:DimensionValueSource;
    usf:canonicalName "roleserviceidentity";
    usf:valueSourceKind "derivedselector";
    usf:definition "Values derived per subject as the union of declared roles and exact usf:ServiceIdentity resources bound to the subject capability; neither membership creates a grant.".
dvs:routekind a usf:DimensionValueSource;
    usf:canonicalName "routekind";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:RouteKind"^^xsd:anyURI.
dvs:scheduledjob a usf:DimensionValueSource;
    usf:canonicalName "scheduledjob";
    usf:valueSourceKind "derivedselector";
    usf:definition "Values derived per subject by the generator as workflows whose execution policy declares time-triggered schedule behaviour.".
dvs:secretclass a usf:DimensionValueSource;
    usf:canonicalName "secretclass";
    usf:valueSourceKind "classinstances";
    usf:valueSourceClassIri "urn:usf:ontology:SecretClassification"^^xsd:anyURI.
dvs:sessionmodel a usf:DimensionValueSource;
    usf:canonicalName "sessionmodel";
    usf:valueSourceKind "classinstances";
