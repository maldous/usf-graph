# Foundation-only structural projections let the conformance fixture exercise
# selectors over derived operational records without asserting those records.
# They are evaluated only by the foundation assessment and never enter live
# generation, disposition, evidence admission or publication.
<urn:usf:foundationprojectionidentitymode:digestshadow> a usf:FoundationProjectionIdentityMode; usf:canonicalName "digestshadow".
<urn:usf:foundationprojectionidentitymode:sourcealias> a usf:FoundationProjectionIdentityMode; usf:canonicalName "sourcealias".

