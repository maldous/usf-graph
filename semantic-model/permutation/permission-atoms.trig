# ── Tenant context permission ────────────────────────────────────────────────
pa:tenantcontextread a usf:PermissionAtom;
    usf:canonicalName "tenantcontextread";
    usf:definition "Read tenant host identity resolution context within the requesting tenant boundary.";
    usf:atomCapability cap:tenanthostidentityresolution;
