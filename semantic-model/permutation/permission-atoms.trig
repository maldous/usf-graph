# ── Provider permissions ─────────────────────────────────────────────────────
pa:providerread a usf:PermissionAtom;
    usf:canonicalName "providerread";
    usf:definition "Read a single provider configuration by identifier within the requesting tenant boundary.";
    usf:atomCapability cap:providerconfigurationplane;
    usf:atomResourceClass <urn:usf:ontology:ProviderConfiguration>;
    usf:atomAction actionkind:get;
