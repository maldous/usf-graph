@prefix usf: <urn:usf:ontology:>.
@prefix actiongroup: <urn:usf:actiongroup:>.
@prefix actionkind: <urn:usf:actionkind:>.

<urn:usf:graph:permutation-actions> {
actiongroup:administrativeandpolicy a usf:ActionGroup;
  usf:canonicalName "administrativeandpolicy";
  usf:definition "Action group covering assignment, authorisation-decision and policy lifecycle actions for administration and policy.".
actiongroup:connectionandsession a usf:ActionGroup;
  usf:canonicalName "connectionandsession";
  usf:definition "Action group covering establishment, exchange, keep-alive and termination actions on connections and sessions.".
actiongroup:dataandtransaction a usf:ActionGroup;
  usf:canonicalName "dataandtransaction";
  usf:definition "Action group covering transaction boundaries, statement-level data manipulation and data lifecycle actions.".
actiongroup:eventandmessaging a usf:ActionGroup;
  usf:canonicalName "eventandmessaging";
  usf:definition "Action group covering publication, consumption, acknowledgement, redelivery and dead-letter actions for events and messages.".
actiongroup:executionandworkflow a usf:ActionGroup;
  usf:canonicalName "executionandworkflow";
  usf:definition "Action group covering scheduling, control, recovery and completion actions on executions and workflows.".
actiongroup:genericresource a usf:ActionGroup;
  usf:canonicalName "genericresource";
  usf:definition "Action group covering the generic lifecycle, retrieval, mutation, transfer, assurance and state-control actions applicable to any managed resource.".
actiongroup:objectandfile a usf:ActionGroup;
  usf:canonicalName "objectandfile";
  usf:definition "Action group covering storage, transfer, assurance and lifecycle actions on objects and files.".
actiongroup:provider a usf:ActionGroup;
  usf:canonicalName "provider";
  usf:definition "Action group covering configuration, inspection, availability and credential actions for external providers.".
actiongroup:securityandidentity a usf:ActionGroup;
  usf:canonicalName "securityandidentity";
  usf:definition "Action group covering authentication, token, delegation, credential and emergency-access actions for security and identity.".
actiongroup:webhook a usf:ActionGroup;
  usf:canonicalName "webhook";
  usf:definition "Action group covering registration, delivery, testing and secret-management actions for webhooks.".
actiongroup:websocketsurface a usf:ActionGroup;
  usf:canonicalName "websocketsurface";
  usf:definition "Mandatory consideration set for every WebSocket-capable surface: each listed action must be explicitly considered and may be forbidden or marked not applicable, but may not be omitted because existing code lacks it.";
  usf:mandatoryConsiderationAction actionkind:abort, actionkind:authenticate, actionkind:authorise, actionkind:close, actionkind:connect, actionkind:disconnect, actionkind:heartbeat, actionkind:open, actionkind:ping, actionkind:pong, actionkind:read, actionkind:receive, actionkind:reconnect, actionkind:resume, actionkind:send, actionkind:subscribe, actionkind:unsubscribe, actionkind:write.
actionkind:abort a usf:ActionKind;
  usf:canonicalName "abort";
  usf:actionLabel "abort";
  usf:inActionGroup actiongroup:connectionandsession;
  usf:definition "Terminate a connection or session immediately without orderly shutdown.".
actionkind:acknowledge a usf:ActionKind;
  usf:canonicalName "acknowledge";
  usf:actionLabel "acknowledge";
  usf:inActionGroup actiongroup:eventandmessaging, actiongroup:executionandworkflow;
  usf:definition "Confirm successful receipt or processing of a message or work item.".
actionkind:activate a usf:ActionKind;
  usf:canonicalName "activate";
  usf:actionLabel "activate";
  usf:inActionGroup actiongroup:genericresource;
  usf:definition "Bring a resource into active operational effect.".
actionkind:approve a usf:ActionKind;
  usf:canonicalName "approve";
  usf:actionLabel "approve";
  usf:inActionGroup actiongroup:genericresource;
  usf:definition "Record an affirmative decision that permits a pending resource or request to proceed.".
actionkind:approveelevation a usf:ActionKind;
  usf:canonicalName "approveelevation";
  usf:actionLabel "approveElevation";
  usf:inActionGroup actiongroup:securityandidentity;
  usf:definition "Approve a pending request for temporarily elevated privileges.".
actionkind:archive a usf:ActionKind;
  usf:canonicalName "archive";
  usf:actionLabel "archive";
  usf:inActionGroup actiongroup:genericresource;
  usf:definition "Move a resource into long-term inactive retention while preserving it.".
actionkind:assign a usf:ActionKind;
  usf:canonicalName "assign";
  usf:actionLabel "assign";
  usf:inActionGroup actiongroup:administrativeandpolicy;
  usf:definition "Attach a role, duty or resource to a principal or target.".
actionkind:attest a usf:ActionKind;
  usf:canonicalName "attest";
  usf:actionLabel "attest";
  usf:inActionGroup actiongroup:administrativeandpolicy;
  usf:definition "Formally declare that a subject satisfies a stated requirement.".
actionkind:authenticate a usf:ActionKind;
  usf:canonicalName "authenticate";
  usf:actionLabel "authenticate";
  usf:inActionGroup actiongroup:connectionandsession;
  usf:definition "Prove the identity of a principal on a connection or session.".
actionkind:authorise a usf:ActionKind;
  usf:canonicalName "authorise";
  usf:actionLabel "authorise";
  usf:inActionGroup actiongroup:connectionandsession;
  usf:definition "Establish that an authenticated principal may perform requested actions on a connection or session.".
actionkind:backup a usf:ActionKind;
  usf:canonicalName "backup";
  usf:actionLabel "backup";
  usf:inActionGroup actiongroup:dataandtransaction;
  usf:definition "Produce a recoverable copy of data for protection against loss.".
actionkind:begin a usf:ActionKind;
  usf:canonicalName "begin";
  usf:actionLabel "begin";
  usf:inActionGroup actiongroup:dataandtransaction;
  usf:definition "Open a new transaction boundary.".
actionkind:breakglass a usf:ActionKind;
  usf:canonicalName "breakglass";
  usf:actionLabel "breakGlass";
  usf:inActionGroup actiongroup:securityandidentity;
