actionkind:disable a usf:ActionKind;
  usf:canonicalName "disable";
  usf:actionLabel "disable";
  usf:inActionGroup actiongroup:genericresource, actiongroup:provider, actiongroup:webhook;
  usf:definition "Turn off a resource or integration so it ceases to take effect.".
actionkind:disconnect a usf:ActionKind;
  usf:canonicalName "disconnect";
  usf:actionLabel "disconnect";
