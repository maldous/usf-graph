actionkind:callback a usf:ActionKind;
  usf:canonicalName "callback";
  usf:actionLabel "callback";
  usf:inActionGroup actiongroup:securityandidentity;
  usf:definition "Complete an externally initiated authentication or authorisation flow at a return endpoint.".
actionkind:cancel a usf:ActionKind;
  usf:canonicalName "cancel";
  usf:actionLabel "cancel";
  usf:inActionGroup actiongroup:executionandworkflow;
  usf:definition "Request orderly termination of an execution before completion.".
actionkind:certify a usf:ActionKind;
  usf:canonicalName "certify";
  usf:actionLabel "certify";
  usf:inActionGroup actiongroup:administrativeandpolicy;
  usf:definition "Issue a formal certification that a subject has passed evaluation.".
actionkind:close a usf:ActionKind;
  usf:canonicalName "close";
  usf:actionLabel "close";
  usf:inActionGroup actiongroup:connectionandsession;
  usf:definition "End a connection or session through orderly shutdown.".
actionkind:commit a usf:ActionKind;
  usf:canonicalName "commit";
  usf:actionLabel "commit";
  usf:inActionGroup actiongroup:dataandtransaction;
  usf:definition "Make the effects of an open transaction permanent.".
actionkind:compensate a usf:ActionKind;
  usf:canonicalName "compensate";
  usf:actionLabel "compensate";
  usf:inActionGroup actiongroup:executionandworkflow;
  usf:definition "Apply a compensating action that semantically reverses completed work.".
actionkind:complete a usf:ActionKind;
  usf:canonicalName "complete";
  usf:actionLabel "complete";
  usf:inActionGroup actiongroup:executionandworkflow;
  usf:definition "Mark an execution or work item as successfully finished.".
actionkind:configure a usf:ActionKind;
  usf:canonicalName "configure";
  usf:actionLabel "configure";
  usf:inActionGroup actiongroup:provider;
  usf:definition "Set or change the operating configuration of a provider or component.".
actionkind:connect a usf:ActionKind;
  usf:canonicalName "connect";
  usf:actionLabel "connect";
  usf:inActionGroup actiongroup:connectionandsession;
  usf:definition "Establish a transport-level link to an endpoint.".
actionkind:consume a usf:ActionKind;
  usf:canonicalName "consume";
  usf:actionLabel "consume";
  usf:inActionGroup actiongroup:eventandmessaging;
  usf:definition "Take delivery of messages from a queue or stream for processing.".
actionkind:copy a usf:ActionKind;
  usf:canonicalName "copy";
  usf:actionLabel "copy";
  usf:inActionGroup actiongroup:genericresource, actiongroup:objectandfile;
  usf:definition "Duplicate a resource to another location while retaining the original.".
actionkind:create a usf:ActionKind;
  usf:canonicalName "create";
  usf:actionLabel "create";
  usf:inActionGroup actiongroup:executionandworkflow, actiongroup:genericresource;
  usf:definition "Bring a new resource or execution into existence.".
actionkind:deactivate a usf:ActionKind;
  usf:canonicalName "deactivate";
  usf:actionLabel "deactivate";
  usf:inActionGroup actiongroup:genericresource;
  usf:definition "Take a resource out of active operational effect without deleting it.".
actionkind:deadletter a usf:ActionKind;
  usf:canonicalName "deadletter";
  usf:actionLabel "deadLetter";
  usf:inActionGroup actiongroup:eventandmessaging;
  usf:definition "Move a message that cannot be processed to the dead-letter destination.".
actionkind:delegate a usf:ActionKind;
  usf:canonicalName "delegate";
  usf:actionLabel "delegate";
  usf:inActionGroup actiongroup:securityandidentity;
  usf:definition "Confer a subset of a principal's authority on another principal.".
actionkind:delete a usf:ActionKind;
  usf:canonicalName "delete";
  usf:actionLabel "delete";
  usf:inActionGroup actiongroup:dataandtransaction, actiongroup:genericresource, actiongroup:objectandfile, actiongroup:webhook;
  usf:definition "Remove a resource so it is no longer available through normal operations.".
actionkind:deliver a usf:ActionKind;
  usf:canonicalName "deliver";
  usf:actionLabel "deliver";
  usf:inActionGroup actiongroup:webhook;
