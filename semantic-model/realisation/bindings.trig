impl:semanticmodelcompiler a usf:Implementation;
    usf:canonicalName "semanticmodelcompiler";
    usf:repositoryName "semantic-model-compilation";
    usf:definition "Repository-local deterministic compiler, command boundary and proof algorithm that validate the registered semantic model and publish an exact candidate state through the controlled authority transaction.";
    usf:implementsContract sc:compilersemanticenforcement.
port:semanticauthoritycontrol a usf:Port;
    usf:canonicalName "semanticauthoritycontrol";
    usf:repositoryName "semantic-authority-control";
    usf:definition "Authority access boundary for digest-bound reads, candidate validation, transactional publication and verified read-only export consumption.";
    usf:portForContract sc:compilersemanticenforcement;
    usf:permitsProviderMode pmode:liveauthoritycontrol, pmode:deterministictestsubstitute, pmode:externalsandbox;
    usf:providerFailureBehaviour "Invalid configuration, authentication failure, authority drift, transport failure, validation failure and ambiguous transaction closure fail closed; mutation is never retried blindly and rollback is verified before any recovery attempt.";
    usf:providerSecurityBoundary "Credentials enter only through modelled secret references, never appear in results, and grant only the least-privilege live authority operations required by the coordinator; verified exports are digest-bound and read-only.";
    usf:providerMaximumAttempts 1.
prov:livestardogsemanticauthority a usf:Provider;
    usf:canonicalName "livestardogsemanticauthority";
    usf:repositoryName "live-stardog-semantic-authority";
    usf:definition "Validated live Stardog state and its controlled mutation transaction, which remain the sole current semantic authority.";
    usf:hasProviderMode pmode:liveauthoritycontrol;
    usf:fulfilsPort port:semanticauthoritycontrol.
prov:verifiedsemanticauthorityexport a usf:Provider;
    usf:canonicalName "verifiedsemanticauthorityexport";
    usf:repositoryName "verified-semantic-authority-export";
    usf:definition "Exact authority-digest-bound read-only export admitted solely for deterministic isolated validation; it cannot publish or establish current freshness.";
    usf:hasProviderMode pmode:deterministictestsubstitute;
    usf:fulfilsPort port:semanticauthoritycontrol.
prov:compilerfocusedtestsubstitute a usf:Provider;
    usf:canonicalName "compilerfocusedtestsubstitute";
    usf:repositoryName "compiler-focused-test-substitute";
    usf:definition "Declared repository-local deterministic provider used only by focused compiler, gateway, rollback-failure and contamination controls; it has no live authority access and cannot make publication or live-parity claims.";
    usf:hasProviderMode pmode:deterministictestsubstitute;
    usf:fulfilsPort port:semanticauthoritycontrol.
prov:stardogsandboxsemanticauthority a usf:Provider;
    usf:canonicalName "stardogsandboxsemanticauthority";
    usf:repositoryName "stardog-sandbox-semantic-authority";
    usf:definition "A declared Stardog sandbox binding for production-shaped staging behaviour; it is not live semantic authority and cannot make publication or live-parity claims.";
    usf:hasProviderMode pmode:externalsandbox;
    usf:fulfilsPort port:semanticauthoritycontrol.
adp:stardogsemanticauthority a usf:Adapter;
    usf:canonicalName "stardogsemanticauthority";
    usf:repositoryName "stardog-semantic-authority";
    usf:definition "Repository-local adapter implementing the semantic authority control port for live Stardog and exact verified read-only exports.";
    usf:implementsPort port:semanticauthoritycontrol;
    usf:bindsProvider prov:livestardogsemanticauthority, prov:verifiedsemanticauthorityexport, prov:compilerfocusedtestsubstitute, prov:stardogsandboxsemanticauthority.

<urn:usf:realisationoption:livestardogwithverifiedreadonlyexport> a usf:RealisationOption, usf:ComposedRealisationOption;
    usf:canonicalName "livestardogwithverifiedreadonlyexport";
    usf:definition "Live Stardog remains the only mutation boundary; exact digest-bound exports support isolated read-only validation without becoming authority.".
<urn:usf:realisationoption:livestardogonly> a usf:RealisationOption;
    usf:canonicalName "livestardogonly";
    usf:definition "Every semantic operation requires network access to live Stardog, preventing a network-isolated read-only rebuild.".
<urn:usf:realisationoption:genericrdfauthorityprovider> a usf:RealisationOption;
    usf:canonicalName "genericrdfauthorityprovider";
    usf:definition "An interchangeable RDF authority provider, rejected because current programme authority is explicitly constrained to validated Stardog state.".
<urn:usf:realisationoption:nodeecmascriptsemanticmodelcompiler> a usf:RealisationOption, usf:ComposedRealisationOption;
    usf:canonicalName "nodeecmascriptsemanticmodelcompiler";
    usf:definition "Repository-local Node.js 22.23.1 ECMAScript-module compiler using integrity-locked N3 2.1.1, rdf-canonize 5.0.0, Stardog SDK 10.0.1 and YAML 2.9.0 inputs.".
<urn:usf:realisationoption:javardfsemanticmodelcompiler> a usf:RealisationOption, usf:ComposedRealisationOption;
    usf:canonicalName "javardfsemanticmodelcompiler";
    usf:definition "Repository-local Java RDF compiler with an additional virtual-machine toolchain and equivalent Stardog transaction, canonicalisation and validation responsibilities.".
<urn:usf:realisationoption:pythonrdfsemanticmodelcompiler> a usf:RealisationOption, usf:ComposedRealisationOption;
    usf:canonicalName "pythonrdfsemanticmodelcompiler";
    usf:definition "Repository-local Python RDF compiler with an additional interpreter toolchain and equivalent Stardog transaction, canonicalisation and validation responsibilities.".
<urn:usf:realisationdecision:semanticauthorityaccess> a usf:RealisationDecision;
    usf:canonicalName "semanticauthorityaccess";
    usf:decisionState <urn:usf:decisionstate:superseded>;
    usf:considersOption <urn:usf:realisationoption:livestardogwithverifiedreadonlyexport>, <urn:usf:realisationoption:livestardogonly>, <urn:usf:realisationoption:genericrdfauthorityprovider>;
    usf:decisionRationale "Live Stardog is independently required as the sole current authority and controlled mutation boundary. A verified exact-digest export is additionally selected for read-only isolated validation because it preserves Stardog-derived meaning while enabling the mandatory network-isolated rebuild; it cannot publish, prove freshness beyond its bound digest or replace live authority. Generic RDF substitution is forbidden and live-only access cannot satisfy hermetic bootstrap closure.";
    usf:authorisesRepository "usf";
    usf:authorisesSourcePath "capabilities/semantic-model-compilation", "configuration/semantic-assurance", "processes/semantic-assurance", "provider-bindings/stardog", "semantic-model", "assurance";
    usf:authorisesRealisationType usf:Implementation, usf:Adapter, usf:Binding;
    usf:requiresADR <urn:usf:adrrequirement:semanticauthorityaccess>;
    usf:supersededBy <urn:usf:realisationdecision:semanticmodelcompilationrealisation>.
<urn:usf:adrrequirement:semanticauthorityaccess> a usf:ADRRequirement;
    usf:canonicalName "semanticauthorityaccess".
<urn:usf:adrrecord:semanticauthorityaccess> a usf:ADRRecord;
    usf:canonicalName "semanticauthorityaccess";
    usf:recordsDecision <urn:usf:realisationdecision:semanticauthorityaccess>.
<urn:usf:realisationdecision:semanticmodelcompilationrealisation> a usf:RealisationDecision;
    usf:canonicalName "semanticmodelcompilationrealisation";
    usf:decisionState <urn:usf:decisionstate:accepted>;
    usf:decisionForContract sc:compilersemanticenforcement;
    usf:considersOption <urn:usf:realisationoption:nodeecmascriptsemanticmodelcompiler>, <urn:usf:realisationoption:javardfsemanticmodelcompiler>, <urn:usf:realisationoption:pythonrdfsemanticmodelcompiler>;
    usf:selectsOption <urn:usf:realisationoption:nodeecmascriptsemanticmodelcompiler>;
    usf:hasDecisionEvaluation <urn:usf:decisionevaluation:semanticmodelcompilationrealisation>;
    usf:decisionRationale "The Node.js 22.23.1 ECMAScript-module option is selected as a realisation decision, not a semantic requirement: its single repository-local runtime executes the compiler, commands and proof tooling; the locked libraries provide direct RDF parsing, RDFC-1.0 canonicalisation, YAML parsing and native Stardog transaction access. Java and Python can satisfy the contract but add a second toolchain without a clearer responsibility, security, data-ownership or deployment boundary. Live Stardog remains the sole current authority and mutation boundary, while an exact digest-bound export is retained only for network-isolated read-only validation.";
    usf:authorisesRepository "usf";
    usf:authorisesSourcePath "package.json", "package-lock.json", "capabilities/semantic-model-compilation", "configuration/semantic-assurance", "processes/semantic-assurance", "provider-bindings/stardog", "semantic-model", "assurance";
    usf:authorisesRealisationType usf:Implementation, usf:Adapter, usf:Binding;
    usf:supersedesDecision <urn:usf:realisationdecision:semanticauthorityaccess>;
    usf:requiresADR <urn:usf:adrrequirement:semanticmodelcompilationrealisation>.
<urn:usf:realisationdecision:semanticauthoritycontrolselection> a usf:RealisationDecision;
    usf:canonicalName "semanticauthoritycontrolselection";
    usf:decisionState <urn:usf:decisionstate:accepted>;
    usf:decisionForContract sc:compilersemanticenforcement;
    usf:considersOption <urn:usf:realisationoption:livestardogwithverifiedreadonlyexport>, <urn:usf:realisationoption:livestardogonly>, <urn:usf:realisationoption:genericrdfauthorityprovider>;
    usf:selectsOption <urn:usf:realisationoption:livestardogwithverifiedreadonlyexport>;
    usf:hasDecisionEvaluation <urn:usf:decisionevaluation:semanticauthoritycontrolselection>;
    usf:decisionRationale "Validated live Stardog is the required current authority and controlled mutation boundary. A separately bounded verified export is required for deterministic read-only isolation; neither a live-only binding nor a generic RDF substitute can satisfy both obligations.";
    usf:authorisesRepository "usf";
    usf:authorisesSourcePath "configuration/semantic-assurance", "processes/semantic-assurance", "provider-bindings/stardog", "semantic-model", "assurance";
    usf:authorisesRealisationType usf:Implementation, usf:Adapter, usf:Binding;
    usf:supersedesDecision <urn:usf:realisationdecision:semanticauthorityaccess>.
<urn:usf:adrrequirement:semanticmodelcompilationrealisation> a usf:ADRRequirement;
    usf:canonicalName "semanticmodelcompilationrealisation".
<urn:usf:adrrecord:semanticmodelcompilationrealisation> a usf:ADRRecord;
    usf:canonicalName "semanticmodelcompilationrealisation";
    usf:recordsDecision <urn:usf:realisationdecision:semanticmodelcompilationrealisation>.

