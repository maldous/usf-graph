    rdfs:comment "Identifies an existing semantic state projected by a view model.".
usf:AssuranceObligation a owl:Class;
    rdfs:subClassOf usf:DerivedEntity;
    rdfs:label "Assurance obligation";
    rdfs:comment "A universally derived, explicitly blocking or advisory requirement whose satisfaction is computed from executed results and admissible evidence.".
usf:ProofObligation rdfs:subClassOf usf:AssuranceObligation.
usf:TestObligation rdfs:subClassOf usf:AssuranceObligation.
usf:EvidenceRequirement rdfs:subClassOf usf:AssuranceObligation.
usf:AssuranceMatrix a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Assurance matrix";
    rdfs:comment "A governed collection of exact proof-rung, provider-mode, and environment-class cells.".
usf:AssuranceMatrixCell a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Assurance matrix cell";
    rdfs:comment "One exact proof rung, provider mode, and environment class combination; no dimension is inferred from another.".
usf:ReadinessGate a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Readiness gate";
    rdfs:comment "An authored gate whose state is derived from every applicable blocking criterion and never from existential partial coverage.".
usf:GateCriterion a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Gate criterion";
    rdfs:comment "One independently reviewable, evidence-bearing criterion required by a readiness gate.".
usf:ReadinessGateResult a owl:Class;
    rdfs:subClassOf usf:DerivedEntity;
    rdfs:label "Readiness gate result";
    rdfs:comment "The single derived readiness state and reason set for one gate.".
usf:TestExecution a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Test execution";
    rdfs:comment "One observed execution of a test, distinct from the authored test definition.".
usf:TestResult a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Test result";
    rdfs:comment "The observed result of a test execution, including passing and planted-defect detection states.".
usf:IntegrityVerification a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Integrity verification";
    rdfs:comment "An executed verification binding evidence bytes to their governed checksum and signature.".
usf:ObligationEffect a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Obligation effect".
usf:ResultState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Result state".
