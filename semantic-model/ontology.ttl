usf:containsRepository rdfs:label "contains repository";
    rdfs:comment "Relates a workspace to a repository contained by that workspace.".
usf:containsArtefact rdfs:label "contains artefact";
    rdfs:comment "Relates an artefact container to an artefact it owns or locates.".
usf:containsPackage rdfs:label "contains package";
    rdfs:comment "Relates a repository to a governed package it contains.".
usf:containsModule rdfs:label "contains module";
    rdfs:comment "Relates a package to a governed module it contains.".
usf:hasArtefactPlan rdfs:label "has artefact plan";
    rdfs:comment "Identifies an artefact plan owned by a repository.".
usf:ownedByRepository rdfs:label "owned by repository";
    rdfs:comment "Identifies the single repository that owns an artefact plan.".
usf:plansArtefact rdfs:label "plans artefact";
    rdfs:comment "Identifies an artefact declared as an output or retained input by an artefact plan.".
usf:plansSemanticResource rdfs:label "plans semantic resource";
    rdfs:comment "Binds a source-specific artefact plan to the exact semantic resource selected from its generator query.".
usf:governedByPathRule rdfs:label "governed by path rule";
    rdfs:comment "Identifies the deterministic path rule governing an artefact's canonical path.".
usf:canonicalPath rdfs:label "canonical path";
    rdfs:comment "Records one normalised repository-relative canonical path for an artefact.".
usf:pathPattern rdfs:label "path pattern";
    rdfs:comment "Records the deterministic pattern evaluated by a path rule.".
usf:artefactKind rdfs:label "artefact kind";
    rdfs:comment "Classifies an artefact with exactly one closed artefact kind.".
usf:generationInputRole rdfs:label "generation input role";
    rdfs:comment "Declares how an artefact may participate in generation without upgrading its authority.".
usf:hasPhase rdfs:label "has phase";
    rdfs:comment "Identifies a phase declared by a compiler.".
usf:runOfCompiler rdfs:label "run of compiler";
    rdfs:comment "Identifies the compiler whose contract governs a compiler run.".
usf:executesPhase rdfs:label "executes phase";
    rdfs:comment "Identifies a declared compiler phase executed by a run.".
usf:usesComponent rdfs:label "uses component";
    rdfs:comment "Identifies a compiler component assigned to a phase.".
usf:phaseKind rdfs:label "phase kind";
    rdfs:comment "Classifies a compiler phase with one closed phase kind.".
usf:phaseOrder rdfs:label "phase order";
    rdfs:comment "Records the unique non-negative execution order of a compiler phase.".
usf:runMode rdfs:label "run mode";
    rdfs:comment "Classifies a compiler run as full or incremental.".
usf:runState rdfs:label "run state";
    rdfs:comment "Records the observed lifecycle state of a compiler run.".
usf:consumesArtefact rdfs:label "consumes artefact";
    rdfs:comment "Identifies a declared artefact input consumed by a compiler run.".
usf:producesArtefact rdfs:label "produces artefact";
    rdfs:comment "Identifies a governed artefact output produced by a compiler run.".
usf:generatedByComponent rdfs:label "generated by component";
    rdfs:comment "Identifies the compiler component responsible for generating an artefact.".
usf:semanticInputQuery rdfs:label "semantic input query";
    rdfs:comment "Records the semantic query that selects a component's authoritative inputs.".
usf:outputSchema rdfs:label "output schema";
    rdfs:comment "Identifies a governed schema artefact constraining a component output.".
usf:outputPathRule rdfs:label "output path rule";
    rdfs:comment "Identifies the deterministic path rule used by a compiler component.".
usf:integrityPolicy rdfs:label "integrity policy";
    rdfs:comment "Identifies the policy governing integrity checks for a component output.".
usf:normalisationPolicy rdfs:label "normalisation policy";
    rdfs:comment "Identifies the policy governing deterministic normalisation of a component output.".
usf:missingSemanticsConstraint rdfs:label "missing semantics constraint";
    rdfs:comment "Identifies the fail-closed constraint applied when required semantic input is absent.".
usf:requiresEquivalenceKind rdfs:label "requires equivalence kind";
    rdfs:comment "Identifies an equivalence dimension that a component output must satisfy.".
usf:precedesPhase rdfs:label "precedes phase";
    rdfs:comment "Declares an acyclic ordering edge between compiler phases.".
usf:materialisesArtefact rdfs:label "materialises artefact";
    rdfs:comment "Identifies an artefact created or refreshed by a materialisation operation.".
usf:collectsEvidence rdfs:label "collects evidence";
    rdfs:comment "Identifies an evidence result preserved by a collection operation.".
usf:normalisesEvidence rdfs:label "normalises evidence";
    rdfs:comment "Identifies an evidence result transformed without discarding its raw source.".
usf:ingestsEvidence rdfs:label "ingests evidence";
    rdfs:comment "Identifies an evidence result admitted by an ingestion operation.".
usf:buildOfRun rdfs:label "build of run";
    rdfs:comment "Identifies the successful compiler run from which a build was produced.".
usf:buildsArtefact rdfs:label "builds artefact";
    rdfs:comment "Identifies an artefact produced and verified by a build.".
usf:releaseFromBuild rdfs:label "release from build";
    rdfs:comment "Identifies the single build from which a release is assembled.".
usf:releaseBundle rdfs:label "release bundle";
    rdfs:comment "Identifies the canonical bundle carried by a release.".
usf:versionOf rdfs:label "version of";
    rdfs:comment "Identifies the artefact to which a version applies.".
usf:versionIdentifier rdfs:label "version identifier";
    rdfs:comment "Records the canonical identifier of a version under its governing version policy.".
usf:compatibilityState rdfs:label "compatibility state";
    rdfs:comment "Records the observed compatibility relation between source and target versions.".
usf:compatibilitySourceVersion rdfs:label "compatibility source version";
    rdfs:comment "Identifies the source version evaluated by a compatibility contract.".
usf:compatibilityTargetVersion rdfs:label "compatibility target version";
    rdfs:comment "Identifies the target version evaluated by a compatibility contract.".
usf:migratesFromVersion rdfs:label "migrates from version";
    rdfs:comment "Identifies the source version of a governed migration.".
usf:migratesToVersion rdfs:label "migrates to version";
    rdfs:comment "Identifies the target version of a governed migration.".
usf:bundlesArtefact rdfs:label "bundles artefact";
    rdfs:comment "Identifies an artefact included in a bundle.".
usf:bundleKind rdfs:label "bundle kind";
    rdfs:comment "Classifies a bundle with one closed purpose.".
usf:canonicalChecksum rdfs:label "canonical checksum";
    rdfs:comment "Identifies the checksum that binds an artefact's canonical bytes.".
usf:checksumAlgorithm rdfs:label "checksum algorithm";
    rdfs:comment "Identifies the closed digest algorithm used by a checksum.".
usf:checksumValue rdfs:label "checksum value";
    rdfs:comment "Records the lowercase hexadecimal digest value produced by the declared algorithm.".
usf:hasSignature rdfs:label "has signature";
    rdfs:comment "Identifies a signature carried by a bundle.".
usf:signatureMethod rdfs:label "signature method";
    rdfs:comment "Classifies whether a signature is detached from or enveloped with its subject.".
usf:signingPolicy rdfs:label "signing policy";
    rdfs:comment "Identifies the policy that selects cryptographic profile, trust roots, validity, and revocation checks.".
usf:signedBy rdfs:label "signed by";
    rdfs:comment "Identifies the governed signing identity that created a signature.".
usf:signatureValue rdfs:label "signature value";
    rdfs:comment "Records the encoded signature bytes without representing private key material.".
usf:hasAttestation rdfs:label "has attestation";
    rdfs:comment "Identifies an attestation carried by a bundle.".
usf:attestationKind rdfs:label "attestation kind";
    rdfs:comment "Classifies an attestation by the claim boundary it binds.".
usf:attestsTo rdfs:label "attests to";
    rdfs:comment "Identifies an artefact that is the subject of an attestation.".
usf:issuedBy rdfs:label "issued by";
    rdfs:comment "Identifies the governed signing identity that issued an attestation.".
usf:hasProvenance rdfs:label "has provenance";
    rdfs:comment "Identifies a provenance record that describes an artefact's derivation.".
usf:provenanceSubject rdfs:label "provenance subject";
    rdfs:comment "Identifies an artefact described by a provenance record.".
usf:hasSoftwareBillOfMaterials rdfs:label "has software bill of materials";
    rdfs:comment "Identifies a software bill of materials included in a bundle.".
usf:describesDependency rdfs:label "describes dependency";
    rdfs:comment "Identifies a dependency described by a software bill of materials.".
usf:hasDependencyLock rdfs:label "has dependency lock";
    rdfs:comment "Identifies a dependency lock used by a build.".
usf:locksDependency rdfs:label "locks dependency";
    rdfs:comment "Identifies an artefact dependency fixed by a dependency lock.".
usf:lockedVersion rdfs:label "locked version";
    rdfs:comment "Identifies a version fixed by a dependency lock.".
usf:lockChecksum rdfs:label "lock checksum";
    rdfs:comment "Identifies the checksum binding the complete dependency lock.".
usf:equivalenceKind rdfs:label "equivalence kind";
    rdfs:comment "Classifies the explicit comparison dimension of an equivalence claim.".
usf:equivalenceResult rdfs:label "equivalence result";
    rdfs:comment "Records the observed outcome of an equivalence claim.".
usf:equivalenceSubject rdfs:label "equivalence subject";
    rdfs:comment "Identifies an artefact evaluated as an equivalence subject.".
usf:equivalenceOracle rdfs:label "equivalence oracle";
    rdfs:comment "Identifies a declared artefact used only as an equivalence oracle.".
usf:verifiesRun rdfs:label "verifies run";
    rdfs:comment "Identifies a compiler run evaluated by an equivalence claim.".
usf:cleanRoomInput rdfs:label "clean-room input";
    rdfs:comment "Identifies an admitted semantic-authority, retained, or materialised input to clean-room generation.".
usf:cleanRoomOutput rdfs:label "clean-room output";
    rdfs:comment "Identifies a governed output produced by clean-room generation.".
usf:cleanRoomEquivalence rdfs:label "clean-room equivalence";
    rdfs:comment "Identifies an equivalence claim required by clean-room generation.".
usf:sourceIntegrityChecksum rdfs:label "source integrity checksum";
    rdfs:comment "Identifies a checksum verifying an admitted clean-room input.".
usf:deterministicOutputChecksum rdfs:label "deterministic output checksum";
    rdfs:comment "Identifies the canonical aggregate checksum of a compiler run's outputs.".
usf:incrementalBaseline rdfs:label "incremental baseline";
    rdfs:comment "Identifies the full compiler run against which an incremental run is compared.".
usf:ArtefactFamily a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Artefact family";
    rdfs:comment "A closed semantic family whose durable or external representations are governed by one materialisation rule.".
usf:StorageClass a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Storage class";
    rdfs:comment "A closed class of storage destinations; storage never changes semantic authority.".
usf:RepresentationFormat a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Representation format";
    rdfs:comment "A closed, media-type-bound representation selected by an active materialisation contract.".
usf:MaterialisationRule a owl:Class;
    rdfs:subClassOf usf:Constraint;
    rdfs:label "Materialisation rule";
    rdfs:comment "A complete rule binding one artifact family to storage, representation, authority, generation, retention, supersession, path and naming constraints.".
usf:PathRole a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Path role".
usf:NamingRule a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Naming rule".
usf:NumberingScope a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Numbering scope".
usf:GenerationMode a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Generation mode".
usf:AuthorityClass a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Authority class".
usf:RetentionClass a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Retention class".
usf:SupersessionRule a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Supersession rule".
usf:ProjectionType a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Projection type".
usf:ExternalPayloadDescriptor a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "External payload descriptor";
    rdfs:comment "A small authoritative envelope for an immutable external payload. The descriptor records identity and verification metadata; it is not the payload.".
usf:MaterialisationPlan a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Materialisation plan";
    rdfs:comment "A bounded, deterministic projection of active authority containing ordered path operations; the plan is not authority.".
usf:MaterialisationOperation a owl:Class;
    rdfs:subClassOf usf:Operation;
    rdfs:label "Materialisation operation".
usf:GatewayOperation a owl:Class;
    rdfs:subClassOf usf:Operation;
    rdfs:label "Gateway operation";
    rdfs:comment "A bounded read or coordinator-only mutation exposed by the semantic gateway.".
usf:AgentTaskPacket a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Agent task packet";
    rdfs:comment "A bounded, authority-digest-bound projection that gives an AI agent all and only the current semantic context needed to realise or validate a contract. It is not authority.".
usf:TechnicalStandard a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Technical standard";
    rdfs:comment "A retained latest stable edition used to define a representation or canonicalisation rule.".
usf:governedArtefactFamily a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:MaterialisationRule;
    rdfs:range usf:ArtefactFamily.
usf:usesMaterialisationRule a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ArtefactFamily;
    rdfs:range usf:MaterialisationRule.
usf:usesStorageClass a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:MaterialisationRule;
    rdfs:range usf:StorageClass.
usf:usesRepresentationFormat a owl:ObjectProperty;
    rdfs:domain usf:MaterialisationRule;
    rdfs:range usf:RepresentationFormat.
usf:usesPathRole a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:MaterialisationRule;
    rdfs:range usf:PathRole.
usf:usesNamingRule a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:MaterialisationRule;
    rdfs:range usf:NamingRule.
usf:usesNumberingScope a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:MaterialisationRule;
