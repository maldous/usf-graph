usf:CapabilityOwnerRole a owl:Class;
    rdfs:subClassOf usf:AssuranceOwnerRole;
    rdfs:label "Capability owner role";
    rdfs:comment "The durable role accountable for one capability and its executable contract delivery.".
usf:DeployableProcess a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Deployable process";
    rdfs:comment "An independently startable, health-checked and operable process boundary assembled from capability interfaces.".
usf:ProcessBoundaryClass a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Process boundary class";
    rdfs:comment "A controlled classification separating tenant product runtime, operator control-plane and semantic assurance responsibilities.".
usf:EnvironmentTopology a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Environment topology";
    rdfs:comment "A complete repository-local execution topology for a semantic environment purpose.".
usf:SchemaChangeSeries a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Schema change series";
    rdfs:comment "An owner-scoped, append-only, checksum-immutable and rollback-governed sequence of persistent-state changes.".
usf:TransactionBoundary a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Transaction boundary";
    rdfs:comment "The atomicity, consistency and concurrency boundary owned by one capability.".
usf:RepresentativeDataSet a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Representative data set";
    rdfs:comment "Deterministic non-secret data that exercises normal, boundary and recovery behaviour for a data owner.".
usf:WorkflowExecutionPolicy a owl:Class;
    rdfs:subClassOf usf:Policy;
    rdfs:label "Workflow execution policy";
    rdfs:comment "The timeout, retry, idempotency, concurrency and persistence rules for a workflow.".
usf:ConfigurationValueType a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Configuration value type".
usf:repositoryName a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:range xsd:string;
    rdfs:label "repository name";
    rdfs:comment "The explicit stable lowercase kebab-case repository token independently derived from semantic purpose.".
usf:portForContract a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Port;
    rdfs:range usf:SemanticContract.
usf:eventForContract a owl:ObjectProperty, owl:FunctionalProperty;
