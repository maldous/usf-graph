    rdfs:subClassOf usf:Operation;
    rdfs:label "Compiler run".
usf:Build a owl:Class;
    rdfs:subClassOf usf:Operation;
    rdfs:label "Build".
usf:Release a owl:Class;
    rdfs:subClassOf usf:Operation;
    rdfs:label "Release".
usf:Version a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Version".
usf:CompatibilityContract a owl:Class;
    rdfs:subClassOf usf:SemanticContract;
    rdfs:label "Compatibility contract".
usf:Signature a owl:Class;
    rdfs:subClassOf usf:Artefact;
    rdfs:label "Signature".
usf:SigningIdentity a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Signing identity";
    rdfs:comment "A governed identity authorised to sign an artefact or issue an attestation; secret key material is not represented in graph authority.".
usf:Attestation a owl:Class;
    rdfs:subClassOf usf:Artefact;
    rdfs:label "Attestation".
usf:ProvenanceRecord a owl:Class;
    rdfs:subClassOf usf:Artefact;
    rdfs:label "Provenance record".
usf:SoftwareBillOfMaterials a owl:Class;
    rdfs:subClassOf usf:Artefact;
    rdfs:label "Software bill of materials".
usf:DependencyLock a owl:Class;
    rdfs:subClassOf usf:Artefact;
    rdfs:label "Dependency lock".
usf:Checksum a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Checksum";
    rdfs:comment "A digest record that identifies canonical bytes; it describes an artefact but is not itself a materialised file.".
usf:Bundle a owl:Class;
    rdfs:subClassOf usf:Artefact;
    rdfs:label "Bundle".
usf:EquivalenceClaim a owl:Class;
    rdfs:subClassOf usf:Claim;
    rdfs:label "Equivalence claim";
    rdfs:comment "A falsifiable claim comparing declared subjects under an explicit equivalence kind and observed result.".
usf:EquivalenceRule a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Equivalence rule";
    rdfs:comment "An authored comparison contract declaring the semantic fields, equivalence dimensions, evaluator, input role, and fail-closed diagnostic required before a source may be retired or replaced.".
usf:CleanRoomGeneration a owl:Class;
    rdfs:subClassOf usf:CompilerRun;
    rdfs:label "Clean-room generation";
    rdfs:comment "A compiler run whose inputs are limited to semantic authority and declared retained or materialised artefacts.".
usf:ArtefactKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Artefact kind".
usf:GenerationInputRole a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Generation input role".
usf:CompilerPhaseKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Compiler phase kind".
usf:CompilerRunMode a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Compiler run mode".
usf:CompilerRunState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Compiler run state".
usf:CompatibilityState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Compatibility state".
usf:ChecksumAlgorithm a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Checksum algorithm".
usf:SignatureMethod a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Signature method".
usf:AttestationKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Attestation kind".
usf:EquivalenceKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Equivalence kind".
usf:EquivalenceResult a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Equivalence result".
usf:BundleKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Bundle kind".
usf:Repository rdfs:comment "A governed versioned repository that owns artefact plans and contains packages and artefacts.".
usf:Workspace rdfs:comment "A bounded working context that may contain one or more governed repositories.".
usf:Package rdfs:comment "A distributable or addressable artefact containing governed modules.".
usf:Module rdfs:comment "A bounded artefact unit contained by a package.".
usf:CompilerComponent rdfs:comment "An implementation component with explicit semantic input, output shape, path, integrity, normalisation, and equivalence contracts.".
usf:Generator rdfs:comment "A compiler component that deterministically produces governed artefacts from declared semantic inputs.".
usf:Renderer rdfs:comment "A presentation realisation that is accepted only when it satisfies its RendererContract; compiler generation remains the responsibility of a Generator.".
usf:Transform rdfs:comment "A compiler component that deterministically maps declared input artefacts to governed output artefacts.".
usf:ArtefactMaterialisation rdfs:comment "An operation that creates or refreshes a declared artefact without changing its semantic identity.".
usf:EvidenceCollection rdfs:comment "An operation that preserves emitted evidence as collected evidence without silent loss.".
usf:EvidenceNormalisation rdfs:comment "An operation that creates a deterministic normalised evidence representation while retaining raw evidence.".
usf:EvidenceIngestion rdfs:comment "An operation that admits validated evidence into its governed destination.".
usf:CompilerPhase rdfs:comment "One ordered kind of compiler work with declared component ownership.".
usf:CompilerRun rdfs:comment "One observed execution of a compiler in a full or incremental mode.".
usf:Build rdfs:comment "A governed operation that turns a successful compiler run into verified artefacts with dependency closure.".
usf:Release rdfs:comment "A governed operation that promotes one build into a signed, attested, provenance-bound bundle.".
usf:Version rdfs:comment "A governed identity assigned to one artefact under an explicit version policy.".
usf:CompatibilityContract rdfs:comment "A semantic contract that evaluates compatibility between explicit source and target versions.".
usf:Signature rdfs:comment "An integrity artefact binding encoded signature bytes, signing method, policy, and signing identity to a subject.".
usf:Attestation rdfs:comment "A signed statement that binds an issuer to explicit artefact subjects and an attestation kind.".
usf:ProvenanceRecord rdfs:comment "A governed artefact describing the derivation inputs and process for one or more artefact subjects.".
usf:SoftwareBillOfMaterials rdfs:comment "A governed inventory of dependencies included in or required by a bundle.".
usf:DependencyLock rdfs:comment "A checksum-bound artefact fixing dependency and version pairs used by a build.".
usf:Checksum rdfs:comment "A canonical digest value paired with a closed digest algorithm.".
usf:Bundle rdfs:comment "A checksum-bound aggregate artefact containing a declared set of governed artefacts.".
usf:ArtefactKind rdfs:comment "A closed dimension classifying governed artefacts by semantic kind.".
usf:GenerationInputRole rdfs:comment "A closed dimension declaring how an artefact may participate in generation or equivalence.".
usf:CompilerPhaseKind rdfs:comment "A closed dimension classifying ordered compiler phases.".
usf:CompilerRunMode rdfs:comment "A closed dimension distinguishing full and incremental compiler runs.".
usf:CompilerRunState rdfs:comment "A closed dimension recording the observed lifecycle state of a compiler run.".
usf:CompatibilityState rdfs:comment "A closed dimension recording compatibility, incompatibility, migration need, or indeterminacy.".
usf:ChecksumAlgorithm rdfs:comment "A closed set of digest algorithms permitted for canonical checksums.".
usf:SignatureMethod rdfs:comment "A closed dimension distinguishing detached and enveloped signature representation.".
usf:AttestationKind rdfs:comment "A closed dimension classifying the boundary asserted by an attestation.".
usf:EquivalenceKind rdfs:comment "A closed dimension naming the semantic comparison performed by an equivalence claim.".
usf:EquivalenceResult rdfs:comment "A closed dimension recording equivalent, not-equivalent, or indeterminate outcomes.".
usf:BundleKind rdfs:comment "A closed dimension classifying a bundle by its governed purpose.".
usf:containsRepository a owl:ObjectProperty;
    rdfs:domain usf:Workspace;
    rdfs:range usf:Repository.
usf:containsArtefact a owl:ObjectProperty;
    rdfs:domain usf:ArtefactContainer;
    rdfs:range usf:Artefact.
