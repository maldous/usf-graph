usf:AssuranceFramework rdfs:label "Assurance framework";
    rdfs:comment "A governed external or internal control framework represented without implying certification.".
usf:FrameworkEdition rdfs:label "Framework edition";
    rdfs:comment "A versioned edition of an assurance framework with explicit effective and withdrawal dates.".
usf:FrameworkClause rdfs:label "Framework clause";
    rdfs:comment "A clause identified within a particular framework edition.".
usf:FrameworkControl rdfs:label "Framework control";
    rdfs:comment "A control reference defined by a particular framework edition.".
usf:ControlImplementation rdfs:label "Control implementation";
    rdfs:comment "A governed implementation state and ownership record for one USF control.".
usf:ControlScopeMapping rdfs:label "Control scope mapping";
    rdfs:comment "A reason-coded mapping from a control to a capability and semantic contract.".
usf:ControlMappingReason rdfs:label "Control mapping reason";
    rdfs:comment "A closed reason explaining why a control applies to a mapped semantic scope.".
usf:ControlStatus rdfs:label "Control status";
    rdfs:comment "A closed lifecycle or approval state for a control implementation or statement of applicability.".
usf:StatementOfApplicability rdfs:label "Statement of applicability";
    rdfs:comment "A governed set of applicability decisions for one framework edition and explicit scope.".
usf:ApplicabilityDecision rdfs:label "Applicability decision";
    rdfs:comment "A reviewable decision about one framework control, including status and rationale.".
usf:ApplicabilityStatus rdfs:label "Applicability status";
    rdfs:comment "A closed state distinguishing pending, applicable, and not-applicable decisions.".
usf:AssuranceOwnerRole rdfs:label "Assurance owner role";
    rdfs:comment "A role accountable or responsible for an assurance decision, implementation, or review.".
usf:ControlException rdfs:label "Control exception";
    rdfs:comment "A time-bounded reviewed exception to a control implementation with explicit compensation.".
usf:CompensatingControl rdfs:label "Compensating control";
    rdfs:comment "A control deliberately used to reduce risk while an exception applies.".
usf:RiskAssessment rdfs:label "Risk assessment";
    rdfs:comment "A dated assessment recording inherent and residual likelihood, impact, and computed scores.".
usf:RiskTreatment rdfs:label "Risk treatment";
    rdfs:comment "A governed treatment plan connecting a risk to controls, ownership, status, and due date.".
usf:TreatmentStatus rdfs:label "Treatment status";
    rdfs:comment "A closed lifecycle state for a risk treatment.".
usf:RiskAcceptance rdfs:label "Risk acceptance";
    rdfs:comment "A time-bounded accountable acceptance of explicitly assessed residual risk.".
usf:ControlAssessment rdfs:label "Control assessment";
    rdfs:comment "An observed effectiveness assessment of one control implementation using identified evidence.".
usf:AssessmentOutcome rdfs:label "Assessment outcome";
    rdfs:comment "A closed observed outcome for a control assessment.".
usf:AssuranceFinding rdfs:label "Assurance finding";
    rdfs:comment "A reasoned finding emitted by a control assessment and tracked to resolution or acceptance.".
usf:FindingStatus rdfs:label "Finding status";
    rdfs:comment "A closed lifecycle state for an assurance finding.".
usf:CorrectiveAction rdfs:label "Corrective action";
    rdfs:comment "An owned and dated action intended to remediate an assurance finding.".
usf:ActionStatus rdfs:label "Action status";
    rdfs:comment "A closed lifecycle state for a corrective action.".
usf:ControlReview rdfs:label "Control review";
    rdfs:comment "An independent or accountable review of a governed assurance subject.".
usf:EvidenceReview rdfs:label "Evidence review";
    rdfs:comment "A dated review of evidence by an identified assurance role.".
