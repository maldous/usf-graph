# ── Permutation closure meta-model ─────────────────────────────────────────
# Semantic meta-layer for operational-permutation and authorisation closure.
# It enumerates and dispositions existing USF semantics; it is not a second
# domain model and grants no authority by itself.

usf:PermutationUniverse a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation universe";
    rdfs:comment "The complete finite, deterministic, digest-bound candidate universe across all permutation families for one authority digest.".
usf:PermutationFamily a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation family";
    rdfs:comment "One multi-axis operational family with ordered finite dimensions, applicability rules, a stable-key algorithm and closure requirements.".
usf:PermutationFamilyDimensionBinding a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation family dimension binding";
    rdfs:comment "Orders one dimension within one family and records whether it is conditionally active.".
usf:PermutationDimensionValue a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation dimension value".
usf:DimensionValueSource a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Dimension value source";
    rdfs:comment "The closed, validated, digest-bound source from which one dimension's finite values are derived.".
usf:PermutationApplicabilityRule a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation applicability rule";
    rdfs:comment "An explicit, proved rule excluding or including candidate combinations; exclusions are never silent.".
usf:PermutationCell a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation cell";
    rdfs:comment "Exactly one materialised candidate combination with exactly one closure disposition.".
usf:PermutationClosureDisposition a owl:Class;
    rdfs:subClassOf usf:PermutationDisposition;
    rdfs:label "Permutation closure disposition";
    rdfs:comment "Closed disposition set for closure cells: required, allowed, forbidden, notapplicable, deferred, unresolved.".
usf:PermutationDispositionReason a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Permutation disposition reason".
usf:PermutationFamilyReview a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation family review";
    rdfs:comment "Census record assigning one subject exactly one family-applicability disposition.".
usf:PermutationFamilyReviewDisposition a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Permutation family review disposition".
usf:OperationalSurfaceClassification a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Operational surface classification".
usf:PermutationCoverage a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation coverage";
    rdfs:comment "Coverage record binding one cell to its semantic, permission, principal, token, lifecycle, test, evidence, proof, environment and audit coverage state.".
usf:PermutationProof a owl:Class;
    rdfs:subClassOf usf:Proof;
    rdfs:label "Permutation proof";
    rdfs:comment "Deterministic semantic-exhaustiveness proof independently recomputing the candidate universe.".
usf:PermutationPartition a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation partition";
    rdfs:comment "Deterministic partition of the universe by family and capability for bounded storage and query.".
usf:PermissionAtom a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permission atom";
    rdfs:comment "Exact permission semantics: capability, resource, action, scope, boundary, selector, restrictions, delegability, break-glass eligibility and audit category.".
usf:AuthorisationPath a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Authorisation path";
    rdfs:comment "One satisfiable chain from operation through principal kind, role or rule, permission atom, condition profile, boundary, environment and token scope or non-token mode.".
usf:AuthorisationConditionProfile a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Authorisation condition profile";
    rdfs:comment "A finite named conjunction of authorisation conditions referenced by conditional grants.".
usf:PrincipalKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Principal kind".
usf:RolePermissionDisposition a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Role permission disposition";
    rdfs:comment "Exactly one classification of one active role against one relevant permission atom in context.".
usf:RolePermissionDispositionKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Role permission disposition kind".
usf:ResourceSelectorKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Resource selector kind".
usf:ActionKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Action kind".
usf:ActionGroup a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Action group".
usf:Transport a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Transport".
usf:HttpMethod a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "HTTP method".
usf:InteractionPattern a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Interaction pattern".
usf:InteractionDirection a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Interaction direction".
usf:SessionModel a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Session model".
usf:TokenProfile a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Token profile";
    rdfs:comment "A least-privilege token projection derived only from active required or allowed authorisation cells.".
usf:BreakGlassTokenProfile a owl:Class;
    rdfs:subClassOf usf:TokenProfile;
    rdfs:label "Break-glass token profile";
    rdfs:comment "Short-lived, non-refreshable, fully audited emergency token profile requiring reason, approval and post-use review.".
usf:TokenScope a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Token scope";
    rdfs:comment "A stable semantic scope mapping to exact active permission atoms; never broader than its source cells.".
usf:TokenClaimConstraint a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Token claim constraint".
usf:TokenAudience a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Token audience".
usf:TokenIssuerClass a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Token issuer class".
usf:DelegationConstraint a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Delegation constraint".
usf:ResourceSelectorConstraint a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Resource selector constraint".
usf:TokenLifetimePolicy a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Token lifetime policy".
usf:AuthenticationStrengthRequirement a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Authentication strength requirement".
usf:ProofOfPossessionRequirement a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Proof-of-possession requirement".
usf:RevocationPolicy a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Revocation policy".

