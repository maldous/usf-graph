usf:hasEventBinding a owl:ObjectProperty;
    rdfs:domain usf:ViewModel;
    rdfs:range usf:Event;
    rdfs:label "has event binding";
    rdfs:comment "Identifies an existing semantic event observed or produced by a view model.".
usf:hasStateBinding a owl:ObjectProperty;
    rdfs:domain usf:ViewModel;
    rdfs:range usf:State;
