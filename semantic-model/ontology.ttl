usf:processOwnsCapability a owl:ObjectProperty;
    rdfs:domain usf:DeployableProcess;
    rdfs:range usf:Capability;
    rdfs:comment "Identifies capabilities for which this process is the single accountable execution or validation boundary.".
usf:accountableProcessBoundary a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Capability;
    rdfs:range usf:DeployableProcess;
    rdfs:comment "The single process accountable for executing or validating a current capability's behaviour.".
usf:participatesInProcess a owl:ObjectProperty;
    rdfs:domain usf:Capability;
    rdfs:range usf:DeployableProcess;
    rdfs:comment "An explicit process assembly in which the capability executes or validates behaviour, including non-accountable participation.".
