    rdfs:domain usf:Repository;
    rdfs:range usf:Package.
usf:containsModule a owl:ObjectProperty;
    rdfs:domain usf:Package;
    rdfs:range usf:Module.
usf:hasArtefactPlan a owl:ObjectProperty;
    rdfs:domain usf:Repository;
    rdfs:range usf:ArtefactPlan.
usf:ownedByRepository a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ArtefactPlan;
    rdfs:range usf:Repository.
usf:plansArtefact a owl:ObjectProperty;
    rdfs:domain usf:ArtefactPlan;
    rdfs:range usf:Artefact.
usf:plansSemanticResource a owl:ObjectProperty;
    rdfs:domain usf:ArtefactPlan;
    rdfs:range rdfs:Resource.
usf:governedByPathRule a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Artefact;
    rdfs:range usf:PathRule.
usf:canonicalPath a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:Artefact;
    rdfs:range xsd:string.
usf:pathPattern a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:PathRule;
    rdfs:range xsd:string.
usf:artefactKind a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Artefact;
