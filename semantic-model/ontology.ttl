usf:termUsageOwningContract a owl:AnnotationProperty;
    rdfs:label "term usage owning contract".
usf:termUsageLifecycleStage a owl:AnnotationProperty;
    rdfs:label "term usage lifecycle stage".
usf:termUsageRationale a owl:AnnotationProperty;
    rdfs:label "term usage rationale".
usf:Validator a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Validator";
    rdfs:comment "A validator evaluates semantic or structural constraints and may produce evidence but is never semantic authority.".
usf:Feature a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Feature";
    rdfs:comment "A contract-warranted capability of a candidate realisation; source code cannot establish it.".
<urn:usf:termusagestate:usedbysemanticquery> a usf:TermUsageState;
    usf:canonicalName "usedbysemanticquery".
usf:applicableToObligation usf:termUsageState <urn:usf:termusagestate:usedbysemanticquery>;
    usf:termUsageOwningContract <urn:usf:semanticcontract:compilersemanticenforcement>;
    usf:termUsageLifecycleStage "evidence-proof-contract-enforcement";
    usf:termUsageRationale "USED: referenced by lifecycle SHACL or integrity SPARQL; no ordinary authority instance is required solely to make embedded-query use visible.".
usf:authorisedByDecision usf:termUsageState <urn:usf:termusagestate:usedbysemanticquery>;
    usf:termUsageOwningContract <urn:usf:semanticcontract:compilersemanticenforcement>;
    usf:termUsageLifecycleStage "evidence-proof-contract-enforcement";
