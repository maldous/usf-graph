    rdfs:comment "Identifies semantic validation applied to a form field.".
usf:validationConstraint a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ValidationBinding;
    rdfs:range usf:Constraint;
    rdfs:label "validation constraint";
    rdfs:comment "Identifies the existing semantic constraint enforced by a validation binding.".
usf:validationTiming a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ValidationBinding;
    rdfs:range usf:ValidationTiming;
    rdfs:label "validation timing";
    rdfs:comment "Classifies when the bound validation is observed.".
usf:hasErrorBinding a owl:ObjectProperty;
    rdfs:domain usf:ViewModel;
    rdfs:range usf:ErrorBinding;
    rdfs:label "has error binding";
