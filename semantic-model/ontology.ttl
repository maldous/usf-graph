usf:shapeForClass rdfs:range owl:Class.
usf:UISemanticModel a owl:Class;
    rdfs:subClassOf usf:SemanticContract;
    rdfs:label "UI semantic model";
    rdfs:comment "A framework-neutral contract joining one capability to journeys, surfaces, view models, operations, interfaces, policies, permissions, states, events, data, accessibility, localisation, and renderer contracts.".
usf:ViewModel a owl:Class;
    rdfs:subClassOf usf:SemanticContract;
    rdfs:label "View model";
    rdfs:comment "A framework-neutral semantic projection of state, data, operations, errors, validation, and components for one or more surfaces.".
usf:Route a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Route";
    rdfs:comment "A navigable UI route with one deterministic route pattern and route kind; it is distinct from a service Interface.".
usf:Surface a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Surface";
    rdfs:comment "A framework-neutral authored UI surface rendered from a view model and governed by a UI semantic model.".
usf:Form a owl:Class;
    rdfs:subClassOf usf:Surface;
    rdfs:label "Form";
    rdfs:comment "A UI surface that binds fields, validation, errors, permissions, and exactly one submit operation where mutation occurs.".
usf:FormField a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Form field";
    rdfs:comment "One ordered, typed, labelled input or display field with data, validation, accessibility, and localisation bindings.".
usf:ValidationBinding a owl:Class;
    rdfs:subClassOf usf:Constraint;
    rdfs:label "Validation binding";
    rdfs:comment "A binding from a form field to an existing semantic constraint and explicit validation timing.".
usf:ErrorBinding a owl:Class;
    rdfs:subClassOf usf:Constraint;
    rdfs:label "Error binding";
    rdfs:comment "A binding from a stable error code to an interaction state and presentation kind.".
usf:Component a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Component";
    rdfs:comment "A framework-neutral compositional UI primitive whose semantics are expressed by kind, order, children, and view-model binding.".
usf:RendererContract a owl:Class;
    rdfs:subClassOf usf:SemanticContract;
    rdfs:label "Renderer contract";
    rdfs:comment "A deterministic contract connecting a renderer target to input schema, output ArtefactPlan, supported surfaces, E2E journeys, and documentation model.".
usf:AccessibilityProfile a owl:Class;
    rdfs:subClassOf usf:SemanticContract;
    rdfs:label "Accessibility profile";
    rdfs:comment "A grouped set of explicit accessibility requirements; presence does not claim external-standard conformance.".
usf:LocalisationProfile a owl:Class;
    rdfs:subClassOf usf:SemanticContract;
    rdfs:label "Localisation profile";
    rdfs:comment "A grouped set of locale, fallback, formatting, pluralisation, directionality, and message-key requirements.".
usf:Preview a owl:Class;
    rdfs:subClassOf usf:Surface;
    rdfs:label "Preview";
    rdfs:comment "A non-authoritative rendered preview of a declared surface used for review and adversarial inspection.".
usf:UIExposureClass a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "UI exposure class";
    rdfs:comment "A closed decision distinguishing UI-exposed, API-only, internal, and not-exposed capabilities.".
usf:SurfaceKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Surface kind";
    rdfs:comment "A closed, framework-neutral classification of UI and proof surfaces.".
usf:RendererTarget a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Renderer target";
    rdfs:comment "A closed classification of renderer output targets.".
usf:ComponentKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Component kind";
    rdfs:comment "A closed semantic classification of UI component responsibilities.".
usf:FormFieldKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Form field kind";
    rdfs:comment "A closed semantic classification of form field input and display behaviour.".
usf:ValidationTiming a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Validation timing";
    rdfs:comment "A closed classification of when validation is observed.".
usf:ErrorPresentationKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Error presentation kind";
    rdfs:comment "A closed semantic classification of error presentation behaviour.".
usf:AccessibilityRequirementKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Accessibility requirement kind";
    rdfs:comment "A closed classification of explicit accessibility behaviours without a compliance overclaim.".
usf:LocalisationRequirementKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Localisation requirement kind";
    rdfs:comment "A closed classification of explicit localisation behaviours.".
usf:RouteKind a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Route kind";
    rdfs:comment "A closed classification of route audience and security context.".
usf:hasUISemanticModel a owl:ObjectProperty;
    rdfs:domain usf:Capability;
    rdfs:range usf:UISemanticModel;
    rdfs:label "has UI semantic model";
    rdfs:comment "Identifies a UI semantic model owned by a capability.".
usf:uiExposure a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Capability;
    rdfs:range usf:UIExposureClass;
    rdfs:label "UI exposure";
    rdfs:comment "Records exactly one explicit UI exposure decision for a capability.".
usf:hasJourney a owl:ObjectProperty;
    rdfs:domain usf:UISemanticModel;
    rdfs:range usf:Journey;
    rdfs:label "has journey";
    rdfs:comment "Identifies a journey governed by a UI semantic model.".
usf:hasViewModel a owl:ObjectProperty;
    rdfs:domain usf:UISemanticModel;
    rdfs:range usf:ViewModel;
    rdfs:label "has view model";
    rdfs:comment "Identifies a framework-neutral view model governed by a UI semantic model.".
usf:hasSurface a owl:ObjectProperty;
    rdfs:domain usf:UISemanticModel;
    rdfs:range usf:Surface;
    rdfs:label "has surface";
    rdfs:comment "Identifies a surface governed by a UI semantic model.".
usf:surfaceKind a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Surface;
    rdfs:range usf:SurfaceKind;
    rdfs:label "surface kind";
    rdfs:comment "Classifies a surface with exactly one framework-neutral kind.".
usf:surfaceRoute a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Surface;
    rdfs:range usf:Route;
    rdfs:label "surface route";
    rdfs:comment "Identifies the route for a navigable surface.".
usf:routePattern a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:Route;
    rdfs:range xsd:string;
    rdfs:label "route pattern";
    rdfs:comment "Records one deterministic, normalised route pattern.".
usf:routeKind a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Route;
    rdfs:range usf:RouteKind;
    rdfs:label "route kind";
    rdfs:comment "Classifies the audience and security context of a route.".
usf:rendersViewModel a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Surface;
    rdfs:range usf:ViewModel;
    rdfs:label "renders view model";
    rdfs:comment "Identifies the view model rendered by a surface.".
usf:hasForm a owl:ObjectProperty;
    rdfs:domain usf:ViewModel;
    rdfs:range usf:Form;
    rdfs:label "has form";
    rdfs:comment "Identifies a form composed into a view model.".
usf:hasField a owl:ObjectProperty;
    rdfs:domain usf:Form;
    rdfs:range usf:FormField;
    rdfs:label "has field";
    rdfs:comment "Identifies a field composed into a form.".
usf:fieldName a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:FormField;
    rdfs:range xsd:string;
    rdfs:label "field name";
    rdfs:comment "Records the stable semantic name of a form field.".
usf:fieldKind a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:FormField;
    rdfs:range usf:FormFieldKind;
    rdfs:label "field kind";
    rdfs:comment "Classifies a form field with exactly one semantic kind.".
usf:fieldOrder a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:FormField;
    rdfs:range xsd:nonNegativeInteger;
    rdfs:label "field order";
    rdfs:comment "Records a field's unique order within a form.".
usf:viewDataModel a owl:ObjectProperty;
    rdfs:domain usf:ViewModel;
    rdfs:range usf:DataModel;
    rdfs:label "view data model";
    rdfs:comment "Identifies an existing data model projected by a view model.".
usf:fieldDataModel a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:FormField;
    rdfs:range usf:DataModel;
    rdfs:label "field data model";
    rdfs:comment "Identifies the semantic data model containing a field's value.".
usf:loadsOperation a owl:ObjectProperty;
    rdfs:domain usf:ViewModel;
    rdfs:range usf:Operation;
    rdfs:label "loads operation";
    rdfs:comment "Identifies a query or operation that loads a view model.".
usf:submitsOperation a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Form;
    rdfs:range usf:Operation;
    rdfs:label "submits operation";
    rdfs:comment "Identifies the operation invoked by form submission.".
usf:bindsInterface a owl:ObjectProperty;
    rdfs:domain usf:ViewModel;
    rdfs:range usf:Interface;
    rdfs:label "binds interface";
    rdfs:comment "Identifies an existing interface consumed by a view model.".
usf:bindsPolicy a owl:ObjectProperty;
    rdfs:domain usf:UISemanticModel;
    rdfs:range usf:Policy;
    rdfs:label "binds policy";
    rdfs:comment "Identifies an existing policy governing a UI semantic model.".
usf:uiRequiresPermission a owl:ObjectProperty;
    rdfs:domain usf:Surface;
    rdfs:range usf:Permission;
    rdfs:label "UI requires permission";
    rdfs:comment "Identifies a permission required before a surface or action may be exposed.".
usf:hasValidationBinding a owl:ObjectProperty;
    rdfs:domain usf:FormField;
