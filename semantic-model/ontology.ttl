usf:Artefact a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Artefact";
    rdfs:comment "A governed, addressable input or output whose identity, path, integrity, provenance, and generation role can be validated.".
usf:ArtefactContainer a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Artefact container";
    rdfs:comment "A semantic container that owns or locates governed artefacts without making filesystem layout authoritative.".
usf:Repository a owl:Class;
    rdfs:subClassOf usf:ArtefactContainer;
    rdfs:label "Repository".
usf:Workspace a owl:Class;
    rdfs:subClassOf usf:ArtefactContainer;
    rdfs:label "Workspace".
usf:Package a owl:Class;
    rdfs:subClassOf usf:Artefact;
    rdfs:label "Package".
usf:Module a owl:Class;
    rdfs:subClassOf usf:Artefact;
    rdfs:label "Module".
usf:Template a owl:Class;
    rdfs:subClassOf usf:Artefact;
    rdfs:label "Template";
    rdfs:comment "A declared generation input that supplies structure but does not define missing semantics.".
usf:AutomationWorkflowContract a owl:Class;
    rdfs:subClassOf usf:SemanticContract;
    rdfs:label "Automation workflow contract";
    rdfs:comment "A semantic contract for a generated automation workflow whose exact implementation may be supplied by an integrity-bound template.".
usf:AutomationTrigger a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Automation trigger".
usf:AutomationPermission a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Automation permission".
usf:ArtefactPlan a owl:Class;
    rdfs:subClassOf usf:SemanticContract;
    rdfs:label "Artefact plan";
    rdfs:comment "A semantic contract declaring inputs, outputs, generator ownership, deterministic path rules, integrity, and equivalence obligations.".
usf:PathRule a owl:Class;
    rdfs:subClassOf usf:Constraint;
    rdfs:label "Path rule";
    rdfs:comment "A deterministic, validator-checkable rule for deriving one canonical artefact path.".
usf:Compiler a owl:Class;
    rdfs:subClassOf usf:Implementation;
    rdfs:label "Compiler";
    rdfs:comment "An orchestrator that executes declared phases and components against semantic authority without inventing behaviour.".
usf:CompilerComponent a owl:Class;
    rdfs:subClassOf usf:Implementation;
    rdfs:label "Compiler component".
usf:Generator a owl:Class;
    rdfs:subClassOf usf:CompilerComponent;
    rdfs:label "Generator".
usf:Renderer a owl:Class;
    rdfs:subClassOf usf:Implementation;
    rdfs:label "Renderer".
usf:Transform a owl:Class;
    rdfs:subClassOf usf:CompilerComponent;
    rdfs:label "Transform".
usf:Importer a owl:Class;
    rdfs:subClassOf usf:CompilerComponent;
    rdfs:label "Importer";
    rdfs:comment "A component that admits only explicitly declared and integrity-checked inputs.".
usf:ArtefactMaterialisation a owl:Class;
    rdfs:subClassOf usf:Operation;
    rdfs:label "Artefact materialisation".
usf:EvidenceCollection a owl:Class;
    rdfs:subClassOf usf:Operation;
    rdfs:label "Evidence collection".
usf:EvidenceNormalisation a owl:Class;
    rdfs:subClassOf usf:Operation;
    rdfs:label "Evidence normalisation".
usf:EvidenceIngestion a owl:Class;
    rdfs:subClassOf usf:Operation;
    rdfs:label "Evidence ingestion".
usf:CompilerPhase a owl:Class;
    rdfs:subClassOf usf:Operation;
    rdfs:label "Compiler phase".
