@prefix usf: <urn:usf:ontology:>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.

<urn:usf:ontology> a owl:Ontology;
    rdfs:label "Universal Service Foundation ontology".
usf:SemanticAuthority a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Semantic authority";
    rdfs:comment "Validated semantic state in Stardog is the sole semantic authority. ADRs, validators, evidence, proof, code, reports, tickets and documentation have distinct non-authoritative roles.".
usf:EvidenceAdmission a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Evidence admission".
usf:EvidenceAdmissionState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Evidence admission state".
usf:EvidenceFreshnessState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Evidence freshness state".
usf:EvidenceIntegrityState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Evidence integrity state".
usf:EvidenceProvenance a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Evidence provenance".
usf:EvidenceRetentionPolicy a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Evidence retention policy".
usf:EvidenceSupersession a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Evidence supersession".
usf:ProofEvaluation a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Proof evaluation".
usf:ProofResultState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Proof result state".
usf:ProofAlgorithm a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Proof algorithm".
usf:ProofAlgorithmVersion a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Proof algorithm version".
usf:ProofConfidenceState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Proof confidence state".
usf:ProofInvalidationCondition a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Proof invalidation condition".
usf:ProofAuthorityBinding a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Proof authority binding";
    rdfs:comment "Binds a proof result to the exact evaluated authority and to a content-sensitive digest of every non-publication authority graph. A narrowly enumerated self-publication closure may survive its own evidence/proof/activation publication only when a post-publication evaluation rechecks the resulting live authority.".
usf:AuthorityBindingRule a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Authority binding rule".
usf:ContractActivationState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Contract activation state".
usf:RealisationDecision a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Realisation decision".
usf:RealisationOption a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Realisation option".
usf:ComposedRealisationOption a owl:Class;
    rdfs:subClassOf usf:RealisationOption;
    rdfs:label "Composed realisation option";
    rdfs:comment "A candidate realisation whose fitness depends on an explicit, responsibility-bearing set of interoperating components.".
usf:DecisionEvaluation a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Decision evaluation".
usf:EvaluationCriterion a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Evaluation criterion".
usf:CriterionRequirement a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Criterion requirement".
usf:CriterionAssessment a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Criterion assessment".
usf:CriterionEvidenceBinding a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Criterion evidence binding".
usf:LicenceCompatibilityPolicy a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Licence compatibility policy".
usf:CriterionMitigation a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Criterion mitigation";
    rdfs:comment "An explicitly accepted, evidence-backed control that closes a mandatory criterion which is not directly satisfied by an option.".
usf:CandidateCredibilityAssessment a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Candidate credibility assessment".
usf:SoleCandidateJustification a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Sole candidate justification".
usf:CandidateClassExclusion a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Candidate class exclusion".
usf:OptionRejection a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Option rejection".
usf:RejectionReason a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Rejection reason".
usf:OptionComponent a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Option component".
usf:CompositionInterface a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Composition interface";
    rdfs:comment "A contract-bound interaction boundary between selected option components. It records composition compatibility without inventing a product-runtime operation for non-runtime components.".
usf:ComponentIdentity a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Component identity".
usf:PackageComponent a owl:Class;
    rdfs:subClassOf usf:ComponentIdentity;
    rdfs:label "Package component".
usf:RuntimeComponent a owl:Class;
    rdfs:subClassOf usf:ComponentIdentity;
    rdfs:label "Runtime component".
usf:ExternalProviderComponent a owl:Class;
    rdfs:subClassOf usf:ComponentIdentity;
    rdfs:label "External provider component".
usf:RepositoryLocalComponent a owl:Class;
    rdfs:subClassOf usf:ComponentIdentity;
    rdfs:label "Repository-local component".
usf:ContainerImageComponent a owl:Class;
    rdfs:subClassOf usf:ComponentIdentity;
    rdfs:label "Container image component";
    rdfs:comment "A third-party or repository-produced OCI component whose selected identity is an immutable digest-qualified image reference.".
usf:ComponentResponsibility a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Component responsibility".
usf:ComponentIntegrityConstraint a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Component integrity constraint".
usf:LicenceAssessment a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Licence assessment".
usf:VulnerabilityAssessment a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Vulnerability assessment".
usf:SupplyChainAssessment a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Supply-chain assessment".
usf:PortabilityAssessment a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Portability and exit assessment".
usf:CompositionCoverageProof a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Composition coverage proof".
usf:CompositionPermutationAssessment a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Composition permutation assessment".
usf:ComponentCompatibilityAssessment a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Component compatibility assessment";
    rdfs:comment "Evidence-backed compatibility of exact component versions and integrity identities across one declared dependency interface.".
usf:CandidateSearchSpace a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Candidate search space";
    rdfs:comment "A finite, digest-bound set of materially different realisation classes considered for a proven sole-candidate decision.".
usf:RealisationClass a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Realisation class".
usf:PermutationDimension a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation dimension".
usf:PermutationRuleSet a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation rule set".
usf:PermutationClassificationRule a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation classification rule".
usf:PermutationCondition a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation condition".
usf:PermutationEquivalenceProof a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Permutation equivalence proof".
usf:SelectedOptionRealisationMapping a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Selected option realisation mapping".
usf:SelectedComponentConcreteMapping a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Selected component concrete mapping".
usf:DependencyBinding a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Dependency binding";
    rdfs:comment "A digest-bound mapping from one selected component identity to its exact acquired dependency representation.".
usf:ValidationFailureCode a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Validation failure code".
usf:ValidationLayer a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Validation layer".
usf:EvaluationClosureState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Evaluation closure state".
usf:AssessmentResult a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Assessment result".
usf:CriterionApplicability a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Criterion applicability".
usf:CandidateCredibilityState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Candidate credibility state".
usf:RejectionDuration a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Rejection duration".
usf:ComponentRole a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Component role".
usf:PermutationDisposition a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Permutation disposition".
usf:RepresentationDecision a owl:Class;
    rdfs:subClassOf usf:RealisationDecision;
    rdfs:label "Representation decision".
usf:ADRRequirement a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "ADR requirement".
usf:ADRRecord a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "ADR record";
    rdfs:comment "Historical rationale that records but cannot establish semantic truth.".
usf:DecisionState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Decision state".
usf:DecisionSupersession a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Decision supersession".
usf:ValidationObligation a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Validation obligation".
usf:ValidationExecution a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Validation execution".
usf:ValidationResult a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Validation result".
usf:ValidationEnvironment a owl:Class;
    rdfs:subClassOf usf:Environment;
    rdfs:label "Validation environment".
usf:ValidationEvidence a owl:Class;
    rdfs:subClassOf usf:EvidenceResult;
    rdfs:label "Validation evidence".
usf:ExternalWorkRecord a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "External work record";
    rdfs:comment "Optional coordination carrier without semantic authority.".
usf:Report a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Report";
    rdfs:comment "Projection that cannot admit evidence.".
usf:SemanticAdequacyReview a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Semantic adequacy review";
    rdfs:comment "A digest-bound counterfactual review of imported semantic state. The review evaluates authority but cannot itself replace a semantic correction decision.".
usf:SemanticAdequacyReviewState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Semantic adequacy review state".
usf:SemanticAdequacyDisposition a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Semantic adequacy disposition".
usf:SemanticCorrectionDecision a owl:Class;
    rdfs:subClassOf usf:Entity;
    rdfs:label "Semantic correction decision";
    rdfs:comment "An authority mutation decision supported by an accepted semantic adequacy review and exact evidence. It preserves predecessor lineage and selects current semantic identity without importing implementation authority.".
usf:SemanticCorrectionDecisionState a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "Semantic correction decision state".
usf:SemanticAdequacyProof a owl:Class;
    rdfs:subClassOf usf:Proof;
    rdfs:label "Semantic adequacy proof";
    rdfs:comment "A deterministic evaluation of a digest-bound semantic adequacy inventory and independent review. It proves only the reviewed semantic state and never implementation behaviour.".
usf:soleSemanticAuthority a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:SemanticAuthority;
    rdfs:range xsd:boolean.
usf:validatedInStardog a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:SemanticAuthority;
    rdfs:range xsd:boolean.
usf:authorityVerificationState a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:SemanticAuthority;
    rdfs:range xsd:string.
usf:governsNamedGraph a owl:ObjectProperty;
    rdfs:domain usf:SemanticAuthority;
    rdfs:range usf:NamedGraph.
usf:defaultReasoningSchemaGraph a owl:ObjectProperty;
    rdfs:domain usf:SemanticAuthority;
    rdfs:range usf:NamedGraph;
    rdfs:label "default reasoning schema graph";
    rdfs:comment "Identifies exactly the registered named graphs whose OWL/RDFS axioms form Stardog's default reasoning schema. This is narrower than the repository definition-graph class and excludes controlled-value, authority-configuration, registry, shape, authored, observed and derived graphs.".
usf:concernsSemanticSubject a owl:ObjectProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range usf:Entity.
usf:supportsClaim a owl:ObjectProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range usf:Claim.
usf:contentDigest a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range xsd:string.
usf:evidenceProducerDigest a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range xsd:string.
usf:evaluatedAuthorityDigest a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range xsd:string.
usf:mediaType a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range xsd:string.
usf:byteSize a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range xsd:nonNegativeInteger.
usf:storageLocator a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range xsd:anyURI.
usf:wasProducedBy a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range usf:Entity.
usf:collectedInEnvironment a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range usf:Environment.
usf:collectedAt a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range xsd:dateTime.
usf:validUntil a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range xsd:dateTime.
usf:hasFreshnessPolicy a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range usf:EvidenceRetentionPolicy.
usf:hasFreshnessState a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range usf:EvidenceFreshnessState.
usf:hasIntegrityState a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range usf:EvidenceIntegrityState.
usf:hasAdmissionState a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range usf:EvidenceAdmissionState.
usf:admissionForEvidence a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceAdmission;
    rdfs:range usf:EvidenceResult.
usf:admissionDecidedByValidator a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceAdmission;
    rdfs:range usf:ValidatorRule.
usf:hasProvenance a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range usf:EvidenceProvenance.
usf:applicableToObligation a owl:ObjectProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range usf:ProofObligation.
usf:withinValidityScope a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range xsd:boolean.
usf:supersedesEvidence a owl:ObjectProperty;
    rdfs:domain usf:EvidenceResult;
    rdfs:range usf:EvidenceResult.
usf:isSupersededByEvidence a owl:ObjectProperty;
    owl:inverseOf usf:supersedesEvidence.
usf:evaluatesObligation a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofEvaluation;
    rdfs:range usf:ProofObligation.
usf:producesProofResult a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofEvaluation;
    rdfs:range usf:ProofResult.
usf:proofResultForObligation a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:ProofObligation.
usf:usesAdmittedEvidence a owl:ObjectProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:EvidenceResult.
usf:evidenceSetDigest a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range xsd:string.
usf:usesProofAlgorithm a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:ProofAlgorithm.
usf:usesAlgorithmVersion a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:ProofAlgorithmVersion.
usf:proofAlgorithmSourcePath a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofAlgorithm;
    rdfs:range xsd:string.
usf:proofAlgorithmSourceDigest a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofAlgorithm;
    rdfs:range xsd:string.
usf:proofAlgorithmVersionOf a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofAlgorithmVersion;
    rdfs:range usf:ProofAlgorithm.
usf:proofAlgorithmVersionIdentifier a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofAlgorithmVersion;
    rdfs:range xsd:string.
usf:evaluatedByValidator a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:ValidatorRule.
usf:proofExecutionEnvironment a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:Environment.
usf:hasProofResultState a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:ProofResultState.
usf:hasConfidenceState a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:ProofConfidenceState.
usf:confidenceBasis a owl:ObjectProperty;
    rdfs:domain usf:Entity;
    rdfs:range usf:EvidenceResult.
usf:uncertaintyStatement a owl:DatatypeProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range xsd:string.
usf:proofNonclaim a owl:ObjectProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:NonClaim.
usf:evaluatedAt a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range xsd:dateTime.
usf:hasInvalidationCondition a owl:ObjectProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:ProofInvalidationCondition.
usf:hasAuthorityBinding a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:ProofAuthorityBinding.
usf:bindingEvaluatedAuthorityDigest a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofAuthorityBinding;
    rdfs:range xsd:string.
usf:bindingDependencySetDigest a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofAuthorityBinding;
    rdfs:range xsd:string.
usf:bindingDependencyDigestAlgorithm a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofAuthorityBinding;
    rdfs:range xsd:string.
usf:usesAuthorityBindingRule a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofAuthorityBinding;
    rdfs:range usf:AuthorityBindingRule.
usf:excludedAuthorityGraphIri a owl:DatatypeProperty;
    rdfs:domain usf:ProofAuthorityBinding;
    rdfs:range xsd:anyURI.
usf:requiresPostPublicationReevaluation a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofAuthorityBinding;
    rdfs:range xsd:boolean.
usf:authorityBindingEvidenceDigest a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:ProofAuthorityBinding;
    rdfs:range xsd:string.
usf:supersedesProofResult a owl:ObjectProperty;
    rdfs:domain usf:ProofResult;
    rdfs:range usf:ProofResult.
usf:hasActivationState a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:SemanticContract;
    rdfs:range usf:ContractActivationState.
usf:activationReason a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:SemanticContract;
    rdfs:range xsd:string.
usf:mandatoryProofObligation a owl:ObjectProperty;
    rdfs:domain usf:SemanticContract;
    rdfs:range usf:ProofObligation.
usf:reliesOnProofResult a owl:ObjectProperty;
    rdfs:domain usf:SemanticContract;
    rdfs:range usf:ProofResult.
usf:warrantsFeature a owl:ObjectProperty;
    rdfs:domain usf:SemanticContract;
    rdfs:range usf:Feature.
usf:contractConstraint a owl:DatatypeProperty;
    rdfs:domain usf:SemanticContract;
    rdfs:range xsd:string.
usf:requiresRealisationOptionEvaluation a owl:DatatypeProperty, owl:FunctionalProperty;
    rdfs:domain usf:SemanticContract;
    rdfs:range xsd:boolean.
usf:permittedRealisationType a owl:ObjectProperty;
    rdfs:domain usf:SemanticContract;
    rdfs:range owl:Class.
usf:requiredValidation a owl:ObjectProperty;
    rdfs:domain usf:SemanticContract;
    rdfs:range usf:ValidationObligation.
usf:authorisedByDecision a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Realisation;
    rdfs:range usf:RealisationDecision.
usf:realisesOption a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:Realisation;
    rdfs:range usf:RealisationOption.
usf:authorisedSourcePath a owl:DatatypeProperty;
    rdfs:domain usf:Realisation;
    rdfs:range xsd:string.
usf:authorisesSourcePath a owl:DatatypeProperty;
    rdfs:domain usf:RealisationDecision;
    rdfs:range xsd:string.
usf:authorisesRepository a owl:DatatypeProperty;
    rdfs:domain usf:RealisationDecision;
    rdfs:range xsd:string.
usf:authorisesRealisationType a owl:ObjectProperty;
    rdfs:domain usf:RealisationDecision;
    rdfs:range owl:Class.
usf:allowsRealisationPredecessor a owl:ObjectProperty;
    rdfs:domain usf:RealisationState;
    rdfs:range usf:RealisationState.
usf:allowsRealisationSuccessor a owl:ObjectProperty;
    rdfs:domain usf:RealisationState;
    rdfs:range usf:RealisationState.
usf:requiresContractActivationState a owl:ObjectProperty;
    rdfs:domain usf:RealisationState;
    rdfs:range usf:ContractActivationState.
usf:requiresDecisionState a owl:ObjectProperty;
    rdfs:domain usf:RealisationState;
    rdfs:range usf:DecisionState.
usf:requiresRealisationType a owl:ObjectProperty;
    rdfs:domain usf:RealisationState;
    rdfs:range owl:Class.
usf:requiresAuthorisedSourcePath a owl:DatatypeProperty;
    rdfs:domain usf:RealisationState;
    rdfs:range xsd:boolean.
usf:requiresExistingImplementation a owl:DatatypeProperty;
    rdfs:domain usf:RealisationState;
    rdfs:range xsd:boolean.
usf:decisionState a owl:ObjectProperty, owl:FunctionalProperty;
    rdfs:domain usf:RealisationDecision;
    rdfs:range usf:DecisionState.
usf:considersOption a owl:ObjectProperty;
