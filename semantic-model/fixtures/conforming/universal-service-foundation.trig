fx:publicationcoordinationcapability a usf:Capability; usf:canonicalName "publicationcoordinationcapability"; usf:inDomain <urn:usf:capabilitydomain:foundation>; usf:hasContract fx:processcontract; usf:uiExposure <urn:usf:uiexposureclass:notexposed>; usf:accountableProcessBoundary fx:publicationcoordinator; usf:participatesInProcess fx:publicationcoordinator.
