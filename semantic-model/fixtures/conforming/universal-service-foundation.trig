fx:optioncomponenta a usf:OptionComponent;
    usf:canonicalName "optioncomponenta";
    usf:componentForOption fx:composedoption;
    usf:componentIdentity fx:componentidentitya;
    usf:componentRole <urn:usf:componentrole:runtime>;
    usf:componentProviderBinding fx:providerbinding, fx:providerbinding2;
    usf:dependsOnOptionComponent fx:optioncomponentb;
    usf:componentResponsibility "Execute the fixture capability through its declared contract and interface.";
    usf:componentInterface fx:compositioninterface;
    usf:componentEnvironmentBinding fx:localenvironment;
    usf:componentDataOwnershipBoundary "Own only fixture-local data declared by the conformance contract.";
    usf:componentTransactionBoundary "Commit only within the fixture transaction boundary.";
    usf:componentSecurityBoundary "Accept only fixture-declared principals and interfaces.";
    usf:componentSecretBoundary "Receive no ambient credentials.";
    usf:componentDeploymentBoundary "Execute only in the declared fixture environment.";
    usf:componentFailurePropagation "Return typed fixture failures across the composition interface.";
    usf:componentRetryPolicy "Retry only declared idempotent fixture operations.";
    usf:componentTimeoutPolicy "Apply finite declared fixture timeouts.";
    usf:componentUpgradeCompatibility "Require composition-interface compatibility before replacement.";
    usf:componentRollbackOrder "Roll back after fixture dependants and before dependencies.";
    usf:componentReplacementBoundary "Replace independently only after equivalent option evaluation.".
fx:optioncomponentb a usf:OptionComponent;
    usf:canonicalName "optioncomponentb";
    usf:componentForOption fx:composedoption;
    usf:componentIdentity fx:componentidentityb;
    usf:componentRole <urn:usf:componentrole:adapter>;
    usf:componentResponsibility "Adapt the fixture capability to its declared provider port.";
    usf:componentInterface fx:compositioninterface;
    usf:componentEnvironmentBinding fx:localenvironment;
    usf:componentDataOwnershipBoundary "Own no product data outside the fixture adapter boundary.";
    usf:componentTransactionBoundary "Do not extend the provider transaction boundary.";
    usf:componentSecurityBoundary "Preserve fixture tenant and provider boundaries.";
    usf:componentSecretBoundary "Accept credentials only through the declared fixture provider binding.";
    usf:componentDeploymentBoundary "Execute only in the declared fixture environment.";
    usf:componentFailurePropagation "Translate provider failures into declared fixture failures.";
    usf:componentRetryPolicy "Retry only provider operations declared safe and idempotent.";
    usf:componentTimeoutPolicy "Apply finite provider timeouts.";
    usf:componentUpgradeCompatibility "Require provider-port compatibility before upgrade.";
    usf:componentRollbackOrder "Roll back before the runtime component.";
    usf:componentReplacementBoundary "Replace independently behind the stable fixture port.".
fx:componentidentitya a usf:ComponentIdentity; usf:canonicalName "componentidentitya".
fx:componentidentityb a usf:ComponentIdentity; usf:canonicalName "componentidentityb".
fx:componentresponsibilitya a usf:ComponentResponsibility;
    usf:canonicalName "componentresponsibilitya";
    usf:responsibilityForComponent fx:optioncomponenta;
    usf:responsibilityForRequirement fx:contractcontractsfacet;
    usf:responsibilityOwner fx:composedoption.
fx:componentresponsibilityb a usf:ComponentResponsibility;
    usf:canonicalName "componentresponsibilityb";
    usf:responsibilityForComponent fx:optioncomponentb;
    usf:responsibilityForRequirement fx:contractreadinessmodelfacet;
    usf:responsibilityOwner fx:composedoption.
fx:compositioninterface a usf:CompositionInterface;
    usf:canonicalName "compositioninterface";
    usf:compositionInterfaceForContract fx:contract;
    usf:compositionInterfaceResponsibility "Connect the fixture runtime component to its provider adapter.";
    usf:compositionInterfaceSecurityBoundary "Preserve declared tenant, principal and credential boundaries.";
    usf:compositionInterfaceFailureBehaviour "Propagate only typed bounded fixture failures.".
fx:localenvironment a usf:Environment;
    usf:canonicalName "localenvironment";
    usf:hasEnvironmentClass <urn:usf:environmentclass:local>;
    usf:permitsProviderMode <urn:usf:providermode:repositorylocalservice>.
<urn:usf:environment:localdev> a usf:Environment;
    usf:canonicalName "localdev";
    usf:hasEnvironmentClass <urn:usf:environmentclass:local>;
    usf:permitsProviderMode <urn:usf:providermode:deterministictestsubstitute>, <urn:usf:providermode:repositorylocalservice>.
<urn:usf:environment:hermetic> a usf:Environment;
    usf:canonicalName "hermetic";
    usf:hasEnvironmentClass <urn:usf:environmentclass:hermetic>;
    usf:permitsProviderMode <urn:usf:providermode:deterministictestsubstitute>.
<urn:usf:environment:productionshaped> a usf:Environment;
    usf:canonicalName "productionshaped";
    usf:hasEnvironmentClass <urn:usf:environmentclass:productionshaped>;
    usf:permitsProviderMode <urn:usf:providermode:repositorylocalservice>.
fx:provider a usf:Provider;
    usf:canonicalName "provider";
    usf:fulfilsPort fx:providerport;
    usf:hasProviderMode <urn:usf:providermode:repositorylocalservice>.
fx:providerbinding a usf:Binding;
    usf:canonicalName "providerbinding";
    usf:bindingProvider fx:provider;
    usf:bindsPort fx:providerport;
    usf:hasProviderMode <urn:usf:providermode:repositorylocalservice>;
    usf:bindingEnvironment fx:localenvironment;
    usf:bindingState <urn:usf:bindingstate:available>.
fx:providerport2 a usf:Port;
    usf:canonicalName "providerport2";
    usf:repositoryName "tenant-resource-sandbox";
    usf:portForContract fx:contract;
    usf:permitsProviderMode <urn:usf:providermode:externalsandbox>;
    usf:portPermitsActionKind <urn:usf:actionkind:read>;
    usf:providerFailureBehaviour "Fail closed on sandbox unavailability without falling back to a live provider.".
fx:sandboxenvironment a usf:Environment;
    usf:canonicalName "sandboxenvironment";
    usf:hasEnvironmentClass <urn:usf:environmentclass:productionshaped>;
    usf:permitsProviderMode <urn:usf:providermode:externalsandbox>.
fx:provider2 a usf:Provider;
    usf:canonicalName "provider2";
    usf:fulfilsPort fx:providerport2;
    usf:hasProviderMode <urn:usf:providermode:externalsandbox>.
fx:providerbinding2 a usf:Binding;
    usf:canonicalName "providerbinding2";
    usf:bindingProvider fx:provider2;
    usf:bindsPort fx:providerport2;
    usf:hasProviderMode <urn:usf:providermode:externalsandbox>;
    usf:bindingEnvironment fx:sandboxenvironment;
    usf:bindingState <urn:usf:bindingstate:unavailable>.
<urn:usf:bindingstate:available> a usf:BindingState.
<urn:usf:bindingstate:unavailable> a usf:BindingState.
fx:externaldependency a usf:ExternalDependency;
    usf:canonicalName "externaldependency";
    usf:externalDependencyAtPort fx:providerport;
    usf:externalDependencyProvider fx:provider;
    usf:externalDependencyFailureMode <urn:usf:permutationdimensionvalue:failuremodeunavailable>;
    usf:externalDependencyRecoveryAction <urn:usf:permutationdimensionvalue:recoveryactionretry>.

fx:datamodel a usf:DataModel;
    usf:canonicalName "datamodel";
    usf:backsCapability fx:capability;
    usf:enforcesTenancy fx:tenantboundary;
    usf:tenancyStrategy <urn:usf:tenancystrategy:forcedrls>;
    usf:hasSchemaChangeSeries fx:schemachangeseries;
    usf:hasTransactionBoundary fx:transactionboundary;
    usf:governedByMigrationPolicy fx:migrationpolicy;
    usf:persistedUnder fx:persistencecontract;
    usf:hasRepresentativeDataSet fx:representativedataset;
    usf:protectedByRecovery fx:backuprestore;
    usf:hasDataField fx:useremail, fx:passwordhash, fx:auditeventpayload, fx:filemetadata,
        fx:filecontent, fx:notificationrecipient, fx:tenantidentifier,
        fx:providercredentialreference, fx:publicdisplayname.
fx:schemachangeseries a usf:SchemaChangeSeries; usf:canonicalName "schemachangeseries".
fx:transactionboundary a usf:TransactionBoundary; usf:canonicalName "transactionboundary".
fx:migrationpolicy a usf:MigrationPolicy; usf:canonicalName "migrationpolicy".
fx:persistencecontract a usf:PersistenceContract; usf:canonicalName "persistencecontract".
fx:representativedataset a usf:RepresentativeDataSet; usf:canonicalName "representativedataset".
fx:backuprestore a usf:BackupRestore; usf:canonicalName "backuprestore".

