        <urn:usf:surfacekind:queryview>.
fx:renderer a usf:Renderer; usf:canonicalName "renderer".
fx:rendererinput a usf:Artefact; usf:canonicalName "rendererinput".
fx:rendereroutputplan a usf:ArtefactPlan; usf:canonicalName "rendereroutputplan".
fx:form a usf:Form, usf:Surface;
    usf:canonicalName "form";
    usf:surfaceKind <urn:usf:surfacekind:form>;
    usf:rendersViewModel fx:viewmodel;
    usf:uiRequiresPermission fx:resourcewritepermission;
    usf:surfaceRoute fx:authenticatedroute;
    usf:hasField fx:tenantresourcefield;
    usf:submitsOperation fx:createresource.
fx:readinesssurface a usf:Surface; usf:canonicalName "readinesssurface"; usf:surfaceKind <urn:usf:surfacekind:webroute>; usf:rendersViewModel fx:viewmodel; usf:uiRequiresPermission fx:publicreadinesspermission; usf:surfaceRoute fx:publicroute.
fx:streamsurface a usf:Surface; usf:canonicalName "streamsurface"; usf:surfaceKind <urn:usf:surfacekind:queryview>; usf:rendersViewModel fx:viewmodel; usf:uiRequiresPermission fx:eventsubscribepermission; usf:surfaceRoute fx:streamroute.
fx:viewmodel a usf:ViewModel;
    usf:canonicalName "viewmodel";
    usf:hasForm fx:form;
    usf:viewDataModel fx:datamodel;
    usf:hasComponent fx:formactioncomponent;
    usf:hasErrorBinding fx:errorbinding;
    usf:loadsOperation fx:readresource;
    usf:bindsInterface fx:httpapi;
    usf:hasEventBinding fx:event;
    usf:hasStateBinding fx:pendingstate.
fx:formactioncomponent a usf:Component; usf:canonicalName "formactioncomponent"; usf:componentKind <urn:usf:componentkind:action>; usf:componentOrder 0.
fx:tenantresourcefield a usf:FormField; usf:canonicalName "tenantresourcefield"; usf:fieldName "displayName"; usf:fieldKind <urn:usf:formfieldkind:text>; usf:fieldOrder 0; usf:fieldDataModel fx:datamodel; usf:hasValidationBinding fx:tenantresourcevalidation.
fx:tenantresourcevalidation a usf:ValidationBinding; usf:canonicalName "tenantresourcevalidation"; usf:validationConstraint fx:tenantresourceconstraint; usf:validationTiming <urn:usf:validationtiming:submit>.
fx:tenantresourceconstraint a usf:Constraint; usf:canonicalName "tenantresourceconstraint".
fx:errorbinding a usf:ErrorBinding;
    usf:canonicalName "errorbinding";
    usf:errorCode "forbidden";
    usf:errorState fx:forbiddeninteractionstate;
    usf:errorPresentation <urn:usf:errorpresentationkind:forbidden>.
fx:forbiddeninteractionstate a usf:InteractionState;
    usf:canonicalName "forbiddeninteractionstate".
fx:authenticatedroute a usf:Route; usf:canonicalName "authenticatedroute"; usf:routePattern "/tenant-resources"; usf:routeKind <urn:usf:routekind:authenticated>.
fx:publicroute a usf:Route; usf:canonicalName "publicroute"; usf:routePattern "/ready"; usf:routeKind <urn:usf:routekind:public>.
fx:streamroute a usf:Route; usf:canonicalName "streamroute"; usf:routePattern "/tenant-resources/stream"; usf:routeKind <urn:usf:routekind:tenant>.

