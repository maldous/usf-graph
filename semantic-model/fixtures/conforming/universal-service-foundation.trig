fx:event a usf:Event;
    usf:canonicalName "event";
    usf:eventDeliveryForm <urn:usf:eventdeliveryform:messageenvelope>;
    usf:carriesMessage fx:message;
    usf:hasDeliverySemantics <urn:usf:deliverysemantics:atleastonce>;
    usf:eventForContract fx:contract;
    usf:requiredPublisher fx:capability;
    usf:requiredConsumer fx:capability;
    usf:requiredPublishPermission fx:eventpublishpermission;
    usf:requiredSubscribePermission fx:eventsubscribepermission;
    usf:requiredConsumePermission fx:eventconsumepermission;
    usf:requiredAcknowledgePermission fx:eventacknowledgepermission;
    usf:requiredReplayPermission fx:eventreplaypermission;
    usf:requiredDeadLetterPermission fx:eventdeadletterpermission;
    usf:requiredSubscriptionAdministrationPermission fx:eventsubscriptionadminpermission;
    usf:requiredEventMetadataViewPermission fx:eventmetadataviewpermission;
    usf:eventPublisherPrincipalKind <urn:usf:principalkind:serviceidentity>;
    usf:eventConsumerPrincipalKind <urn:usf:principalkind:serviceidentity>;
    usf:eventTenantBoundary fx:tenantboundary;
    usf:eventDeliveryTransport <urn:usf:transport:eventbus>;
    usf:eventPayloadResourceClassIri "urn:usf:foundationfixture:tenantresourcepayload"^^xsd:anyURI;
    usf:eventMetadataResourceClassIri "urn:usf:foundationfixture:eventmetadata"^^xsd:anyURI.
fx:message a usf:Message;
    usf:canonicalName "message";
    usf:messageForContract fx:contract;
    usf:messageSchemaRequirement "Finite fixture work-item schema with tenant, identifier, attempt and due-instant fields.".
fx:directevent a usf:Event;
    usf:canonicalName "directevent";
    usf:eventDeliveryForm <urn:usf:eventdeliveryform:directnotification>;
    usf:hasDeliverySemantics <urn:usf:deliverysemantics:atleastonce>;
    usf:eventForContract fx:contract;
    usf:requiredPublisher fx:capability;
    usf:requiredConsumer fx:capability.

fx:workflow a usf:Workflow;
    usf:canonicalName "workflow";
    usf:workflowForContract fx:contract;
    usf:workflowExecutionPolicy fx:workflowpolicy;
    usf:hasState fx:pendingstate, fx:completedstate;
    usf:hasTransition fx:completetransition.
fx:workflowpolicy a usf:WorkflowExecutionPolicy;
    usf:canonicalName "workflowpolicy";
    usf:appliesToCapability fx:capability;
    usf:maximumAttempts 3;
    usf:timeoutMilliseconds 30000;
    usf:retryBehaviour "Retry bounded transient failures and preserve the terminal cause.";
    usf:concurrencyBehaviour "One active claim per tenant resource and idempotency key.";
    usf:scheduleBehaviour "Persist an explicit due instant and recover missed execution after restart.";
    usf:scheduleTriggerKind <urn:usf:scheduletriggerkind:fixedinstant>.
fx:pendingstate a usf:State.
fx:completedstate a usf:State.
fx:pendingstate usf:canonicalName "pendingstate".
fx:completedstate usf:canonicalName "completedstate".
fx:completetransition a usf:Transition;
    usf:canonicalName "completetransition";
    usf:fromState fx:pendingstate;
    usf:toState fx:completedstate;
    usf:onEvent fx:event;
    usf:onOperation fx:createresource.

fx:providerport a usf:Port;
    usf:canonicalName "providerport";
    usf:repositoryName "tenant-resource-store";
    usf:portForContract fx:contract;
    usf:permitsProviderMode <urn:usf:providermode:deterministictestsubstitute>, <urn:usf:providermode:repositorylocalservice>, <urn:usf:providermode:externalsandbox>;
    usf:portPermitsActionKind <urn:usf:actionkind:create>, <urn:usf:actionkind:read>,
        <urn:usf:actionkind:list>, <urn:usf:actionkind:search>, <urn:usf:actionkind:export>,
        <urn:usf:actionkind:delete>, <urn:usf:actionkind:purge>, <urn:usf:actionkind:publish>,
        <urn:usf:actionkind:subscribe>, <urn:usf:actionkind:consume>,
        <urn:usf:actionkind:acknowledge>, <urn:usf:actionkind:replay>, <urn:usf:actionkind:update>;
    usf:providerFailureBehaviour "Reject unavailable writes, bound retries and expose dependency readiness.";
    usf:providerSecurityBoundary "Tenant data remains within the declared provider and credential boundary.";
    usf:providerMaximumAttempts 3.

fx:composedoption a usf:RealisationOption, usf:ComposedRealisationOption;
    usf:canonicalName "composedoption";
    usf:representsRealisationClass <urn:usf:realisationclass:repositorylocalsemanticauthority>;
    usf:hasOptionComponent fx:optioncomponenta, fx:optioncomponentb;
    usf:hasComponentResponsibility fx:componentresponsibilitya, fx:componentresponsibilityb.
fx:decisionevaluation a usf:DecisionEvaluation;
    usf:canonicalName "decisionevaluation";
    usf:evaluationClosureState <urn:usf:evaluationclosurestate:incomplete>;
    usf:hasCriterionRequirement fx:criterionrequirement;
    usf:hasCriterionAssessment fx:criterionassessment;
    usf:hasCandidateCredibilityAssessment fx:candidatecredibilityassessment.
fx:criterionrequirement a usf:CriterionRequirement;
    usf:canonicalName "criterionrequirement";
    usf:criterionForEvaluation fx:decisionevaluation;
    usf:requiresCriterion <urn:usf:evaluationcriterion:testability>;
    usf:criterionApplicability <urn:usf:criterionapplicability:applicable>;
    usf:criterionMandatory false.
fx:criterionassessment a usf:CriterionAssessment;
    usf:canonicalName "criterionassessment";
    usf:assessmentForEvaluation fx:decisionevaluation;
    usf:assessmentForOption fx:composedoption;
    usf:assessmentForCriterion <urn:usf:evaluationcriterion:testability>;
    usf:assessmentResult <urn:usf:assessmentresult:insufficientevidence>.
fx:candidatecredibilityassessment a usf:CandidateCredibilityAssessment;
    usf:canonicalName "candidatecredibilityassessment";
    usf:credibilityForEvaluation fx:decisionevaluation;
    usf:credibilityForOption fx:composedoption;
    usf:credibilityState <urn:usf:candidatecredibilitystate:excluded>.
fx:candidatesearchspace a usf:CandidateSearchSpace;
    usf:canonicalName "candidatesearchspace";
    usf:candidateDiscoveryCriteria "Search repository-local, external-provider and composed realisation classes without inherited preference.";
    usf:searchesRealisationClass <urn:usf:realisationclass:repositorylocalsemanticauthority>,
        <urn:usf:realisationclass:otherlivesemanticauthority>;
    usf:candidateSearchInvalidationCondition "Re-evaluate when the semantic requirements or available realisation classes change.".
fx:optionrejection a usf:OptionRejection;
    usf:canonicalName "optionrejection";
    usf:rejectionForEvaluation fx:decisionevaluation;
    usf:rejectsOption fx:composedoption;
    usf:hasRejectionReason fx:rejectionreason.
fx:rejectionreason a usf:RejectionReason;
    usf:canonicalName "rejectionreason";
    usf:rejectionCriterion <urn:usf:evaluationcriterion:testability>;
    usf:rejectionDuration <urn:usf:rejectionduration:conditional>;
    usf:rejectionStatement "Fixture-only rejection remains conditional while executable evidence is unavailable.";
    usf:reopeningCondition "Reopen when current admitted executable evidence becomes available.".

