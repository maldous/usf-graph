fx:ordinaryconfiguration a usf:ConfigurationKey;
    usf:canonicalName "ordinaryconfiguration";
    usf:configures fx:capability;
    usf:hasSecretClassification <urn:usf:secretclassification:nonsecret>;
    usf:configurationValueType <urn:usf:configurationvaluetype:integer>;
    usf:configurationRequired true;
    usf:configurationConstraint "Integer milliseconds in the inclusive range 1 through 60000.";
    usf:configurationForEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:productionshaped>;
    usf:secretValueMustBeReferenced false.
fx:secretconfiguration a usf:ConfigurationKey;
    usf:canonicalName "secretconfiguration";
    usf:configures fx:capability;
    usf:hasSecretClassification <urn:usf:secretclassification:secret>;
    usf:configurationValueType <urn:usf:configurationvaluetype:secretreference>;
    usf:configurationRequired true;
    usf:configurationConstraint "A non-empty modelled secret reference; inline credential bytes are prohibited.";
    usf:configurationForEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:productionshaped>;
    usf:secretValueMustBeReferenced true.

fx:uimodel a usf:UISemanticModel;
