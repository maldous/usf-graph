fx:httpapi a usf:Interface;
    usf:canonicalName "httpapi";
    usf:interfaceForContract fx:contract;
    usf:hasOperation fx:createresource, fx:readresource.
fx:readinessinterface a usf:Interface;
    usf:canonicalName "readinessinterface";
    usf:interfaceForContract fx:contract;
    usf:hasOperation fx:readreadiness.
fx:streaminterface a usf:Interface;
    usf:canonicalName "streaminterface";
    usf:interfaceForContract fx:contract;
    usf:hasOperation fx:subscribeevents.
fx:coordinatorinterface a usf:Interface;
    usf:canonicalName "coordinatorinterface";
    usf:interfaceForContract fx:contract;
    usf:hasOperation fx:publishauthority.

fx:createresource a usf:Command;
    usf:canonicalName "createresource";
    usf:idempotent true;
    usf:idempotencyKeyRequired true;
    usf:timeoutMilliseconds 30000;
    usf:concurrencyBehaviour "Serialise writes by tenant resource and idempotency key.";
    usf:operationErrorBehaviour "Reject invalid input and unavailable persistence with a stable error classification.";
    usf:requiresPermission fx:resourcewritepermission;
    usf:emitsAuditEvent fx:operationauditevent.
fx:readresource a usf:Query, usf:Operation;
    usf:canonicalName "readresource";
    usf:idempotent true;
    usf:idempotencyKeyRequired false;
    usf:timeoutMilliseconds 10000;
    usf:concurrencyBehaviour "Permit concurrent reads while preserving tenant isolation.";
    usf:operationErrorBehaviour "Return stable not-found, forbidden and dependency-unavailable classifications.";
    usf:requiresPermission fx:resourcereadpermission, fx:resourceexportpermission;
    usf:emitsAuditEvent fx:operationauditevent;
    usf:emitsSignal fx:requestsignal.
fx:requestsignal a usf:ObservabilitySignal;
    usf:canonicalName "requestsignal";
    usf:signalKind <urn:usf:signalkind:trace>;
    usf:correlatesWith fx:operationauditevent.
fx:requestfailurealert a usf:Alert;
    usf:canonicalName "requestfailurealert";
    usf:triggeredBySignal fx:requestsignal.
fx:readreadiness a usf:Query;
    usf:canonicalName "readreadiness";
    usf:idempotent true;
    usf:idempotencyKeyRequired false;
    usf:timeoutMilliseconds 2000;
    usf:concurrencyBehaviour "Permit concurrent probes without mutable service state.";
    usf:operationErrorBehaviour "Report dependency-not-ready without exposing protected details.";
    usf:requiresPermission fx:publicreadinesspermission.
fx:subscribeevents a usf:Command;
    usf:canonicalName "subscribeevents";
    usf:idempotent true;
    usf:idempotencyKeyRequired true;
    usf:timeoutMilliseconds 30000;
    usf:concurrencyBehaviour "Deduplicate one durable subscription per tenant, principal and subscription key.";
    usf:operationErrorBehaviour "Reject cross-tenant, unsupported transport and duplicate incompatible subscriptions.";
    usf:requiresPermission fx:eventsubscribepermission;
    usf:emitsAuditEvent fx:operationauditevent.
fx:publishauthority a usf:GatewayOperation;
    usf:canonicalName "publishauthority";
    usf:idempotent true;
    usf:idempotencyKeyRequired true;
    usf:timeoutMilliseconds 60000;
    usf:concurrencyBehaviour "Permit one coordinator-owned semantic publication transaction at a time.";
    usf:operationErrorBehaviour "Fail closed and roll back on stale authority, validation, proof or publication failure.";
    usf:gatewayOperationIdentifier "usf.authority.publish";
    usf:mutatesSemanticAuthority true;
    usf:coordinatorOnly true;
    usf:maximumInputBytes 16777216;
    usf:maximumOutputBytes 16777216;
    usf:requiresPermission fx:authoritypublishpermission.

fx:resourcewritepermission a usf:Permission; usf:canonicalName "resourcewritepermission".
fx:resourcereadpermission a usf:Permission; usf:canonicalName "resourcereadpermission".
fx:resourceexportpermission a usf:Permission; usf:canonicalName "resourceexportpermission".
fx:publicreadinesspermission a usf:Permission; usf:canonicalName "publicreadinesspermission".
fx:eventpublishpermission a usf:Permission; usf:canonicalName "eventpublishpermission".
fx:eventsubscribepermission a usf:Permission; usf:canonicalName "eventsubscribepermission".
