    usf:canonicalName "tenantworkeridentity";
    usf:serviceIdentityForCapability fx:capability;
    usf:serviceIdentityPrincipalKind <urn:usf:principalkind:serviceidentity>;
    usf:serviceIdentityEnvironmentClass <urn:usf:environmentclass:local>, <urn:usf:environmentclass:hermetic>, <urn:usf:environmentclass:productionshaped>;
    usf:serviceIdentityDigest "sha256:69ba97e48965007a3fc3824d76963561db2830964a1f8acd57c4dd0f00e5e261".

fx:processdependency a usf:DeployableProcessDependency;
    usf:canonicalName "processdependency";
    usf:processDependencySource fx:httpapiservice;
    usf:processDependencyTarget fx:eventconsumerworker;
    usf:processDependencyInterface fx:streaminterface;
    usf:processDependencyEnvironment <urn:usf:environment:localdev>;
    usf:processDependencyProviderMode <urn:usf:providermode:repositorylocalservice>;
    usf:processDependencyRequirementKind <urn:usf:processdependencyrequirementkind:runtime>;
    usf:processDependencyFailureHandling fx:processdependencyfailurehandling.
fx:processdependencyfailurehandling a usf:ProcessDependencyFailureHandling;
    usf:canonicalName "processdependencyfailurehandling";
    usf:failureHandlingForProcessDependency fx:processdependency;
    usf:processDependencyFailureMode <urn:usf:permutationdimensionvalue:failuremodeunavailable>;
    usf:processDependencyRecoveryAction <urn:usf:permutationdimensionvalue:recoveryactionretry>;
    usf:processDependencyTimeoutPolicy "Fail within the declared fixture timeout.";
    usf:processDependencyRetryPolicy "Retry only declared idempotent fixture requests with a finite attempt bound.";
    usf:processDependencyFailurePropagation "Return the declared provider-unavailable result and withhold readiness.".

fx:httpapiservice a usf:DeployableProcess;
    usf:canonicalName "httpapiservice"; usf:repositoryName "http-api-service";
    usf:definition "Tenant HTTP API process with explicit readiness, drain and recovery obligations.";
    usf:processBoundaryClass <urn:usf:processboundaryclass:productruntime>;
    usf:processOwnsCapability fx:capability; usf:processForCapability fx:capability;
    usf:processServiceIdentity fx:tenantworkeridentity;
    usf:processProvidesInterface fx:httpapi, fx:readinessinterface;
    usf:processConsumesInterface fx:streaminterface;
    usf:hasProcessDependency fx:processdependency;
    usf:processInterfaceRequirement "Serve authenticated tenant operations and a public dependency-aware readiness route.";
    usf:processLifecycleRequirement "Initialise, configure, start, become ready, drain, stop, restart, recover, upgrade and roll back.";
    usf:processTenantSecuritySeparationRequirement "Every tenant request remains scoped to its authenticated tenant and cross-tenant access fails closed.";
    usf:processSupportsEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:hermetic>, <urn:usf:environment:productionshaped>;
    usf:processSecurityBoundary "Terminate authenticated HTTP at the process boundary and pass only validated tenant context inward.";
    usf:processReadinessRequirement "Ready only after configuration and tenant data dependencies are usable.";
    usf:processResourceLimit "Bound request bytes, concurrency, memory and graceful-drain duration.";
    usf:emitsSignal fx:requestsignal;
    usf:producesEvent fx:event;
    usf:processLifecycleObligation <urn:usf:permutationdimensionvalue:lifecycleobligationinitialise>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationconfigure>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationstart>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationbecomeready>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationdrain>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationstop>;
    usf:processPrincipalKind <urn:usf:principalkind:serviceidentity>;
    usf:processEnvironmentClass <urn:usf:environmentclass:local>, <urn:usf:environmentclass:hermetic>, <urn:usf:environmentclass:productionshaped>;
    usf:processProviderMode <urn:usf:providermode:deterministictestsubstitute>, <urn:usf:providermode:repositorylocalservice>.
fx:eventconsumerworker a usf:DeployableProcess;
    usf:canonicalName "eventconsumerworker"; usf:repositoryName "event-consumer-worker";
    usf:definition "Durable event-consumer worker with explicit retry, acknowledgement and dead-letter behaviour.";
    usf:processBoundaryClass <urn:usf:processboundaryclass:productruntime>;
    usf:processOwnsCapability fx:eventconsumercapability; usf:processForCapability fx:capability, fx:eventconsumercapability;
    usf:processProvidesInterface fx:streaminterface;
    usf:processInterfaceRequirement "Consume tenant-scoped durable events and expose bounded streaming state.";
    usf:processLifecycleRequirement "Start, become ready, pause, drain in-flight delivery, stop, recover and redrive.";
    usf:processTenantSecuritySeparationRequirement "Partition subscriptions, payload access and acknowledgements by tenant.";
    usf:processSupportsEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:productionshaped>;
    usf:processSecurityBoundary "Only the declared service identity may consume and acknowledge bounded tenant deliveries.";
    usf:processReadinessRequirement "Ready only while the queue substitute or production-shaped provider is reachable.";
    usf:processResourceLimit "Bound concurrent deliveries, attempts, payload bytes and dead-letter retention.";
    usf:consumesEvent fx:event;
    usf:processLifecycleObligation <urn:usf:permutationdimensionvalue:lifecycleobligationinitialise>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationconfigure>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationstart>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationbecomeready>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationdrain>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationstop>;
    usf:processPrincipalKind <urn:usf:principalkind:serviceidentity>;
    usf:processEnvironmentClass <urn:usf:environmentclass:local>, <urn:usf:environmentclass:hermetic>, <urn:usf:environmentclass:productionshaped>;
    usf:processProviderMode <urn:usf:providermode:deterministictestsubstitute>, <urn:usf:providermode:repositorylocalservice>.
fx:scheduledjobrunner a usf:DeployableProcess;
    usf:canonicalName "scheduledjobrunner"; usf:repositoryName "scheduled-job-runner";
    usf:definition "Scheduled workflow runner that persists due work and recovers missed execution.";
    usf:processBoundaryClass <urn:usf:processboundaryclass:productruntime>;
    usf:processOwnsCapability fx:scheduledjobcapability; usf:processForCapability fx:capability, fx:scheduledjobcapability;
    usf:processProvidesInterface fx:httpapi;
    usf:processInterfaceRequirement "Execute only declared scheduled workflows and expose bounded administration through the service API.";
    usf:processLifecycleRequirement "Start, reconcile due work, pause claims, drain, recover missed work, upgrade and roll back.";
    usf:processTenantSecuritySeparationRequirement "Schedule ownership, claims and resulting operations remain tenant-scoped.";
    usf:processSupportsEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:productionshaped>;
    usf:processSecurityBoundary "Only the service identity may claim due work and every invoked operation rechecks authority.";
    usf:processReadinessRequirement "Ready after schedule persistence and clock-control dependencies are validated.";
    usf:processResourceLimit "Bound claim batch size, execution concurrency and retry attempts.";
    usf:processLifecycleObligation <urn:usf:permutationdimensionvalue:lifecycleobligationinitialise>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationconfigure>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationstart>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationbecomeready>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationdrain>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationstop>;
    usf:processPrincipalKind <urn:usf:principalkind:serviceidentity>;
    usf:processEnvironmentClass <urn:usf:environmentclass:local>, <urn:usf:environmentclass:hermetic>, <urn:usf:environmentclass:productionshaped>;
    usf:processProviderMode <urn:usf:providermode:deterministictestsubstitute>, <urn:usf:providermode:repositorylocalservice>.
fx:semanticcompiler a usf:DeployableProcess;
    usf:canonicalName "semanticcompiler"; usf:repositoryName "semantic-compiler";
    usf:definition "Assurance control-plane process that compiles and validates bounded semantic candidates.";
    usf:processBoundaryClass <urn:usf:processboundaryclass:assurancecontrolplane>;
    usf:processOwnsCapability fx:semanticcompilercapability; usf:processForCapability fx:capability, fx:semanticcompilercapability;
    usf:processProvidesInterface fx:httpapi;
    usf:processInterfaceRequirement "Accept only digest-bound candidate input and emit deterministic validation evidence.";
    usf:processLifecycleRequirement "Initialise locked tooling, validate, stop without mutation and reproduce identical outputs.";
    usf:processTenantSecuritySeparationRequirement "Assurance input is bounded by authority digest and cannot become product runtime state.";
    usf:processSupportsEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:productionshaped>;
    usf:processSecurityBoundary "No authority mutation or ambient source access is permitted in the compiler process.";
    usf:processReadinessRequirement "Ready only after locked parser, validator and proof inputs pass integrity checks.";
    usf:processResourceLimit "Bound graph bytes, constraints, execution time and generated output size.";
    usf:processLifecycleObligation <urn:usf:permutationdimensionvalue:lifecycleobligationinitialise>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationconfigure>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationstart>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationbecomeready>,
        <urn:usf:permutationdimensionvalue:lifecycleobligationdrain>,
