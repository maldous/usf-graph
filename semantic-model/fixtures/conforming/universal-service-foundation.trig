fx:capability a usf:Capability;
    usf:canonicalName "capability";
    usf:definition "Fixture-only tenant service operations spanning synchronous, streaming, event, scheduled, stateful, data and operator-control scenarios.";
    usf:inDomain <urn:usf:capabilitydomain:foundation>;
    usf:accountableProcessBoundary fx:httpapiservice;
    usf:participatesInProcess fx:httpapiservice, fx:eventconsumerworker, fx:scheduledjobrunner,
        fx:semanticcompiler, fx:publicationcoordinator, fx:databasemigrationprocess,
        fx:backuprestoreprocess, fx:webhookdeliveryworker;
    usf:uiExposure <urn:usf:uiexposureclass:uiexposed>;
    usf:hasContract fx:contract;
    usf:hasUISemanticModel fx:uimodel.
fx:contract a usf:SemanticContract;
    usf:canonicalName "contract";
    usf:definition "Fixture-only semantic contract used solely to prove foundation expressiveness.";
    usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:proposed>;
    usf:declaresFacet fx:contractlifecyclefacet, fx:contractstatemodelfacet,
        fx:contractpermissionsfacet, fx:contractcontractsfacet, fx:contractvalidationfacet,
        fx:contracterrormodelfacet, fx:contractauditmodelfacet, fx:contractreadinessmodelfacet,
        fx:contractprooffacet, fx:contractuisemanticsfacet.

fx:contractlifecyclefacet a usf:ContractFacet; usf:canonicalName "contractlifecyclefacet"; usf:facetKind <urn:usf:facetkind:lifecycle>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "The conformance service has explicit process, workflow and contract lifecycle semantics.".
fx:contractstatemodelfacet a usf:ContractFacet; usf:canonicalName "contractstatemodelfacet"; usf:facetKind <urn:usf:facetkind:statemodel>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "The conformance workflow has explicit states and transitions.".
fx:contractpermissionsfacet a usf:ContractFacet; usf:canonicalName "contractpermissionsfacet"; usf:facetKind <urn:usf:facetkind:permissions>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Operations name permission requirements without granting any principal those permissions.".
fx:contractcontractsfacet a usf:ContractFacet; usf:canonicalName "contractcontractsfacet"; usf:facetKind <urn:usf:facetkind:contracts>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Interfaces, operations, data, events and processes are bound to explicit fixture contracts.".
fx:contractvalidationfacet a usf:ContractFacet; usf:canonicalName "contractvalidationfacet"; usf:facetKind <urn:usf:facetkind:validation>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Positive, negative and semantic validation obligations are represented without fabricated results.".
fx:contracterrormodelfacet a usf:ContractFacet; usf:canonicalName "contracterrormodelfacet"; usf:facetKind <urn:usf:facetkind:errormodel>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Operations state bounded timeout, concurrency and error behaviour.".
fx:contractauditmodelfacet a usf:ContractFacet; usf:canonicalName "contractauditmodelfacet"; usf:facetKind <urn:usf:facetkind:auditmodel>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Mutating operations identify their required audit event.".
fx:contractreadinessmodelfacet a usf:ContractFacet; usf:canonicalName "contractreadinessmodelfacet"; usf:facetKind <urn:usf:facetkind:readinessmodel>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Processes declare readiness and dependency recovery obligations.".
fx:contractprooffacet a usf:ContractFacet; usf:canonicalName "contractprooffacet"; usf:facetKind <urn:usf:facetkind:proof>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Required combinations create pending test, evidence and proof obligations.".

# Non-authorising conformance input. These template resources exercise finite token
# semantics without minting an operational permission, scope, profile or path.
fx:tokenprofiletemplate a usf:TokenProfileTemplate;
    usf:canonicalName "foundationtokenprofiletemplate";
    usf:tokenProfileTemplateKind "foundationconformanceaccesstoken";
    usf:tokenProfileTemplateClaimConstraint
        <urn:usf:tokenclaimconstrainttemplate:issuer>,
        <urn:usf:tokenclaimconstrainttemplate:audience>;
    usf:tokenProfileTemplateNonTokenMode false;
    usf:tokenProfileTemplateDigest "sha256:aed900946665fe96fd780ca671c90485ab5a0f50e23145adbaa677ada56be9bb".
fx:tokenprofilesecuritybinding a usf:TokenProfileTemplateSecurityBinding;
    usf:canonicalName "foundationtokenprofilesecuritybinding";
    usf:securityBindingForTokenProfileTemplate fx:tokenprofiletemplate;
    usf:securityBindingIssuerClass <urn:usf:tokenissuerclass:platformidentityauthority>;
    usf:securityBindingAudience <urn:usf:tokenaudience:foundationapi>;
    usf:securityBindingLifetimePolicy <urn:usf:tokenlifetimepolicy:boundedaccess>;
    usf:securityBindingAuthenticationStrength <urn:usf:authenticationstrengthrequirement:authenticated>;
    usf:securityBindingProofOfPossession <urn:usf:proofofpossessionrequirement:bearerpermitted>;
    usf:securityBindingRevocationPolicy <urn:usf:revocationpolicy:revocablebeforeexpiry>;
    usf:securityBindingDelegationConstraint <urn:usf:delegationconstraint:delegationprohibited>;
    usf:tokenProfileTemplateSecurityBindingDigest "sha256:8dc314c708e3daf90f7fefb569961cba38d9db838d0b64493c4e1f23a81889ca".

fx:automationworkflowcontract a usf:AutomationWorkflowContract;
    usf:canonicalName "automationworkflowcontract";
    usf:definition "Fixture-only automation contract proving finite trigger and permission modelling without granting runtime authority.";
    usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:proposed>;
    usf:workflowTemplate <urn:usf:template:specvalidationworkflowtemplate>;
    usf:requiredWorkflowTrigger <urn:usf:automationtrigger:pushmain>;
    usf:requiredAutomationPermission <urn:usf:automationpermission:contentsread>;
    usf:requiredValidatorRule <urn:usf:validatorrule:validatecontractconformance>.
fx:contractuisemanticsfacet a usf:ContractFacet; usf:canonicalName "contractuisemanticsfacet"; usf:facetKind <urn:usf:facetkind:uisemantics>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "The UI-exposed primary capability has framework-neutral routes, surfaces, forms and view semantics.".

fx:processcontract a usf:SemanticContract;
    usf:canonicalName "processcontract";
    usf:definition "Fixture-only contract for independent process-owned capabilities that have no user-interface exposure.";
    usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:proposed>;
    usf:declaresFacet fx:processlifecyclefacet, fx:processstatemodelfacet,
        fx:processpermissionsfacet, fx:processcontractsfacet, fx:processvalidationfacet,
        fx:processerrormodelfacet, fx:processauditmodelfacet, fx:processreadinessmodelfacet,
        fx:processprooffacet, fx:processuisemanticsfacet.
fx:processlifecyclefacet a usf:ContractFacet; usf:canonicalName "processlifecyclefacet"; usf:facetKind <urn:usf:facetkind:lifecycle>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Each process exposes finite lifecycle obligations.".
fx:processstatemodelfacet a usf:ContractFacet; usf:canonicalName "processstatemodelfacet"; usf:facetKind <urn:usf:facetkind:statemodel>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Process lifecycle state is explicit and bounded.".
fx:processpermissionsfacet a usf:ContractFacet; usf:canonicalName "processpermissionsfacet"; usf:facetKind <urn:usf:facetkind:permissions>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Process principals and security boundaries are explicit without grants.".
fx:processcontractsfacet a usf:ContractFacet; usf:canonicalName "processcontractsfacet"; usf:facetKind <urn:usf:facetkind:contracts>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Every process has one owned capability and declared interfaces.".
fx:processvalidationfacet a usf:ContractFacet; usf:canonicalName "processvalidationfacet"; usf:facetKind <urn:usf:facetkind:validation>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Readiness and lifecycle behaviour are validation obligations.".
fx:processerrormodelfacet a usf:ContractFacet; usf:canonicalName "processerrormodelfacet"; usf:facetKind <urn:usf:facetkind:errormodel>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Failure, drain, recovery and rollback behaviour are declared.".
fx:processauditmodelfacet a usf:ContractFacet; usf:canonicalName "processauditmodelfacet"; usf:facetKind <urn:usf:facetkind:auditmodel>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Process lifecycle transitions require auditable evidence.".
fx:processreadinessmodelfacet a usf:ContractFacet; usf:canonicalName "processreadinessmodelfacet"; usf:facetKind <urn:usf:facetkind:readinessmodel>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Every process declares readiness, resource and environment obligations.".
fx:processprooffacet a usf:ContractFacet; usf:canonicalName "processprooffacet"; usf:facetKind <urn:usf:facetkind:proof>; usf:facetStatus <urn:usf:facetstatus:complete>; usf:facetStatement "Process accountability and interface coverage are proof obligations.".
fx:processuisemanticsfacet a usf:ContractFacet; usf:canonicalName "processuisemanticsfacet"; usf:facetKind <urn:usf:facetkind:uisemantics>; usf:facetStatus <urn:usf:facetstatus:notapplicable>; usf:facetStatement "These process-owned fixture capabilities expose no independent user interface.".

fx:eventconsumercapability a usf:Capability; usf:canonicalName "eventconsumercapability"; usf:inDomain <urn:usf:capabilitydomain:eventsworkflow>; usf:hasContract fx:processcontract; usf:uiExposure <urn:usf:uiexposureclass:notexposed>; usf:accountableProcessBoundary fx:eventconsumerworker; usf:participatesInProcess fx:eventconsumerworker.
