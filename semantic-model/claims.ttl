@prefix usf: <urn:usf:ontology:>.
@prefix clm: <urn:usf:claim:>.
@prefix ncl: <urn:usf:nonclaim:>.
@prefix sc: <urn:usf:semanticcontract:>.

clm:accessibilitygate a usf:Claim;
    usf:canonicalName "accessibilitygate".
clm:auditbeforechange a usf:Claim;
    usf:canonicalName "auditbeforechange".
clm:boundedassurancegates a usf:Claim;
    usf:canonicalName "boundedassurancegates".
clm:boundedruntimeproofs a usf:Claim;
    usf:canonicalName "boundedruntimeproofs".
clm:devfoundationsubstrateclosure a usf:Claim;
    usf:canonicalName "devfoundationsubstrateclosure".
clm:contractfaithfultestsubstitution a usf:Claim;
    usf:canonicalName "contractfaithfultestsubstitution".
clm:failclosedauthorization a usf:Claim;
    usf:canonicalName "failclosedauthorization".
clm:hermeticruntimelineageproof a usf:Claim;
    usf:canonicalName "hermeticruntimelineageproof".
clm:openapiauthority a usf:Claim;
    usf:canonicalName "openapiauthority".
clm:operatorproofcockpit a usf:Claim;
    usf:canonicalName "operatorproofcockpit".
clm:prooffreshnessanchor a usf:Claim;
    usf:canonicalName "prooffreshnessanchor".
clm:selfdefiningusf a usf:Claim;
    usf:canonicalName "selfdefiningusf".
clm:semanticfirstevidencebacked a usf:Claim;
    usf:canonicalName "semanticfirstevidencebacked".
clm:tenantisolationproven a usf:Claim;
    usf:canonicalName "tenantisolationproven".
ncl:lineagenotcurrentreadiness a usf:NonClaim;
    usf:canonicalName "lineagenotcurrentreadiness".
ncl:productionshapednotproductionlive a usf:NonClaim;
    usf:canonicalName "productionshapednotproductionlive".
ncl:reportslowestauthority a usf:NonClaim;
    usf:canonicalName "reportslowestauthority".
ncl:semanticadequacyreviewnotimplementationproof a usf:NonClaim;
    usf:canonicalName "semanticadequacyreviewnotimplementationproof".
ncl:testsubstitutionnotstagingreadiness a usf:NonClaim;
    usf:canonicalName "testsubstitutionnotstagingreadiness".
ncl:controlmappingnotoperatingeffectiveness a usf:NonClaim;
    usf:canonicalName "controlmappingnotoperatingeffectiveness".
sc:universalservicefoundationscopeandprinciples usf:asserts clm:accessibilitygate, clm:auditbeforechange, clm:boundedassurancegates, clm:boundedruntimeproofs, clm:devfoundationsubstrateclosure, clm:failclosedauthorization, clm:hermeticruntimelineageproof, clm:openapiauthority, clm:operatorproofcockpit, clm:prooffreshnessanchor, clm:selfdefiningusf, clm:semanticfirstevidencebacked, clm:tenantisolationproven;
    usf:disclaims ncl:controlmappingnotoperatingeffectiveness, ncl:lineagenotcurrentreadiness, ncl:productionshapednotproductionlive, ncl:reportslowestauthority, ncl:semanticadequacyreviewnotimplementationproof.
