@prefix usf: <urn:usf:ontology:>.
@prefix agt: <urn:usf:agent:>.
@prefix acn: <urn:usf:agentconstraint:>.
@prefix cnk: <urn:usf:constraintkind:>.

<urn:usf:graph:agents> {
agt:usfagent a usf:Agent;
    usf:canonicalName "usfagent";
    usf:hasConstraint acn:semanticfirstduty, acn:authorityconflictstop, acn:authorisedmaterialisationonly, acn:compactverifiedresult.
acn:semanticfirstduty a usf:AgentConstraint;
    usf:canonicalName "semanticfirstduty";
    usf:constraintKind cnk:duty.
acn:authorityconflictstop a usf:AgentConstraint;
    usf:canonicalName "authorityconflictstop";
    usf:constraintKind cnk:stopcondition.
acn:authorisedmaterialisationonly a usf:AgentConstraint;
    usf:canonicalName "authorisedmaterialisationonly";
    usf:constraintKind cnk:forbidden.
acn:compactverifiedresult a usf:AgentConstraint;
    usf:canonicalName "compactverifiedresult";
    usf:constraintKind cnk:requiredoutput
}
