@prefix usf: <urn:usf:ontology:>.
@prefix val: <urn:usf:validatorrule:>.
@prefix sev: <urn:usf:severity:>.
@prefix ng: <urn:usf:namedgraph:>.
@prefix dfc: <urn:usf:defect:>.
@prefix shp: <urn:usf:shape:>.

<urn:usf:graph:validators> {
shp:adaptershape a usf:Shape;
    usf:canonicalName "adaptershape".
shp:agentconstraintshape a usf:Shape;
    usf:canonicalName "agentconstraintshape".
shp:agentshape a usf:Shape;
    usf:canonicalName "agentshape".
shp:auditeventshape a usf:Shape;
    usf:canonicalName "auditeventshape".
shp:bindingshape a usf:Shape;
    usf:canonicalName "bindingshape".
shp:capabilityshape a usf:Shape;
    usf:canonicalName "capabilityshape".
shp:commandshape a usf:Shape;
    usf:canonicalName "commandshape".
shp:configurationkeyshape a usf:Shape;
    usf:canonicalName "configurationkeyshape".
shp:consentrequirementshape a usf:Shape;
    usf:canonicalName "consentrequirementshape".
shp:contractfacetcompletenessshape a usf:Shape;
    usf:canonicalName "contractfacetcompletenessshape".
shp:contractfacetshape a usf:Shape;
    usf:canonicalName "contractfacetshape".
shp:controlshape a usf:Shape;
    usf:canonicalName "controlshape".
shp:coverageshape a usf:Shape;
    usf:canonicalName "coverageshape".
shp:datamodelshape a usf:Shape;
    usf:canonicalName "datamodelshape".
shp:defectshape a usf:Shape;
    usf:canonicalName "defectshape".
shp:environmentshape a usf:Shape;
    usf:canonicalName "environmentshape".
shp:eventshape a usf:Shape;
    usf:canonicalName "eventshape".
shp:evidencerequirementshape a usf:Shape;
    usf:canonicalName "evidencerequirementshape".
shp:evidenceresultshape a usf:Shape;
    usf:canonicalName "evidenceresultshape".
shp:evidencesatisfactionshape a usf:Shape;
    usf:canonicalName "evidencesatisfactionshape".
shp:fixtureshape a usf:Shape;
    usf:canonicalName "fixtureshape".
shp:implementationshape a usf:Shape;
    usf:canonicalName "implementationshape".
shp:interfaceshape a usf:Shape;
    usf:canonicalName "interfaceshape".
shp:journeyshape a usf:Shape;
    usf:canonicalName "journeyshape".
shp:materialisationfoundationshape a usf:Shape;
    usf:canonicalName "materialisationfoundationshape".
shp:observabilitysignalshape a usf:Shape;
    usf:canonicalName "observabilitysignalshape".
shp:operationshape a usf:Shape;
    usf:canonicalName "operationshape".
shp:permissionshape a usf:Shape;
    usf:canonicalName "permissionshape".
shp:policyshape a usf:Shape;
    usf:canonicalName "policyshape".
shp:portshape a usf:Shape;
    usf:canonicalName "portshape".
shp:promotionshape a usf:Shape;
    usf:canonicalName "promotionshape".
shp:proofexecutionshape a usf:Shape;
    usf:canonicalName "proofexecutionshape".
shp:proofobligationshape a usf:Shape;
    usf:canonicalName "proofobligationshape".
shp:proofresultshape a usf:Shape;
    usf:canonicalName "proofresultshape".
shp:proofshape a usf:Shape;
    usf:canonicalName "proofshape".
shp:providershape a usf:Shape;
    usf:canonicalName "providershape".
shp:readinessshape a usf:Shape;
    usf:canonicalName "readinessshape".
shp:realisationshape a usf:Shape;
    usf:canonicalName "realisationshape".
shp:riskshape a usf:Shape;
    usf:canonicalName "riskshape".
shp:semanticcontractshape a usf:Shape;
    usf:canonicalName "semanticcontractshape".
shp:semanticadequacyreviewshape a usf:Shape;
    usf:canonicalName "semanticadequacyreviewshape".
shp:semanticadequacydispositionshape a usf:Shape;
    usf:canonicalName "semanticadequacydispositionshape".
shp:semanticcorrectiondecisionshape a usf:Shape;
    usf:canonicalName "semanticcorrectiondecisionshape".
shp:serviceshape a usf:Shape;
    usf:canonicalName "serviceshape".
shp:shapeconceptshape a usf:Shape;
    usf:canonicalName "shapeconceptshape".
shp:surfaceshape a usf:Shape;
    usf:canonicalName "surfaceshape".
shp:testobligationshape a usf:Shape;
    usf:canonicalName "testobligationshape".
shp:testshape a usf:Shape;
    usf:canonicalName "testshape".
shp:transitionshape a usf:Shape;
    usf:canonicalName "transitionshape".
shp:validatorruleshape a usf:Shape;
    usf:canonicalName "validatorruleshape".
val:validatesemanticadequacy a usf:ValidatorRule;
    usf:canonicalName "validatesemanticadequacy";
    usf:enforcesShape shp:semanticadequacyreviewshape, shp:semanticadequacydispositionshape, shp:semanticcorrectiondecisionshape;
    usf:resultCode "validatesemanticadequacy";
    usf:targetsGraph ng:semanticdepth;
    usf:validatorSeverity sev:blocking.
val:validatematerialisationcontrolplane a usf:ValidatorRule;
    usf:canonicalName "validatematerialisationcontrolplane";
    usf:resultCode "validatematerialisationcontrolplane";
    usf:targetsGraph ng:materialisation;
    usf:validatorSeverity sev:blocking.
val:validateauthorityintegrity a usf:ValidatorRule;
    usf:canonicalName "validateauthorityintegrity";
    usf:detectsDefect dfc:adridentity, dfc:alias, dfc:authorityinversion, dfc:duplicatemeaning, dfc:forbiddenmetadata, dfc:hyphenatedidentifier, dfc:invalidcasing, dfc:missinggraphreference, dfc:overloadedterm, dfc:undefinedterm;
    usf:enforcesShape shp:shapeconceptshape, shp:semanticcontractshape;
    usf:resultCode "validateauthorityintegrity";
    usf:targetsGraph ng:ontology, ng:taxonomy, ng:vocabulary, ng:authority, ng:registry;
    usf:validatorSeverity sev:blocking.
val:validateoriginindependence a usf:ValidatorRule;
    usf:canonicalName "validateoriginindependence";
    usf:detectsDefect dfc:externalworktrackingidentifier, dfc:externalworkrecordidentifier, dfc:repositorymetadata, dfc:sourcepath;
    usf:resultCode "validateoriginindependence";
    usf:targetsGraph ng:authority, ng:claims, ng:capabilities, ng:policies, ng:interfaces, ng:interactions, ng:platform, ng:data, ng:signals, ng:experience, ng:proofs, ng:evidence, ng:controls, ng:tests, ng:bindings, ng:agents, ng:validators, ng:enterprise, ng:assuranceprofiles, ng:readinessgates, ng:ui, ng:renderers, ng:generation, ng:semanticdepth, ng:materialisation;
    usf:validatorSeverity sev:blocking.
val:validatecontractconformance a usf:ValidatorRule;
    usf:canonicalName "validatecontractconformance";
    usf:detectsDefect dfc:environmentmismatch, dfc:incompleterealisation, dfc:missingauditsignal, dfc:missingcontractfacet, dfc:missingpermission, dfc:missingtenancyboundary, dfc:providermismatch;
    usf:enforcesShape shp:capabilityshape, shp:commandshape, shp:configurationkeyshape, shp:contractfacetcompletenessshape, shp:environmentshape, shp:interfaceshape, shp:providershape, shp:realisationshape, shp:serviceshape;
    usf:resultCode "validatecontractconformance";
    usf:targetsGraph ng:capabilities, ng:interfaces, ng:platform, ng:data, ng:signals, ng:bindings;
    usf:validatorSeverity sev:blocking.
val:validateassuranceconformance a usf:ValidatorRule;
    usf:canonicalName "validateassuranceconformance";
    usf:detectsDefect dfc:directauthoredreadiness, dfc:insufficientproofrung, dfc:readinessoverclaim, dfc:staleevidence;
    usf:enforcesShape shp:evidenceresultshape, shp:proofresultshape, shp:proofshape, shp:readinessshape;
    usf:resultCode "validateassuranceconformance";
    usf:targetsGraph ng:proofs, ng:evidence, ng:assuranceprofiles, ng:readinessgates, ng:derivedreadiness;
    usf:validatorSeverity sev:blocking.
shp:realisationdecisionshape a usf:Shape;
    usf:canonicalName "realisationdecisionshape".
shp:criterionassessmentshape a usf:Shape;
    usf:canonicalName "criterionassessmentshape".
shp:criterionevidencebindingshape a usf:Shape;
    usf:canonicalName "criterionevidencebindingshape".
shp:optioncomponentshape a usf:Shape;
    usf:canonicalName "optioncomponentshape".
shp:compositioninterfaceshape a usf:Shape;
    usf:canonicalName "compositioninterfaceshape".
shp:criterionrequirementshape a usf:Shape;
    usf:canonicalName "criterionrequirementshape".
shp:criterionmitigationshape a usf:Shape;
    usf:canonicalName "criterionmitigationshape".
shp:realisationoptionselectioncontractshape a usf:Shape;
    usf:canonicalName "realisationoptionselectioncontractshape".
shp:realisationoptionevaluationvalidatortargetshape a usf:Shape;
    usf:canonicalName "realisationoptionevaluationvalidatortargetshape".
val:validaterealisationoptionevaluation a usf:ValidatorRule;
    usf:canonicalName "validaterealisationoptionevaluation";
    usf:detectsDefect dfc:accepteddecisionunprovedcandidate, dfc:fakecandidate, dfc:missingselectedoption, dfc:multipleselectedoptions, dfc:selectedoptionnotconsidered, dfc:missingcriterion, dfc:missingcriterionassessment, dfc:componentcriterionassessmentmissing, dfc:assessmentwithoutevidence, dfc:assessmentevidenceinvalid, dfc:componentassessmentevidenceinvalid, dfc:unjustifiednotapplicablecriterion, dfc:rejectedcandidatewithoutreason, dfc:rejectionreasonwithoutevidence, dfc:floatingpackageversion, dfc:missingpackagedigest, dfc:unknownlicence, dfc:missingvulnerabilityassessment, dfc:compositionfacetuncovered, dfc:compositioncomponentwithoutresponsibility, dfc:incompatiblecomponentversions, dfc:compositionwithoutcurrentcoverageproof, dfc:inheritedproductpreference, dfc:activecontractwithoutevaluation, dfc:decisionstatecardinality, dfc:decisioncontractcardinality, dfc:decisionevaluationcardinality, dfc:evaluationdependencydrift, dfc:mandatorycriterionwithoutmitigation, dfc:missingsupplychainassessment, dfc:componentkindcardinality, dfc:incompletecomponentboundary, dfc:unclassifiedcompositionpermutation, dfc:missingproviderenvironmentbinding, dfc:compositiondependencyinvalid, dfc:selectedoptionrealisationmappingcardinality, dfc:selectedcomponentconcretemappingcardinality, dfc:selectedcomponentconcretemappingtypemismatch, dfc:selectionmappingdependencydrift, dfc:realisationoptionvalidatorgraphscopemismatch;
    usf:enforcesShape shp:realisationdecisionshape, shp:criterionassessmentshape, shp:criterionevidencebindingshape, shp:criterionrequirementshape, shp:criterionmitigationshape, shp:optioncomponentshape, shp:compositioninterfaceshape, shp:realisationoptionselectioncontractshape, shp:realisationoptionevaluationvalidatortargetshape;
    usf:resultCode "realisationoptionevaluationclosure";
    usf:targetsGraph ng:vocabulary, ng:capabilities, ng:interfaces, ng:evidence, ng:bindings, ng:materialisation, ng:derivedreadiness;
    usf:validatorSeverity sev:blocking.
val:validatevalidatorcoverage a usf:ValidatorRule;
    usf:canonicalName "validatevalidatorcoverage";
    usf:detectsDefect dfc:missingvalidatorcoverage;
    usf:enforcesShape shp:defectshape, shp:validatorruleshape;
    usf:resultCode "validatevalidatorcoverage";
    usf:targetsGraph ng:tests, ng:validators;
    usf:validatorSeverity sev:blocking
}
