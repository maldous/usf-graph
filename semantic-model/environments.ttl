@prefix usf: <urn:usf:ontology:>.
@prefix env: <urn:usf:environment:>.
@prefix envc: <urn:usf:environmentclass:>.
@prefix pmode: <urn:usf:providermode:>.
@prefix prom: <urn:usf:promotion:>.

env:ci a usf:Environment;
    usf:canonicalName "ci";
    usf:hasEnvironmentClass envc:integration;
    usf:permitsProviderMode pmode:deterministictestsubstitute, pmode:repositorylocalservice.
env:authoritycontrol a usf:Environment;
    usf:canonicalName "authoritycontrol";
    usf:hasEnvironmentClass envc:authoritycontrol;
    usf:permitsProviderMode pmode:liveauthoritycontrol.
env:hermetic a usf:Environment;
    usf:canonicalName "hermetic";
    usf:hasEnvironmentClass envc:hermetic;
    usf:permitsProviderMode pmode:deterministictestsubstitute.
env:integrationtest a usf:Environment;
    usf:canonicalName "integrationtest";
    usf:hasEnvironmentClass envc:integration;
    usf:permitsProviderMode pmode:deterministictestsubstitute, pmode:repositorylocalservice.
env:localdev a usf:Environment;
    usf:canonicalName "localdev";
    usf:hasEnvironmentClass envc:local;
    usf:permitsProviderMode pmode:deterministictestsubstitute, pmode:repositorylocalservice.
env:productionlive a usf:Environment;
    usf:canonicalName "productionlive";
    usf:hasEnvironmentClass envc:productionlive;
    usf:permitsProviderMode pmode:liveexternal.
env:productionshaped a usf:Environment;
    usf:canonicalName "productionshaped";
    usf:hasEnvironmentClass envc:productionshaped;
    usf:permitsProviderMode pmode:externalsandbox, pmode:repositorylocalservice.
env:staging a usf:Environment;
    usf:canonicalName "staging";
    usf:hasEnvironmentClass envc:staging;
    usf:permitsProviderMode pmode:externalsandbox, pmode:repositorylocalservice.
prom:claimrules a usf:Promotion;
    usf:canonicalName "claimrules";
    usf:promotesFrom env:localdev;
    usf:promotesTo env:localdev.
prom:promotedevtotest a usf:Promotion;
    usf:canonicalName "promotedevtotest";
    usf:promotesFrom env:localdev;
    usf:promotesTo env:integrationtest.
prom:promotestagingtoproduction a usf:Promotion;
    usf:canonicalName "promotestagingtoproduction";
    usf:promotesFrom env:staging;
    usf:promotesTo env:productionlive.
prom:promotetesttostaging a usf:Promotion;
    usf:canonicalName "promotetesttostaging";
    usf:promotesFrom env:integrationtest;
    usf:promotesTo env:staging.
prom:repositoryenvironmentladdergovernance a usf:Promotion;
    usf:canonicalName "repositoryenvironmentladdergovernance";
    usf:promotesFrom env:localdev;
    usf:promotesTo env:localdev.
prom:usfdevteststagingartifactpromotioncontract a usf:Promotion;
    usf:canonicalName "usfdevteststagingartifactpromotioncontract";
    usf:promotesFrom env:localdev;
    usf:promotesTo env:localdev.
<urn:usf:environmenttopology:development> a usf:EnvironmentTopology;
    usf:canonicalName "development";
    usf:repositoryName "development";
    usf:definition "Complete repository-local development execution topology.";
    usf:includesEnvironment env:localdev;
    usf:topologyReadinessRequirement "All processes start from tracked source, validate configuration, apply schema changes, load representative data and expose dependency-aware readiness.";
    usf:topologyIsolationRequirement "May use deterministic substitutes or repository-local services; reset is deterministic and no hidden host defaults are consumed.".
<urn:usf:environmenttopology:test> a usf:EnvironmentTopology;
    usf:canonicalName "test";
    usf:repositoryName "test";
    usf:definition "Complete repository-local test execution topology.";
    usf:includesEnvironment env:hermetic, env:integrationtest, env:ci;
    usf:topologyReadinessRequirement "Unit, contract, integration and end-to-end suites run with deterministic time, randomness, failure injection, database state and provider responses.";
    usf:topologyIsolationRequirement "Starts with empty dependency and runtime state, uses no original repository or work tracker, and rejects unrelated host files, variables and services.".
<urn:usf:environmenttopology:staging> a usf:EnvironmentTopology;
    usf:canonicalName "staging";
    usf:repositoryName "staging";
    usf:definition "Complete repository-local staging execution topology.";
    usf:includesEnvironment env:productionshaped, env:staging;
    usf:topologyReadinessRequirement "Production-shaped processes, persistence, queues, security, observability, backup, restore, upgrade and rollback are healthy before readiness.";
    usf:topologyIsolationRequirement "Deterministic substitutes are forbidden; repository-local production-shaped services or admitted external sandboxes use explicit credentials and nonclaims.".
<urn:usf:environmenttopology:development> a usf:EnvironmentTopology;
    usf:canonicalName "development";
    usf:repositoryName "development";
    usf:definition "Complete repository-local development execution topology.";
    usf:includesEnvironment env:localdev;
    usf:topologyReadinessRequirement "All processes start from tracked source, validate configuration, apply schema changes, load representative data and expose dependency-aware readiness.";
    usf:topologyIsolationRequirement "May use deterministic substitutes or repository-local services; reset is deterministic and no hidden host defaults are consumed.".
<urn:usf:environmenttopology:test> a usf:EnvironmentTopology;
    usf:canonicalName "test";
    usf:repositoryName "test";
    usf:definition "Complete repository-local test execution topology.";
    usf:includesEnvironment env:hermetic, env:integrationtest, env:ci;
    usf:topologyReadinessRequirement "Unit, contract, integration and end-to-end suites run with deterministic time, randomness, failure injection, database state and provider responses.";
    usf:topologyIsolationRequirement "Starts with empty dependency and runtime state, uses no original repository or work tracker, and rejects unrelated host files, variables and services.".
<urn:usf:environmenttopology:staging> a usf:EnvironmentTopology;
    usf:canonicalName "staging";
    usf:repositoryName "staging";
    usf:definition "Complete repository-local staging execution topology.";
    usf:includesEnvironment env:productionshaped, env:staging;
    usf:topologyReadinessRequirement "Production-shaped processes, persistence, queues, security, observability, backup, restore, upgrade and rollback are healthy before readiness.";
    usf:topologyIsolationRequirement "Deterministic substitutes are forbidden; repository-local production-shaped services or admitted external sandboxes use explicit credentials and nonclaims.".
