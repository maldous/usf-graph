cfg:semanticauthorityaccessmode a usf:ConfigurationKey;
    usf:canonicalName "semanticauthorityaccessmode";
    usf:repositoryName "semantic-authority-access-mode";
    usf:definition "Selects live Stardog access or an exact digest-bound read-only Stardog authority export; neither mode changes the sole semantic authority.";
    usf:hasSecretClassification seck:nonsecret;
    usf:configures <urn:usf:capability:semanticmodelcompilation>;
    usf:configurationValueType <urn:usf:configurationvaluetype:enumeration>;
    usf:configurationRequired true;
    usf:configurationConstraint "Exactly live or verified-export. Semantic mutation requires live Stardog; verified-export is read-only and must bind the expected authority digest.";
    usf:configurationForEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:hermetic>, <urn:usf:environment:integrationtest>, <urn:usf:environment:ci>, <urn:usf:environment:productionshaped>, <urn:usf:environment:staging>;
    usf:secretValueMustBeReferenced false.
cfg:semanticauthorityexpectedauthoritydigest a usf:ConfigurationKey;
    usf:canonicalName "semanticauthorityexpectedauthoritydigest";
    usf:repositoryName "semantic-authority-expected-authority-digest";
    usf:definition "Pins every semantic-assurance operation to one exact current Stardog authority digest.";
    usf:hasSecretClassification seck:nonsecret;
    usf:configures <urn:usf:capability:semanticmodelcompilation>;
    usf:configurationValueType <urn:usf:configurationvaluetype:string>;
    usf:configurationRequired true;
    usf:configurationConstraint "Lower-case sha256 digest; observed drift fails before planning, proof, publication or materialisation.";
    usf:configurationForEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:hermetic>, <urn:usf:environment:integrationtest>, <urn:usf:environment:ci>, <urn:usf:environment:productionshaped>, <urn:usf:environment:staging>;
    usf:secretValueMustBeReferenced false.
cfg:semanticauthorityendpoint a usf:ConfigurationKey;
    usf:canonicalName "semanticauthorityendpoint";
    usf:repositoryName "semantic-authority-endpoint";
    usf:definition "Declares the credential-free HTTPS endpoint of live Stardog semantic authority.";
    usf:hasSecretClassification seck:nonsecret;
    usf:configures <urn:usf:capability:semanticmodelcompilation>;
    usf:configurationValueType <urn:usf:configurationvaluetype:string>;
    usf:configurationRequired false;
    usf:configurationConstraint "Required only in live mode; absolute HTTPS, no credentials, query, fragment, loopback or implicit default.";
    usf:configurationForEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:productionshaped>, <urn:usf:environment:staging>;
    usf:secretValueMustBeReferenced false.
cfg:semanticauthoritydatabase a usf:ConfigurationKey;
    usf:canonicalName "semanticauthoritydatabase";
    usf:repositoryName "semantic-authority-database";
    usf:definition "Names the exact Stardog database used as semantic authority.";
    usf:hasSecretClassification seck:nonsecret;
    usf:configures <urn:usf:capability:semanticmodelcompilation>;
    usf:configurationValueType <urn:usf:configurationvaluetype:string>;
    usf:configurationRequired false;
    usf:configurationConstraint "Required only in live mode; explicit portable database identifier with no ambient default.";
    usf:configurationForEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:productionshaped>, <urn:usf:environment:staging>;
    usf:secretValueMustBeReferenced false.
cfg:semanticauthorityauthenticationmode a usf:ConfigurationKey;
    usf:canonicalName "semanticauthorityauthenticationmode";
    usf:repositoryName "semantic-authority-authentication-mode";
    usf:definition "Selects token or basic authentication for live Stardog access without carrying credential bytes.";
    usf:hasSecretClassification seck:nonsecret;
    usf:configures <urn:usf:capability:semanticmodelcompilation>;
    usf:configurationValueType <urn:usf:configurationvaluetype:enumeration>;
    usf:configurationRequired false;
    usf:configurationConstraint "Required only in live mode; exactly token or basic and consistent with the supplied secret references.";
    usf:configurationForEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:productionshaped>, <urn:usf:environment:staging>;
    usf:secretValueMustBeReferenced false.
cfg:semanticauthoritytokenreference a usf:ConfigurationKey;
    usf:canonicalName "semanticauthoritytokenreference";
    usf:repositoryName "semantic-authority-token-reference";
    usf:definition "Provides an opaque secret reference for Stardog token authentication.";
    usf:hasSecretClassification seck:secret;
    usf:configures <urn:usf:capability:semanticmodelcompilation>;
    usf:configurationValueType <urn:usf:configurationvaluetype:secretreference>;
    usf:configurationRequired false;
    usf:configurationConstraint "Required only for live token mode; secret:// reference only and mutually exclusive with basic-auth references.";
    usf:configurationForEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:productionshaped>, <urn:usf:environment:staging>;
    usf:secretValueMustBeReferenced true.
cfg:semanticauthorityusernamereference a usf:ConfigurationKey;
    usf:canonicalName "semanticauthorityusernamereference";
    usf:repositoryName "semantic-authority-username-reference";
    usf:definition "Provides an opaque secret reference for the Stardog basic-auth username.";
    usf:hasSecretClassification seck:secret;
    usf:configures <urn:usf:capability:semanticmodelcompilation>;
    usf:configurationValueType <urn:usf:configurationvaluetype:secretreference>;
    usf:configurationRequired false;
    usf:configurationConstraint "Required with the password reference only for live basic mode; secret:// reference only and mutually exclusive with token mode.";
    usf:configurationForEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:productionshaped>, <urn:usf:environment:staging>;
    usf:secretValueMustBeReferenced true.
cfg:semanticauthoritypasswordreference a usf:ConfigurationKey;
    usf:canonicalName "semanticauthoritypasswordreference";
    usf:repositoryName "semantic-authority-password-reference";
    usf:definition "Provides an opaque secret reference for the Stardog basic-auth password.";
    usf:hasSecretClassification seck:secret;
    usf:configures <urn:usf:capability:semanticmodelcompilation>;
    usf:configurationValueType <urn:usf:configurationvaluetype:secretreference>;
    usf:configurationRequired false;
    usf:configurationConstraint "Required with the username reference only for live basic mode; secret:// reference only and mutually exclusive with token mode.";
    usf:configurationForEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:productionshaped>, <urn:usf:environment:staging>;
    usf:secretValueMustBeReferenced true.
