    usf:layoutRoleDeploymentBoundary "Agent-product compatibility boundary; not application runtime.".
<urn:usf:realisationdecision:repositoryarchitectureandnaming> a usf:RealisationDecision, usf:RepositoryArchitectureDecision;
    usf:canonicalName "repositoryarchitectureandnaming";
    usf:decisionState <urn:usf:decisionstate:accepted>;
    usf:decisionForContract <urn:usf:semanticcontract:repositoryexternalartefactmaterialisation>;
    usf:considersOption <urn:usf:realisationoption:capabilitycellswithprocessassemblies>, <urn:usf:realisationoption:processcentricrepository>, <urn:usf:realisationoption:domainservicerepository>, <urn:usf:realisationoption:technologylayeredrepository>;
    usf:selectsOption <urn:usf:realisationoption:capabilitycellswithprocessassemblies>;
    usf:hasDecisionEvaluation <urn:usf:decisionevaluation:repositoryarchitectureandnaming>;
    usf:decisionRationale "Capability cells with thin deployable process assemblies most accurately preserve semantic ownership, dependency direction, data and security boundaries, independent testing and environment composition. Process-centric and technology-layered alternatives obscure ownership; independently deployable domain services are not required for every capability. Compatibility paths are isolated projections rather than target architecture.";
    usf:usesRepositoryNamingStandard <urn:usf:repositorynamingstandard:semanticpurpose>;
    usf:selectsRepositoryLayoutRole path:repositorydirective, path:processsource, path:capabilitysource, path:runtimemechanismsource, path:providerbindingsource, path:persistencesource, path:configurationsource, path:environmentsource, path:semanticmodelsource, path:assurancesource, path:operationssource, path:documentationsource, path:generatedoutput, path:programmeexecutionstate, path:claudeagentintegration, path:codexagentintegration;
    usf:authorisesSourcePath ".", "processes", "capabilities", "runtime-mechanisms", "provider-bindings", "persistence", "configuration", "environments", "semantic-model", "assurance", "operations", "documentation", ".work/generated", ".work/programme", ".claude/skills/usf", ".codex/skills/usf";
    usf:authorisesRepository "usf";
    usf:authorisesRealisationType usf:Implementation;
    usf:requiresADR <urn:usf:adrrequirement:repositoryarchitectureandnaming>.
<urn:usf:adrrequirement:repositoryarchitectureandnaming> a usf:ADRRequirement;
    usf:canonicalName "repositoryarchitectureandnaming".
<urn:usf:adrrecord:repositoryarchitectureandnaming> a usf:ADRRecord;
    usf:canonicalName "repositoryarchitectureandnaming";
    usf:recordsDecision <urn:usf:realisationdecision:repositoryarchitectureandnaming>.
<urn:usf:realisation:repositoryarchitectureandnaming> a usf:Realisation;
    usf:canonicalName "repositoryarchitectureandnaming";
    usf:realisesContract <urn:usf:semanticcontract:repositoryexternalartefactmaterialisation>;
    usf:authorisedByDecision <urn:usf:realisationdecision:repositoryarchitectureandnaming>;
    usf:authorisedSourcePath "semantic-model";
    usf:realisationState <urn:usf:realisationstate:implementable>.
