    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "Every plan, descriptor, projection and realisation is validated and failures close the gate.".
cf:repositoryexternalartefactmaterialisationerrormodel a usf:ContractFacet;
    usf:canonicalName "repositoryexternalartefactmaterialisationerrormodel";
    usf:facetKind facet:errormodel;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "Stable failure codes identify rule, path, digest, signature, size, isolation and transaction violations.".
cf:repositoryexternalartefactmaterialisationauditmodel a usf:ContractFacet;
    usf:canonicalName "repositoryexternalartefactmaterialisationauditmodel";
    usf:facetKind facet:auditmodel;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "Authority digests, exact evidence-set digests, operation keys and immutable payload digests make mutations auditable.".
cf:repositoryexternalartefactmaterialisationreadinessmodel a usf:ContractFacet;
    usf:canonicalName "repositoryexternalartefactmaterialisationreadinessmodel";
    usf:facetKind facet:readinessmodel;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "Readiness requires digest-bound representative proof, two independent clean clones, empty runtime state, poisoned-host isolation and deterministic repeated materialisation.".
cf:repositoryexternalartefactmaterialisationproof a usf:ContractFacet;
    usf:canonicalName "repositoryexternalartefactmaterialisationproof";
    usf:facetKind facet:proof;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "The mandatory proof evaluates an exact admitted evidence set with negative cases and explicit nonclaims.".
cf:repositoryexternalartefactmaterialisationuisemantics a usf:ContractFacet;
    usf:canonicalName "repositoryexternalartefactmaterialisationuisemantics";
    usf:facetKind facet:uisemantics;
    usf:facetStatus <urn:usf:facetstatus:notapplicable>;
    usf:facetStatement "No user-interface semantic surface is introduced by this foundation.".
