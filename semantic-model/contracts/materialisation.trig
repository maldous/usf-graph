<urn:usf:repositorynamingstandard:semanticpurpose> a usf:RepositoryNamingStandard;
    usf:canonicalName "semanticpurpose";
    usf:directoryNamingAlgorithm "Derive one stable semantic responsibility, normalise Unicode to ASCII words, lowercase, join words with single hyphens, and reject lifecycle, delivery-sequence, tracker and inherited-source identity.";
    usf:fileNamingAlgorithm "Name the semantic subject and file role, then append the language- or format-native extension; a filename never encodes an external work record, delivery sequence, implementation status or historical source location.";
    usf:languageNativeNamingRule "Filesystem names remain lowercase kebab case; language symbols may use the selected language native convention only inside source bytes.";
    usf:configurationNamingRule "Use <subject>[.<environment>].<format> only when the environment distinction is semantically real; commit schemas and safe defaults, never secret values or hidden fallback files.";
    usf:schemaChangeNamingRule "Use repository-local monotonic cNNNNNN-<semantic-purpose>.<format> within the owning store; the six-digit ordinal is never reused or renumbered and never comes from an external tracker.";
    usf:testNamingRule "Use <subject>.<unit|contract|integration|end-to-end|adversarial>.test.<language-extension>; unit tests may be co-located, while cross-boundary and environment tests live under assurance.";
    usf:environmentNamingRule "Name environment directories development, test and staging; name selected orchestration files by their tool-native stable filename inside that directory, including compose.yaml only when Compose is independently selected.";
    usf:proofValidationNamingRule "Use <semantic-subject>.<evidence|proof|validation>.<format> and bind every result to current authority, source, configuration, environment and provider-mode digests.";
    usf:authoredPlacementRule "Authored content exists in exactly one canonical responsibility role; aliases or product integrations are explicit compatibility projections and never alternate authority.";
    usf:generatedPlacementRule "Generated projections and build outputs live under .work/generated or verified CAS, remain untracked unless a contract explicitly requires a tracked representation, and are never clean-clone source inputs.";
    usf:singularPluralNamingRule "Top-level collection roles use plural nouns where countable and stable mass nouns otherwise; child directories use a singular semantic purpose unless they are genuine collections.";
    usf:caseNamingRule "Directories and ordinary filenames use lowercase ASCII kebab case; AGENTS.md, GOAL.md and product-required shim or skill filenames are the only uppercase compatibility exceptions.";
    usf:abbreviationNamingRule "Use an abbreviation only when it is the independently clearest domain term; lowercase it in paths, define it semantically, and never invent an abbreviation to shorten an inherited name.";
    usf:historicalNameDispositionRule "Every inherited name is bound to the accepted counterfactual disposition inventory and is independently selected, renamed, consolidated, split, removed or historical-only; matching history is permitted only with independent warrant.";
    usf:prohibitedCanonicalToken "wave-zero", "wave-one", "wave-two", "wave-three", "wave-four", "wave-five", "wave-six", "initial-suite", "bootstrap", "reference-kernel", "executable-suite", "migration", "legacy", "replacement", "temporary", "v2", "external-tracker-identifier", "external-work-record-ordinal", "core", "common", "shared", "utils", "helpers", "misc";
    usf:trackerDerivedIdentityProhibited true;
    usf:sourceDerivedIdentityProhibited true;
    usf:operationalSequenceIdentityProhibited true.
path:repositorydirective a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "repositorydirective";
    usf:authorisedParentPath ".";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Repository-level governance and agent entry directives.";
    usf:layoutRoleAllowedContent "AGENTS.md, GOAL.md, tool-specific shims, licence and root package or workspace manifests only.";
    usf:layoutRoleForbiddenContent "Capability source, generated output, secrets, evidence payloads and deployment definitions.";
    usf:layoutRoleDependencyRule "Root directives may refer to every role but no executable source may depend on root prose.";
    usf:layoutRoleDeploymentBoundary "Repository control boundary; never a deployable process.".
path:processsource a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "processsource";
    usf:authorisedParentPath "processes";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Deployable process entry points and composition assemblies.";
    usf:layoutRoleAllowedContent "API ingress, user-delivery, worker, scheduler, operator-control and semantic-assurance process assemblies.";
    usf:layoutRoleForbiddenContent "Capability business logic, provider implementations, persistence ownership and generated output.";
    usf:layoutRoleDependencyRule "May depend on capability interfaces, runtime mechanisms, provider bindings, configuration and persistence; no role may depend on a process assembly.";
    usf:layoutRoleDeploymentBoundary "Each child is independently startable, health-checked and deployable.".
path:capabilitysource a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "capabilitysource";
    usf:authorisedParentPath "capabilities";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Capability-owned executable business behaviour.";
    usf:layoutRoleAllowedContent "Modules grouped by stable semantic capability ownership with ports, commands, events and co-located unit tests.";
    usf:layoutRoleForbiddenContent "Deployable bootstrapping, cross-capability catch-alls, provider SDK calls and unrelated shared utilities.";
    usf:layoutRoleDependencyRule "May depend on explicit runtime-mechanism ports and its own data contracts; capability-to-capability calls require declared interfaces or events.";
    usf:layoutRoleDeploymentBoundary "Change and test boundary for one semantic capability; not independently deployed unless separately decided.".
path:runtimemechanismsource a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "runtimemechanismsource";
    usf:authorisedParentPath "runtime-mechanisms";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Explicit cross-capability execution mechanisms.";
    usf:layoutRoleAllowedContent "Authorisation context, event transport, queue semantics, idempotency, scheduling and other deliberately shared runtime mechanisms.";
    usf:layoutRoleForbiddenContent "Product-specific business rules, provider bindings, environment orchestration and vague common or utility modules.";
    usf:layoutRoleDependencyRule "May expose ports to processes and capabilities; may depend on persistence and configuration abstractions, never on capability implementations.";
    usf:layoutRoleDeploymentBoundary "Reusable runtime boundary with independent contract and integration tests.".
path:providerbindingsource a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "providerbindingsource";
    usf:authorisedParentPath "provider-bindings";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "External-system and substrate adapters.";
    usf:layoutRoleAllowedContent "Adapters that implement declared ports, provider-specific configuration schemas and deterministic test substitutes.";
    usf:layoutRoleForbiddenContent "Capability policy, direct cross-tenant access, undeclared provider calls and production credentials.";
    usf:layoutRoleDependencyRule "Depends inward on ports and configuration; capability and runtime source never depend on provider SDK types.";
    usf:layoutRoleDeploymentBoundary "Provider-specific security and operational boundary selected per environment.".
path:persistencesource a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "persistencesource";
    usf:authorisedParentPath "persistence";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Owned data definitions and recovery mechanics.";
    usf:layoutRoleAllowedContent "Schemas, repository-local change series, representative data, transaction ownership, backup, restore, upgrade and rollback assets.";
    usf:layoutRoleForbiddenContent "Application business logic, secrets, provider credentials and unowned global schemas.";
    usf:layoutRoleDependencyRule "Each store subtree names one semantic owner; processes and capabilities access it only through the owner-defined persistence interface.";
    usf:layoutRoleDeploymentBoundary "Data ownership, transaction, tenancy and recovery boundary.".
path:configurationsource a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "configurationsource";
    usf:authorisedParentPath "configuration";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Typed configuration and secret-reference contracts.";
    usf:layoutRoleAllowedContent "Configuration schemas, validation, safe non-secret defaults and environment-variable or secret-reference definitions.";
    usf:layoutRoleForbiddenContent "Secret values, environment orchestration, capability implementation and generated runtime state.";
    usf:layoutRoleDependencyRule "Consumed inward through typed configuration interfaces; no hidden defaults or host-state discovery.";
    usf:layoutRoleDeploymentBoundary "Repository-wide configuration contract; values are supplied by environments.".
path:environmentsource a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "environmentsource";
    usf:authorisedParentPath "environments";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Development, deterministic test and production-shaped staging composition.";
    usf:layoutRoleAllowedContent "Locked build definitions, environment orchestration, dependency wiring, health/readiness probes and environment-specific non-secret inputs.";
    usf:layoutRoleForbiddenContent "Business logic, semantic authority, mutable tags, secret values and test-only substitutes in staging.";
    usf:layoutRoleDependencyRule "Composes processes, provider bindings, persistence and configuration; production source never depends on environment definitions.";
    usf:layoutRoleDeploymentBoundary "One independently runnable topology per environment class.".
path:semanticmodelsource a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "semanticmodelsource";
    usf:authorisedParentPath "semantic-model";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Stardog-governed semantic source and its transactional compiler.";
    usf:layoutRoleAllowedContent "Ontology, vocabulary, contracts, claims, rules, shapes, fixtures, compiler, gateway and authority lifecycle tests.";
    usf:layoutRoleForbiddenContent "Product runtime implementation, runtime evidence payloads, generated projections and work-tracker exports.";
    usf:layoutRoleDependencyRule "Authorises all other roles; may inspect repository source for validation but is not imported as a product runtime dependency.";
    usf:layoutRoleDeploymentBoundary "Semantic control-plane boundary; Stardog remains the sole live mutation boundary.".
path:assurancesource a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "assurancesource";
    usf:authorisedParentPath "assurance";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Executable testing, evidence, proof and validation mechanisms.";
    usf:layoutRoleAllowedContent "Contract, integration, end-to-end, adversarial and clean-room tests; evidence collectors; proof algorithms; validators and schemas.";
    usf:layoutRoleForbiddenContent "Product business logic, production runtime dependencies, admitted payload bytes and completion claims without evidence.";
    usf:layoutRoleDependencyRule "May depend on every executable role for observation; no production process or capability may depend on assurance code.";
    usf:layoutRoleDeploymentBoundary "Independent evidence and verification boundary.".
path:operationssource a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "operationssource";
    usf:authorisedParentPath "operations";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Operator administration and recoverability.";
    usf:layoutRoleAllowedContent "Administrative commands, runbooks, diagnostics, backup/restore, upgrade/rollback and incident-recovery tooling.";
    usf:layoutRoleForbiddenContent "Product UI, capability business logic, embedded credentials and generated evidence.";
    usf:layoutRoleDependencyRule "Invokes explicit process, capability and persistence administration interfaces; no bypass of authorisation or tenancy.";
    usf:layoutRoleDeploymentBoundary "Human and automation operator boundary.".
path:documentationsource a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "documentationsource";
    usf:authorisedParentPath "documentation";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Authored human-facing repository documentation.";
    usf:layoutRoleAllowedContent "Architecture, developer, operator, API, automation and user journey documentation tied to semantic identifiers.";
    usf:layoutRoleForbiddenContent "Semantic truth, executable source, runtime evidence and copied external requirements.";
    usf:layoutRoleDependencyRule "May cite current authority and executable interfaces; never authorises them.";
    usf:layoutRoleDeploymentBoundary "Human-consumption boundary; tracked and reviewable.".
path:generatedoutput a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "generatedoutput";
    usf:authorisedParentPath ".work/generated";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Regenerable local projections and build outputs.";
    usf:layoutRoleAllowedContent "Digest-bound generated contracts, interface models, reports, test projections and release candidates.";
    usf:layoutRoleForbiddenContent "Authored source, semantic authority, required clean-clone inputs and admitted evidence payloads.";
    usf:layoutRoleDependencyRule "May be regenerated only from tracked source plus verified dependencies; no authored role may require pre-existing contents.";
    usf:layoutRoleDeploymentBoundary "Untracked, disposable execution output.".
path:programmeexecutionstate a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "programmeexecutionstate";
    usf:authorisedParentPath ".work/programme";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Atomic continuation ledger and recovery checkpoint.";
    usf:layoutRoleAllowedContent "Digest-bound phase, completed/partial/superseded state, transaction ownership, CAS descriptors and next exact action.";
    usf:layoutRoleForbiddenContent "Semantic authority, executable source, evidence payloads, credentials and conversational transcripts.";
    usf:layoutRoleDependencyRule "May point to Git, Stardog and CAS digests; no build or runtime may consume it as source.";
    usf:layoutRoleDeploymentBoundary "Untracked coordination state outside Git.".
path:claudeagentintegration a usf:PathRole, usf:RepositoryLayoutRole;
    usf:canonicalName "claudeagentintegration";
    usf:authorisedParentPath ".claude/skills/usf";
    usf:materialisesOnDemand true;
    usf:layoutRoleOwner <urn:usf:capability:repositoryexternalartefactmaterialisation>;
    usf:layoutRoleSemanticResponsibility "Claude product integration for the canonical agent-neutral USF operating skill.";
    usf:layoutRoleAllowedContent "Compatibility skill manifest and instruction projection only.";
    usf:layoutRoleForbiddenContent "Independent semantic requirements, implementation source, programme memory and tool-specific authority.";
    usf:layoutRoleDependencyRule "Must remain meaning-equivalent to the canonical agent-neutral skill content and cannot override GOAL.md or Stardog.";
    usf:layoutRoleDeploymentBoundary "Agent-product compatibility boundary; not application runtime.".
