    usf:canonicalName "repositoryexternalartefactmaterialisationlifecycle";
    usf:facetKind facet:lifecycle;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "Proof-blocked, eligible, active, superseded and retired materialisation states remain distinct.".
