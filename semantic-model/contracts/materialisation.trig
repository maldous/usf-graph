naming:repositorysemanticpurpose a usf:NamingRule;
    usf:canonicalName "repositorysemanticpurpose";
    usf:filenamePattern "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*(?:.[a-z0-9]+)+$".
