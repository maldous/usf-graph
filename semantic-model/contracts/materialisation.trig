    usf:canonicalName "standalonesemanticgraph".
<urn:usf:feature:repositorymaterialisation> a usf:Feature;
    usf:canonicalName "repositorymaterialisation".
<urn:usf:feature:externalpayloadverification> a usf:Feature;
