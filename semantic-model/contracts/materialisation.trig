<urn:usf:feature:transactionalmodelupdate> a usf:Feature;
    usf:canonicalName "transactionalmodelupdate".
<urn:usf:semanticcontract:repositoryexternalartefactmaterialisation> a usf:SemanticContract;
    usf:canonicalName "repositoryexternalartefactmaterialisation";
    usf:requiresRealisationOptionEvaluation true;
    usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:active>;
    usf:hasActivationState <urn:usf:contractactivationstate:active>;
    usf:activationReason "Current authority-bound evidence proves the fail-closed planner, validator and transactional apply control plane against the accepted independent layout decision; activation authorises exact validated materialisation plans but does not establish final repository, environment or suite readiness.";
    usf:mandatoryProofObligation <urn:usf:proofobligation:repositoryexternalartefactmaterialisation>;
    usf:reliesOnProofResult <urn:usf:proofresult:repositorymaterialisationcontrolplane>;
    usf:asserts <urn:usf:claim:standalonesemanticgraphrepository>, <urn:usf:claim:semanticcontrolpayloadseparation>, <urn:usf:claim:authorityboundmaterialisation>, <urn:usf:claim:deterministicmaterialisation>, <urn:usf:claim:boundedagentconsumption>, <urn:usf:claim:transactionalsemanticmodelevolution>;
    usf:disclaims <urn:usf:nonclaim:externalpayloadissemanticauthority>, <urn:usf:nonclaim:projectionissemanticauthority>, <urn:usf:nonclaim:externalworkrecordisnotauthority>, <urn:usf:nonclaim:runtimeresultsbelongingit>, <urn:usf:nonclaim:parentrepositorydependency>, <urn:usf:nonclaim:materialisationcontrolplaneproofisfinalsuitereadiness>;
    usf:warrantsFeature <urn:usf:feature:standalonesemanticgraph>, <urn:usf:feature:repositorymaterialisation>, <urn:usf:feature:externalpayloadverification>, <urn:usf:feature:transactionalmodelupdate>;
    usf:permittedRealisationType usf:Implementation;
    usf:requiredValidation <urn:usf:validationobligation:repositoryexternalartefactmaterialisation>;
    usf:declaresFacet cf:repositoryexternalartefactmaterialisationlifecycle, cf:repositoryexternalartefactmaterialisationstatemodel, cf:repositoryexternalartefactmaterialisationpermissions, cf:repositoryexternalartefactmaterialisationcontracts, cf:repositoryexternalartefactmaterialisationvalidation, cf:repositoryexternalartefactmaterialisationerrormodel, cf:repositoryexternalartefactmaterialisationauditmodel, cf:repositoryexternalartefactmaterialisationreadinessmodel, cf:repositoryexternalartefactmaterialisationproof, cf:repositoryexternalartefactmaterialisationuisemantics;
    usf:contractConstraint "Validated live Stardog state is the sole semantic control plane; every repository or external representation only materialises an authorised decision and never becomes semantic authority.", "This standalone repository owns all source, configuration, semantic definitions, credentials boundaries, agent directives, proof mechanisms and tests required for its operation and has no parent or original-source repository dependency.", "The compiler may update registered Stardog named graphs only in a validated transaction and must roll back all targeted graphs on any parse, SHACL, integrity, derivation, contamination or publication failure.", "Only a coordinator may mutate semantic authority; workers and ordinary agents receive bounded digest-bound projections and query current authority before acting.", "Every AI-agent realisation or validation packet contains semantic identifiers, the current authority digest, contract state, objective, claims, nonclaims, authorised actions, paths and formats, acceptance obligations, validation obligations, result requirements and fail-closed stop conditions; missing or stale fields prohibit action.", "Materialisation plans remain bounded: write bytes are either inline or referenced from the configured operator-local CAS by a locator whose digest equals the exact operation content digest; remote and unverified plan content is forbidden.", "Agent packets are at most 65536 canonical JSON bytes and 256 items, contain no credentials or unbounded evidence payloads, and are regenerated whenever their authority digest no longer matches live Stardog state.", "No tracked path, format, storage class, directory or realisation may be created before an active contract and accepted decision authorise it.", "Repository automation is Git-tracked only when current layout authority gives it one semantic home and exact digest; no external platform convention establishes that home.", "Historical source-equivalence payloads are provenance-only, have explicit sunset state, and cannot authorise target semantics, architecture, naming or clean-clone inputs.", "External payloads are immutable and content-addressed; their small digest, media type, byte size, artifact type and locator envelopes remain in Stardog.", "The default external payload store is an operator-local content-addressed store outside Git; selecting any managed, paid or remote backend requires a separate accepted decision and proof.", "Runtime evidence, proof output, validation output, logs, screenshots, binaries, archives, database state and generated caches are not Git source unless an active contract explicitly requires an exact tracked representation.", "Only current stable representation editions independently selected by an accepted decision may be active; drafts and superseded editions remain historical only.", "Repository-local ordinals are permitted only where the naming standard defines a stable authored governance or schema-change sequence; ordinals are never reused, renumbered or derived from an external tracker, while content-addressed payloads use digests.", "No empty anticipated directory is created and no lifecycle or programme phase name establishes a permanent path.", "No embedded database, queue, cache or index technology is semantic authority; any selected runtime use requires an independently warranted realisation decision.".
