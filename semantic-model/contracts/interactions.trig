<urn:usf:workflowexecutionpolicy:durableworkflowapproval> a usf:WorkflowExecutionPolicy;
    usf:canonicalName "durableworkflowapproval";
    usf:policyConstrains wf:durableworkflowapproval;
    usf:maximumAttempts 5;
    usf:timeoutMilliseconds 86400000;
    usf:retryBehaviour "Persist before acknowledgement; retry transient delivery failures and dead-letter after the final attempt.";
