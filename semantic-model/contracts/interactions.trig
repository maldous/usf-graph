<urn:usf:workflowexecutionpolicy:authenticationidentitycontext> a usf:WorkflowExecutionPolicy;
    usf:canonicalName "authenticationidentitycontext";
    usf:policyConstrains wf:authenticationidentitycontext;
    usf:maximumAttempts 2;
    usf:timeoutMilliseconds 10000;
    usf:retryBehaviour "Retry only transient identity-directory failures; invalid identity, host or permission context is terminal.";
    usf:concurrencyBehaviour "Tenant and actor context are immutable for one request and cannot be client-overridden.";
    usf:scheduleBehaviour "Not time-triggered unless an explicit due instant is part of the workflow request; no hidden host scheduler is permitted.".
wf:authenticationidentitycontext usf:repositoryName "authenticationidentitycontext";
    usf:definition "Durable state-transition workflow owned by authentication platform.";
    usf:workflowForContract <urn:usf:semanticcontract:authenticationplatform>;
    usf:workflowExecutionPolicy <urn:usf:workflowexecutionpolicy:authenticationidentitycontext>;
    usf:crossesCapability cap:authenticationplatform.
<urn:usf:workflowexecutionpolicy:authenticationlogin> a usf:WorkflowExecutionPolicy;
    usf:canonicalName "authenticationlogin";
    usf:policyConstrains wf:authenticationlogin;
    usf:maximumAttempts 2;
    usf:timeoutMilliseconds 10000;
    usf:retryBehaviour "Retry only transient provider transport failure; invalid credentials and policy denials are terminal.";
    usf:concurrencyBehaviour "One login result per challenge identifier; replayed completed challenges are rejected.";
    usf:scheduleBehaviour "Not time-triggered unless an explicit due instant is part of the workflow request; no hidden host scheduler is permitted.".
wf:authenticationlogin usf:repositoryName "authenticationlogin";
