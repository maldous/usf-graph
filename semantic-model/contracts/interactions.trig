<urn:usf:workflowexecutionpolicy:bulkoperationlifecycle> a usf:WorkflowExecutionPolicy;
    usf:canonicalName "bulkoperationlifecycle";
    usf:policyConstrains wf:bulkoperationlifecycle;
    usf:maximumAttempts 3;
    usf:timeoutMilliseconds 300000;
    usf:retryBehaviour "Retry only transient provider failures with bounded exponential backoff; validation and authorisation failures are terminal.";
    usf:concurrencyBehaviour "One active operation per tenant and idempotency key; conflicting writes fail closed.";
    usf:scheduleBehaviour "Not time-triggered unless an explicit due instant is part of the workflow request; no hidden host scheduler is permitted.".
