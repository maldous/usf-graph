@prefix usf: <urn:usf:ontology:>.
@prefix aud: <urn:usf:auditevent:>.
@prefix sig: <urn:usf:observabilitysignal:>.
@prefix alr: <urn:usf:alert:>.
@prefix acat: <urn:usf:auditcategory:>.
@prefix asev: <urn:usf:auditseverity:>.
@prefix sigk: <urn:usf:signalkind:>.
@prefix op: <urn:usf:operation:>.

<urn:usf:graph:signals> {
alr:auditgap a usf:Alert;
    usf:canonicalName "auditgap";
    usf:triggeredBySignal sig:requesttrace.
alr:authfailurespike a usf:Alert;
    usf:canonicalName "authfailurespike";
    usf:triggeredBySignal sig:requesttrace.
alr:backupfailure a usf:Alert;
    usf:canonicalName "backupfailure";
    usf:triggeredBySignal sig:requesttrace.
alr:errorratehigh a usf:Alert;
    usf:canonicalName "errorratehigh";
    usf:triggeredBySignal sig:requesttrace.
alr:latencyhigh a usf:Alert;
    usf:canonicalName "latencyhigh";
    usf:triggeredBySignal sig:requesttrace.
alr:providerunavailable a usf:Alert;
    usf:canonicalName "providerunavailable";
    usf:triggeredBySignal sig:requesttrace.
alr:quotabreach a usf:Alert;
    usf:canonicalName "quotabreach";
    usf:triggeredBySignal sig:requesttrace.
alr:tenantisolationbreach a usf:Alert;
    usf:canonicalName "tenantisolationbreach";
    usf:triggeredBySignal sig:requesttrace.
aud:apikeycreation a usf:AuditEvent;
    usf:canonicalName "apikeycreation";
    usf:recordsOperation op:apikeycreate;
    usf:auditCategory acat:security;
    usf:auditSeverity asev:high.
aud:authenticationloginattempt a usf:AuditEvent;
    usf:canonicalName "authenticationloginattempt";
    usf:recordsOperation op:authloginpost;
    usf:auditCategory acat:authentication;
    usf:auditSeverity asev:info.
aud:fileupload a usf:AuditEvent;
    usf:canonicalName "fileupload";
    usf:recordsOperation op:filesupload;
    usf:auditCategory acat:file;
    usf:auditSeverity asev:notice.
aud:jobcancellation a usf:AuditEvent;
    usf:canonicalName "jobcancellation";
    usf:recordsOperation op:jobscancel;
    usf:auditCategory acat:job;
    usf:auditSeverity asev:notice.
aud:jobcreation a usf:AuditEvent;
    usf:canonicalName "jobcreation";
    usf:recordsOperation op:jobscreate;
    usf:auditCategory acat:job;
    usf:auditSeverity asev:notice.
aud:notificationcancellation a usf:AuditEvent;
    usf:canonicalName "notificationcancellation";
    usf:recordsOperation op:notificationscancel;
    usf:auditCategory acat:notification;
    usf:auditSeverity asev:notice.
aud:notificationcreation a usf:AuditEvent;
    usf:canonicalName "notificationcreation";
    usf:recordsOperation op:notificationscreate;
    usf:auditCategory acat:notification;
    usf:auditSeverity asev:notice.
aud:notificationdispatch a usf:AuditEvent;
    usf:canonicalName "notificationdispatch";
    usf:recordsOperation op:notificationssend;
    usf:auditCategory acat:notification;
    usf:auditSeverity asev:notice.
aud:notificationtemplatecreation a usf:AuditEvent;
    usf:canonicalName "notificationtemplatecreation";
    usf:recordsOperation op:notificationtemplatescreate;
    usf:auditCategory acat:notification;
    usf:auditSeverity asev:notice.
op:apikeycreate usf:emitsSignal sig:requesttrace, sig:auditcorrelation.
op:authloginpost usf:emitsSignal sig:authloginaudit, sig:authloginduration, sig:requesttrace, sig:auditcorrelation.
op:filesupload usf:emitsSignal sig:requesttrace, sig:auditcorrelation.
op:jobscancel usf:emitsSignal sig:requesttrace, sig:auditcorrelation.
op:jobscreate usf:emitsSignal sig:requesttrace, sig:auditcorrelation.
op:notificationscancel usf:emitsSignal sig:requesttrace, sig:auditcorrelation.
op:notificationscreate usf:emitsSignal sig:requesttrace, sig:auditcorrelation.
op:notificationssend usf:emitsSignal sig:requesttrace, sig:auditcorrelation.
op:notificationtemplatescreate usf:emitsSignal sig:requesttrace, sig:auditcorrelation.
sig:auditcorrelation a usf:ObservabilitySignal;
    usf:canonicalName "auditcorrelation";
    usf:signalKind sigk:correlationidentifier;
    usf:correlatesWith aud:apikeycreation, aud:authenticationloginattempt, aud:fileupload, aud:jobcancellation, aud:jobcreation, aud:notificationcancellation, aud:notificationcreation, aud:notificationdispatch, aud:notificationtemplatecreation.
sig:authloginaudit a usf:ObservabilitySignal;
    usf:canonicalName "authloginaudit";
    usf:signalKind sigk:log.
sig:authloginduration a usf:ObservabilitySignal;
    usf:canonicalName "authloginduration";
    usf:signalKind sigk:metric.
sig:requesttrace a usf:ObservabilitySignal;
    usf:canonicalName "requesttrace";
    usf:signalKind sigk:trace.
sig:runtimeproofoutput a usf:ObservabilitySignal;
    usf:canonicalName "runtimeproofoutput";
    usf:signalKind sigk:runtimeproofoutput.
sig:serviceresourceidentity a usf:ObservabilitySignal;
    usf:canonicalName "serviceresourceidentity";
    usf:signalKind sigk:serviceresourceattribute
}
