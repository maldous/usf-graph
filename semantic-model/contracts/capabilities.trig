    usf:intentionallyStandalone true;
    usf:decisionRationale "Repository assurance capability executed by the repository-local semantic compiler against live Stardog authority; it is not product runtime and does not warrant an artificial deployable service.";
    usf:inDomain dom:foundation;
    usf:uiExposure <urn:usf:uiexposureclass:notexposed>;
