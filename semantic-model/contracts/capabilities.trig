<urn:usf:deployableprocess:apiingress> a usf:DeployableProcess;
    usf:canonicalName "apiingress";
    usf:repositoryName "api-ingress";
    usf:definition "Accepts authenticated commands and queries, enforces tenant, permission, rate and request boundaries, and exposes capability interfaces.";
    usf:processBoundaryClass <urn:usf:processboundaryclass:productruntime>;
    usf:processOwnsCapability cap:abacpolicydecisionpoint, cap:apikeyspersonalaccesstokens, cap:authenticationplatform, cap:customdomainsdnsownershiptlscanonical, cap:delegatedadministrationroles, cap:entitlementengine, cap:historyreadmodelreadonlyprojection, cap:internalservicecatalogandreadiness, cap:objectstorageandtenantprefixesandsignedurls, cap:productcatalogplansprices, cap:quotaenforcement, cap:ratelimitingapi, cap:rbacrolesandpermissions, cap:searchandindexingproductsearch, cap:suborganisations, cap:subscriptionsinvoicespaymentmethodsdunning, cap:tenantcanonicaldomainsetunset, cap:tenantdomainactivationauthclient, cap:tenantgroups, cap:tenanthostidentityresolution, cap:tenantidentityrecordandfqdn, cap:tenantlifecycleprovisionsuspenddeleteexport, cap:useridentityandtenantmembership;
    usf:processForCapability cap:abacpolicydecisionpoint, cap:apikeyspersonalaccesstokens, cap:authenticationplatform, cap:customdomainsdnsownershiptlscanonical, cap:delegatedadministrationroles, cap:enduserprofileandpreferencesselfservice, cap:entitlementengine, cap:historyreadmodelreadonlyprojection, cap:internalservicecatalogandreadiness, cap:notificationdeliveryandpreferencesandchannels, cap:objectstorageandtenantprefixesandsignedurls, cap:productcatalogplansprices, cap:quotaenforcement, cap:ratelimitingapi, cap:rbacrolesandpermissions, cap:relationalstorageandmigrationsandrls, cap:searchandindexingproductsearch, cap:suborganisations, cap:scheduledjobsbuiltinontheeventsubstrate, cap:subscriptionsinvoicespaymentmethodsdunning, cap:tenantcanonicaldomainsetunset, cap:tenantdataimportexport, cap:tenantdomainactivationauthclient, cap:tenantgroups, cap:tenanthostidentityresolution, cap:tenantidentityrecordandfqdn, cap:tenantlifecycleprovisionsuspenddeleteexport, cap:useridentityandtenantmembership;
    usf:processProvidesInterface <urn:usf:interface:abacpolicydecisionpointoperations>, <urn:usf:interface:apikeyspersonalaccesstokensoperations>, <urn:usf:interface:authenticationplatformoperations>, <urn:usf:interface:enduserprofileandpreferencesselfserviceoperations>, <urn:usf:interface:internalservicecatalogandreadinessoperations>, <urn:usf:interface:notificationdeliveryandpreferencesandchannelsoperations>, <urn:usf:interface:objectstorageandtenantprefixesandsignedurlsoperations>, <urn:usf:interface:rbacrolesandpermissionsoperations>, <urn:usf:interface:scheduledjobsbuiltinontheeventsubstrateoperations>, <urn:usf:interface:tenanthostidentityresolutionoperations>;
    usf:processInterfaceRequirement "Versioned authenticated HTTP command and query interfaces; every route names its owning contract and capability.";
    usf:processLifecycleRequirement "Starts through configuration validation and dependency initialisation, becomes ready only after mandatory checks, degrades explicitly, drains accepted work, and stops or fails without partial durable effects.";
    usf:processTenantSecuritySeparationRequirement "Every request, message, event, lease and state access carries an immutable resolved tenant context; cross-tenant access is denied and tested.";
    usf:processSupportsEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:staging>;
    usf:processSecurityBoundary "Least-privilege identity, explicit tenant context, deny-by-default authorisation, secret references only, and auditable privileged operations.";
    usf:processReadinessRequirement "Ready only after configuration validation, schema compatibility and every mandatory dependency health check; liveness never implies readiness.";
    usf:processResourceLimit "CPU, memory, request or work concurrency, queue depth and graceful-shutdown deadlines are explicit environment configuration and tested at their boundaries.".
