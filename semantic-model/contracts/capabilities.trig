sc:compilersemanticenforcement usf:declaresFacet cf:compilersemanticenforcementlifecycle, cf:compilersemanticenforcementstatemodel, cf:compilersemanticenforcementpermissions, cf:compilersemanticenforcementcontracts, cf:compilersemanticenforcementvalidation, cf:compilersemanticenforcementerrormodel, cf:compilersemanticenforcementauditmodel, cf:compilersemanticenforcementreadinessmodel, cf:compilersemanticenforcementproof, cf:compilersemanticenforcementuisemantics.
cf:compilersemanticenforcementlifecycle a usf:ContractFacet;
    usf:canonicalName "compilersemanticenforcementlifecycle";
    usf:facetKind facet:lifecycle;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "The contract is current only while the live authority, realisation decision and validation obligations agree; any bound digest drift blocks publication and invalidates dependent projections.".
cf:compilersemanticenforcementstatemodel a usf:ContractFacet;
    usf:canonicalName "compilersemanticenforcementstatemodel";
    usf:facetKind facet:statemodel;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "Compilation moves atomically through load, authored validation, observation, derivation, derived validation, integrity, contamination, count verification and commit; every failure transitions to verified rollback.".
cf:compilersemanticenforcementpermissions a usf:ContractFacet;
    usf:canonicalName "compilersemanticenforcementpermissions";
    usf:facetKind facet:permissions;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "Read-only workers may query bounded authority; only the coordinator may open the controlled Stardog mutation transaction, and no path may bypass validation or rollback.".
cf:compilersemanticenforcementcontracts a usf:ContractFacet;
    usf:canonicalName "compilersemanticenforcementcontracts";
    usf:facetKind facet:contracts;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "Inputs are the registered repository-local semantic sources and exact current authority witness; outputs are deterministic projections and a transaction result bound to their digests.".
cf:compilersemanticenforcementvalidation a usf:ContractFacet;
    usf:canonicalName "compilersemanticenforcementvalidation";
    usf:facetKind facet:validation;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "Local syntax and focused constraints precede exact candidate validation in Stardog; publication requires authored, observed and derived conformance plus integrity, contamination and count gates.".
cf:compilersemanticenforcementerrormodel a usf:ContractFacet;
    usf:canonicalName "compilersemanticenforcementerrormodel";
    usf:facetKind facet:errormodel;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "Invalid input, authority drift, transport failure, SHACL failure, derivation failure, integrity failure and ambiguous transaction closure fail closed with stable phase context and no secret-bearing response body.".
cf:compilersemanticenforcementauditmodel a usf:ContractFacet;
    usf:canonicalName "compilersemanticenforcementauditmodel";
    usf:facetKind facet:auditmodel;
    usf:facetStatus <urn:usf:facetstatus:complete>;
