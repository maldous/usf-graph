cf:compilersemanticenforcementreadinessmodel a usf:ContractFacet;
    usf:canonicalName "compilersemanticenforcementreadinessmodel";
    usf:facetKind facet:readinessmodel;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "The compiler is ready only when current authority is reachable, registered inputs are locally valid, the controlled transaction boundary is available and rollback can be verified.".
cf:compilersemanticenforcementproof a usf:ContractFacet;
    usf:canonicalName "compilersemanticenforcementproof";
    usf:facetKind facet:proof;
    usf:facetStatus <urn:usf:facetstatus:complete>;
    usf:facetStatement "Proof binds the current authority digest, compiler source digest, registered configuration, actual Stardog candidate transaction, generated projections and validation result; historical source or reference artefacts cannot satisfy it.".
cf:compilersemanticenforcementuisemantics a usf:ContractFacet;
