    usf:definition "Compiles, validates, proves and transactionally publishes semantic authority while keeping runtime implementation and evidence scopes explicit.";
    usf:processBoundaryClass <urn:usf:processboundaryclass:assurancecontrolplane>;
    usf:processOwnsCapability cap:codequalityandsecretanddependencyscanning, cap:deterministicdevelopmentandtestsubstitutes, cap:e2econfidenceladderstageaware, cap:openapidrifthardgate, cap:repositoryexternalartefactmaterialisation, cap:semanticmodelcompilation, cap:tenantisolationproof, cap:universalservicefoundationscopeandprinciples;
    usf:processForCapability cap:codequalityandsecretanddependencyscanning, cap:deterministicdevelopmentandtestsubstitutes, cap:e2econfidenceladderstageaware, cap:openapidrifthardgate, cap:repositoryexternalartefactmaterialisation, cap:semanticmodelcompilation, cap:tenantisolationproof, cap:universalservicefoundationscopeandprinciples;
    usf:processProvidesInterface <urn:usf:interface:openapidrifthardgateoperations>;
    usf:processInterfaceRequirement "Repository-local command and Stardog-gateway interface for validation, proof and controlled publication; it is not a product service.";
    usf:processLifecycleRequirement "Starts through configuration validation and dependency initialisation, becomes ready only after mandatory checks, degrades explicitly, drains accepted work, and stops or fails without partial durable effects.";
    usf:processTenantSecuritySeparationRequirement "No product tenant data, host cache or product runtime credential is an implicit assurance input; inspected payloads are digest-bound and minimally disclosed.";
    usf:processSupportsEnvironment <urn:usf:environment:localdev>, <urn:usf:environment:integrationtest>, <urn:usf:environment:staging>;
    usf:processSecurityBoundary "Least-privilege identity, explicit tenant context, deny-by-default authorisation, secret references only, and auditable privileged operations.";
    usf:processReadinessRequirement "Ready only after configuration validation, schema compatibility and every mandatory dependency health check; liveness never implies readiness.";
    usf:processResourceLimit "CPU, memory, request or work concurrency, queue depth and graceful-shutdown deadlines are explicit environment configuration and tested at their boundaries."
}
