@prefix usf: <urn:usf:ontology:>.
@prefix gcl: <urn:usf:graphclass:>.
@prefix ng: <urn:usf:namedgraph:>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

<urn:usf:authority:validatedsemanticstate> a usf:SemanticAuthority;
    usf:canonicalName "validatedsemanticstate";
    usf:soleSemanticAuthority true;
    usf:validatedInStardog true;
    usf:defaultReasoningSchemaGraph ng:ontology, ng:taxonomy;
    usf:authorityVerificationState "validator-and-shacl-conformant".
gcl:definitiongraph usf:mayDeclareTerms true;
    usf:mayAssertInstances true;
    usf:authoritative false;
    usf:loadedAsAuthority true;
    usf:mayReference gcl:definitiongraph.
gcl:authoredgraph usf:mayDeclareTerms false;
    usf:mayAssertInstances true;
    usf:authoritative false;
    usf:loadedAsAuthority true;
    usf:mayReference gcl:definitiongraph, gcl:authoredgraph.
gcl:shapegraph usf:mayDeclareTerms false;
    usf:mayAssertInstances false;
    usf:authoritative false;
    usf:loadedAsAuthority true;
    usf:mayConstrain gcl:definitiongraph, gcl:authoredgraph, gcl:derivedgraph;
    usf:mayReference gcl:definitiongraph, gcl:authoredgraph, gcl:derivedgraph.
gcl:rulegraph usf:mayDeclareTerms false;
    usf:mayAssertInstances false;
    usf:authoritative false;
    usf:loadedAsAuthority true;
    usf:mayDerive gcl:derivedgraph;
    usf:mayReference gcl:definitiongraph, gcl:authoredgraph, gcl:derivedgraph.
gcl:derivedgraph usf:mayDeclareTerms false;
    usf:mayAssertInstances true;
    usf:authoritative false;
    usf:loadedAsAuthority true;
    usf:mayReference gcl:definitiongraph, gcl:authoredgraph, gcl:derivedgraph.
gcl:fixturegraph usf:mayDeclareTerms false;
    usf:mayAssertInstances true;
    usf:authoritative false;
    usf:loadedAsAuthority false;
    usf:mayReference gcl:definitiongraph.
gcl:observedgraph usf:mayDeclareTerms false;
    usf:mayAssertInstances true;
    usf:authoritative false;
    usf:loadedAsAuthority false;
    usf:loadedForValidation true;
    usf:loadedForDerivation true;
    usf:mayReference gcl:definitiongraph, gcl:authoredgraph, gcl:observedgraph.
gcl:shapegraph usf:mayConstrain gcl:observedgraph;
    usf:mayReference gcl:observedgraph.
gcl:rulegraph usf:mayReference gcl:observedgraph.
gcl:derivedgraph usf:mayReference gcl:observedgraph.
