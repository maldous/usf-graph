@prefix usf: <urn:usf:ontology:>.
@prefix tax: <urn:usf:taxonomy:>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

usf:SemanticFamily a owl:Class;
    rdfs:subClassOf usf:ControlledValue;
    rdfs:label "SemanticFamily";
    rdfs:comment "A top-level grouping of ontology classes into one coherent concern.".
usf:classifiedAs a owl:ObjectProperty;
    rdfs:range usf:SemanticFamily;
    rdfs:label "classifiedAs";
    rdfs:comment "Classifies an ontology class under one semantic family.".
tax:contract a usf:SemanticFamily;
    usf:canonicalName "contract".
tax:interaction a usf:SemanticFamily;
    usf:canonicalName "interaction".
tax:platform a usf:SemanticFamily;
    usf:canonicalName "platform".
tax:experience a usf:SemanticFamily;
    usf:canonicalName "experience".
tax:assurance a usf:SemanticFamily;
    usf:canonicalName "assurance".
tax:realisation a usf:SemanticFamily;
    usf:canonicalName "realisation".
tax:execution a usf:SemanticFamily;
    usf:canonicalName "execution".
tax:derivation a usf:SemanticFamily;
    usf:canonicalName "derivation".
tax:authority a usf:SemanticFamily;
    usf:canonicalName "authority".
