@prefix usf: <urn:usf:ontology:>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix shp: <urn:usf:shacl:>.

shp:ProofObligationShape a sh:NodeShape;
    usf:canonicalName "proofobligationshape";
    sh:targetClass usf:ProofObligation.
_:b34_b34_n3-329 sh:path usf:obligationFor;
    sh:minCount 1;
    sh:message "obligationsubject: proof obligation must name what it is for".
shp:ProofObligationShape sh:property _:b34_b34_n3-329.
_:b34_b34_n3-330 sh:path usf:requiresRung;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:ProofRung;
    sh:message "obligationrung: proof obligation must require one minimum rung".
shp:ProofObligationShape sh:property _:b34_b34_n3-330.
_:b34_b34_n3-331 sh:path usf:derivedFrom;
    sh:minCount 1;
    sh:message "derivedprovenance: derived entity must record its authored source".
shp:ProofObligationShape sh:property _:b34_b34_n3-331.
shp:TestObligationShape a sh:NodeShape;
    usf:canonicalName "testobligationshape";
    sh:targetClass usf:TestObligation.
_:b34_b34_n3-332 sh:path usf:obligationFor;
    sh:minCount 1;
    sh:message "obligationsubject: test obligation must name what it is for".
shp:TestObligationShape sh:property _:b34_b34_n3-332.
_:b34_b34_n3-333 sh:path usf:derivedFrom;
    sh:minCount 1.
shp:TestObligationShape sh:property _:b34_b34_n3-333.
shp:EvidenceRequirementShape a sh:NodeShape;
    usf:canonicalName "evidencerequirementshape";
    sh:targetClass usf:EvidenceRequirement.
_:b34_b34_n3-334 sh:path usf:requiresEvidenceKind;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:EvidenceKind.
shp:EvidenceRequirementShape sh:property _:b34_b34_n3-334.
_:b34_b34_n3-335 sh:path usf:requiresFreshness;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:Freshness.
shp:EvidenceRequirementShape sh:property _:b34_b34_n3-335.
_:b34_b34_n3-336 sh:path usf:derivedFrom;
    sh:minCount 1.
shp:EvidenceRequirementShape sh:property _:b34_b34_n3-336.
shp:SurfaceShape a sh:NodeShape;
    usf:canonicalName "surfaceshape";
    sh:targetClass usf:DerivedSurface.
_:b34_b34_n3-337 sh:path usf:surfaceOf;
    sh:minCount 1;
    sh:message "surfacesubject: surface must name what it surfaces".
shp:SurfaceShape sh:property _:b34_b34_n3-337.
_:b34_b34_n3-338 sh:path usf:derivedFrom;
    sh:minCount 1.
shp:SurfaceShape sh:property _:b34_b34_n3-338.
shp:CoverageShape a sh:NodeShape;
    usf:canonicalName "coverageshape";
    sh:targetClass usf:Coverage.
_:b34_b34_n3-339 sh:path usf:coverageOf;
    sh:minCount 1.
shp:CoverageShape sh:property _:b34_b34_n3-339.
_:b34_b34_n3-340 sh:path usf:coverageState;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:CoverageState.
shp:CoverageShape sh:property _:b34_b34_n3-340.
_:b34_b34_n3-341 sh:path usf:derivedFrom;
    sh:minCount 1.
shp:CoverageShape sh:property _:b34_b34_n3-341.
shp:ReadinessShape a sh:NodeShape;
    usf:canonicalName "readinessshape";
    sh:targetClass usf:Readiness.
_:b34_b34_n3-342 sh:path usf:readinessOf;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:Capability;
    sh:message "readinesssubject: readiness must be of exactly one capability".
shp:ReadinessShape sh:property _:b34_b34_n3-342.
_:b34_b34_n3-343 sh:path usf:readinessState;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:ReadinessState.
shp:ReadinessShape sh:property _:b34_b34_n3-343.
_:b34_b34_n3-344 sh:path usf:readinessRung;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:ProofRung.
shp:ReadinessShape sh:property _:b34_b34_n3-344.
_:b34_b34_n3-345 sh:path usf:derivedFrom;
    sh:minCount 1;
    sh:message "derivedprovenance: readiness must record the authored state it was derived from".
shp:ReadinessShape sh:property _:b34_b34_n3-345.
shp:EvidenceSatisfactionShape a sh:NodeShape;
    usf:canonicalName "evidencesatisfactionshape";
    sh:targetClass usf:EvidenceResult.
_:b34_b34_n3-346 sh:message "providermismatch: evidence provider mode is not permitted by the requirement it satisfies";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n            $this usf:satisfies ?req .\n            $this usf:usesProviderMode ?pm .\n            ?req usf:requiresProviderMode ?need .\n            FILTER NOT EXISTS { $this usf:usesProviderMode ?need }\n            FILTER(?pm != ?need)\n        }".
shp:EvidenceSatisfactionShape sh:sparql _:b34_b34_n3-346.
_:b34_b34_n3-347 sh:message "staleevidence: stale evidence cannot satisfy a requirement that requires fresh evidence";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n            $this usf:satisfies ?req .\n            $this usf:hasFreshness ?f . ?f usf:canonicalName \"stale\" .\n            ?req usf:requiresFreshness ?rf . ?rf usf:canonicalName \"fresh\" .\n        }".
shp:EvidenceSatisfactionShape sh:sparql _:b34_b34_n3-347.
