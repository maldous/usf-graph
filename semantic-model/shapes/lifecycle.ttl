@prefix usf: <urn:usf:ontology:>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix admission: <urn:usf:evidenceadmissionstate:>.
@prefix freshnessstate: <urn:usf:evidencefreshnessstate:>.
@prefix integritystate: <urn:usf:evidenceintegritystate:>.
@prefix proofstate: <urn:usf:proofresultstate:>.
@prefix contractstate: <urn:usf:contractactivationstate:>.

<urn:usf:shape:proofobligationevidence> a sh:NodeShape;
    sh:targetClass usf:ProofObligation.
_:b38_b38_n3-556 sh:path usf:requiresEvidence;
    sh:minCount 1;
    sh:class usf:EvidenceRequirement.
<urn:usf:shape:proofobligationevidence> sh:property _:b38_b38_n3-556.
<urn:usf:shape:successfulproofresult> a sh:NodeShape;
    sh:targetClass usf:ProofResult.
_:b38_b38_n3-557 sh:message "Successful proof requires exact admitted fresh integrity-valid applicable evidence, a complete non-circular evidence pipeline, and evaluation metadata.";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nPREFIX admission: <urn:usf:evidenceadmissionstate:>\nPREFIX freshnessstate: <urn:usf:evidencefreshnessstate:>\nPREFIX integritystate: <urn:usf:evidenceintegritystate:>\nPREFIX proofstate: <urn:usf:proofresultstate:>\nPREFIX resultstate: <urn:usf:resultstate:>\nPREFIX es: <urn:usf:evidencestage:>\nSELECT $this WHERE { $this usf:hasProofResultState proofstate:successful . FILTER (NOT EXISTS {$this usf:proofResultForObligation ?o} || NOT EXISTS {$this usf:usesAdmittedEvidence ?e} || NOT EXISTS {$this usf:evidenceSetDigest ?d} || NOT EXISTS {$this usf:usesProofAlgorithm ?a} || NOT EXISTS {$this usf:usesAlgorithmVersion ?v} || NOT EXISTS {$this usf:evaluatedByValidator ?validator} || NOT EXISTS {$this usf:proofExecutionEnvironment ?env} || NOT EXISTS {$this usf:hasConfidenceState ?c} || NOT EXISTS {$this usf:evaluatedAt ?t} || NOT EXISTS {$this usf:hasInvalidationCondition ?i} || EXISTS {$this usf:proofResultForObligation ?o ; usf:usesAdmittedEvidence ?e . FILTER (NOT EXISTS {?e usf:hasAdmissionState admission:admitted ; usf:hasFreshnessState freshnessstate:fresh ; usf:hasIntegrityState integritystate:valid ; usf:applicableToObligation ?o ; usf:withinValidityScope true} || NOT EXISTS {?e usf:evidenceStage es:emitted, es:collected, es:normalised, es:ingested, es:signed, es:integrityverified ; usf:collectedBy ?collection ; usf:normalisedBy ?normalisation ; usf:ingestedBy ?ingestion ; usf:evidenceSignature ?signature ; usf:evidenceChecksum ?checksum ; usf:integrityVerification ?verification . ?collection a usf:EvidenceCollection . ?normalisation a usf:EvidenceNormalisation . ?ingestion a usf:EvidenceIngestion . ?signature a usf:Signature . ?checksum a usf:Checksum . ?verification a usf:IntegrityVerification ; usf:verifiesEvidence ?e ; usf:verificationState resultstate:passed .})}) }".
<urn:usf:shape:successfulproofresult> sh:sparql _:b38_b38_n3-557.
<urn:usf:shape:evidenceboundconfidence> a sh:NodeShape;
    sh:targetSubjectsOf usf:hasConfidenceState.
_:b38_b38_n3-558 sh:message "Confidence requires successful evidence-bound proof.";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nPREFIX admission: <urn:usf:evidenceadmissionstate:>\nPREFIX freshnessstate: <urn:usf:evidencefreshnessstate:>\nPREFIX integritystate: <urn:usf:evidenceintegritystate:>\nPREFIX proofstate: <urn:usf:proofresultstate:>\nPREFIX contractstate: <urn:usf:contractactivationstate:>\nSELECT $this WHERE { FILTER NOT EXISTS {$this a usf:ProofResult ; usf:hasProofResultState proofstate:successful ; usf:usesAdmittedEvidence ?e ; usf:confidenceBasis ?e} }".
<urn:usf:shape:evidenceboundconfidence> sh:sparql _:b38_b38_n3-558.
<urn:usf:shape:activecontractproof> a sh:NodeShape;
    sh:targetClass usf:SemanticContract.
_:b38_b38_n3-559 sh:message "Active contracts require current successful proof for every mandatory obligation.";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nPREFIX admission: <urn:usf:evidenceadmissionstate:>\nPREFIX freshnessstate: <urn:usf:evidencefreshnessstate:>\nPREFIX integritystate: <urn:usf:evidenceintegritystate:>\nPREFIX proofstate: <urn:usf:proofresultstate:>\nPREFIX contractstate: <urn:usf:contractactivationstate:>\nSELECT $this WHERE { $this usf:hasActivationState contractstate:active . FILTER (NOT EXISTS {$this usf:mandatoryProofObligation ?o} || EXISTS {$this usf:mandatoryProofObligation ?o . FILTER NOT EXISTS {$this usf:reliesOnProofResult ?r . ?r usf:proofResultForObligation ?o ; usf:hasProofResultState proofstate:successful ; usf:usesAdmittedEvidence ?e ; usf:confidenceBasis ?e . ?e usf:hasAdmissionState admission:admitted ; usf:hasFreshnessState freshnessstate:fresh ; usf:hasIntegrityState integritystate:valid}}) }".
<urn:usf:shape:activecontractproof> sh:sparql _:b38_b38_n3-559.
<urn:usf:shape:implementablestatedefinition> a sh:NodeShape;
    sh:targetNode <urn:usf:realisationstate:implementable>.
_:b38_b38_n3-560 sh:path usf:canonicalName;
    sh:hasValue "implementable".
<urn:usf:shape:implementablestatedefinition> sh:property _:b38_b38_n3-560.
_:b38_b38_n3-561 sh:path usf:allowsRealisationPredecessor.
<urn:usf:shape:implementablestatedefinition> sh:property _:b38_b38_n3-561.
_:b38_b38_n3-562 sh:path usf:allowsRealisationSuccessor;
    sh:minCount 1;
    sh:class usf:RealisationState.
<urn:usf:shape:implementablestatedefinition> sh:property _:b38_b38_n3-562.
_:b38_b38_n3-563 sh:path usf:requiresContractActivationState;
    sh:hasValue contractstate:active.
<urn:usf:shape:implementablestatedefinition> sh:property _:b38_b38_n3-563.
_:b38_b38_n3-564 sh:path usf:requiresDecisionState;
    sh:hasValue <urn:usf:decisionstate:accepted>.
<urn:usf:shape:implementablestatedefinition> sh:property _:b38_b38_n3-564.
_:b38_b38_n3-565 sh:path usf:requiresRealisationType;
    sh:hasValue usf:Implementation.
<urn:usf:shape:implementablestatedefinition> sh:property _:b38_b38_n3-565.
_:b38_b38_n3-566 sh:path usf:requiresAuthorisedSourcePath;
    sh:hasValue true .
<urn:usf:shape:implementablestatedefinition> sh:property _:b38_b38_n3-566.
_:b38_b38_n3-567 sh:path usf:requiresExistingImplementation;
    sh:hasValue false .
<urn:usf:shape:implementablestatedefinition> sh:property _:b38_b38_n3-567.
<urn:usf:shape:implementablerealisation> a sh:NodeShape;
    sh:targetNode <urn:usf:ontology>.
_:b38_b38_n3-568 sh:message "Implementable realisation requires an active evidence-backed contract, successful proof, accepted decision, authorised implementation type and an exactly authorised path.";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nPREFIX admission: <urn:usf:evidenceadmissionstate:>\nPREFIX freshnessstate: <urn:usf:evidencefreshnessstate:>\nPREFIX integritystate: <urn:usf:evidenceintegritystate:>\nPREFIX proofstate: <urn:usf:proofresultstate:>\nPREFIX contractstate: <urn:usf:contractactivationstate:>\nSELECT $this WHERE {\n  FILTER EXISTS {\n    ?realisation a usf:Realisation ; usf:realisationState <urn:usf:realisationstate:implementable> ; usf:realisesContract ?c .\n    FILTER NOT EXISTS {\n        ?c usf:hasActivationState contractstate:active ; usf:mandatoryProofObligation ?ob ;\n           usf:reliesOnProofResult ?pr ; usf:permittedRealisationType ?type .\n        ?pr usf:proofResultForObligation ?ob ; usf:hasProofResultState proofstate:successful ;\n            usf:usesAdmittedEvidence ?e ; usf:confidenceBasis ?e .\n        ?e usf:hasAdmissionState admission:admitted ; usf:hasFreshnessState freshnessstate:fresh ;\n           usf:hasIntegrityState integritystate:valid ; usf:applicableToObligation ?ob ; usf:withinValidityScope true .\n        ?realisation usf:authorisedByDecision ?d ; usf:authorisedSourcePath ?path .\n        ?d usf:decisionState <urn:usf:decisionstate:accepted> ; usf:authorisesSourcePath ?path ;\n           usf:authorisesRealisationType ?type .\n    }\n  }\n}".
<urn:usf:shape:implementablerealisation> sh:sparql _:b38_b38_n3-568.
<urn:usf:shape:validationevidenceentry> a sh:NodeShape;
    sh:targetClass usf:ValidationResult.
_:b38_b38_n3-569 sh:path usf:entersEvidenceLifecycleAs;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:ValidationEvidence.
<urn:usf:shape:validationevidenceentry> sh:property _:b38_b38_n3-569.
<urn:usf:shape:proofalgorithmsource> a sh:NodeShape;
    sh:targetClass usf:ProofAlgorithm.
_:b38_b38_n3-570 sh:path usf:proofAlgorithmSourcePath;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string;
    sh:pattern "^assurance/[A-Za-z0-9._/-]+$".
<urn:usf:shape:proofalgorithmsource> sh:property _:b38_b38_n3-570.
_:b38_b38_n3-571 sh:path usf:proofAlgorithmSourceDigest;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string;
    sh:pattern "^sha256:[0-9a-f]{64}$".
<urn:usf:shape:proofalgorithmsource> sh:property _:b38_b38_n3-571.
<urn:usf:shape:proofalgorithmversionidentity> a sh:NodeShape;
    sh:targetClass usf:ProofAlgorithmVersion.
_:b38_b38_n3-572 sh:path usf:proofAlgorithmVersionOf;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:ProofAlgorithm.
<urn:usf:shape:proofalgorithmversionidentity> sh:property _:b38_b38_n3-572.
_:b38_b38_n3-573 sh:path usf:proofAlgorithmVersionIdentifier;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string;
    sh:pattern "^[0-9]+[.][0-9]+[.][0-9]+$".
<urn:usf:shape:proofalgorithmversionidentity> sh:property _:b38_b38_n3-573.
<urn:usf:shape:forbiddenshortcuts> a sh:NodeShape;
    sh:targetSubjectsOf usf:establishesSemanticTruth, usf:directlyActivatesContract, usf:directlyAdmitsEvidence, usf:directlyEstablishesProof.
_:b38_b38_n3-574 sh:message "ADR, external-work-record, report and test authority inversions are forbidden.";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nPREFIX admission: <urn:usf:evidenceadmissionstate:>\nPREFIX freshnessstate: <urn:usf:evidencefreshnessstate:>\nPREFIX integritystate: <urn:usf:evidenceintegritystate:>\nPREFIX proofstate: <urn:usf:proofresultstate:>\nPREFIX contractstate: <urn:usf:contractactivationstate:>\nSELECT $this WHERE { {$this a usf:ADRRecord ; usf:establishesSemanticTruth ?x} UNION {$this a usf:ExternalWorkRecord ; usf:directlyActivatesContract ?x} UNION {$this a usf:Report ; usf:directlyAdmitsEvidence ?x} UNION {$this a usf:Test ; usf:directlyEstablishesProof ?x} }".
<urn:usf:shape:forbiddenshortcuts> sh:sparql _:b38_b38_n3-574.
