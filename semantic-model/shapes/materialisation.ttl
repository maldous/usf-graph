    sh:message "layout-role-home: selected roles require unique canonical parent homes and exact decision path authority";
    sh:select "SELECT $this WHERE {\n      $this usf:selectsRepositoryLayoutRole ?role .\n      ?role usf:authorisedParentPath ?parent .\n      { FILTER NOT EXISTS { $this usf:authorisesSourcePath ?parent } }\n      UNION\n      { $this usf:selectsRepositoryLayoutRole ?other . ?other usf:authorisedParentPath ?parent . FILTER(?other != ?role) }\n    }".
