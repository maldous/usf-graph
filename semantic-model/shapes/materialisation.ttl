shp:AgentTaskPacketShape sh:property _:b39_b39_n3-638.
_:b39_b39_n3-639 sh:path usf:packetForContract;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:SemanticContract.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-639.
_:b39_b39_n3-640 sh:path usf:packetObjective;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string;
    sh:minLength 1.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-640.
_:b39_b39_n3-641 sh:path usf:packetClaim;
    sh:minCount 1;
    sh:class usf:Claim.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-641.
_:b39_b39_n3-642 sh:path usf:packetNonclaim;
    sh:minCount 1;
    sh:class usf:NonClaim.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-642.
_:b39_b39_n3-643 sh:path usf:packetAuthorisedAction;
