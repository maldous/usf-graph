_:b39_b39_n3-675 sh:prefixes usf:prefixes;
    sh:message "operation-move-source: move-path requires one distinct governed source path and its exact digest";
    sh:select "SELECT $this WHERE {\n      $this usf:operationAction \"move-path\" ; usf:operationPath ?destination .\n      FILTER(NOT EXISTS { $this usf:operationSourcePath ?source ; usf:operationSourceDigest ?digest . FILTER(?source != ?destination) })\n    }".
shp:MaterialisationOperationShape sh:sparql _:b39_b39_n3-675.
_:b39_b39_n3-676 sh:prefixes usf:prefixes;
    sh:message "operation-delete-source: delete-path requires the exact source digest";
    sh:select "SELECT $this WHERE {\n      $this usf:operationAction \"delete-path\" .\n      FILTER NOT EXISTS { $this usf:operationSourceDigest ?digest }\n    }".
shp:MaterialisationOperationShape sh:sparql _:b39_b39_n3-676.
_:b39_b39_n3-677 sh:prefixes usf:prefixes;
    sh:message "operation-write-metadata: write-file requires an exact content digest, artefact family and authorised representation";
    sh:select "SELECT $this WHERE {\n      $this usf:operationAction \"write-file\" .\n      FILTER(\n        NOT EXISTS { $this usf:operationContentDigest ?digest } ||\n        NOT EXISTS { $this usf:operationArtefactFamily ?family } ||\n        NOT EXISTS { $this usf:operationRepresentationFormat ?format } ||\n        NOT EXISTS {\n          $this usf:operationArtefactFamily ?family ; usf:operationRepresentationFormat ?format ; usf:operationPathRole ?role .\n          ?family usf:usesMaterialisationRule ?rule .\n          ?rule usf:usesRepresentationFormat ?format ; usf:usesPathRole ?role .\n        }\n      )\n    }".
shp:MaterialisationOperationShape sh:sparql _:b39_b39_n3-677.
_:b39_b39_n3-678 sh:prefixes usf:prefixes;
    sh:message "operation-write-locator: a CAS content locator must carry the exact operation digest";
    sh:select "SELECT $this WHERE {\n      $this usf:operationContentDigest ?digest ; usf:operationContentLocator ?locator .\n      FILTER(STR(?locator) != CONCAT(\"cas://sha256/\", STRAFTER(?digest, \"sha256:\")))\n    }".
shp:MaterialisationOperationShape sh:sparql _:b39_b39_n3-678.
_:b39_b39_n3-679 sh:prefixes usf:prefixes;
    sh:message "operation-authorised-parent: operation path must equal or descend from its authorised parent";
    sh:select "SELECT $this WHERE {\n      $this usf:operationPath ?path ; usf:operationPathRole ?role .\n      ?role usf:authorisedParentPath ?parent .\n      FILTER((?parent = '.' && CONTAINS(?path, '/')) ||\n             (?parent != '.' && ?path != ?parent && !STRSTARTS(?path, CONCAT(?parent, '/'))))\n    }".
shp:MaterialisationOperationShape sh:sparql _:b39_b39_n3-679.
_:b39_b39_n3-680 sh:prefixes usf:prefixes;
    sh:message "operation-portable-path: operation paths reject traversal, reserved names and forbidden canonical segments";
    sh:select "SELECT $this WHERE {\n      $this usf:operationPath ?path .\n      FILTER(REGEX(?path, '(^|/)(v2|legacy|old|new|temp|transitional|usf)(/|$)') &&\n             !STRSTARTS(?path, '.claude/skills/usf/') && !STRSTARTS(?path, '.codex/skills/usf/'))\n    }".
shp:MaterialisationOperationShape sh:sparql _:b39_b39_n3-680.
_:b39_b39_n3-681 sh:prefixes usf:prefixes;
    sh:message "operation-filename-rule: write filenames must satisfy their authorised family naming rule";
    sh:select "SELECT $this WHERE {\n      $this usf:operationAction \"write-file\" ; usf:operationPath ?path ; usf:operationArtefactFamily ?family .\n      ?family usf:usesMaterialisationRule ?rule . ?rule usf:usesNamingRule ?naming . ?naming usf:filenamePattern ?pattern .\n      BIND(REPLACE(?path, '^.*/', '') AS ?filename)\n      FILTER(!REGEX(?filename, ?pattern))\n    }".
shp:MaterialisationOperationShape sh:sparql _:b39_b39_n3-681.
_:b39_b39_n3-682 sh:prefixes usf:prefixes;
    sh:message "operation-current-layout-authority: historical or superseded resources cannot authorise materialisation";
    sh:select "SELECT $this WHERE {\n      {\n        { $this usf:operationPathRole ?resource }\n        UNION { $this usf:operationArtefactFamily ?resource }\n        UNION { $this usf:operationArtefactFamily/usf:usesMaterialisationRule ?resource }\n      }\n      FILTER EXISTS { ?resource usf:semanticAdequacyDisposition ?anyDisposition }\n      FILTER NOT EXISTS {\n        ?resource usf:semanticAdequacyDisposition <urn:usf:semanticadequacydisposition:independentlywarrantedretained>\n      }\n    }".
shp:MaterialisationOperationShape sh:sparql _:b39_b39_n3-682.
