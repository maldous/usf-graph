    sh:datatype xsd:string;
    sh:minLength 1.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-643.
_:b39_b39_n3-644 sh:path usf:packetAuthorisedPath;
    sh:datatype xsd:string;
    sh:minLength 1;
    sh:maxCount 256.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-644.
_:b39_b39_n3-645 sh:path usf:packetAuthorisedFormat;
    sh:class usf:RepresentationFormat;
    sh:maxCount 256.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-645.
_:b39_b39_n3-646 sh:path usf:packetAcceptanceObligation;
    sh:minCount 1;
    sh:class usf:Entity.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-646.
_:b39_b39_n3-647 sh:path usf:packetValidationObligation;
    sh:minCount 1;
    sh:class usf:ValidationObligation.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-647.
_:b39_b39_n3-648 sh:path usf:packetResultRequirement;
    sh:minCount 1;
    sh:datatype xsd:string;
    sh:minLength 1.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-648.
_:b39_b39_n3-649 sh:path usf:packetStopCondition;
    sh:minCount 1;
    sh:datatype xsd:string;
    sh:minLength 1.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-649.
_:b39_b39_n3-650 sh:path usf:packetMaximumBytes;
    sh:minCount 1;
    sh:maxCount 1;
    sh:minInclusive 1;
    sh:maxInclusive 65536.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-650.
_:b39_b39_n3-651 sh:path usf:packetMaximumItems;
    sh:minCount 1;
    sh:maxCount 1;
    sh:minInclusive 1;
    sh:maxInclusive 256.
shp:AgentTaskPacketShape sh:property _:b39_b39_n3-651.
_:b39_b39_n3-652 sh:prefixes usf:prefixes;
    sh:message "agent-packet-active-authority: an agent packet must project a currently active, evidence-backed contract";
    sh:select "SELECT $this WHERE {\n      $this usf:packetForContract ?contract .\n      FILTER NOT EXISTS {\n        ?contract usf:hasActivationState <urn:usf:contractactivationstate:active> ;\n                  usf:mandatoryProofObligation ?obligation ; usf:reliesOnProofResult ?result .\n        ?result usf:proofResultForObligation ?obligation ;\n                usf:hasProofResultState <urn:usf:proofresultstate:successful> .\n      }\n    }".
shp:AgentTaskPacketShape sh:sparql _:b39_b39_n3-652.
shp:MaterialisationPlanShape a sh:NodeShape;
    usf:canonicalName "materialisationplanshape";
    sh:targetClass usf:MaterialisationPlan.
_:b39_b39_n3-653 sh:path usf:planForContract;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:SemanticContract.
shp:MaterialisationPlanShape sh:property _:b39_b39_n3-653.
_:b39_b39_n3-654 sh:path usf:planAuthorityDigest;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string;
    sh:pattern "^sha256:[0-9a-f]{64}$".
shp:MaterialisationPlanShape sh:property _:b39_b39_n3-654.
_:b39_b39_n3-655 sh:path usf:hasMaterialisationOperation;
    sh:minCount 1;
    sh:maxCount 256;
    sh:class usf:MaterialisationOperation.
shp:MaterialisationPlanShape sh:property _:b39_b39_n3-655.
_:b39_b39_n3-656 sh:prefixes usf:prefixes;
    sh:message "plan-active-contract: a materialisation plan may only project an active evidence-backed contract";
    sh:select "SELECT $this WHERE {\n      $this usf:planForContract ?contract .\n      FILTER NOT EXISTS {\n        ?contract usf:hasActivationState <urn:usf:contractactivationstate:active> ;\n                  usf:mandatoryProofObligation ?obligation ; usf:reliesOnProofResult ?result .\n        ?result usf:proofResultForObligation ?obligation ;\n                usf:hasProofResultState <urn:usf:proofresultstate:successful> .\n      }\n    }".
shp:MaterialisationPlanShape sh:sparql _:b39_b39_n3-656.
_:b39_b39_n3-657 sh:prefixes usf:prefixes;
    sh:message "plan-operation-order: operation indexes are unique within a plan";
    sh:select "SELECT $this WHERE {\n      $this usf:hasMaterialisationOperation ?left, ?right .\n      ?left usf:operationIndex ?index . ?right usf:operationIndex ?index .\n      FILTER(?left != ?right)\n    }".
shp:MaterialisationPlanShape sh:sparql _:b39_b39_n3-657.
