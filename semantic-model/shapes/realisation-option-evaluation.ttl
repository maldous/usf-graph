@prefix usf: <urn:usf:ontology:>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix shp: <urn:usf:shacl:>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

shp:RealisationDecisionShape a sh:NodeShape;
    usf:canonicalName "realisationdecisionshape";
    sh:targetClass usf:RealisationDecision.
_:oe_decision_state sh:path usf:decisionState;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:DecisionState;
    sh:message "decisionstatecardinality: realisation decision must declare exactly one state".
shp:RealisationDecisionShape sh:property _:oe_decision_state.
_:oe_decision_contract sh:message "decisioncontractmissing: accepted realisation decision must identify exactly one governed contract";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> .\n  { FILTER NOT EXISTS { $this usf:decisionForContract ?contract . ?contract a usf:SemanticContract } }\n  UNION\n  { $this usf:decisionForContract ?contract . FILTER NOT EXISTS { ?contract a usf:SemanticContract } }\n  UNION\n  { $this usf:decisionForContract ?left, ?right . FILTER(?left != ?right) }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_decision_contract.
_:oe_decision_evaluation sh:message "decisionevaluationmissing: accepted realisation decision must identify exactly one structured evaluation";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> .\n  { FILTER NOT EXISTS { $this usf:hasDecisionEvaluation ?evaluation . ?evaluation a usf:DecisionEvaluation } }\n  UNION\n  { $this usf:hasDecisionEvaluation ?evaluation . FILTER NOT EXISTS { ?evaluation a usf:DecisionEvaluation } }\n  UNION\n  { $this usf:hasDecisionEvaluation ?left, ?right . FILTER(?left != ?right) }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_decision_evaluation.
_:oe_accepted_selection sh:message "accepteddecisionselectedoptioncardinality: accepted decision must identify exactly one selected option";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> .\n  { FILTER NOT EXISTS { $this usf:selectsOption ?selected } }\n  UNION\n  { $this usf:selectsOption ?left, ?right . FILTER(?left != ?right) }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_accepted_selection.
_:oe_selected_considered sh:message "selectedoptionoutsidecandidateset: selected option must be one of the decision's considered candidates";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption ?selected .\n  FILTER NOT EXISTS { $this usf:considersOption ?selected }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_selected_considered.
_:oe_accepted_closure sh:message "accepteddecisionevaluationincomplete: accepted decision requires complete digest-bound evaluation inputs and, when derived, a complete closure state";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> .\n  { FILTER NOT EXISTS {\n      $this usf:hasDecisionEvaluation ?evaluation .\n      ?evaluation usf:evaluationForDecision $this ; usf:evaluationAuthorityDigest ?authorityDigest ;\n        usf:evaluationDependencySetDigest ?dependencyDigest ; usf:evaluationEvidenceDigest ?evidenceDigest ;\n        usf:evaluationImplementationSourceDigest ?implementationDigest ; usf:evaluationProducerDigest ?producerDigest ;\n        usf:evaluationEvidenceResult ?currentEvidence ; usf:evaluationInvalidationCondition ?invalidation ;\n        usf:independentSelectionBasis true ; usf:selectionBasisEvidence ?currentEvidence .\n      ?currentEvidence a usf:EvidenceResult, usf:CompositeEvidenceResult ; usf:contentDigest ?evidenceDigest ;\n        usf:evaluatedAuthorityDigest ?authorityDigest ; usf:evidenceProducerDigest ?producerDigest ;\n        usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ; usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ;\n        usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ; usf:withinValidityScope true .\n      FILTER(REGEX(?authorityDigest, '^sha256:[0-9a-f]{64}$'))\n      FILTER(REGEX(?dependencyDigest, '^sha256:[0-9a-f]{64}$'))\n      FILTER(REGEX(?evidenceDigest, '^sha256:[0-9a-f]{64}$'))\n      FILTER(REGEX(?implementationDigest, '^sha256:[0-9a-f]{64}$'))\n      FILTER(REGEX(?producerDigest, '^sha256:[0-9a-f]{64}$'))\n    } }\n  UNION\n  { $this usf:hasDecisionEvaluation ?evaluation .\n    FILTER EXISTS { ?evaluation usf:evaluationClosureState ?derivedState }\n    FILTER NOT EXISTS { ?evaluation usf:evaluationClosureState <urn:usf:evaluationclosurestate:complete> }\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_accepted_closure.
_:oe_candidate_path sh:message "accepteddecisioncandidatesetincomplete: accepted decision needs two distinct credible candidates or a current evidence-bound sole-candidate proof";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation ; usf:selectsOption ?selected .\n  FILTER NOT EXISTS {\n    $this usf:considersOption ?oa, ?ob .\n    ?evaluation usf:hasCandidateCredibilityAssessment ?ca, ?cb .\n    ?ca usf:credibilityForOption ?oa ; usf:credibilityState <urn:usf:candidatecredibilitystate:credible> ; usf:credibilityEvidence ?ea .\n    ?cb usf:credibilityForOption ?ob ; usf:credibilityState <urn:usf:candidatecredibilitystate:credible> ; usf:credibilityEvidence ?eb .\n    FILTER(?oa != ?ob)\n  }\n  FILTER NOT EXISTS {\n    ?evaluation usf:hasSoleCandidateJustification ?sole .\n    ?sole usf:soleCandidateForOption ?selected ; usf:hasCandidateSearchSpace ?space ; usf:hasCandidateClassExclusion ?exclusion ;\n      usf:soleCandidateEvidence ?evidence ; usf:soleCandidateInvalidationCondition ?invalidation .\n    ?space a usf:CandidateSearchSpace ; usf:candidateDiscoveryCriteria ?criteria ; usf:searchesRealisationClass ?classA, ?classB ;\n      usf:candidateSearchSpaceDigest ?spaceDigest ; usf:candidateSearchEvidence ?evidence ; usf:candidateSearchInvalidationCondition ?spaceInvalidation .\n    FILTER(?classA != ?classB)\n    ?exclusion usf:excludesRealisationClass ?excludedClass ; usf:exclusionReason ?reason ; usf:exclusionEvidence ?evidence .\n    ?evidence a usf:EvidenceResult ; usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ;\n      usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ; usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ;\n      usf:withinValidityScope true .\n    FILTER(REGEX(?spaceDigest, '^sha256:[0-9a-f]{64}$'))\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_candidate_path.
_:oe_candidate_credibility sh:message "candidatecredibilityinvalid: every considered candidate must be a real option with exactly one current evidence-backed credibility assessment";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:considersOption ?option ; usf:hasDecisionEvaluation ?evaluation .\n  FILTER(\n    NOT EXISTS { ?option a usf:RealisationOption } ||\n    NOT EXISTS {\n      ?evaluation usf:hasCandidateCredibilityAssessment ?credibility .\n      ?credibility usf:credibilityForEvaluation ?evaluation ; usf:credibilityForOption ?option ; usf:credibilityState ?state ; usf:credibilityEvidence ?evidence .\n      ?evidence usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ; usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ; usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ; usf:withinValidityScope true .\n    } || EXISTS {\n      ?evaluation usf:hasCandidateCredibilityAssessment ?left, ?right .\n      ?left usf:credibilityForOption ?option . ?right usf:credibilityForOption ?option .\n      FILTER(?left != ?right)\n    }\n  )\n}".
shp:RealisationDecisionShape sh:sparql _:oe_candidate_credibility.
_:oe_criterion_set sh:message "evaluationcriterionmissing: every canonical evaluation criterion must have exactly one declared requirement";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation .\n  ?criterion a usf:EvaluationCriterion .\n  FILTER(\n    NOT EXISTS { ?evaluation usf:hasCriterionRequirement ?requirement . ?requirement usf:requiresCriterion ?criterion } ||\n    EXISTS { ?evaluation usf:hasCriterionRequirement ?left, ?right . ?left usf:requiresCriterion ?criterion . ?right usf:requiresCriterion ?criterion . FILTER(?left != ?right) }\n  )\n}".
shp:RealisationDecisionShape sh:sparql _:oe_criterion_set.
_:oe_criterion_cross_product sh:message "candidatecriterionassessmentmissing: every considered candidate and declared criterion requires exactly one assessment";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:considersOption ?option ; usf:hasDecisionEvaluation ?evaluation .\n  ?evaluation usf:hasCriterionRequirement/usf:requiresCriterion ?criterion .\n  OPTIONAL { ?assessment a usf:CriterionAssessment ; usf:assessmentForEvaluation ?evaluation ; usf:assessmentForOption ?option ; usf:assessmentForCriterion ?criterion . FILTER NOT EXISTS { ?assessment usf:assessmentForComponent ?component } }\n}\nGROUP BY $this ?evaluation ?option ?criterion\nHAVING(COUNT(DISTINCT ?assessment) != 1)".
shp:RealisationDecisionShape sh:sparql _:oe_criterion_cross_product.
_:oe_assessment_evidence usf:constraintFailureCode <urn:usf:validationfailurecode:assessmentevidenceinvalid>;
    sh:message "criterionassessmentevidenceinvalid: option assessment requires current admitted evidence and an exact criterion-bounded supporting-manifest projection";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation .\n  ?assessment a usf:CriterionAssessment ; usf:assessmentForEvaluation ?evaluation .\n  FILTER NOT EXISTS { ?assessment usf:assessmentForComponent ?component }\n  FILTER NOT EXISTS {\n    ?assessment usf:assessmentResult ?result ; usf:assessmentMethod ?method ; usf:assessmentEvidence ?evidence ; usf:assessmentForCriterion ?criterion ;\n      usf:assessmentAuthorityDigest ?authorityDigest ; usf:assessmentEvidenceDigest ?evidenceDigest ; usf:assessmentConfidence ?confidence ;\n      usf:hasCriterionEvidenceBinding ?binding .\n    ?evaluation usf:evaluationAuthorityDigest ?authorityDigest ; usf:evaluationEvidenceDigest ?evidenceDigest ; usf:evaluationProducerDigest ?producerDigest .\n    ?binding usf:bindingForAssessment ?assessment ; usf:bindingEvidenceResult ?evidence ; usf:bindingSupportingManifest ?manifest ;\n      usf:bindingSupportDigest ?supportDigest ; usf:bindingAuthorityDigest ?authorityDigest ; usf:bindingEvidenceDigest ?evidenceDigest .\n    ?evidence a usf:EvidenceResult, usf:CompositeEvidenceResult ; usf:contentDigest ?evidenceDigest ; usf:evaluatedAuthorityDigest ?authorityDigest ;\n      usf:evidenceProducerDigest ?producerDigest ; usf:hasSupportingEvidenceManifest ?manifest ;\n      usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ; usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ;\n      usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ; usf:withinValidityScope true .\n    ?manifest a usf:EvidenceScopeManifest ; usf:scopeSupportsCriterion ?criterion .\n    FILTER NOT EXISTS { ?manifest usf:scopeProhibitsCriterion ?criterion }\n    FILTER(REGEX(?supportDigest, '^sha256:[0-9a-f]{64}$'))\n    FILTER(?result != <urn:usf:assessmentresult:insufficientevidence>)\n    FILTER(?confidence >= 0.0 && ?confidence <= 1.0)\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_assessment_evidence.
_:oe_component_assessment_evidence usf:constraintFailureCode <urn:usf:validationfailurecode:componentassessmentevidenceinvalid>;
    sh:message "componentassessmentevidenceinvalid: component assessment requires current admitted evidence and an exact criterion-bounded supporting-manifest projection";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation .\n  ?assessment a usf:CriterionAssessment ; usf:assessmentForEvaluation ?evaluation ; usf:assessmentForComponent ?component .\n  FILTER NOT EXISTS {\n    ?assessment usf:assessmentResult ?result ; usf:assessmentMethod ?method ; usf:assessmentEvidence ?evidence ; usf:assessmentForCriterion ?criterion ;\n      usf:assessmentAuthorityDigest ?authorityDigest ; usf:assessmentEvidenceDigest ?evidenceDigest ; usf:assessmentConfidence ?confidence ;\n      usf:hasCriterionEvidenceBinding ?binding .\n    ?evaluation usf:evaluationAuthorityDigest ?authorityDigest ; usf:evaluationEvidenceDigest ?evidenceDigest ; usf:evaluationProducerDigest ?producerDigest .\n    ?binding usf:bindingForAssessment ?assessment ; usf:bindingEvidenceResult ?evidence ; usf:bindingSupportingManifest ?manifest ;\n      usf:bindingSupportDigest ?supportDigest ; usf:bindingAuthorityDigest ?authorityDigest ; usf:bindingEvidenceDigest ?evidenceDigest .\n    ?evidence a usf:EvidenceResult, usf:CompositeEvidenceResult ; usf:contentDigest ?evidenceDigest ; usf:evaluatedAuthorityDigest ?authorityDigest ;\n      usf:evidenceProducerDigest ?producerDigest ; usf:hasSupportingEvidenceManifest ?manifest ;\n      usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ; usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ;\n      usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ; usf:withinValidityScope true .\n    ?manifest a usf:EvidenceScopeManifest ; usf:scopeSupportsCriterion ?criterion .\n    FILTER NOT EXISTS { ?manifest usf:scopeProhibitsCriterion ?criterion }\n    FILTER(REGEX(?supportDigest, '^sha256:[0-9a-f]{64}$'))\n    FILTER(?result != <urn:usf:assessmentresult:insufficientevidence>)\n    FILTER(?confidence >= 0.0 && ?confidence <= 1.0)\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_component_assessment_evidence.
_:oe_not_applicable sh:message "criterionnotapplicableunexplained: not-applicable criteria require explicit justification and matching assessment result";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation .\n  ?evaluation usf:hasCriterionRequirement ?requirement .\n  { ?requirement usf:criterionApplicability <urn:usf:criterionapplicability:notapplicable> ; usf:requiresCriterion ?criterion .\n    FILTER NOT EXISTS { ?requirement usf:applicabilityJustification ?justification } }\n  UNION\n  { ?requirement usf:criterionApplicability <urn:usf:criterionapplicability:notapplicable> ; usf:requiresCriterion ?criterion .\n    ?assessment usf:assessmentForEvaluation ?evaluation ; usf:assessmentForCriterion ?criterion .\n    FILTER NOT EXISTS { ?assessment usf:assessmentResult <urn:usf:assessmentresult:notapplicablewithjustification> ; usf:assessmentLimitation ?limitation } }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_not_applicable.
_:oe_rejections sh:message "crediblerejectedcandidateunexplained: every credible non-selected candidate needs a criterion-specific evidence-backed rejection and reopening rule";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation ; usf:selectsOption ?selected .\n  ?evaluation usf:hasCandidateCredibilityAssessment ?credibility .\n  ?credibility usf:credibilityForOption ?option ; usf:credibilityState <urn:usf:candidatecredibilitystate:credible> .\n  FILTER(?option != ?selected)\n  FILTER NOT EXISTS {\n    ?evaluation usf:hasOptionRejection ?rejection .\n    ?rejection usf:rejectionForEvaluation ?evaluation ; usf:rejectsOption ?option ; usf:hasRejectionReason ?reason .\n    ?reason usf:rejectionCriterion ?criterion ; usf:rejectionEvidence ?evidence ; usf:rejectionDuration ?duration ;\n      usf:rejectionStatement ?statement ; usf:reopeningCondition ?condition .\n    ?evidence a usf:EvidenceResult ; usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ;\n      usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ; usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ;\n      usf:withinValidityScope true .\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_rejections.
_:oe_selected_package_integrity sh:message "selectedcomponentintegrityincomplete: every selected component requires an exact observed identity, current vulnerability and supply-chain evidence, and third-party components also require current licence evidence";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation ; usf:selectsOption ?option .\n  ?evaluation usf:evaluationAuthorityDigest ?authorityDigest ; usf:evaluationEvidenceDigest ?evidenceDigest .\n  ?option usf:hasOptionComponent/usf:componentIdentity ?component .\n  ?component a ?kind .\n  FILTER(?kind IN (usf:PackageComponent, usf:RuntimeComponent, usf:RepositoryLocalComponent, usf:ExternalProviderComponent, usf:ContainerImageComponent))\n  FILTER NOT EXISTS {\n    ?component usf:componentVersion ?version ; usf:componentDistributionSource ?distribution ; usf:componentIntegrityDigest ?integrity ;\n      usf:componentObservationDigest ?observationDigest ; usf:componentAcquisitionSource ?source ; usf:componentDependencyLockDigest ?lock ;\n      usf:componentPatchPolicy ?patch ; usf:componentContinuityRule ?continuity ; usf:hasIntegrityConstraint/usf:integrityConstraintDigest ?integrity ;\n      usf:hasVulnerabilityAssessment ?vulnerability ; usf:hasSupplyChainAssessment ?supply .\n    ?vulnerability usf:vulnerabilityScannerIdentity ?scanner ; usf:vulnerabilityAssessmentMethod ?vulnerabilityMethod ;\n      usf:vulnerabilityAssessmentScope ?vulnerabilityScope ; usf:vulnerabilityAssessmentLimitation ?vulnerabilityLimitation ;\n      usf:vulnerabilityPolicyDigest ?vulnerabilityPolicyDigest ; usf:vulnerabilityAssessedAt ?assessedAt ;\n      usf:vulnerabilityEvidence ?evidence ; usf:vulnerabilityPolicy ?policy ; usf:acceptedVulnerabilityCount 0 .\n    ?supply usf:supplyChainEvidence ?evidence ; usf:supplyChainProvenance ?provenance ;\n      usf:dependencyDisclosureState ?disclosure ; usf:supplyChainAssessmentLimitation ?supplyLimitation .\n    ?evidence a usf:EvidenceResult ; usf:contentDigest ?evidenceDigest ; usf:evaluatedAuthorityDigest ?authorityDigest ;\n      usf:evidenceProducerDigest ?producerDigest ; usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ;\n      usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ; usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ; usf:withinValidityScope true .\n    FILTER(REGEX(?integrity, '^(sha256:[0-9a-f]{64}|sha512-[A-Za-z0-9+/=]+)$'))\n    FILTER(REGEX(?observationDigest, '^sha256:[0-9a-f]{64}$'))\n    FILTER(REGEX(?lock, '^sha256:[0-9a-f]{64}$'))\n    FILTER(REGEX(?vulnerabilityPolicyDigest, '^sha256:[0-9a-f]{64}$'))\n    FILTER(((?kind = usf:PackageComponent || ?kind = usf:RepositoryLocalComponent) && EXISTS { ?supply usf:componentDependencySetDigest ?dependencySet . FILTER(REGEX(?dependencySet, '^sha256:[0-9a-f]{64}$')) }) || ((?kind != usf:PackageComponent && ?kind != usf:RepositoryLocalComponent) && NOT EXISTS { ?supply usf:componentDependencySetDigest ?unexpectedDependencySet }))\n    FILTER((?kind = usf:RepositoryLocalComponent) || EXISTS {\n      ?component usf:hasLicenceAssessment ?licence .\n      ?licence usf:licenceIdentifier ?licenceId ; usf:licenceEvidence ?evidence ; usf:licenceCompatible true ;\n        usf:usesLicenceCompatibilityPolicy/usf:licencePolicyDigest ?licencePolicyDigest ; usf:licenceAssessmentMethod ?licenceMethod ;\n        usf:licenceUsageContext ?usage ; usf:licenceAssessmentLimitation ?licenceLimitation ; usf:licenceCompatibilityCondition ?licenceCondition .\n      FILTER(LCASE(STR(?licenceId)) != 'unknown' && REGEX(?licencePolicyDigest, '^sha256:[0-9a-f]{64}$'))\n    })\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_selected_package_integrity.
_:oe_floating_component_version sh:message "selectedpackageversionfloating: selected package and runtime versions must be exact and immutable";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption ?option .\n  ?option usf:hasOptionComponent/usf:componentIdentity ?component . ?component a ?kind ; usf:componentVersion ?version .\n  FILTER(?kind = usf:PackageComponent || ?kind = usf:RuntimeComponent)\n  FILTER(REGEX(LCASE(STR(?version)), '^(latest|next|stable|main|master|head|[~><=*^])') || !REGEX(STR(?version), '^[0-9]+([.][0-9]+){0,3}([+-][0-9A-Za-z.-]+)?$'))\n}".
shp:RealisationDecisionShape sh:sparql _:oe_floating_component_version.
_:oe_unknown_licence sh:message "selectedcomponentlicenceunknown: a selected third-party component cannot use an unknown licence";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption ?option .\n  ?option usf:hasOptionComponent/usf:componentIdentity ?component . ?component a ?kind ; usf:hasLicenceAssessment/usf:licenceIdentifier ?identifier .\n  FILTER(?kind IN (usf:PackageComponent, usf:RuntimeComponent, usf:ExternalProviderComponent, usf:ContainerImageComponent))\n  FILTER(LCASE(STR(?identifier)) = 'unknown')\n}".
shp:RealisationDecisionShape sh:sparql _:oe_unknown_licence.
_:oe_vulnerability_assessment sh:message "selectedcomponentvulnerabilitymissing: selected third-party components require current vulnerability and supply-chain evidence";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation ; usf:selectsOption ?option .\n  ?evaluation usf:evaluationAuthorityDigest ?authorityDigest ; usf:evaluationEvidenceDigest ?evidenceDigest .\n  ?option usf:hasOptionComponent/usf:componentIdentity ?component . ?component a ?kind .\n  FILTER(?kind IN (usf:PackageComponent, usf:RuntimeComponent, usf:RepositoryLocalComponent, usf:ExternalProviderComponent, usf:ContainerImageComponent))\n  FILTER NOT EXISTS {\n    ?component usf:hasVulnerabilityAssessment ?vulnerability ; usf:hasSupplyChainAssessment ?supply .\n    ?vulnerability usf:vulnerabilityEvidence ?evidence ; usf:vulnerabilityAssessedAt ?assessedAt ; usf:vulnerabilityScannerIdentity ?scanner ;\n      usf:vulnerabilityAssessmentMethod ?method ; usf:vulnerabilityAssessmentScope ?scope ; usf:vulnerabilityAssessmentLimitation ?limitation ;\n      usf:vulnerabilityPolicyDigest ?policyDigest ; usf:acceptedVulnerabilityCount 0 .\n    ?supply usf:supplyChainEvidence ?evidence ; usf:dependencyDisclosureState ?disclosure ; usf:supplyChainAssessmentLimitation ?supplyLimitation .\n    ?evidence usf:contentDigest ?evidenceDigest ; usf:evaluatedAuthorityDigest ?authorityDigest ; usf:evidenceProducerDigest ?producerDigest ;\n      usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ; usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ;\n      usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ; usf:withinValidityScope true .\n    FILTER(((?kind = usf:PackageComponent || ?kind = usf:RepositoryLocalComponent) && EXISTS { ?supply usf:componentDependencySetDigest ?dependencyDigest . FILTER(REGEX(?dependencyDigest, '^sha256:[0-9a-f]{64}$')) }) || ((?kind != usf:PackageComponent && ?kind != usf:RepositoryLocalComponent) && NOT EXISTS { ?supply usf:componentDependencySetDigest ?unexpectedDependencySet }))\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_vulnerability_assessment.
_:oe_evaluation_evidence_exact sh:message "evaluationdependencydrift: accepted evaluation must bind one exact current composite evidence result with matching authority, content and producer digests";
    sh:select """PREFIX usf: <urn:usf:ontology:>
SELECT $this WHERE {
  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation .
  FILTER(
    NOT EXISTS {
      ?evaluation usf:evaluationAuthorityDigest ?authorityDigest ; usf:evaluationEvidenceDigest ?evidenceDigest ;
        usf:evaluationProducerDigest ?producerDigest ; usf:evaluationEvidenceResult ?evidence .
      ?evidence a usf:EvidenceResult, usf:CompositeEvidenceResult ; usf:contentDigest ?evidenceDigest ;
        usf:evaluatedAuthorityDigest ?authorityDigest ; usf:evidenceProducerDigest ?producerDigest ;
        usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ;
        usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ;
        usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ; usf:withinValidityScope true .
    } || EXISTS {
      ?evaluation usf:evaluationEvidenceResult ?left, ?right . FILTER(?left != ?right)
    }
  )
}""".
shp:RealisationDecisionShape sh:sparql _:oe_evaluation_evidence_exact.
_:oe_licence_evidence_exact sh:message "licenceassessmentinvalid: every selected third-party component requires one assessment bound only to the evaluation's exact current evidence";
    sh:select """PREFIX usf: <urn:usf:ontology:>
SELECT $this WHERE {
  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation/usf:evaluationEvidenceResult ?evidence ; usf:selectsOption ?option .
  ?option usf:hasOptionComponent/usf:componentIdentity ?component . ?component a ?kind .
  FILTER(?kind IN (usf:PackageComponent, usf:RuntimeComponent, usf:ExternalProviderComponent, usf:ContainerImageComponent))
  FILTER NOT EXISTS {
    ?component usf:hasLicenceAssessment ?assessment . ?assessment usf:licenceEvidence ?evidence .
    FILTER NOT EXISTS { ?component usf:hasLicenceAssessment ?otherAssessment . FILTER(?otherAssessment != ?assessment) }
    FILTER NOT EXISTS { ?assessment usf:licenceEvidence ?otherEvidence . FILTER(?otherEvidence != ?evidence) }
  }
}""".
shp:RealisationDecisionShape sh:sparql _:oe_licence_evidence_exact.
_:oe_vulnerability_evidence_exact sh:message "vulnerabilityassessmentmissing: every selected component requires one zero-accepted-vulnerability assessment bound only to the evaluation's exact current evidence";
    sh:select """PREFIX usf: <urn:usf:ontology:>
SELECT $this WHERE {
  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation/usf:evaluationEvidenceResult ?evidence ; usf:selectsOption ?option .
  ?option usf:hasOptionComponent/usf:componentIdentity ?component .
  FILTER NOT EXISTS {
    ?component usf:hasVulnerabilityAssessment ?assessment .
    ?assessment usf:vulnerabilityEvidence ?evidence ; usf:acceptedVulnerabilityCount 0 .
    FILTER NOT EXISTS { ?component usf:hasVulnerabilityAssessment ?otherAssessment . FILTER(?otherAssessment != ?assessment) }
    FILTER NOT EXISTS { ?assessment usf:vulnerabilityEvidence ?otherEvidence . FILTER(?otherEvidence != ?evidence) }
  }
}""".
shp:RealisationDecisionShape sh:sparql _:oe_vulnerability_evidence_exact.
_:oe_supply_evidence_exact sh:message "supplychainassessmentmissing: every selected component requires one supply-chain assessment bound only to the evaluation's exact current evidence";
    sh:select """PREFIX usf: <urn:usf:ontology:>
SELECT $this WHERE {
  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation/usf:evaluationEvidenceResult ?evidence ; usf:selectsOption ?option .
  ?option usf:hasOptionComponent/usf:componentIdentity ?component .
  FILTER NOT EXISTS {
    ?component usf:hasSupplyChainAssessment ?assessment . ?assessment usf:supplyChainEvidence ?evidence .
    FILTER NOT EXISTS { ?component usf:hasSupplyChainAssessment ?otherAssessment . FILTER(?otherAssessment != ?assessment) }
    FILTER NOT EXISTS { ?assessment usf:supplyChainEvidence ?otherEvidence . FILTER(?otherEvidence != ?evidence) }
  }
}""".
shp:RealisationDecisionShape sh:sparql _:oe_supply_evidence_exact.
_:oe_composition sh:message "selectedcompositioncoverageincomplete: selected composition requires component responsibilities, environment bindings and a current successful zero-gap coverage proof";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption ?option .\n  ?option a usf:ComposedRealisationOption .\n  FILTER NOT EXISTS {\n    ?option usf:hasOptionComponent ?component ; usf:hasComponentResponsibility ?responsibility ;\n      usf:hasCompositionCoverageProof ?proof ; usf:hasCompositionPermutationAssessment ?permutations .\n    ?component usf:componentForOption ?option ; usf:componentIdentity ?identity ; usf:componentRole ?role ; usf:componentResponsibility ?statement .\n    ?responsibility usf:responsibilityForComponent ?component ; usf:responsibilityForRequirement ?requirement ; usf:responsibilityOwner ?owner .\n    ?proof usf:coverageProofForOption ?option ; usf:compositionProofSuccessful true ; usf:compositionProofCurrent true ;\n      usf:compositionProofAuthorityDigest ?authorityDigest ; usf:compositionProofImplementationDigest ?implementationDigest ;\n      usf:compositionProofEvidence ?evidence ; usf:compositionProofDigest ?proofDigest ;\n      usf:requiredFacetCount ?requiredFacets ; usf:coveredFacetCount ?coveredFacets ;\n      usf:requiredPortCount ?requiredPorts ; usf:implementedPortCount ?implementedPorts ;\n      usf:orphanResponsibilityCount 0 ; usf:duplicateResponsibilityCount 0 ; usf:incompatibleInterfaceCount 0 ;\n      usf:unusedComponentCount 0 ; usf:unclassifiedPermutationCount 0 .\n    ?permutations usf:permutationForOption ?option ; usf:permutationDimensionSetDigest ?dimensionDigest ;\n      usf:permutationCaseCount ?caseCount ; usf:permutationDisposition ?disposition ; usf:permutationEvidence ?evidence .\n    FILTER(?requiredFacets = ?coveredFacets && ?requiredPorts = ?implementedPorts)\n    FILTER(REGEX(?authorityDigest, '^sha256:[0-9a-f]{64}$'))\n    FILTER(REGEX(?implementationDigest, '^sha256:[0-9a-f]{64}$'))\n    FILTER(REGEX(?proofDigest, '^sha256:[0-9a-f]{64}$'))\n    FILTER(REGEX(?dimensionDigest, '^sha256:[0-9a-f]{64}$'))\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_composition.
_:oe_component_responsibility sh:message "compositioncomponentresponsibilitymissing: every selected composition component requires an owned semantic responsibility";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption ?option .\n  ?option a usf:ComposedRealisationOption ; usf:hasOptionComponent ?component .\n  FILTER NOT EXISTS { ?option usf:hasComponentResponsibility ?responsibility . ?responsibility usf:responsibilityForComponent ?component ; usf:responsibilityForRequirement ?requirement ; usf:responsibilityOwner ?owner }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_component_responsibility.
_:oe_composition_facet sh:message "compositionfacetuncovered: a selected composition coverage proof must cover every required facet and port";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption/usf:hasCompositionCoverageProof ?proof .\n  ?proof usf:requiredFacetCount ?requiredFacets ; usf:coveredFacetCount ?coveredFacets ; usf:requiredPortCount ?requiredPorts ; usf:implementedPortCount ?implementedPorts .\n  FILTER(?requiredFacets != ?coveredFacets || ?requiredPorts != ?implementedPorts)\n}".
shp:RealisationDecisionShape sh:sparql _:oe_composition_facet.
_:oe_component_interfaces usf:constraintFailureCode <urn:usf:validationfailurecode:compositioninterfaceincompatible>;
    sh:message "compositioninterfaceincompatible: selected composition interfaces must be compatible";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption/usf:hasCompositionCoverageProof ?proof .\n  ?proof usf:incompatibleInterfaceCount ?count . FILTER(?count != 0)\n}".
shp:RealisationDecisionShape sh:sparql _:oe_component_interfaces.
_:oe_component_versions usf:constraintFailureCode <urn:usf:validationfailurecode:componentversionincompatible>;
    sh:message "componentversionincompatible: selected composition component versions must be compatible";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption/usf:hasCompositionCoverageProof ?proof .\n  ?proof usf:incompatibleComponentVersionCount ?count . FILTER(?count != 0)\n}".
shp:RealisationDecisionShape sh:sparql _:oe_component_versions.
_:oe_environment_bindings sh:message "selectedproviderenvironmentbindingsmissing: selected option must cover development, deterministic test and production-shaped staging provider bindings";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption ?option .\n  ?option a usf:ComposedRealisationOption .\n  FILTER(\n    NOT EXISTS { ?option usf:hasOptionComponent/usf:componentEnvironmentBinding <urn:usf:environment:localdev> } ||\n    NOT EXISTS { ?option usf:hasOptionComponent/usf:componentEnvironmentBinding <urn:usf:environment:hermetic> } ||\n    NOT EXISTS { ?option usf:hasOptionComponent/usf:componentEnvironmentBinding <urn:usf:environment:productionshaped> }\n  )\n}".
shp:RealisationDecisionShape sh:sparql _:oe_environment_bindings.
_:oe_independent_selection sh:message "selectionbasisnotindependentlywarranted: accepted selection requires current evidence that it is independent of inherited use";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation .\n  FILTER NOT EXISTS {\n    ?evaluation usf:independentSelectionBasis true ; usf:selectionBasisEvidence ?evidence .\n    ?evidence usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ; usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ; usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ; usf:withinValidityScope true .\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_independent_selection.

shp:CriterionAssessmentShape a sh:NodeShape;
    usf:canonicalName "criterionassessmentshape";
    sh:targetClass usf:CriterionAssessment.
_:oe_assessment_option sh:path usf:assessmentForOption; sh:minCount 1; sh:maxCount 1; sh:class usf:RealisationOption; sh:message "assessmentoptioncardinality: criterion assessment requires exactly one candidate".
shp:CriterionAssessmentShape sh:property _:oe_assessment_option.
_:oe_assessment_criterion sh:path usf:assessmentForCriterion; sh:minCount 1; sh:maxCount 1; sh:class usf:EvaluationCriterion; sh:message "assessmentcriterioncardinality: criterion assessment requires exactly one criterion".
shp:CriterionAssessmentShape sh:property _:oe_assessment_criterion.
_:oe_assessment_result sh:path usf:assessmentResult; sh:minCount 1; sh:maxCount 1; sh:class usf:AssessmentResult; sh:message "assessmentresultcardinality: criterion assessment requires exactly one closed-vocabulary result".
shp:CriterionAssessmentShape sh:property _:oe_assessment_result.

shp:CriterionEvidenceBindingShape a sh:NodeShape;
    usf:canonicalName "criterionevidencebindingshape";
    sh:targetClass usf:CriterionEvidenceBinding;
    sh:property [ sh:path usf:bindingForAssessment; sh:minCount 1; sh:maxCount 1; sh:class usf:CriterionAssessment; sh:message "criterionevidencebindingassessmentcardinality: evidence binding requires exactly one assessment" ];
    sh:property [ sh:path usf:bindingEvidenceResult; sh:minCount 1; sh:maxCount 1; sh:class usf:CompositeEvidenceResult; sh:message "criterionevidencebindingresultcardinality: evidence binding requires exactly one composite evidence result" ];
    sh:property [ sh:path usf:bindingSupportingManifest; sh:minCount 1; sh:class usf:EvidenceScopeManifest; sh:message "criterionevidencebindingscopemissing: evidence binding requires at least one separately typed supporting manifest" ];
    sh:property [ sh:path usf:bindingSupportDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$"; sh:message "criterionevidencebindingsupportdigestinvalid: evidence binding requires one exact support projection digest" ].

shp:OptionComponentShape a sh:NodeShape;
    usf:canonicalName "optioncomponentshape";
    sh:targetClass usf:OptionComponent.
_:oe_component_role sh:path usf:componentRole; sh:minCount 1; sh:maxCount 1; sh:class usf:ComponentRole; sh:message "componentrolemissing: option component requires exactly one semantic responsibility role".
shp:OptionComponentShape sh:property _:oe_component_role.
_:oe_component_identity sh:path usf:componentIdentity; sh:minCount 1; sh:maxCount 1; sh:class usf:ComponentIdentity; sh:message "componentidentitymissing: option component requires exactly one component identity".
shp:OptionComponentShape sh:property _:oe_component_identity.

# Realisation-option evaluation closure additions are separate constraints so each
# planted defect produces a stable, specific violation code.
_:oe_digest_coherence sh:message "evaluationdigestbindingincoherent: accepted evaluation evidence, authority, producer and dependency digests must bind one current admitted payload";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation .\n  FILTER NOT EXISTS {\n    ?evaluation usf:evaluationForDecision $this ; usf:evaluationAuthorityDigest ?authorityDigest ;\n      usf:evaluationDependencySetDigest ?dependencyDigest ; usf:evaluationEvidenceDigest ?evidenceDigest ;\n      usf:evaluationImplementationSourceDigest ?implementationDigest ; usf:evaluationProducerDigest ?producerDigest ;\n      usf:selectionBasisEvidence ?evidence .\n    ?evidence a usf:EvidenceResult ; usf:contentDigest ?evidenceDigest ; usf:evaluatedAuthorityDigest ?authorityDigest ;\n      usf:evidenceProducerDigest ?producerDigest ; usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ;\n      usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ; usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ; usf:withinValidityScope true .\n    ?collection a usf:EvidenceCollection ; usf:collectedEvidence ?evidence ; usf:sourceDigest ?dependencyDigest .\n    FILTER(REGEX(?authorityDigest, '^sha256:[0-9a-f]{64}$'))\n    FILTER(REGEX(?dependencyDigest, '^sha256:[0-9a-f]{64}$'))\n    FILTER(REGEX(?evidenceDigest, '^sha256:[0-9a-f]{64}$'))\n    FILTER(REGEX(?implementationDigest, '^sha256:[0-9a-f]{64}$'))\n    FILTER(REGEX(?producerDigest, '^sha256:[0-9a-f]{64}$'))\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_digest_coherence.

_:oe_criterion_requirement_metadata sh:message "criterionrequirementmetadatacardinality: every criterion requirement needs exactly one evaluation, criterion, applicability and mandatory boolean, with not-applicable criteria non-mandatory";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation .\n  ?evaluation usf:hasCriterionRequirement ?requirement .\n  FILTER(\n    NOT EXISTS { ?requirement usf:criterionForEvaluation ?evaluation } ||\n    EXISTS { ?requirement usf:criterionForEvaluation ?left, ?right . FILTER(?left != ?right) } ||\n    NOT EXISTS { ?requirement usf:requiresCriterion ?criterion } ||\n    EXISTS { ?requirement usf:requiresCriterion ?leftCriterion, ?rightCriterion . FILTER(?leftCriterion != ?rightCriterion) } ||\n    NOT EXISTS { ?requirement usf:criterionApplicability ?applicability } ||\n    EXISTS { ?requirement usf:criterionApplicability ?leftApplicability, ?rightApplicability . FILTER(?leftApplicability != ?rightApplicability) } ||\n    NOT EXISTS { ?requirement usf:criterionMandatory ?mandatory . FILTER(DATATYPE(?mandatory) = <http://www.w3.org/2001/XMLSchema#boolean>) } ||\n    EXISTS { ?requirement usf:criterionMandatory ?leftMandatory, ?rightMandatory . FILTER(?leftMandatory != ?rightMandatory) } ||\n    EXISTS { ?requirement usf:criterionApplicability <urn:usf:criterionapplicability:notapplicable> ; usf:criterionMandatory true }\n  )\n}".
shp:RealisationDecisionShape sh:sparql _:oe_criterion_requirement_metadata.

_:oe_mandatory_criterion_closure sh:message "mandatorycriterionunsatisfiedorunmitigated: every credible candidate must satisfy each applicable mandatory criterion or bind one accepted current-evidence mitigation";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?evaluation .\n  ?evaluation usf:evaluationAuthorityDigest ?authorityDigest ; usf:evaluationEvidenceDigest ?evidenceDigest ; usf:evaluationProducerDigest ?producerDigest ;\n    usf:hasCandidateCredibilityAssessment ?credibility ; usf:hasCriterionRequirement ?requirement .\n  ?credibility usf:credibilityForOption ?option ; usf:credibilityState <urn:usf:candidatecredibilitystate:credible> .\n  ?requirement usf:requiresCriterion ?criterion ; usf:criterionApplicability <urn:usf:criterionapplicability:applicable> ; usf:criterionMandatory true .\n  ?assessment a usf:CriterionAssessment ; usf:assessmentForEvaluation ?evaluation ; usf:assessmentForOption ?option ; usf:assessmentForCriterion ?criterion .\n  FILTER NOT EXISTS { ?assessment usf:assessmentResult <urn:usf:assessmentresult:satisfies> }\n  FILTER NOT EXISTS {\n    ?assessment usf:assessmentMitigation ?mitigation .\n    ?mitigation a usf:CriterionMitigation ; usf:mitigationAccepted true ; usf:mitigationStatement ?statement ;\n      usf:mitigationEvidence ?evidence ; usf:mitigationInvalidationCondition ?invalidation .\n    ?evidence a usf:EvidenceResult ; usf:contentDigest ?evidenceDigest ; usf:evaluatedAuthorityDigest ?authorityDigest ;\n      usf:evidenceProducerDigest ?producerDigest ; usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ;\n      usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ; usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ; usf:withinValidityScope true .\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_mandatory_criterion_closure.

_:oe_structural_facet_coverage sh:message "compositionfacetresponsibilitymissing: every contract facet requires exactly one valid selected-component responsibility";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:decisionForContract ?contract ; usf:selectsOption ?option .\n  ?option a usf:ComposedRealisationOption . ?contract usf:declaresFacet ?requirement .\n  OPTIONAL { ?option usf:hasComponentResponsibility ?responsibility . ?responsibility usf:responsibilityOwner ?option ; usf:responsibilityForRequirement ?requirement ; usf:responsibilityForComponent ?component . ?option usf:hasOptionComponent ?component . }\n}\nGROUP BY $this ?option ?requirement\nHAVING(COUNT(DISTINCT ?responsibility) != 1)".
shp:RealisationDecisionShape sh:sparql _:oe_structural_facet_coverage.

_:oe_structural_port_coverage sh:message "compositionportresponsibilitymissing: every contract port requires exactly one valid selected-component responsibility";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:decisionForContract ?contract ; usf:selectsOption ?option .\n  ?option a usf:ComposedRealisationOption . ?requirement a usf:Port ; usf:portForContract ?contract .\n  OPTIONAL { ?option usf:hasComponentResponsibility ?responsibility . ?responsibility usf:responsibilityOwner ?option ; usf:responsibilityForRequirement ?requirement ; usf:responsibilityForComponent ?component . ?option usf:hasOptionComponent ?component . }\n}\nGROUP BY $this ?option ?requirement\nHAVING(COUNT(DISTINCT ?responsibility) != 1)".
shp:RealisationDecisionShape sh:sparql _:oe_structural_port_coverage.

_:oe_dependency_membership sh:message "compositiondependencyoutsideoption: dependency edges must remain within one selected option and may not self-reference";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption ?option . ?option usf:hasOptionComponent ?source .\n  ?source usf:dependsOnOptionComponent ?target .\n  FILTER(?source = ?target || NOT EXISTS { ?option usf:hasOptionComponent ?target })\n}".
shp:RealisationDecisionShape sh:sparql _:oe_dependency_membership.

_:oe_dependency_cycle sh:message "compositiondependencycycle: selected component dependencies must be acyclic";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption/usf:hasOptionComponent ?component .\n  ?component usf:dependsOnOptionComponent+ ?component .\n}".
shp:RealisationDecisionShape sh:sparql _:oe_dependency_cycle.

_:oe_dependency_interface sh:message "compositiondependencyinterfacemissing: every dependency edge requires a shared typed interface governed by the selected contract";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:decisionForContract ?contract ; usf:selectsOption ?option .\n  ?option usf:hasOptionComponent ?source, ?target . ?source usf:dependsOnOptionComponent ?target .\n  FILTER NOT EXISTS { ?source usf:componentInterface ?interface . ?target usf:componentInterface ?interface . ?interface a usf:CompositionInterface ; usf:compositionInterfaceForContract ?contract }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_dependency_interface.

_:oe_component_dependency_coverage sh:message "compositioncomponentdependencyuncovered: every component in a multi-component selected option must participate in its dependency graph";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption ?option .\n  ?option usf:hasOptionComponent ?component, ?other . FILTER(?component != ?other)\n  FILTER NOT EXISTS { ?component usf:dependsOnOptionComponent ?dependency }\n  FILTER NOT EXISTS { ?dependent usf:dependsOnOptionComponent ?component . ?option usf:hasOptionComponent ?dependent }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_component_dependency_coverage.

_:oe_composition_projection_binding sh:message "compositionprojectiondigestmissing: composition proof must bind the exact component-responsibility projection and permutation payload";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption/usf:hasCompositionCoverageProof ?proof .\n  FILTER NOT EXISTS { ?proof usf:compositionProjectionDigest ?projectionDigest ; usf:compositionPermutationPayloadDigest ?permutationDigest . FILTER(REGEX(?projectionDigest, '^sha256:[0-9a-f]{64}$') && REGEX(?permutationDigest, '^sha256:[0-9a-f]{64}$')) }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_composition_projection_binding.

_:oe_component_bearing_option_type usf:constraintFailureCode <urn:usf:validationfailurecode:componentresponsibilitymissing>;
    sh:message "componentresponsibilitymissing: an option with components must be explicitly typed as a composed realisation option";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE { $this usf:decisionState <urn:usf:decisionstate:accepted>; usf:selectsOption ?option . ?option usf:hasOptionComponent ?component . FILTER NOT EXISTS { ?option a usf:ComposedRealisationOption } }".
shp:RealisationDecisionShape sh:sparql _:oe_component_bearing_option_type.

_:oe_component_assessment_missing usf:constraintFailureCode <urn:usf:validationfailurecode:componentcriterionassessmentmissing>;
    sh:message "componentcriterionassessmentmissing: every selected component and applicable criterion requires exactly one component assessment";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE { $this usf:decisionState <urn:usf:decisionstate:accepted>; usf:hasDecisionEvaluation ?evaluation; usf:selectsOption ?option . ?option a usf:ComposedRealisationOption; usf:hasOptionComponent ?component . ?evaluation usf:hasCriterionRequirement ?requirement . ?requirement usf:requiresCriterion ?criterion; usf:criterionApplicability <urn:usf:criterionapplicability:applicable> . FILTER NOT EXISTS { ?assessment a usf:CriterionAssessment; usf:assessmentForEvaluation ?evaluation; usf:assessmentForOption ?option; usf:assessmentForComponent ?component; usf:assessmentForCriterion ?criterion } }".
shp:RealisationDecisionShape sh:sparql _:oe_component_assessment_missing.

_:oe_component_assessment_duplicate usf:constraintFailureCode <urn:usf:validationfailurecode:componentcriterionassessmentduplicate>;
    sh:message "componentcriterionassessmentduplicate: a selected component and criterion may have only one component assessment";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE { $this usf:decisionState <urn:usf:decisionstate:accepted>; usf:hasDecisionEvaluation ?evaluation; usf:selectsOption ?option . ?left a usf:CriterionAssessment; usf:assessmentForEvaluation ?evaluation; usf:assessmentForOption ?option; usf:assessmentForComponent ?component; usf:assessmentForCriterion ?criterion . ?right a usf:CriterionAssessment; usf:assessmentForEvaluation ?evaluation; usf:assessmentForOption ?option; usf:assessmentForComponent ?component; usf:assessmentForCriterion ?criterion . FILTER(?left != ?right) }".
shp:RealisationDecisionShape sh:sparql _:oe_component_assessment_duplicate.

_:oe_component_assessment_responsibility usf:constraintFailureCode <urn:usf:validationfailurecode:componentassessmentresponsibilitymismatch>;
    sh:message "componentassessmentresponsibilitymismatch: component assessment responsibility bindings must exactly equal the selected component responsibility set";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE { $this usf:decisionState <urn:usf:decisionstate:accepted>; usf:hasDecisionEvaluation ?evaluation; usf:selectsOption ?option . ?assessment a usf:CriterionAssessment; usf:assessmentForEvaluation ?evaluation; usf:assessmentForOption ?option; usf:assessmentForComponent ?component . { ?option usf:hasComponentResponsibility ?responsibility . ?responsibility usf:responsibilityForComponent ?component . FILTER NOT EXISTS { ?assessment usf:assessmentForResponsibility ?responsibility } } UNION { ?assessment usf:assessmentForResponsibility ?responsibility . FILTER NOT EXISTS { ?option usf:hasComponentResponsibility ?responsibility . ?responsibility usf:responsibilityForComponent ?component } } }".
shp:RealisationDecisionShape sh:sparql _:oe_component_assessment_responsibility.

_:oe_component_kind_cardinality usf:constraintFailureCode <urn:usf:validationfailurecode:componentkindcardinality>;
    sh:message "componentkindcardinality: each selected component identity requires exactly one supported component kind";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE { $this usf:decisionState <urn:usf:decisionstate:accepted>; usf:selectsOption/usf:hasOptionComponent/usf:componentIdentity ?identity . OPTIONAL { ?identity a ?kind . FILTER(?kind IN (usf:PackageComponent, usf:RuntimeComponent, usf:RepositoryLocalComponent, usf:ExternalProviderComponent, usf:ContainerImageComponent)) } } GROUP BY $this ?identity HAVING(COUNT(DISTINCT ?kind) != 1)".
shp:RealisationDecisionShape sh:sparql _:oe_component_kind_cardinality.

_:oe_repository_local_closure usf:constraintFailureCode <urn:usf:validationfailurecode:repositorylocalsourcedigestmissing>;
    sh:message "repositorylocalsourcedigestmissing: selected repository-local identities require exact source, toolchain, lock and integrity bindings";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE { $this usf:decisionState <urn:usf:decisionstate:accepted>; usf:selectsOption/usf:hasOptionComponent/usf:componentIdentity ?identity . ?identity a usf:RepositoryLocalComponent . FILTER NOT EXISTS { ?identity usf:componentVersion \"source-digest-bound\"; usf:componentIntegrityDigest ?digest; usf:componentImplementationSourceDigest ?digest; usf:componentToolchainDigest ?toolchain; usf:componentDependencyLockDigest ?lock; usf:componentAcquisitionSource \"urn:usf:repository:usf\"^^<http://www.w3.org/2001/XMLSchema#anyURI> . FILTER(REGEX(?digest, '^sha256:[0-9a-f]{64}$') && REGEX(?toolchain, '^sha256:[0-9a-f]{64}$') && REGEX(?lock, '^sha256:[0-9a-f]{64}$')) } }".
shp:RealisationDecisionShape sh:sparql _:oe_repository_local_closure.

_:oe_provider_binding_exact usf:constraintFailureCode <urn:usf:validationfailurecode:externalproviderbindingmissing>;
    sh:message "externalproviderbindingmissing: each selected provider-role component requires exactly one compatible binding for every declared environment";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE { $this usf:decisionState <urn:usf:decisionstate:accepted>; usf:selectsOption/usf:hasOptionComponent ?component . ?component usf:componentRole <urn:usf:componentrole:provider>; usf:componentEnvironmentBinding ?environment; usf:componentProviderMode ?mode . OPTIONAL { ?component usf:componentProviderBinding ?binding . ?binding usf:inEnvironment ?environment; usf:hasProviderMode ?mode; usf:bindsProvider ?provider; usf:bindsPort ?port . ?provider usf:hasProviderMode ?mode; usf:fulfilsPort ?port } } GROUP BY $this ?component ?environment HAVING(COUNT(DISTINCT ?binding) != 1)".
shp:RealisationDecisionShape sh:sparql _:oe_provider_binding_exact.

_:oe_container_immutable usf:constraintFailureCode <urn:usf:validationfailurecode:containerimagemutablereference>;
    sh:message "containerimagemutablereference: selected container images require an OCI sha256 digest reference matching the integrity binding";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE { $this usf:decisionState <urn:usf:decisionstate:accepted>; usf:selectsOption/usf:hasOptionComponent/usf:componentIdentity ?identity . ?identity a usf:ContainerImageComponent . FILTER NOT EXISTS { ?identity usf:componentAcquisitionSource ?source; usf:componentIntegrityDigest ?digest . FILTER(REGEX(STR(?source), '@sha256:[0-9a-f]{64}$') && CONCAT('sha256:', REPLACE(STR(?source), '^.*@sha256:', '')) = ?digest) } }".
shp:RealisationDecisionShape sh:sparql _:oe_container_immutable.

_:oe_composition_zero_counts usf:constraintFailureCode <urn:usf:validationfailurecode:compositioncoverageproofstaleormissing>;
    sh:message "compositioncoverageproofstaleormissing: current composition proof requires every structural and permutation counter to be zero";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE { $this usf:decisionState <urn:usf:decisionstate:accepted>; usf:selectsOption/usf:hasCompositionCoverageProof ?proof . FILTER NOT EXISTS { ?proof usf:compositionProofSuccessful true; usf:compositionProofCurrent true; usf:orphanResponsibilityCount 0; usf:duplicateResponsibilityCount 0; usf:invalidDependencyCount 0; usf:incompatibleInterfaceCount 0; usf:incompatibleComponentVersionCount 0; usf:unusedComponentCount 0; usf:unclassifiedPermutationCount 0 } }".
shp:RealisationDecisionShape sh:sparql _:oe_composition_zero_counts.

_:oe_compatibility_exact usf:constraintFailureCode <urn:usf:validationfailurecode:compositioninterfaceincompatible>;
    sh:message "compositioninterfaceincompatible: each selected dependency edge requires exactly one current successful exact-version interface compatibility assessment";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE { $this usf:decisionState <urn:usf:decisionstate:accepted>; usf:selectsOption ?option . ?option usf:hasOptionComponent ?source, ?target . ?source usf:dependsOnOptionComponent ?target; usf:componentIdentity ?sourceIdentity; usf:componentInterface ?interface . ?target usf:componentIdentity ?targetIdentity; usf:componentInterface ?interface . ?sourceIdentity usf:componentVersion ?sourceVersion; usf:componentIntegrityDigest ?sourceDigest . ?targetIdentity usf:componentVersion ?targetVersion; usf:componentIntegrityDigest ?targetDigest . OPTIONAL { ?assessment a usf:ComponentCompatibilityAssessment; usf:compatibilityForSourceComponent ?source; usf:compatibilityForTargetComponent ?target; usf:compatibilityForInterface ?interface; usf:compatibilitySourceVersion ?sourceVersion; usf:compatibilityTargetVersion ?targetVersion; usf:compatibilitySourceIntegrityDigest ?sourceDigest; usf:compatibilityTargetIntegrityDigest ?targetDigest; usf:compatibilitySuccessful true; usf:compatibilityCurrent true; usf:compatibilityEvidence ?evidence . ?evidence usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted>; usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh>; usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid>; usf:withinValidityScope true } } GROUP BY $this ?source ?target ?interface HAVING(COUNT(DISTINCT ?assessment) != 1)".
shp:RealisationDecisionShape sh:sparql _:oe_compatibility_exact.

_:oe_permutation_rule_set usf:constraintFailureCode <urn:usf:validationfailurecode:permutationrulesetinvalid>;
    sh:message "permutationrulesetinvalid: a selected composition requires one digest-bound finite deterministic rule set with exactly one default rule";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted>; usf:selectsOption ?option .\n  ?option a usf:ComposedRealisationOption .\n  {\n    FILTER NOT EXISTS {\n      ?option usf:hasCompositionPermutationAssessment ?assessment .\n      ?assessment usf:usesPermutationRuleSet ?ruleSet; usf:permutationEvidence ?evidence .\n      ?ruleSet usf:permutationRuleSetDigest ?digest; usf:hasPermutationDimension ?dimension; usf:hasPermutationClassificationRule ?rule .\n      ?dimension usf:permutationDimensionKey ?key; usf:permutationAllowedValue ?value .\n      ?rule usf:permutationRulePriority ?priority; usf:permutationRuleDisposition ?disposition; usf:permutationRuleDefault ?default; usf:permutationRuleEvidence ?evidence .\n      FILTER(REGEX(?digest, '^sha256:[0-9a-f]{64}$'))\n    }\n  }\n  UNION\n  {\n    FILTER NOT EXISTS {\n      ?option usf:hasCompositionPermutationAssessment/usf:usesPermutationRuleSet/usf:hasPermutationClassificationRule ?defaultRule .\n      ?defaultRule usf:permutationRuleDefault true .\n    }\n  }\n  UNION\n  {\n    ?option usf:hasCompositionPermutationAssessment/usf:usesPermutationRuleSet/usf:hasPermutationClassificationRule ?leftDefault, ?rightDefault .\n    ?leftDefault usf:permutationRuleDefault true . ?rightDefault usf:permutationRuleDefault true .\n    FILTER(?leftDefault != ?rightDefault)\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_permutation_rule_set.

_:oe_selected_mapping_exact usf:constraintFailureCode <urn:usf:validationfailurecode:selectedoptionrealisationmappingcardinality>;
    sh:message "selectedoptionrealisationmappingcardinality: each accepted decision requires exactly one active selected-option mapping";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> .\n  { FILTER NOT EXISTS { ?mapping a usf:SelectedOptionRealisationMapping ; usf:mappingForDecision $this ; usf:mappingState <urn:usf:mappingstate:active> } }\n  UNION\n  { ?left a usf:SelectedOptionRealisationMapping ; usf:mappingForDecision $this ; usf:mappingState <urn:usf:mappingstate:active> .\n    ?right a usf:SelectedOptionRealisationMapping ; usf:mappingForDecision $this ; usf:mappingState <urn:usf:mappingstate:active> . FILTER(?left != ?right) }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_selected_mapping_exact.

_:oe_component_mapping_cardinality usf:constraintFailureCode <urn:usf:validationfailurecode:selectedcomponentconcretemappingcardinality>;
    sh:message "selectedcomponentconcretemappingcardinality: each selected component requires exactly one active concrete mapping";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption ?option . ?option usf:hasOptionComponent ?component .\n  { FILTER NOT EXISTS { ?mapping a usf:SelectedComponentConcreteMapping ; usf:componentMappingForOption ?option ; usf:componentMappingForComponent ?component ; usf:mappingState <urn:usf:mappingstate:active> } }\n  UNION\n  { ?left a usf:SelectedComponentConcreteMapping ; usf:componentMappingForOption ?option ; usf:componentMappingForComponent ?component ; usf:mappingState <urn:usf:mappingstate:active> .\n    ?right a usf:SelectedComponentConcreteMapping ; usf:componentMappingForOption ?option ; usf:componentMappingForComponent ?component ; usf:mappingState <urn:usf:mappingstate:active> . FILTER(?left != ?right) }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_component_mapping_cardinality.

_:oe_mapping_dependency_drift usf:constraintFailureCode <urn:usf:validationfailurecode:selectionmappingdependencydrift>;
    sh:message "selectionmappingdependencydrift: every active mapping must bind the selected resources and current evaluation digests";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:decisionForContract ?contract ; usf:hasDecisionEvaluation ?evaluation ; usf:selectsOption ?option .\n  ?evaluation usf:evaluationAuthorityDigest ?authorityDigest ; usf:evaluationEvidenceDigest ?evidenceDigest ; usf:evaluationImplementationSourceDigest ?implementationDigest .\n  { ?mapping a usf:SelectedOptionRealisationMapping ; usf:mappingForDecision $this ; usf:mappingState <urn:usf:mappingstate:active> .\n    FILTER NOT EXISTS { ?mapping usf:mappingForEvaluation ?evaluation ; usf:mappingForSelectedOption ?option ; usf:mappingToRealisation ?realisation ; usf:mappingAuthorityDigest ?authorityDigest ; usf:mappingEvaluationDigest ?evidenceDigest ; usf:mappingImplementationSourceDigest ?implementationDigest . ?realisation usf:authorisedByDecision $this ; usf:realisesContract ?contract ; usf:realisesOption ?option . FILTER NOT EXISTS { ?mapping usf:mappingToRealisation ?otherRealisation . FILTER(?otherRealisation != ?realisation) } } }\n  UNION\n  { ?option usf:hasOptionComponent ?component . ?mapping a usf:SelectedComponentConcreteMapping ; usf:componentMappingForOption ?option ; usf:componentMappingForComponent ?component ; usf:mappingState <urn:usf:mappingstate:active> .\n    FILTER NOT EXISTS { ?mapping usf:mappingAuthorityDigest ?authorityDigest ; usf:mappingEvaluationDigest ?evidenceDigest ; usf:mappingImplementationSourceDigest ?implementationDigest } }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_mapping_dependency_drift.

_:oe_component_mapping_type usf:constraintFailureCode <urn:usf:validationfailurecode:selectedcomponentconcretemappingtypemismatch>;
    sh:message "selectedcomponentconcretemappingtypemismatch: concrete mapping targets must match component role, identity and dependency bindings";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:decisionState <urn:usf:decisionstate:accepted> ; usf:selectsOption ?option . ?option usf:hasOptionComponent ?component .\n  ?component usf:componentRole ?role ; usf:componentIdentity ?identity .\n  ?mapping a usf:SelectedComponentConcreteMapping ; usf:componentMappingForOption ?option ; usf:componentMappingForComponent ?component ; usf:mappingState <urn:usf:mappingstate:active> .\n  BIND(EXISTS { ?identity a usf:PackageComponent } || EXISTS { ?identity a usf:RuntimeComponent } || EXISTS { ?identity a usf:ContainerImageComponent } AS ?dependencyBacked)\n  BIND(EXISTS { ?mapping usf:componentMappingToImplementation ?implementation . ?implementation a usf:Implementation . FILTER NOT EXISTS { ?mapping usf:componentMappingToImplementation ?otherImplementation . FILTER(?otherImplementation != ?implementation) } } AS ?oneImplementation)\n  BIND(EXISTS { ?mapping usf:componentMappingToAdapter ?adapter . ?adapter a usf:Adapter . FILTER NOT EXISTS { ?mapping usf:componentMappingToAdapter ?otherAdapter . FILTER(?otherAdapter != ?adapter) } } AS ?oneAdapter)\n  BIND(EXISTS { ?identity usf:componentVersion ?version ; usf:componentIntegrityDigest ?integrityDigest ; usf:componentDependencyLockDigest ?lockDigest ; usf:componentAcquisitionSource ?acquisitionSource . ?mapping usf:componentMappingToDependencyBinding ?dependencyBinding . ?dependencyBinding a usf:DependencyBinding ; usf:dependencyBindingForComponentIdentity ?identity ; usf:dependencyBindingVersion ?version ; usf:dependencyBindingIntegrityDigest ?integrityDigest ; usf:dependencyBindingLockDigest ?lockDigest ; usf:dependencyBindingAcquisitionSource ?acquisitionSource ; usf:dependencyBindingRepresentation ?representation ; usf:dependencyBindingMaterialisationRule ?materialisationRule . FILTER NOT EXISTS { ?mapping usf:componentMappingToDependencyBinding ?otherDependencyBinding . FILTER(?otherDependencyBinding != ?dependencyBinding) } } AS ?oneDependencyBinding)\n  BIND(NOT EXISTS { ?mapping usf:componentMappingToProviderBinding ?mappedBinding . FILTER NOT EXISTS { ?component usf:componentProviderBinding ?mappedBinding . ?mappedBinding a usf:Binding } } && NOT EXISTS { ?component usf:componentProviderBinding ?requiredBinding . FILTER NOT EXISTS { ?mapping usf:componentMappingToProviderBinding ?requiredBinding . ?requiredBinding a usf:Binding } } AS ?providerBindingSetExact)\n  BIND(NOT EXISTS { ?mapping usf:componentMappingToImplementation ?unexpectedImplementation } AS ?noImplementation)\n  BIND(NOT EXISTS { ?mapping usf:componentMappingToAdapter ?unexpectedAdapter } AS ?noAdapter)\n  BIND(NOT EXISTS { ?mapping usf:componentMappingToProviderBinding ?unexpectedProviderBinding } AS ?noProviderBinding)\n  BIND(NOT EXISTS { ?mapping usf:componentMappingToDependencyBinding ?unexpectedDependencyBinding } AS ?noDependencyBinding)\n  FILTER NOT EXISTS {\n    FILTER((?role = <urn:usf:componentrole:provider> && ?providerBindingSetExact && ?noImplementation && ?noAdapter && ?noDependencyBinding) || (?role = <urn:usf:componentrole:adapter> && ?oneAdapter && ?noImplementation && ?noProviderBinding && ((?dependencyBacked && ?oneDependencyBinding) || (!?dependencyBacked && ?noDependencyBinding))) || (?role != <urn:usf:componentrole:provider> && ?role != <urn:usf:componentrole:adapter> && ?dependencyBacked && ?oneDependencyBinding && ?noImplementation && ?noAdapter && ?noProviderBinding) || (?role != <urn:usf:componentrole:provider> && ?role != <urn:usf:componentrole:adapter> && !?dependencyBacked && ?oneImplementation && ?noAdapter && ?noProviderBinding && ?noDependencyBinding))\n  }\n}".
shp:RealisationDecisionShape sh:sparql _:oe_component_mapping_type.

shp:CriterionRequirementShape a sh:NodeShape;
    usf:canonicalName "criterionrequirementshape";
    sh:targetClass usf:CriterionRequirement.
_:oe_requirement_evaluation sh:path usf:criterionForEvaluation; sh:minCount 1; sh:maxCount 1; sh:class usf:DecisionEvaluation; sh:message "criterionrequirementevaluationcardinality: criterion requirement requires exactly one evaluation".
shp:CriterionRequirementShape sh:property _:oe_requirement_evaluation.
_:oe_requirement_criterion sh:path usf:requiresCriterion; sh:minCount 1; sh:maxCount 1; sh:class usf:EvaluationCriterion; sh:message "criterionidentitycardinality: criterion requirement requires exactly one criterion".
shp:CriterionRequirementShape sh:property _:oe_requirement_criterion.
_:oe_requirement_applicability sh:path usf:criterionApplicability; sh:minCount 1; sh:maxCount 1; sh:class usf:CriterionApplicability; sh:message "criterionapplicabilitycardinality: criterion requirement requires exactly one applicability".
shp:CriterionRequirementShape sh:property _:oe_requirement_applicability.
_:oe_requirement_mandatory sh:path usf:criterionMandatory; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:boolean; sh:message "criterionmandatorycardinality: criterion requirement requires exactly one mandatory boolean".
shp:CriterionRequirementShape sh:property _:oe_requirement_mandatory.

shp:CriterionMitigationShape a sh:NodeShape;
    usf:canonicalName "criterionmitigationshape";
    sh:targetClass usf:CriterionMitigation.
_:oe_mitigation_accepted sh:path usf:mitigationAccepted; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:boolean; sh:hasValue true; sh:message "criterionmitigationaccepted: criterion mitigation must be explicitly accepted".
shp:CriterionMitigationShape sh:property _:oe_mitigation_accepted.
_:oe_mitigation_statement sh:path usf:mitigationStatement; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "criterionmitigationstatementcardinality: criterion mitigation requires one statement".
shp:CriterionMitigationShape sh:property _:oe_mitigation_statement.
_:oe_mitigation_evidence sh:path usf:mitigationEvidence; sh:minCount 1; sh:maxCount 1; sh:class usf:EvidenceResult; sh:message "criterionmitigationevidencecardinality: criterion mitigation requires one evidence result".
shp:CriterionMitigationShape sh:property _:oe_mitigation_evidence.
_:oe_mitigation_invalidation sh:path usf:mitigationInvalidationCondition; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "criterionmitigationinvalidationcardinality: criterion mitigation requires one invalidation condition".
shp:CriterionMitigationShape sh:property _:oe_mitigation_invalidation.

_:oe_component_option sh:path usf:componentForOption; sh:minCount 1; sh:maxCount 1; sh:class usf:RealisationOption; sh:message "componentoptioncardinality: option component requires exactly one owning option".
shp:OptionComponentShape sh:property _:oe_component_option.
_:oe_component_statement sh:path usf:componentResponsibility; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componentresponsibilitycardinality: option component requires exactly one responsibility statement".
shp:OptionComponentShape sh:property _:oe_component_statement.
_:oe_component_data sh:path usf:componentDataOwnershipBoundary; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componentdataownershipboundarycardinality: option component requires exactly one data-ownership boundary".
shp:OptionComponentShape sh:property _:oe_component_data.
_:oe_component_transaction sh:path usf:componentTransactionBoundary; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componenttransactionboundarycardinality: option component requires exactly one transaction boundary".
shp:OptionComponentShape sh:property _:oe_component_transaction.
_:oe_component_security sh:path usf:componentSecurityBoundary; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componentsecurityboundarycardinality: option component requires exactly one security boundary".
shp:OptionComponentShape sh:property _:oe_component_security.
_:oe_component_secret sh:path usf:componentSecretBoundary; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componentsecretboundarycardinality: option component requires exactly one secret boundary".
shp:OptionComponentShape sh:property _:oe_component_secret.
_:oe_component_deployment sh:path usf:componentDeploymentBoundary; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componentdeploymentboundarycardinality: option component requires exactly one deployment boundary".
shp:OptionComponentShape sh:property _:oe_component_deployment.
_:oe_component_failure sh:path usf:componentFailurePropagation; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componentfailurepropagationcardinality: option component requires exactly one failure-propagation rule".
shp:OptionComponentShape sh:property _:oe_component_failure.
_:oe_component_retry sh:path usf:componentRetryPolicy; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componentretrypolicycardinality: option component requires exactly one retry policy".
shp:OptionComponentShape sh:property _:oe_component_retry.
_:oe_component_timeout sh:path usf:componentTimeoutPolicy; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componenttimeoutpolicycardinality: option component requires exactly one timeout policy".
shp:OptionComponentShape sh:property _:oe_component_timeout.
_:oe_component_upgrade sh:path usf:componentUpgradeCompatibility; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componentupgradecompatibilitycardinality: option component requires exactly one upgrade-compatibility rule".
shp:OptionComponentShape sh:property _:oe_component_upgrade.
_:oe_component_rollback sh:path usf:componentRollbackOrder; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componentrollbackordercardinality: option component requires exactly one rollback order".
shp:OptionComponentShape sh:property _:oe_component_rollback.
_:oe_component_replacement sh:path usf:componentReplacementBoundary; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "componentreplacementboundarycardinality: option component requires exactly one replacement boundary".
shp:OptionComponentShape sh:property _:oe_component_replacement.

shp:CompositionInterfaceShape a sh:NodeShape;
    usf:canonicalName "compositioninterfaceshape";
    sh:targetClass usf:CompositionInterface.
_:oe_composition_interface_contract sh:path usf:compositionInterfaceForContract; sh:minCount 1; sh:maxCount 1; sh:class usf:SemanticContract; sh:message "compositioninterfacecontractcardinality: composition interface requires exactly one governing contract".
shp:CompositionInterfaceShape sh:property _:oe_composition_interface_contract.
_:oe_composition_interface_responsibility sh:path usf:compositionInterfaceResponsibility; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "compositioninterfaceresponsibilitycardinality: composition interface requires exactly one responsibility boundary".
shp:CompositionInterfaceShape sh:property _:oe_composition_interface_responsibility.
_:oe_composition_interface_security sh:path usf:compositionInterfaceSecurityBoundary; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "compositioninterfacesecurityboundarycardinality: composition interface requires exactly one security boundary".
shp:CompositionInterfaceShape sh:property _:oe_composition_interface_security.
_:oe_composition_interface_failure sh:path usf:compositionInterfaceFailureBehaviour; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:message "compositioninterfacefailurebehaviourcardinality: composition interface requires exactly one failure boundary".
shp:CompositionInterfaceShape sh:property _:oe_composition_interface_failure.

shp:RealisationOptionSelectionContractShape a sh:NodeShape;
    usf:canonicalName "realisationoptionselectioncontractshape";
    sh:targetClass usf:SemanticContract.
_:oe_active_contract_selection sh:message "activecontractselectionevaluationmissing: an active contract requiring option evaluation needs an accepted structured decision";
    sh:select "PREFIX usf: <urn:usf:ontology:>\nSELECT $this WHERE {\n  $this usf:hasActivationState <urn:usf:contractactivationstate:active> ; usf:requiresRealisationOptionEvaluation true .\n  FILTER NOT EXISTS { ?decision a usf:RealisationDecision ; usf:decisionState <urn:usf:decisionstate:accepted> ; usf:decisionForContract $this ; usf:hasDecisionEvaluation ?evaluation . ?evaluation a usf:DecisionEvaluation ; usf:evaluationForDecision ?decision }\n}".
shp:RealisationOptionSelectionContractShape sh:sparql _:oe_active_contract_selection.
