@prefix usf: <urn:usf:ontology:>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix shp: <urn:usf:shacl:>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

shp:RealisationShape a sh:NodeShape;
    usf:canonicalName "realisationshape";
    sh:targetClass usf:Realisation.
_:b41_b41_n3-758 sh:path usf:realisesContract;
    sh:minCount 1;
    sh:class usf:SemanticContract;
    sh:message "realisationcontract: realisation must realise at least one semantic contract".
shp:RealisationShape sh:property _:b41_b41_n3-758.
_:b41_b41_n3-759 sh:path usf:realisingImplementation;
    sh:class usf:Implementation;
    sh:message "realisationimplementation: a realising implementation must be a declared implementation".
shp:RealisationShape sh:property _:b41_b41_n3-759.
_:b41_b41_n3-760 sh:path usf:viaService;
    sh:class usf:Service;
    sh:message "realisationservice: a realisation service must be a declared service".
shp:RealisationShape sh:property _:b41_b41_n3-760.
_:b41_b41_n3-761 sh:path usf:viaAdapter;
    sh:class usf:Adapter;
    sh:message "realisationadapter: a realisation adapter must be a declared adapter".
shp:RealisationShape sh:property _:b41_b41_n3-761.
_:b41_b41_n3-762 sh:path usf:viaBinding;
    sh:class usf:Binding;
    sh:message "realisationbinding: a realisation binding must be a declared binding".
shp:RealisationShape sh:property _:b41_b41_n3-762.
_:b41_b41_n3-763 sh:path usf:realisationState;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:RealisationState;
    sh:message "realisationstate: realisation must declare one state".
shp:RealisationShape sh:property _:b41_b41_n3-763.
_:b41_b41_n3-764 sh:prefixes usf:prefixes;
    sh:message "realisationrealiser: a realisation claiming completed realisation must name an implementation, service, adapter or binding; contract-only, implementable, deferred, not-claimed and deprecated states are exempt";
    sh:select "SELECT $this WHERE {\n          $this usf:realisationState ?state .\n          FILTER(?state NOT IN (<urn:usf:realisationstate:contractonly>, <urn:usf:realisationstate:implementable>, <urn:usf:realisationstate:deferred>,\n                                <urn:usf:realisationstate:notclaimed>, <urn:usf:realisationstate:deprecated>))\n          FILTER NOT EXISTS { $this usf:realisingImplementation ?implementation }\n          FILTER NOT EXISTS { $this usf:viaService ?service }\n          FILTER NOT EXISTS { $this usf:viaAdapter ?adapter }\n          FILTER NOT EXISTS { $this usf:viaBinding ?binding }\n        }".
shp:RealisationShape sh:sparql _:b41_b41_n3-764.
_:b41_b41_n3-765 sh:prefixes usf:prefixes;
    sh:message "realisationdecision: a completed realisation must be authorised by an accepted decision; contract-only, implementable, deferred, not-claimed and deprecated states are exempt";
    sh:select "SELECT $this WHERE {\n          $this usf:realisationState ?state .\n          FILTER(?state NOT IN (<urn:usf:realisationstate:contractonly>, <urn:usf:realisationstate:implementable>, <urn:usf:realisationstate:deferred>,\n                                <urn:usf:realisationstate:notclaimed>, <urn:usf:realisationstate:deprecated>))\n          FILTER NOT EXISTS {\n            $this usf:authorisedByDecision ?decision .\n            ?decision usf:decisionState <urn:usf:decisionstate:accepted> ;\n              usf:selectsOption ?selected ; usf:hasDecisionEvaluation ?evaluation .\n            ?evaluation usf:evaluationForDecision ?decision ;\n              usf:evaluationClosureState <urn:usf:evaluationclosurestate:complete> .\n          }\n        }".
shp:RealisationShape sh:sparql _:b41_b41_n3-765.
shp:ImplementationShape a sh:NodeShape;
    usf:canonicalName "implementationshape";
    sh:targetClass usf:Implementation.
shp:ServiceShape a sh:NodeShape;
    usf:canonicalName "serviceshape";
    sh:targetClass usf:Service.
_:b41_b41_n3-766 sh:path usf:dependsOnService;
    sh:maxCount 0;
    sh:message "servicedependencysuperseded: broad service dependencies are prohibited; use an explicit DeployableProcessDependency".
shp:ServiceShape sh:property _:b41_b41_n3-766.
shp:AdapterShape a sh:NodeShape;
    usf:canonicalName "adaptershape";
    sh:targetClass usf:Adapter.
_:b41_b41_n3-767 sh:path usf:implementsPort;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:Port;
    sh:message "adapterport: adapter must implement exactly one port".
shp:AdapterShape sh:property _:b41_b41_n3-767.
_:b41_b41_n3-768 sh:path usf:bindsProvider;
    sh:minCount 1;
    sh:class usf:Provider;
    sh:message "adapterprovider: adapter must bind at least one provider".
shp:AdapterShape sh:property _:b41_b41_n3-768.
shp:BindingShape a sh:NodeShape;
    usf:canonicalName "bindingshape";
    sh:targetClass usf:Binding.
_:b41_b41_n3-769 sh:path usf:bindsPort;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:Port;
    sh:message "bindingport: binding must name exactly one port".
shp:BindingShape sh:property _:b41_b41_n3-769.
_:b41_b41_n3-770 sh:path usf:bindingProvider;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:Provider;
    sh:message "bindingprovider: binding must name exactly one provider".
shp:BindingShape sh:property _:b41_b41_n3-770.
_:binding_environment sh:path usf:bindingEnvironment;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:Environment;
    sh:message "BINDING_ENVIRONMENT_MISSING: binding must name exactly one typed runtime environment".
shp:BindingShape sh:property _:binding_environment.
_:binding_generic_provider_prohibited sh:path usf:bindsProvider;
    sh:maxCount 0;
    sh:message "BINDING_GENERIC_PROVIDER_PROHIBITED: binding provider identity must use the typed bindingProvider relation".
shp:BindingShape sh:property _:binding_generic_provider_prohibited.
_:binding_generic_environment_prohibited sh:path usf:inEnvironment;
    sh:maxCount 0;
    sh:message "BINDING_GENERIC_ENVIRONMENT_PROHIBITED: runtime binding environment must use the typed bindingEnvironment relation".
shp:BindingShape sh:property _:binding_generic_environment_prohibited.
_:b41_b41_n3-771 sh:path usf:hasProviderMode;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:ProviderMode;
    sh:message "bindingprovidermode: binding must declare exactly one provider mode".
shp:BindingShape sh:property _:b41_b41_n3-771.
_:b41_b41_n3-772 sh:path usf:bindingState;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:BindingState;
    sh:message "bindingstate: binding must declare exactly one lifecycle state".
shp:BindingShape sh:property _:b41_b41_n3-772.
_:binding_provider_port_coherence sh:prefixes usf:prefixes;
    sh:message "BINDING_PROVIDER_PORT_MISMATCH: the selected provider must fulfil the bound port";
    sh:select "SELECT $this WHERE { $this usf:bindingProvider ?provider ; usf:bindsPort ?port . FILTER NOT EXISTS { ?provider usf:fulfilsPort ?port } }".
shp:BindingShape sh:sparql _:binding_provider_port_coherence.
_:binding_provider_mode_coherence sh:prefixes usf:prefixes;
    sh:message "BINDING_PROVIDER_MODE_MISMATCH: the selected provider must declare the binding provider mode";
    sh:select "SELECT $this WHERE { $this usf:bindingProvider ?provider ; usf:hasProviderMode ?mode . FILTER NOT EXISTS { ?provider usf:hasProviderMode ?mode } }".
shp:BindingShape sh:sparql _:binding_provider_mode_coherence.
_:binding_port_mode_coherence sh:prefixes usf:prefixes;
    sh:message "BINDING_PORT_MODE_PROHIBITED: the bound port must permit the binding provider mode";
    sh:select "SELECT $this WHERE { $this usf:bindsPort ?port ; usf:hasProviderMode ?mode . FILTER NOT EXISTS { ?port usf:permitsProviderMode ?mode } }".
shp:BindingShape sh:sparql _:binding_port_mode_coherence.
