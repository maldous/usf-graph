_:b40_b40_n3-742 sh:message "detecteddefectwithoutdefect: detected-defect result must identify a planted defect";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n          $this usf:resultState <urn:usf:resultstate:detecteddefect> .\n          FILTER NOT EXISTS { $this usf:detectedDefect ?defect }\n        }".
shp:TestResultShape sh:sparql _:b40_b40_n3-742.
shp:EvidencePipelineShape a sh:NodeShape;
    usf:canonicalName "evidencepipelineshape";
    sh:targetClass usf:EvidenceResult.
_:b40_b40_n3-743 sh:path usf:evidenceFor;
    sh:minCount 1.
shp:EvidencePipelineShape sh:property _:b40_b40_n3-743.
_:b40_b40_n3-744 sh:message "freshvalidationevidencewithoutpassingvalidation: fresh validation evidence must originate from a passing validation result";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n          $this a usf:ValidationEvidence ; usf:hasFreshness <urn:usf:freshness:fresh> .\n          FILTER NOT EXISTS {\n            ?validationResult a usf:ValidationResult ;\n              usf:resultState <urn:usf:resultstate:passed> ;\n              usf:entersEvidenceLifecycleAs $this .\n            ?execution a usf:ValidationExecution ;\n              usf:producesValidationResult ?validationResult\n          }\n        }".
shp:EvidencePipelineShape sh:sparql _:b40_b40_n3-744.
_:b40_b40_n3-745 sh:message "admissibleevidencemissingpipeline: satisfying evidence lacks a required stage or pipeline operation";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n          ?requirement usf:satisfiedByEvidence $this ; usf:requiresEvidenceStage ?stage .\n          FILTER NOT EXISTS { $this usf:evidenceStage ?stage }\n        }".
shp:EvidencePipelineShape sh:sparql _:b40_b40_n3-745.
_:b40_b40_n3-746 sh:message "admissibleevidenceunsigned: satisfying evidence lacks signature, checksum, or passing integrity verification";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n          ?requirement usf:satisfiedByEvidence $this .\n          FILTER(\n            NOT EXISTS { $this usf:evidenceSignature ?signature } ||\n            NOT EXISTS { $this usf:evidenceChecksum ?checksum } ||\n            NOT EXISTS {\n              $this usf:integrityVerification ?verification .\n              ?verification usf:verifiesEvidence $this ;\n                usf:verificationState <urn:usf:resultstate:passed> .\n            }\n          )\n        }".
shp:EvidencePipelineShape sh:sparql _:b40_b40_n3-746.
