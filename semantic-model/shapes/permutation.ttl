shp:PermutationRelationshipSignatureReviewShape sh:property _:prsr19.
_:prsr20 sh:path usf:relationshipSignatureReviewRegistryDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
