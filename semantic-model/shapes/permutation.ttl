    sh:message "UNIVERSAL_REVIEW_REASON_CODE_INVALID: one stable reason code is required".
shp:SemanticTermPermutationReviewShape sh:property _:stpr5.
_:stpr6 sh:path usf:termPermutationSourcePlane; sh:minCount 1; sh:maxCount 1; sh:minLength 1;
