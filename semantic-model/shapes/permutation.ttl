shp:PermutationRelationshipSignatureReviewShape sh:property _:prsr20.
_:prsr21 sh:path usf:relationshipSignatureReviewEvidenceDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
