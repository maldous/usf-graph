_:stpr4Closed sh:path usf:termPermutationFamilyCandidateState;
    sh:in (<urn:usf:permutationfamilycandidateclassification:notafamilycandidate> <urn:usf:permutationfamilycandidateclassification:authorityreviewrequired> <urn:usf:permutationfamilycandidateclassification:warranted> <urn:usf:permutationfamilycandidateclassification:rejected>);
    sh:message "UNIVERSAL_REVIEW_FAMILY_STATE_OUTSIDE_CLOSED_SET: family-candidate classification must be one of the four controlled values".
