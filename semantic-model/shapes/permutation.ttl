shp:SemanticTermPermutationReviewShape sh:property _:stpr6.
_:stpr7 sh:path usf:termPermutationAuthorityDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
