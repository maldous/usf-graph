shp:SemanticTermPermutationReviewShape sh:property _:stpr7.
_:stpr8 sh:path usf:termPermutationInventoryDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "UNIVERSAL_REVIEW_INVENTORY_BINDING_ABSENT: one exact inventory digest is required".
shp:SemanticTermPermutationReviewShape sh:property _:stpr8.
_:stpr9 sh:path usf:termPermutationReviewDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "UNIVERSAL_REVIEW_DIGEST_ABSENT: one exact review digest is required".
shp:SemanticTermPermutationReviewShape sh:property _:stpr9.
_:stpr10 sh:prefixes usf:prefixes;
    sh:message "UNIVERSAL_REVIEW_AUTHORISATION_PROHIBITED: a semantic-term review cannot establish truth, activate a contract, admit evidence or establish proof directly";
    sh:select "SELECT $this WHERE { $this ?predicate ?value . FILTER (?predicate IN (usf:establishesSemanticTruth, usf:directlyActivatesContract, usf:directlyAdmitsEvidence, usf:directlyEstablishesProof)) } LIMIT 1".
shp:SemanticTermPermutationReviewShape sh:sparql _:stpr10.

shp:PermutationReviewCoverageShape a sh:NodeShape;
    usf:canonicalName "permutationreviewcoverageshape";
    sh:targetClass usf:PermutationReviewCoverage.
_:prc1 sh:path usf:permutationReviewAuthorityDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "PERMUTATION_REVIEW_AUTHORITY_BINDING_ABSENT: coverage needs one exact authority digest".
shp:PermutationReviewCoverageShape sh:property _:prc1.
_:prc2 sh:path usf:permutationReviewInventoryDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "PERMUTATION_REVIEW_INVENTORY_BINDING_ABSENT: coverage needs one exact semantic-input inventory digest".
shp:PermutationReviewCoverageShape sh:property _:prc2.
_:prc3 sh:path usf:permutationReviewFamilyRegistryDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "PERMUTATION_REVIEW_REGISTRY_BINDING_ABSENT: coverage needs one exact family-registry digest".
shp:PermutationReviewCoverageShape sh:property _:prc3.
_:prc4 sh:path usf:permutationReviewTermSetAlgorithm; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string;
    sh:message "PERMUTATION_REVIEW_TERM_ALGORITHM_ABSENT: coverage needs one deterministic term-set algorithm identity".
shp:PermutationReviewCoverageShape sh:property _:prc4.
_:prc4Exact sh:path usf:permutationReviewTermSetAlgorithm; sh:in ("semantic-input-term-key-set-v1");
    sh:message "PERMUTATION_REVIEW_TERM_ALGORITHM_MISMATCH: term-set algorithm must be semantic-input-term-key-set-v1".
shp:PermutationReviewCoverageShape sh:property _:prc4Exact.
_:prc5 sh:path usf:permutationReviewFamilySignatureAlgorithm; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string;
    sh:message "PERMUTATION_REVIEW_FAMILY_ALGORITHM_ABSENT: coverage needs one deterministic family-signature algorithm identity".
shp:PermutationReviewCoverageShape sh:property _:prc5.
_:prc5Exact sh:path usf:permutationReviewFamilySignatureAlgorithm; sh:in ("family-record-canonical-json-sha256-v1");
    sh:message "PERMUTATION_REVIEW_FAMILY_ALGORITHM_MISMATCH: family-signature algorithm must be family-record-canonical-json-sha256-v1".
shp:PermutationReviewCoverageShape sh:property _:prc5Exact.
_:prc6 sh:path usf:permutationReviewExpectedTerm; sh:minCount 1; sh:nodeKind sh:IRI;
    sh:message "PERMUTATION_REVIEW_EXPECTED_TERM_SET_EMPTY: coverage needs the complete expected term set".
shp:PermutationReviewCoverageShape sh:property _:prc6.
_:prc7 sh:path usf:permutationReviewTermReview; sh:minCount 1; sh:class usf:SemanticTermPermutationReview;
    sh:message "PERMUTATION_REVIEW_TERM_REVIEW_SET_EMPTY: coverage needs its exact term-review set".
shp:PermutationReviewCoverageShape sh:property _:prc7.
_:prc8 sh:path usf:permutationReviewExpectedFamily; sh:minCount 1; sh:class usf:PermutationFamily;
    sh:message "PERMUTATION_REVIEW_EXPECTED_FAMILY_SET_EMPTY: coverage needs the complete registered-family set".
shp:PermutationReviewCoverageShape sh:property _:prc8.
_:prc9 sh:path usf:permutationReviewFamilySignatureReview; sh:minCount 1; sh:class usf:PermutationFamilySignatureReview;
    sh:message "PERMUTATION_REVIEW_FAMILY_REVIEW_SET_EMPTY: coverage needs its exact family-signature review set".
shp:PermutationReviewCoverageShape sh:property _:prc9.
_:prc10 sh:path usf:permutationReviewDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "PERMUTATION_REVIEW_COVERAGE_DIGEST_ABSENT: coverage needs one exact digest".
shp:PermutationReviewCoverageShape sh:property _:prc10.
_:prc11 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_REVIEW_TERM_SET_MISMATCH: expected terms and reviewed terms must be identical";
    sh:select "SELECT $this WHERE { $this usf:permutationReviewExpectedTerm ?expectedWitness; usf:permutationReviewTermReview ?reviewWitness . { $this usf:permutationReviewExpectedTerm ?term . FILTER NOT EXISTS { $this usf:permutationReviewTermReview ?review . ?review usf:reviewedSemanticTerm ?term } } UNION { $this usf:permutationReviewTermReview ?review . ?review usf:reviewedSemanticTerm ?term . FILTER NOT EXISTS { $this usf:permutationReviewExpectedTerm ?term } } } LIMIT 1".
shp:PermutationReviewCoverageShape sh:sparql _:prc11.
_:prc12 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_REVIEW_TERM_DUPLICATE: each expected semantic term must have exactly one linked review";
    sh:select "SELECT $this WHERE { $this usf:permutationReviewTermReview ?left, ?right . ?left usf:reviewedSemanticTerm ?term . ?right usf:reviewedSemanticTerm ?term . FILTER (?left != ?right) } LIMIT 1".
shp:PermutationReviewCoverageShape sh:sparql _:prc12.
_:prc13 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_REVIEW_TERM_BINDING_MISMATCH: linked term reviews must share the coverage authority and inventory digests";
    sh:select "SELECT $this WHERE { $this usf:permutationReviewAuthorityDigest ?authority; usf:permutationReviewInventoryDigest ?inventory; usf:permutationReviewTermReview ?review . ?review usf:termPermutationAuthorityDigest ?reviewAuthority; usf:termPermutationInventoryDigest ?reviewInventory . FILTER (?authority != ?reviewAuthority || ?inventory != ?reviewInventory) } LIMIT 1".
shp:PermutationReviewCoverageShape sh:sparql _:prc13.
_:prc14 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_REVIEW_FAMILY_SET_MISMATCH: expected families and reviewed family signatures must be identical";
    sh:select "SELECT $this WHERE { $this usf:permutationReviewExpectedFamily ?expectedWitness; usf:permutationReviewFamilySignatureReview ?reviewWitness . { $this usf:permutationReviewExpectedFamily ?family . FILTER NOT EXISTS { $this usf:permutationReviewFamilySignatureReview ?review . ?review usf:reviewedPermutationFamily ?family } } UNION { $this usf:permutationReviewFamilySignatureReview ?review . ?review usf:reviewedPermutationFamily ?family . FILTER NOT EXISTS { $this usf:permutationReviewExpectedFamily ?family } } } LIMIT 1".
shp:PermutationReviewCoverageShape sh:sparql _:prc14.
_:prc15 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_REVIEW_FAMILY_DUPLICATE: each expected family must have exactly one linked signature review";
    sh:select "SELECT $this WHERE { $this usf:permutationReviewFamilySignatureReview ?left, ?right . ?left usf:reviewedPermutationFamily ?family . ?right usf:reviewedPermutationFamily ?family . FILTER (?left != ?right) } LIMIT 1".
shp:PermutationReviewCoverageShape sh:sparql _:prc15.
_:prc16 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_REVIEW_FAMILY_BINDING_MISMATCH: linked family-signature reviews must share the coverage authority and registry digests";
    sh:select "SELECT $this WHERE { $this usf:permutationReviewAuthorityDigest ?authority; usf:permutationReviewFamilyRegistryDigest ?registry; usf:permutationReviewFamilySignatureReview ?review . ?review usf:familySignatureReviewAuthorityDigest ?reviewAuthority; usf:familySignatureReviewRegistryDigest ?reviewRegistry . FILTER (?authority != ?reviewAuthority || ?registry != ?reviewRegistry) } LIMIT 1".
shp:PermutationReviewCoverageShape sh:sparql _:prc16.
_:prc17 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_REVIEW_COVERAGE_DUPLICATE: one authority, semantic-input inventory and family-registry tuple may have only one coverage resource";
    sh:select "SELECT $this WHERE { $this usf:permutationReviewAuthorityDigest ?authority; usf:permutationReviewInventoryDigest ?inventory; usf:permutationReviewFamilyRegistryDigest ?registry . ?other a usf:PermutationReviewCoverage; usf:permutationReviewAuthorityDigest ?authority; usf:permutationReviewInventoryDigest ?inventory; usf:permutationReviewFamilyRegistryDigest ?registry . FILTER (?other != $this) } LIMIT 1".
shp:PermutationReviewCoverageShape sh:sparql _:prc17.
_:prc18 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_REVIEW_AUTHORISATION_PROHIBITED: a coverage projection cannot establish truth, activate a contract, admit evidence or establish proof directly";
    sh:select "SELECT $this WHERE { $this ?predicate ?value . FILTER (?predicate IN (usf:establishesSemanticTruth, usf:directlyActivatesContract, usf:directlyAdmitsEvidence, usf:directlyEstablishesProof)) } LIMIT 1".
shp:PermutationReviewCoverageShape sh:sparql _:prc18.

shp:PermutationFamilySignatureReviewShape a sh:NodeShape;
    usf:canonicalName "permutationfamilysignaturereviewshape";
    sh:targetClass usf:PermutationFamilySignatureReview.
_:pfsr1 sh:path usf:reviewedPermutationFamily; sh:minCount 1; sh:maxCount 1; sh:class usf:PermutationFamily;
