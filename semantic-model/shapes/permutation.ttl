shp:FoundationConformanceProjectionRuleShape sh:property _:fcpr6.
_:fcpr7 sh:prefixes usf:prefixes;
    sh:message "FOUNDATION_PROJECTION_MAPPING_INCOMPLETE: digest-shadow rules need mappings and only the permission-atom structural alias may carry mappings";
    sh:select "SELECT $this WHERE { $this usf:foundationProjectionIdentityMode ?mode . { FILTER (?mode = <urn:usf:foundationprojectionidentitymode:digestshadow>) FILTER NOT EXISTS { $this usf:foundationProjectionPredicateMapping ?mapping } } UNION { FILTER (?mode = <urn:usf:foundationprojectionidentitymode:sourcealias>) $this usf:foundationProjectionPredicateMapping ?mapping . FILTER NOT EXISTS { $this usf:foundationProjectionSourceClass usf:FoundationPermissionAtomWitness; usf:foundationProjectionTargetClass usf:PermissionAtom } } UNION { FILTER (?mode = <urn:usf:foundationprojectionidentitymode:sourcealias>) $this usf:foundationProjectionSourceClass usf:FoundationPermissionAtomWitness; usf:foundationProjectionTargetClass usf:PermissionAtom . FILTER NOT EXISTS { $this usf:foundationProjectionPredicateMapping ?mapping } } }".
shp:FoundationConformanceProjectionRuleShape sh:sparql _:fcpr7.

