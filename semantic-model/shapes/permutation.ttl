shp:PermutationFamilyCandidateShape sh:property _:pfcrPredicate.
_:pfcrTerminalClass sh:path usf:candidateRelationshipTerminalClass; sh:maxCount 1; sh:nodeKind sh:IRI;
    sh:message "UNIVERSAL_CANDIDATE_TERMINAL_CLASS_INVALID: object relationship candidate terminal class must be one IRI".
shp:PermutationFamilyCandidateShape sh:property _:pfcrTerminalClass.
_:pfcrTerminalDatatype sh:path usf:candidateRelationshipTerminalDatatype; sh:maxCount 1; sh:nodeKind sh:IRI;
    sh:message "UNIVERSAL_CANDIDATE_TERMINAL_DATATYPE_INVALID: datatype relationship candidate terminal datatype must be one IRI".
shp:PermutationFamilyCandidateShape sh:property _:pfcrTerminalDatatype.
_:pfcr4 sh:path usf:candidateFamilyClassification; sh:minCount 1; sh:maxCount 1; sh:class usf:PermutationFamilyCandidateClassification;
    sh:message "UNIVERSAL_CANDIDATE_CLASSIFICATION_ABSENT: one controlled authority-review state is required".
shp:PermutationFamilyCandidateShape sh:property _:pfcr4.
_:pfcr4Closed sh:path usf:candidateFamilyClassification;
    sh:in (<urn:usf:permutationfamilycandidateclassification:notafamilycandidate> <urn:usf:permutationfamilycandidateclassification:authorityreviewrequired> <urn:usf:permutationfamilycandidateclassification:warranted> <urn:usf:permutationfamilycandidateclassification:rejected>);
    sh:message "UNIVERSAL_CANDIDATE_CLASSIFICATION_OUTSIDE_CLOSED_SET: candidate classification must be one of the four controlled values".
shp:PermutationFamilyCandidateShape sh:property _:pfcr4Closed.
_:pfcr5 sh:path usf:candidateFamilyReasonCode; sh:minCount 1; sh:maxCount 1; sh:pattern "^UNIVERSAL_[A-Z0-9_]+$";
    sh:message "UNIVERSAL_CANDIDATE_REASON_INVALID: one stable reason code is required".
shp:PermutationFamilyCandidateShape sh:property _:pfcr5.
_:pfcr6 sh:path usf:candidateFamilyAuthorityDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "UNIVERSAL_CANDIDATE_AUTHORITY_BINDING_ABSENT: one exact authority digest is required".
shp:PermutationFamilyCandidateShape sh:property _:pfcr6.
_:pfcr7 sh:path usf:candidateFamilyInventoryDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "UNIVERSAL_CANDIDATE_INVENTORY_BINDING_ABSENT: one exact inventory digest is required".
shp:PermutationFamilyCandidateShape sh:property _:pfcr7.
_:pfcr8 sh:path usf:candidateFamilyDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "UNIVERSAL_CANDIDATE_DIGEST_ABSENT: one exact candidate digest is required".
shp:PermutationFamilyCandidateShape sh:property _:pfcr8.
_:pfcr9 sh:path usf:candidateFamilyMissingTermCount; sh:maxCount 1; sh:datatype xsd:nonNegativeInteger;
    sh:message "UNIVERSAL_CANDIDATE_MISSING_TERM_COUNT_INVALID: missing-term count must be one non-negative integer".
shp:PermutationFamilyCandidateShape sh:property _:pfcr9.
_:pfcr10 sh:path usf:candidateFamilyEmptyAxisCount; sh:maxCount 1; sh:datatype xsd:nonNegativeInteger;
    sh:message "UNIVERSAL_CANDIDATE_EMPTY_AXIS_COUNT_INVALID: empty-axis count must be one non-negative integer".
shp:PermutationFamilyCandidateShape sh:property _:pfcr10.
_:pfcr11 sh:prefixes usf:prefixes;
    sh:message "UNIVERSAL_CANDIDATE_WARRANTED_WITH_GAPS: a warranted family candidate cannot retain missing terms or empty finite axes";
    sh:select """
      SELECT $this WHERE {
        $this usf:candidateFamilyKind <urn:usf:permutationfamilycandidatekind:multiaxisfamily>;
              usf:candidateFamilyClassification <urn:usf:permutationfamilycandidateclassification:warranted>;
              usf:candidateFamilyMissingTermCount ?missing;
              usf:candidateFamilyEmptyAxisCount ?empty.
        FILTER (?missing != 0 || ?empty != 0)
      }
    """.
shp:PermutationFamilyCandidateShape sh:sparql _:pfcr11.
_:pfcrMultiAxis sh:prefixes usf:prefixes;
    sh:message "UNIVERSAL_CANDIDATE_MULTI_AXIS_COMPONENTS_ABSENT: a multi-axis candidate needs axis, selector, missing-term count and empty-axis count components";
    sh:select "SELECT $this WHERE { $this usf:candidateFamilyKind <urn:usf:permutationfamilycandidatekind:multiaxisfamily> . FILTER (!EXISTS { $this usf:candidateFamilyAxisClass ?axis } || !EXISTS { $this usf:candidateFamilySelectorProperty ?selector } || !EXISTS { $this usf:candidateFamilyMissingTermCount ?missing } || !EXISTS { $this usf:candidateFamilyEmptyAxisCount ?empty }) } LIMIT 1".
shp:PermutationFamilyCandidateShape sh:sparql _:pfcrMultiAxis.
_:pfcrRelationship sh:prefixes usf:prefixes;
    sh:message "UNIVERSAL_CANDIDATE_RELATIONSHIP_COMPONENTS_ABSENT: an atomic relationship candidate needs signature, signature digest, direction and predicate components";
    sh:select "SELECT $this WHERE { $this usf:candidateFamilyKind ?kind . FILTER (?kind IN (<urn:usf:permutationfamilycandidatekind:objectrelationship>, <urn:usf:permutationfamilycandidatekind:datatyperelationship>)) FILTER (!EXISTS { $this usf:candidateRelationshipSignature ?signature } || !EXISTS { $this usf:candidateRelationshipSignatureDigest ?digest } || !EXISTS { $this usf:candidateRelationshipDirection ?direction } || !EXISTS { $this usf:candidateRelationshipPredicate ?predicate }) } LIMIT 1".
shp:PermutationFamilyCandidateShape sh:sparql _:pfcrRelationship.
_:pfcrEndpoint sh:prefixes usf:prefixes;
    sh:message "UNIVERSAL_CANDIDATE_ENDPOINT_MODE_INVALID: object candidates need one terminal class and no datatype; datatype candidates need one datatype and no terminal class";
    sh:select "SELECT $this WHERE { $this usf:candidateFamilyKind ?kind . BIND (EXISTS { $this usf:candidateRelationshipTerminalClass ?terminalClass } AS ?hasClass) BIND (EXISTS { $this usf:candidateRelationshipTerminalDatatype ?terminalDatatype } AS ?hasDatatype) FILTER ((?kind = <urn:usf:permutationfamilycandidatekind:objectrelationship> && (!?hasClass || ?hasDatatype)) || (?kind = <urn:usf:permutationfamilycandidatekind:datatyperelationship> && (!?hasDatatype || ?hasClass))) } LIMIT 1".
shp:PermutationFamilyCandidateShape sh:sparql _:pfcrEndpoint.
_:pfcrFormIsolation sh:prefixes usf:prefixes;
    sh:message "UNIVERSAL_CANDIDATE_FORM_COMPONENT_CONFLICT: multi-axis and atomic relationship components cannot be mixed";
    sh:select "SELECT $this WHERE { $this usf:candidateFamilyKind ?kind . FILTER ((?kind = <urn:usf:permutationfamilycandidatekind:multiaxisfamily> && EXISTS { $this ?relationshipComponent ?value . FILTER (?relationshipComponent IN (usf:candidateRelationshipSignature, usf:candidateRelationshipSignatureDigest, usf:candidateRelationshipDirection, usf:candidateRelationshipPredicate, usf:candidateRelationshipTerminalClass, usf:candidateRelationshipTerminalDatatype)) }) || (?kind IN (<urn:usf:permutationfamilycandidatekind:objectrelationship>, <urn:usf:permutationfamilycandidatekind:datatyperelationship>) && EXISTS { $this ?multiAxisComponent ?value . FILTER (?multiAxisComponent IN (usf:candidateFamilyAxisClass, usf:candidateFamilySelectorProperty, usf:candidateFamilyMissingTermCount, usf:candidateFamilyEmptyAxisCount)) })) } LIMIT 1".
shp:PermutationFamilyCandidateShape sh:sparql _:pfcrFormIsolation.
_:pfcr12 sh:prefixes usf:prefixes;
    sh:message "UNIVERSAL_CANDIDATE_AUTHORISATION_PROHIBITED: a family candidate cannot establish truth, activate a contract, admit evidence or establish proof directly";
    sh:select "SELECT $this WHERE { $this ?predicate ?value . FILTER (?predicate IN (usf:establishesSemanticTruth, usf:directlyActivatesContract, usf:directlyAdmitsEvidence, usf:directlyEstablishesProof)) } LIMIT 1".
shp:PermutationFamilyCandidateShape sh:sparql _:pfcr12.
