shp:PermutationFamilySignatureReviewShape sh:property _:pfsr1.
_:pfsr2 sh:path usf:reviewedFamilySubjectRegistration; sh:minCount 1; sh:maxCount 1; sh:class usf:PermutationSubjectRegistration;
    sh:message "PERMUTATION_FAMILY_SIGNATURE_SUBJECT_ABSENT: signature review needs the exact subject registration".
shp:PermutationFamilySignatureReviewShape sh:property _:pfsr2.
_:pfsr3 sh:path usf:reviewedFamilyDimensionBinding; sh:minCount 1; sh:class usf:PermutationFamilyDimensionBinding;
    sh:message "PERMUTATION_FAMILY_SIGNATURE_DIMENSION_SET_EMPTY: signature review needs every ordered dimension binding".
shp:PermutationFamilySignatureReviewShape sh:property _:pfsr3.
_:pfsr4 sh:path usf:reviewedFamilyApplicabilityRule; sh:minCount 1; sh:maxCount 1; sh:class usf:PermutationApplicabilityRule;
    sh:message "PERMUTATION_FAMILY_SIGNATURE_APPLICABILITY_ABSENT: signature review needs the exact applicability rule".
shp:PermutationFamilySignatureReviewShape sh:property _:pfsr4.
_:pfsr5 sh:path usf:familySignatureReviewAuthorityDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "PERMUTATION_FAMILY_SIGNATURE_AUTHORITY_BINDING_ABSENT: signature review needs one exact authority digest".
shp:PermutationFamilySignatureReviewShape sh:property _:pfsr5.
_:pfsr6 sh:path usf:familySignatureReviewRegistryDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "PERMUTATION_FAMILY_SIGNATURE_REGISTRY_BINDING_ABSENT: signature review needs one exact registry digest".
shp:PermutationFamilySignatureReviewShape sh:property _:pfsr6.
_:pfsr7 sh:path usf:reviewedFamilySignatureDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "PERMUTATION_FAMILY_SIGNATURE_DIGEST_ABSENT: signature review needs the independently calculated family signature digest".
shp:PermutationFamilySignatureReviewShape sh:property _:pfsr7.
_:pfsr8 sh:path usf:familySignatureReviewDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "PERMUTATION_FAMILY_SIGNATURE_REVIEW_DIGEST_ABSENT: signature review needs one exact review digest".
shp:PermutationFamilySignatureReviewShape sh:property _:pfsr8.
_:pfsrDisposition sh:path usf:familySignatureReviewDisposition; sh:minCount 1; sh:maxCount 1; sh:class usf:PermutationFamilyModelReviewDisposition;
    sh:message "PERMUTATION_FAMILY_SIGNATURE_DISPOSITION_ABSENT: signature review needs exactly one controlled disposition".
shp:PermutationFamilySignatureReviewShape sh:property _:pfsrDisposition.
_:pfsrDispositionClosed sh:path usf:familySignatureReviewDisposition;
    sh:in (<urn:usf:permutationfamilymodelreviewdisposition:warranted>);
    sh:message "PERMUTATION_FAMILY_SIGNATURE_DISPOSITION_OUTSIDE_CLOSED_SET: only the warranted exact-signature review state is permitted".
shp:PermutationFamilySignatureReviewShape sh:property _:pfsrDispositionClosed.
_:pfsr9 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_FAMILY_SIGNATURE_COMPONENT_MISMATCH: reviewed subject, dimension and applicability components must exactly equal the registered family";
    sh:select "SELECT $this WHERE { $this usf:reviewedPermutationFamily ?family; usf:reviewedFamilySubjectRegistration ?subjectWitness; usf:reviewedFamilyDimensionBinding ?dimensionWitness; usf:reviewedFamilyApplicabilityRule ?applicabilityWitness . ?family usf:familySubjectRegistration ?familySubjectWitness; usf:hasFamilyDimensionBinding ?familyDimensionWitness; usf:familyApplicabilityRule ?familyApplicabilityWitness . { ?family usf:familySubjectRegistration ?component . FILTER NOT EXISTS { $this usf:reviewedFamilySubjectRegistration ?component } } UNION { $this usf:reviewedFamilySubjectRegistration ?component . FILTER NOT EXISTS { ?family usf:familySubjectRegistration ?component } } UNION { ?family usf:hasFamilyDimensionBinding ?component . FILTER NOT EXISTS { $this usf:reviewedFamilyDimensionBinding ?component } } UNION { $this usf:reviewedFamilyDimensionBinding ?component . FILTER NOT EXISTS { ?family usf:hasFamilyDimensionBinding ?component } } UNION { ?family usf:familyApplicabilityRule ?component . FILTER NOT EXISTS { $this usf:reviewedFamilyApplicabilityRule ?component } } UNION { $this usf:reviewedFamilyApplicabilityRule ?component . FILTER NOT EXISTS { ?family usf:familyApplicabilityRule ?component } } } LIMIT 1".
shp:PermutationFamilySignatureReviewShape sh:sparql _:pfsr9.
_:pfsr10 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_FAMILY_SIGNATURE_DUPLICATE: one family and authority/registry snapshot may have only one signature review";
    sh:select "SELECT $this WHERE { $this usf:reviewedPermutationFamily ?family; usf:familySignatureReviewAuthorityDigest ?authority; usf:familySignatureReviewRegistryDigest ?registry . ?other a usf:PermutationFamilySignatureReview; usf:reviewedPermutationFamily ?family; usf:familySignatureReviewAuthorityDigest ?authority; usf:familySignatureReviewRegistryDigest ?registry . FILTER (?other != $this) } LIMIT 1".
shp:PermutationFamilySignatureReviewShape sh:sparql _:pfsr10.
_:pfsr11 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_FAMILY_SIGNATURE_AUTHORISATION_PROHIBITED: a signature review cannot establish truth, activate a contract, admit evidence or establish proof directly";
    sh:select "SELECT $this WHERE { $this ?predicate ?value . FILTER (?predicate IN (usf:establishesSemanticTruth, usf:directlyActivatesContract, usf:directlyAdmitsEvidence, usf:directlyEstablishesProof)) } LIMIT 1".
shp:PermutationFamilySignatureReviewShape sh:sparql _:pfsr11.

