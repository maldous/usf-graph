shp:PermutationRelationshipSignatureReviewShape sh:property _:prsr21.
_:prsr22 sh:path usf:relationshipSignatureReviewAlgorithmDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "PERMUTATION_RELATIONSHIP_REVIEW_ALGORITHM_BINDING_ABSENT: relationship review needs an independent method digest".
shp:PermutationRelationshipSignatureReviewShape sh:property _:prsr22.
_:prsr23 sh:path usf:relationshipSignatureReviewDigest; sh:minCount 1; sh:maxCount 1; sh:datatype xsd:string; sh:pattern "^sha256:[0-9a-f]{64}$";
    sh:message "PERMUTATION_RELATIONSHIP_REVIEW_DIGEST_ABSENT: relationship review needs one exact review digest".
shp:PermutationRelationshipSignatureReviewShape sh:property _:prsr23.
_:prsr24 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_RELATIONSHIP_REVIEW_ENDPOINT_MODE_INVALID: literal signatures need exactly one datatype and no object class; named-node and blank-node signatures prohibit a datatype";
    sh:select "SELECT $this WHERE { $this usf:reviewedRelationshipObjectTermKind ?kind . BIND (EXISTS { $this usf:reviewedRelationshipObjectDatatype ?datatype } AS ?hasDatatype) BIND (EXISTS { $this usf:reviewedRelationshipObjectClass ?objectClass } AS ?hasObjectClass) FILTER ((?kind = <urn:usf:permutationrelationshipobjecttermkind:literal> && (!?hasDatatype || ?hasObjectClass)) || (?kind != <urn:usf:permutationrelationshipobjecttermkind:literal> && ?hasDatatype)) } LIMIT 1".
shp:PermutationRelationshipSignatureReviewShape sh:sparql _:prsr24.
_:prsr25 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_RELATIONSHIP_REVIEW_CANDIDATE_BINDING_INCOMPLETE: candidate identity and digest must be present together";
    sh:select "SELECT $this WHERE { BIND (EXISTS { $this usf:relationshipSignatureReviewCandidate ?candidate } AS ?hasCandidate) BIND (EXISTS { $this usf:relationshipSignatureReviewCandidateDigest ?digest } AS ?hasDigest) FILTER (?hasCandidate != ?hasDigest) } LIMIT 1".
shp:PermutationRelationshipSignatureReviewShape sh:sparql _:prsr25.
_:prsr26 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_RELATIONSHIP_REVIEW_CANDIDATE_DIGEST_MISMATCH: linked candidate and recorded candidate digest must agree";
    sh:select "SELECT $this WHERE { $this usf:relationshipSignatureReviewCandidate ?candidate; usf:relationshipSignatureReviewCandidateDigest ?expected . ?candidate usf:candidateFamilyDigest ?actual . FILTER (?expected != ?actual) } LIMIT 1".
shp:PermutationRelationshipSignatureReviewShape sh:sparql _:prsr26.
_:prsr27 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_RELATIONSHIP_REVIEW_DUPLICATE: one signature and authority/inventory tuple may have only one review";
    sh:select "SELECT $this WHERE { $this usf:reviewedRelationshipSignature ?signature; usf:relationshipSignatureReviewAuthorityDigest ?authority; usf:relationshipSignatureReviewInventoryDigest ?inventory . ?other a usf:PermutationRelationshipSignatureReview; usf:reviewedRelationshipSignature ?signature; usf:relationshipSignatureReviewAuthorityDigest ?authority; usf:relationshipSignatureReviewInventoryDigest ?inventory . FILTER (?other != $this) } LIMIT 1".
shp:PermutationRelationshipSignatureReviewShape sh:sparql _:prsr27.
_:prsr28 sh:prefixes usf:prefixes;
    sh:message "PERMUTATION_RELATIONSHIP_REVIEW_AUTHORISATION_PROHIBITED: a relationship review cannot establish truth, create a family, activate a contract, admit evidence or establish proof directly";
    sh:select "SELECT $this WHERE { $this ?predicate ?value . FILTER (?predicate IN (usf:establishesSemanticTruth, usf:directlyActivatesContract, usf:directlyAdmitsEvidence, usf:directlyEstablishesProof)) } LIMIT 1".
