shp:FoundationConformanceProjectionRuleShape sh:property _:fcpr5.
_:fcpr6 sh:path usf:foundationProjectionRuleDigest; sh:minCount 1; sh:maxCount 1; sh:pattern "^sha256:[0-9a-f]{64}$";
