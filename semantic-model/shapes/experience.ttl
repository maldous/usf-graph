    sh:select "\n            SELECT $this WHERE {\n              $this usf:hasField ?left, ?right .\n              FILTER(STR(?left) < STR(?right))\n              { ?left usf:fieldName ?v . ?right usf:fieldName ?v }\n              UNION\n              { ?left usf:fieldOrder ?v . ?right usf:fieldOrder ?v }\n            }\n        ".
