_:b36_b36_n3-366 sh:message "ui-exposed capabilities require a UI semantic model; all other exposure classes forbid one.";
    sh:prefixes usf:prefixes;
    sh:select "\n            SELECT $this WHERE {\n              $this usf:uiExposure ?exposure .\n              BIND(EXISTS { $this usf:hasUISemanticModel ?model } AS ?hasModel)\n              FILTER((?exposure = <urn:usf:uiexposureclass:uiexposed> && !?hasModel) ||\n                     (?exposure != <urn:usf:uiexposureclass:uiexposed> && ?hasModel))\n            }\n        ".
