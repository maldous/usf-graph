_:b33_b33_n3-246 sh:prefixes usf:prefixes;
    sh:message "UI facet status must agree with exact capability exposure and UI semantic-model authority";
    sh:select "SELECT $this WHERE {\n          $this <urn:usf:ontology:facetKind> <urn:usf:facetkind:uisemantics> .\n          ?contract usf:declaresFacet $this . ?capability usf:hasContract ?contract ; usf:uiExposure ?exposure .\n          $this usf:facetStatus ?status .\n          BIND(EXISTS { ?capability usf:hasUISemanticModel ?model } AS ?hasModel)\n          FILTER((?status = <urn:usf:facetstatus:complete> && (?exposure != <urn:usf:uiexposureclass:uiexposed> || !?hasModel)) ||\n                 (?status = <urn:usf:facetstatus:notapplicable> && (?exposure = <urn:usf:uiexposureclass:uiexposed> || ?hasModel)) ||\n                 ?status = <urn:usf:facetstatus:gap>)\n        }".
