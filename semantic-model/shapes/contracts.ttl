_:b33_b33_n3-241 sh:prefixes usf:prefixes;
    sh:message "contractsupersession: a deprecated contract requires one distinct canonical successor";
    sh:select "SELECT $this WHERE {\n        $this usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:deprecated> .\n        FILTER NOT EXISTS { $this usf:supersededBy ?successor . FILTER(?successor != $this) }\n      }".
