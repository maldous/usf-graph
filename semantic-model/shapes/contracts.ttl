    sh:class usf:DeployableProcess.
shp:ActiveCapabilityProcessBoundaryShape sh:property _:b33_b33_n3-236.
_:b33_b33_n3-237 sh:prefixes usf:prefixes;
    sh:message "capability process accountability and participation must be inverse-complete and assurance boundaries cannot become product runtime";
    sh:select "SELECT $this WHERE {\n        $this usf:hasContract ?contract . ?contract usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:active> .\n        { $this usf:accountableProcessBoundary ?process . FILTER NOT EXISTS { ?process usf:processOwnsCapability $this } }\n        UNION\n        { $this usf:participatesInProcess ?process . FILTER NOT EXISTS { ?process usf:processForCapability $this } }\n        UNION\n        { ?process usf:processForCapability $this . FILTER NOT EXISTS { $this usf:participatesInProcess ?process } }\n        UNION\n        { $this usf:accountableProcessBoundary ?assurance .\n          ?assurance usf:processBoundaryClass <urn:usf:processboundaryclass:assurancecontrolplane> .\n          $this usf:participatesInProcess ?runtime .\n          ?runtime usf:processBoundaryClass <urn:usf:processboundaryclass:productruntime> . }\n      }".
shp:ActiveCapabilityProcessBoundaryShape sh:sparql _:b33_b33_n3-237.
