shp:ActiveCapabilityEncapsulationShape a sh:NodeShape;
    usf:canonicalName "activecapabilityencapsulationshape";
    sh:targetClass usf:Capability.
_:b33_b33_n3-234 sh:prefixes usf:prefixes;
    sh:message "active capability requires definition, repository name and accountable and responsible ownership";
    sh:select "SELECT $this WHERE {\n        $this usf:hasContract ?contract . ?contract usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:active> .\n        FILTER(NOT EXISTS { $this usf:definition ?definition } ||\n               NOT EXISTS { $this usf:repositoryName ?repositoryName } ||\n               NOT EXISTS { $this usf:accountableOwner ?accountable } ||\n               NOT EXISTS { $this usf:responsibleOwner ?responsible })\n      }".
shp:ActiveCapabilityEncapsulationShape sh:sparql _:b33_b33_n3-234.
