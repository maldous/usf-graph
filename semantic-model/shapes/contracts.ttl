shp:CurrentWorkflowShape a sh:NodeShape;
    usf:canonicalName "currentworkflowshape";
    sh:targetClass usf:Workflow.
_:b33_b33_n3-323 sh:prefixes usf:prefixes;
    sh:message "current workflow requires owner, state closure, transitions and execution policy";
    sh:select "SELECT $this WHERE {\n        FILTER NOT EXISTS { $this usf:semanticAdequacyDisposition ?disposition . FILTER(?disposition != <urn:usf:semanticadequacydisposition:independentlywarrantedretained>) }\n        FILTER(NOT EXISTS { $this usf:workflowForContract ?contract } ||\n               NOT EXISTS { $this usf:hasState ?state } ||\n               NOT EXISTS { $this usf:hasTransition ?transition } ||\n               NOT EXISTS { $this usf:workflowExecutionPolicy ?policy })\n      }".
