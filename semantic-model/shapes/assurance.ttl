_:b32_b32_n3-174 sh:prefixes usf:prefixes;
    sh:message "semantic adequacy disposition must select exactly the permitted final identity form";
    sh:select "SELECT $this WHERE {\n        $this usf:semanticAdequacyDisposition ?kind .\n        BIND(EXISTS { $this usf:finalCanonicalSemanticItem ?final } AS ?hasFinal)\n        FILTER(\n          (?kind IN (<urn:usf:semanticadequacydisposition:independentlywarrantedretained>, <urn:usf:semanticadequacydisposition:correctedorrenamed>, <urn:usf:semanticadequacydisposition:consolidated>, <urn:usf:semanticadequacydisposition:split>) && !?hasFinal) ||\n          (?kind IN (<urn:usf:semanticadequacydisposition:superseded>, <urn:usf:semanticadequacydisposition:historicalprovenanceonly>, <urn:usf:semanticadequacydisposition:unresolvedexternaldecision>) && ?hasFinal)\n        )\n      }".
