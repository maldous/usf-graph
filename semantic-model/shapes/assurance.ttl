_:b32_b32_n3-144 sh:message "proofauthoritybinding: self-publication exclusions must be exactly the three closure graphs and five deterministic derived graphs";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n            { $this a usf:ProofAuthorityBinding .\n              FILTER NOT EXISTS { $this usf:excludedAuthorityGraphIri \"urn:usf:graph:capabilities\"^^xsd:anyURI } }\n            UNION\n            { $this a usf:ProofAuthorityBinding .\n              FILTER NOT EXISTS { $this usf:excludedAuthorityGraphIri \"urn:usf:graph:derived:coverage\"^^xsd:anyURI } }\n            UNION\n            { $this a usf:ProofAuthorityBinding .\n              FILTER NOT EXISTS { $this usf:excludedAuthorityGraphIri \"urn:usf:graph:derived:evidence\"^^xsd:anyURI } }\n            UNION\n            { $this a usf:ProofAuthorityBinding .\n              FILTER NOT EXISTS { $this usf:excludedAuthorityGraphIri \"urn:usf:graph:derived:obligations\"^^xsd:anyURI } }\n            UNION\n            { $this a usf:ProofAuthorityBinding .\n              FILTER NOT EXISTS { $this usf:excludedAuthorityGraphIri \"urn:usf:graph:derived:readiness\"^^xsd:anyURI } }\n            UNION\n            { $this a usf:ProofAuthorityBinding .\n              FILTER NOT EXISTS { $this usf:excludedAuthorityGraphIri \"urn:usf:graph:derived:surfaces\"^^xsd:anyURI } }\n            UNION\n            { $this a usf:ProofAuthorityBinding .\n              FILTER NOT EXISTS { $this usf:excludedAuthorityGraphIri \"urn:usf:graph:evidence\"^^xsd:anyURI } }\n            UNION\n            { $this a usf:ProofAuthorityBinding .\n              FILTER NOT EXISTS { $this usf:excludedAuthorityGraphIri \"urn:usf:graph:proofs\"^^xsd:anyURI } }\n            UNION\n            {\n              $this usf:excludedAuthorityGraphIri ?actual .\n              FILTER(?actual NOT IN (\n                \"urn:usf:graph:capabilities\"^^xsd:anyURI,\n                \"urn:usf:graph:derived:coverage\"^^xsd:anyURI,\n                \"urn:usf:graph:derived:evidence\"^^xsd:anyURI,\n                \"urn:usf:graph:derived:obligations\"^^xsd:anyURI,\n                \"urn:usf:graph:derived:readiness\"^^xsd:anyURI,\n                \"urn:usf:graph:derived:surfaces\"^^xsd:anyURI,\n                \"urn:usf:graph:evidence\"^^xsd:anyURI,\n                \"urn:usf:graph:proofs\"^^xsd:anyURI\n              ))\n            }\n        }".
shp:ProofAuthorityBindingShape sh:sparql _:b32_b32_n3-144.
