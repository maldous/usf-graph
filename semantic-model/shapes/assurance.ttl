shp:SemanticAdequacyDispositionShape sh:property shp:SemanticAdequacyDispositionSourceDigestPropertyShape;
    sh:sparql [
        sh:prefixes usf:prefixes;
        sh:message "semantic adequacy proxy identity must equal its source-item digest";
        sh:select "SELECT $this WHERE { $this usf:sourceItemDigest ?digest . FILTER(!STRSTARTS(STR($this), 'urn:usf:historicalitem:') || STRAFTER(STR($this), 'urn:usf:historicalitem:') != STRAFTER(STR(?digest), 'sha256:')) }"
    ].
_:b32_b32_n3-173 sh:path usf:finalCanonicalSemanticItem;
