_:b32_b32_n3-206 sh:message "soadecisionparity: SoA must contain exactly one decision for every control in its edition and none outside it";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n          $this usf:soaForEdition ?edition .\n          { ?edition usf:hasFrameworkControl ?control .\n            FILTER NOT EXISTS { $this usf:hasApplicabilityDecision/usf:decisionForControl ?control } }\n          UNION\n          { $this usf:hasApplicabilityDecision/usf:decisionForControl ?control .\n            FILTER NOT EXISTS { ?edition usf:hasFrameworkControl ?control } }\n          UNION\n          { $this usf:hasApplicabilityDecision ?first, ?second .\n            ?first usf:decisionForControl ?control . ?second usf:decisionForControl ?control .\n            FILTER(STR(?first) < STR(?second)) }\n        }".
