    sh:message "semantic adequacy review item count must equal its exact disposition projection";
    sh:select "SELECT $this WHERE {\n        $this usf:reviewedItemCount ?expected .\n        { SELECT $this (COUNT(DISTINCT ?item) AS ?actual) WHERE {\n            ?item usf:reviewedInSemanticAdequacyReview $this .\n          } GROUP BY $this }\n        FILTER(?actual != ?expected)\n      }".
