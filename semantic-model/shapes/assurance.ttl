_:b32_b32_n3-157 sh:prefixes usf:prefixes;
    sh:message "semantic-review evidence must bind a descriptor selected by the reviewed semantic subject";
    sh:select "SELECT $this WHERE {\n        $this usf:evidenceKind <urn:usf:evidencekind:semanticreviewevidence> ;\n              usf:concernsSemanticSubject ?review ; usf:contentDigest ?digest .\n        FILTER NOT EXISTS {\n          ?review a usf:SemanticAdequacyReview ;\n                  (usf:usesDispositionInventoryDescriptor|usf:usesIndependentReviewDescriptor|usf:usesSemanticAdequacyProofDescriptor) ?descriptor .\n          ?descriptor usf:descriptorDigest ?digest .\n        }\n      }".
