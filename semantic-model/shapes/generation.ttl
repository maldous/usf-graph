    sh:class usf:Checksum.
shp:ArtefactShape sh:property _:b37_b37_n3-472.
_:b37_b37_n3-473 sh:prefixes usf:prefixes;
    sh:message "materialisedartefactchecksum: built or bundled artefact requires a canonical checksum";
    sh:select "SELECT $this WHERE {\n      { ?build usf:buildsArtefact $this } UNION { ?bundle usf:bundlesArtefact $this }\n      FILTER NOT EXISTS { $this usf:canonicalChecksum ?checksum }\n    }".
shp:ArtefactShape sh:sparql _:b37_b37_n3-473.
shp:ArtefactPlanShape a sh:NodeShape;
