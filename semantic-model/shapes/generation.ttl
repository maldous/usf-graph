shp:ArtefactShape a sh:NodeShape;
    usf:canonicalName "artefactshape";
    sh:targetClass usf:Artefact.
_:b37_b37_n3-469 sh:path usf:artefactKind;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class usf:ArtefactKind.
shp:ArtefactShape sh:property _:b37_b37_n3-469.
_:b37_b37_n3-470 sh:path usf:canonicalPath;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string;
    sh:pattern "^(?!/)(?!.*(?:^|/)(?:v2|legacy|old|new|temp|transitional|usf)(?:/|$))(?!.*(?:^|/)\\.\\.(?:/|$)).+$".
shp:ArtefactShape sh:property _:b37_b37_n3-470.
