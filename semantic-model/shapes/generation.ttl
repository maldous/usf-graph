shp:ArtefactPlanShape sh:property _:b37_b37_n3-476.
_:b37_b37_n3-477 sh:prefixes usf:prefixes;
    sh:message "plannedartifactgenerator: every planned artifact requires exactly one compiler component";
    sh:select "SELECT $this WHERE {\n      $this usf:plansArtefact ?artefact .\n      { FILTER NOT EXISTS { ?artefact usf:generatedByComponent ?component . ?component a/rdfs:subClassOf* usf:CompilerComponent } }\n      UNION\n      { ?artefact usf:generatedByComponent ?left, ?right . FILTER(?left != ?right) }\n    }".
shp:ArtefactPlanShape sh:sparql _:b37_b37_n3-477.
_:b37_b37_n3-478 sh:prefixes usf:prefixes;
    sh:message "planspecificsemanticresource: source-specific semantic-contract output requires exactly one planned semantic resource";
    sh:select "SELECT $this WHERE {\n      $this usf:plansArtefact ?artefact .\n      ?artefact usf:generatedByComponent <urn:usf:generator:semanticcontract> .\n      FILTER NOT EXISTS { $this usf:plansSemanticResource ?resource }\n    }".
shp:ArtefactPlanShape sh:sparql _:b37_b37_n3-478.
