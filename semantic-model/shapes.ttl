@prefix usf: <urn:usf:ontology:>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix shp: <urn:usf:shacl:>.

_:b31_b31_n3-104 sh:prefix "usf";
    sh:namespace "urn:usf:ontology:"^^xsd:anyURI.
usf:prefixes sh:declare _:b31_b31_n3-104.
_:b31_b31_n3-105 sh:prefix "rdf";
    sh:namespace "http://www.w3.org/1999/02/22-rdf-syntax-ns#"^^xsd:anyURI.
usf:prefixes sh:declare _:b31_b31_n3-105.
_:b31_b31_n3-106 sh:prefix "rdfs";
    sh:namespace "http://www.w3.org/2000/01/rdf-schema#"^^xsd:anyURI.
usf:prefixes sh:declare _:b31_b31_n3-106.
shp:CanonicalNameShape a sh:NodeShape;
    usf:canonicalName "canonicalnameshape";
    sh:targetClass usf:Entity, usf:ControlledValue.
_:b31_b31_n3-107 sh:path usf:canonicalName;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string;
    sh:pattern "^[a-z][a-z0-9]*$";
    sh:message "canonicalname: missing or non-canonical canonical name (lowercase, nonhyphenated)".
shp:CanonicalNameShape sh:property _:b31_b31_n3-107.
shp:IriHyphenShape a sh:NodeShape;
    usf:canonicalName "irihyphenshape";
    sh:targetClass usf:Entity, usf:ControlledValue.
_:b31_b31_n3-108 sh:pattern "^urn:usf:(.*:)?[^:]*[-_][^:]*$".
shp:IriHyphenShape sh:not _:b31_b31_n3-108;
    sh:message "hyphenatedidentifier: canonical local name contains a hyphen or underscore".
shp:IriNameAgreementShape a sh:NodeShape;
    usf:canonicalName "irinameagreementshape";
    sh:targetNode <urn:usf:ontology>.
_:b31_b31_n3-109 sh:message "canonicalidentity: canonicalName must equal the IRI local segment";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n            FILTER EXISTS {\n                {\n                    ?subject rdf:type/rdfs:subClassOf* usf:Entity .\n                }\n                UNION\n                {\n                    ?subject rdf:type/rdfs:subClassOf* usf:ControlledValue .\n                }\n                FILTER(isIRI(?subject) && STRSTARTS(STR(?subject),'urn:usf:'))\n                ?subject usf:canonicalName ?cn .\n                BIND(REPLACE(STR(?subject),'^.*:','') AS ?loc)\n                FILTER(?loc != STR(?cn))\n            }\n        }".
shp:IriNameAgreementShape sh:sparql _:b31_b31_n3-109.
shp:ContaminationShape a sh:NodeShape;
    usf:canonicalName "contaminationshape";
    sh:targetNode <urn:usf:ontology>.
_:b31_b31_n3-110 sh:message "forbiddenmetadata: forbidden external metadata pattern in IRI";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n            FILTER EXISTS {\n                {\n                    ?subject rdf:type/rdfs:subClassOf* usf:Entity .\n                }\n                UNION\n                {\n                    ?subject rdf:type/rdfs:subClassOf* usf:ControlledValue .\n                }\n                FILTER NOT EXISTS { ?subject usf:observedInCensusRun ?run }\n                FILTER(isIRI(?subject))\n                FILTER(REGEX(STR(?subject),'lin[e]ar[.]app|github[.]com|gitlab[.]com|refs/heads|commitSha|branchName|issueI[d]|projectI[d]|ADR-[0-9]|U[S]F-[0-9]','i'))\n            }\n        }".
shp:ContaminationShape sh:sparql _:b31_b31_n3-110.
_:b31_b31_n3-111 sh:message "forbiddenmetadata: forbidden external metadata pattern in literal value";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n            FILTER EXISTS {\n                {\n                    ?subject rdf:type/rdfs:subClassOf* usf:Entity .\n                }\n                UNION\n                {\n                    ?subject rdf:type/rdfs:subClassOf* usf:ControlledValue .\n                }\n                FILTER NOT EXISTS { ?subject usf:observedInCensusRun ?run }\n                ?subject ?p ?o .\n                FILTER(isLiteral(?o))\n                FILTER(REGEX(STR(?o),'lin[e]ar[.]app|github[.]com|gitlab[.]com|refs/heads|commitSha|branchName|issueI[d]|projectI[d]|ADR-[0-9]|U[S]F-[0-9]'))\n            }\n        }".
shp:ContaminationShape sh:sparql _:b31_b31_n3-111.
shp:ProviderModeShape a sh:NodeShape;
    usf:canonicalName "providermodeshape";
    sh:targetClass usf:ProviderMode.
_:b31_b31_n3-112 sh:path usf:canonicalName;
    sh:minCount 1.
shp:ProviderModeShape sh:property _:b31_b31_n3-112.
shp:SemanticAuthorityReasoningSchemaShape a sh:NodeShape;
    usf:canonicalName "semanticauthorityreasoningschemashape";
    sh:targetClass usf:SemanticAuthority.
_:b31_b31_n3-113 sh:path usf:defaultReasoningSchemaGraph;
    sh:minCount 2;
    sh:maxCount 2;
    sh:nodeKind sh:IRI.
_:b31_b31_n3-114 rdf:first <urn:usf:namedgraph:ontology>;
    rdf:rest _:b31_b31_n3-115.
_:b31_b31_n3-115 rdf:first <urn:usf:namedgraph:taxonomy>;
    rdf:rest rdf:nil.
_:b31_b31_n3-113 sh:in _:b31_b31_n3-114;
    sh:message "reasoningschemagraphs: default reasoning schema contains exactly the ontology and taxonomy named graphs".
shp:SemanticAuthorityReasoningSchemaShape sh:property _:b31_b31_n3-113.
_:b31_b31_n3-116 sh:path usf:defaultReasoningSchemaGraph;
    sh:hasValue <urn:usf:namedgraph:ontology>;
    sh:message "reasoningschemagraphs: ontology graph is required".
shp:SemanticAuthorityReasoningSchemaShape sh:property _:b31_b31_n3-116.
_:b31_b31_n3-117 sh:path usf:defaultReasoningSchemaGraph;
    sh:hasValue <urn:usf:namedgraph:taxonomy>;
    sh:message "reasoningschemagraphs: taxonomy graph is required".
shp:SemanticAuthorityReasoningSchemaShape sh:property _:b31_b31_n3-117.
shp:ContractFacetCompletenessShape a sh:NodeShape;
    usf:canonicalName "contractfacetcompletenessshape";
    sh:targetObjectsOf usf:hasContract.
_:b31_b31_n3-118 sh:message "missingcontractfacet: semantic contract does not declare all ten mandatory facet kinds";
    sh:prefixes usf:prefixes;
    sh:select "SELECT $this WHERE {\n            <urn:usf:ontology> usf:mandatoryFacets/rdf:rest*/rdf:first ?required .\n            FILTER NOT EXISTS {\n                $this usf:declaresFacet ?f . ?f usf:facetKind ?required .\n            }\n        }".
shp:ContractFacetCompletenessShape sh:sparql _:b31_b31_n3-118.
