PREFIX usf: <urn:usf:ontology:>
PREFIX closure: <urn:usf:evaluationclosurestate:>
# Decision-evaluation closure is derived exclusively from structured inputs.
# It never reads a pre-existing closure state, preventing self-warrant.
CONSTRUCT { ?evaluation usf:evaluationClosureState ?state . }
WHERE {
  ?evaluation a usf:DecisionEvaluation ; usf:evaluationForDecision ?decision .
  BIND(EXISTS {
    ?evaluation usf:evaluationAuthorityDigest ?boundAuthority ; usf:evaluationDependencySetDigest ?boundDependency ;
      usf:evaluationEvidenceDigest ?boundDigest ; usf:evaluationProducerDigest ?boundProducer ;
      usf:evaluationEvidenceResult ?evidence .
    ?evidence a usf:EvidenceResult, usf:CompositeEvidenceResult ; usf:contentDigest ?boundDigest .
    FILTER(
      NOT EXISTS { ?evidence usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> } ||
      NOT EXISTS { ?evidence usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> } ||
      NOT EXISTS { ?evidence usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> } ||
      NOT EXISTS { ?evidence usf:withinValidityScope true } ||
      NOT EXISTS { ?evidence usf:evaluatedAuthorityDigest ?boundAuthority } ||
      NOT EXISTS { ?evidence usf:evidenceProducerDigest ?boundProducer } ||
      NOT EXISTS { ?collection a usf:EvidenceCollection ; usf:collectedEvidence ?evidence ; usf:sourceDigest ?boundDependency }
    )
  } AS ?invalidEvidence)
  # Structural closure depth (candidate credibility, criterion and component
  # assessments, mitigations, sole-candidate proofs, package integrity,
  # composition coverage and realisation mappings) is enforced by the
  # registered realisation-option SHACL constraints and the registered
  # closure-evaluation algorithm over the same digest-bound evidence. This
  # projection derives the closure state from the accepted decision backbone
  # and its exact digest-bound admitted evidence.
  BIND(EXISTS {
    ?decision usf:decisionState <urn:usf:decisionstate:accepted> ;
      usf:decisionForContract ?contract ; usf:selectsOption ?selected ; usf:considersOption ?selected ;
      usf:hasDecisionEvaluation ?evaluation .
    ?contract a usf:SemanticContract .
    ?evaluation usf:evaluationAuthorityDigest ?authorityDigest ;
      usf:evaluationDependencySetDigest ?dependencyDigest ; usf:evaluationEvidenceDigest ?evidenceDigest ;
      usf:evaluationImplementationSourceDigest ?implementationDigest ; usf:evaluationProducerDigest ?producerDigest ;
      usf:evaluationEvidenceResult ?basisEvidence ;
      usf:evaluationInvalidationCondition ?invalidation ; usf:independentSelectionBasis true ;
      usf:selectionBasisEvidence ?basisEvidence .
    ?basisEvidence a usf:EvidenceResult, usf:CompositeEvidenceResult ; usf:contentDigest ?evidenceDigest ; usf:evaluatedAuthorityDigest ?authorityDigest ;
      usf:evidenceProducerDigest ?producerDigest ;
      usf:hasAdmissionState <urn:usf:evidenceadmissionstate:admitted> ;
      usf:hasFreshnessState <urn:usf:evidencefreshnessstate:fresh> ;
      usf:hasIntegrityState <urn:usf:evidenceintegritystate:valid> ; usf:withinValidityScope true .
    ?evaluationCollection a usf:EvidenceCollection ; usf:collectedEvidence ?basisEvidence ; usf:sourceDigest ?dependencyDigest .
    FILTER(REGEX(?authorityDigest, "^sha256:[0-9a-f]{64}$"))
    FILTER(REGEX(?dependencyDigest, "^sha256:[0-9a-f]{64}$"))
    FILTER(REGEX(?evidenceDigest, "^sha256:[0-9a-f]{64}$"))
    FILTER(REGEX(?implementationDigest, "^sha256:[0-9a-f]{64}$"))
    FILTER(REGEX(?producerDigest, "^sha256:[0-9a-f]{64}$"))
    FILTER NOT EXISTS { ?evaluation usf:evaluationEvidenceResult ?otherEvidence . FILTER(?otherEvidence != ?basisEvidence) }
    FILTER NOT EXISTS { ?decision usf:selectsOption ?otherSelected . FILTER(?otherSelected != ?selected) }
    FILTER NOT EXISTS { ?decision usf:decisionState ?otherDecisionState . FILTER(?otherDecisionState != <urn:usf:decisionstate:accepted>) }
    FILTER NOT EXISTS { ?decision usf:decisionForContract ?otherContract . FILTER(?otherContract != ?contract) }
    FILTER NOT EXISTS { ?decision usf:hasDecisionEvaluation ?otherEvaluation . FILTER(?otherEvaluation != ?evaluation) }
    FILTER NOT EXISTS { ?evaluation usf:evaluationForDecision ?otherDecision . FILTER(?otherDecision != ?decision) }
  } AS ?closed)
  BIND(IF(?invalidEvidence, closure:invalidated, IF(?closed, closure:complete, closure:incomplete)) AS ?state)
}
#---NEXT---#
PREFIX usf: <urn:usf:ontology:>
PREFIX oe: <urn:usf:obligationeffect:>
PREFIX fresh: <urn:usf:freshness:>
PREFIX rds: <urn:usf:readinessstate:>
PREFIX rr: <urn:usf:readinessreason:>
# Replacement rule 1. One deterministic state per capability. Every applicable
# blocking proof, test, and evidence obligation must be satisfied; partial
# existential coverage can never produce ready.
CONSTRUCT {
  ?readiness a usf:Readiness ; usf:canonicalName ?name ; usf:readinessOf ?capability ;
      usf:readinessState ?state ; usf:readinessRung ?rung ;
      usf:readinessReason ?reason ; usf:derivedFrom ?capability .
}
WHERE {
  ?capability a usf:Capability ; usf:hasContract ?subject .
  FILTER NOT EXISTS {
    ?capability usf:semanticAdequacyDisposition ?capabilityDisposition .
    FILTER(?capabilityDisposition != <urn:usf:semanticadequacydisposition:independentlywarrantedretained>)
  }
  FILTER NOT EXISTS {
    ?subject usf:semanticAdequacyDisposition ?subjectDisposition .
    FILTER(?subjectDisposition != <urn:usf:semanticadequacydisposition:independentlywarrantedretained>)
  }
  BIND(SHA256(STR(?capability)) AS ?digest)
  BIND(CONCAT("r", ?digest) AS ?name)
  BIND(IRI(CONCAT("urn:usf:readiness:", ?name)) AS ?readiness)
  BIND(EXISTS {
    ?obligation a usf:AssuranceObligation ; usf:obligationFor ?subject ; usf:obligationEffect oe:blocking .
  } AS ?evaluated)
  BIND(EXISTS {
    ?subject usf:requiresRealisationOptionEvaluation true ; usf:hasActivationState <urn:usf:contractactivationstate:active> .
    FILTER NOT EXISTS {
      ?selectionDecision a usf:RealisationDecision ; usf:decisionForContract ?subject ;
        usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?selectionEvaluation .
      ?selectionEvaluation usf:evaluationClosureState <urn:usf:evaluationclosurestate:complete> .
    }
  } || EXISTS {
    ?decision a usf:RealisationDecision ; usf:decisionForContract ?subject ;
      usf:decisionState <urn:usf:decisionstate:accepted> ; usf:hasDecisionEvaluation ?decisionEvaluation .
    FILTER NOT EXISTS { ?decisionEvaluation usf:evaluationClosureState <urn:usf:evaluationclosurestate:complete> }
  } AS ?evaluationClosureBlocked)
  BIND(EXISTS {
    ?obligation a usf:AssuranceObligation ; usf:obligationFor ?subject ; usf:obligationEffect oe:blocking .
    VALUES (?obligationClass ?satisfaction) {
      (usf:ProofObligation usf:satisfiedByProofResult)
      (usf:TestObligation usf:satisfiedByTestResult)
      (usf:EvidenceRequirement usf:satisfiedByEvidence)
    }
    ?obligation a ?obligationClass .
    FILTER NOT EXISTS { ?obligation ?satisfaction ?result }
  } AS ?missingBlocking)
  BIND(EXISTS {
    ?requirement a usf:EvidenceRequirement ; usf:obligationFor ?subject .
    ?evidence a usf:EvidenceResult ; usf:evidenceFor ?subject ; usf:hasFreshness fresh:stale .
    FILTER NOT EXISTS { ?requirement usf:satisfiedByEvidence ?evidence }
  } AS ?stale)
  BIND(EXISTS {
    ?requirement a usf:EvidenceRequirement ; usf:obligationFor ?subject ; usf:requiresProviderMode ?requiredMode .
    ?evidence a usf:EvidenceResult ; usf:evidenceFor ?subject ; usf:usesProviderMode ?actualMode .
    FILTER(?requiredMode != ?actualMode)
  } AS ?providerMismatch)
  BIND(EXISTS {
    ?requirement a usf:EvidenceRequirement ; usf:obligationFor ?subject ; usf:requiresEnvironmentClass ?requiredEnvironment .
    ?evidence a usf:EvidenceResult ; usf:evidenceFor ?subject ; usf:inEnvironment/usf:hasEnvironmentClass ?actualEnvironment .
    FILTER(?requiredEnvironment != ?actualEnvironment)
  } AS ?environmentMismatch)
  BIND(EXISTS {
    ?requirement a usf:EvidenceRequirement ; usf:obligationFor ?subject .
    ?evidence a usf:EvidenceResult ; usf:evidenceFor ?subject .
    FILTER NOT EXISTS { ?evidence usf:evidenceSignature ?signature }
  } AS ?unsignedEvidence)
  BIND(EXISTS {
    ?requirement a usf:EvidenceRequirement ; usf:obligationFor ?subject .
    ?evidence a usf:EvidenceResult ; usf:evidenceFor ?subject .
    FILTER NOT EXISTS {
      ?evidence usf:integrityVerification ?verification .
      ?verification usf:verifiesEvidence ?evidence ; usf:verificationState <urn:usf:resultstate:passed> .
    }
  } AS ?integrityUnverified)
  BIND(EXISTS {
    ?testObligation a usf:TestObligation ; usf:obligationFor ?subject .
    ?test usf:testsSubject|usf:testsContract|usf:testsControl ?subject .
    ?testResult a usf:TestResult ; usf:resultForTest ?test ; usf:resultState <urn:usf:resultstate:failed> .
  } AS ?failedTest)
  BIND(EXISTS {
    ?obligation a usf:AssuranceObligation ; usf:obligationFor ?subject ; usf:obligationEffect oe:advisory .
    VALUES (?obligationClass ?satisfaction) {
      (usf:ProofObligation usf:satisfiedByProofResult)
      (usf:TestObligation usf:satisfiedByTestResult)
      (usf:EvidenceRequirement usf:satisfiedByEvidence)
    }
    ?obligation a ?obligationClass .
    FILTER NOT EXISTS { ?obligation ?satisfaction ?result }
  } AS ?missingAdvisory)
  BIND(IF(?evaluationClosureBlocked, rds:notready,
       IF(!?evaluated, rds:unknown,
       IF(?providerMismatch || ?environmentMismatch, rds:incompatible,
       IF(?stale, rds:stale,
       IF(?missingBlocking, rds:notready,
       IF(?missingAdvisory, rds:degraded, rds:ready)))))) AS ?state)
  BIND(IF(?evaluationClosureBlocked, rr:optionevaluationincomplete,
       IF(!?evaluated, rr:unknownevaluation,
       IF(?providerMismatch, rr:incompatibleprovidermode,
       IF(?environmentMismatch, rr:incompatibleenvironment,
       IF(?stale, rr:staleevidence,
       IF(?failedTest, rr:failedtest,
       IF(?unsignedEvidence, rr:unsignedevidence,
       IF(?integrityUnverified, rr:integrityunverified,
       IF(?missingBlocking, rr:missingblockingobligation,
       IF(?missingAdvisory, rr:degradedadvisory, rr:satisfied)))))))))) AS ?reason)
  BIND(IF(?state IN (rds:ready, rds:degraded), <urn:usf:proofrung:behaviour>, <urn:usf:proofrung:discovery>) AS ?rung)
}
#---NEXT---#
PREFIX usf: <urn:usf:ontology:>
PREFIX oe: <urn:usf:obligationeffect:>
PREFIX fresh: <urn:usf:freshness:>
PREFIX rds: <urn:usf:readinessstate:>
PREFIX rr: <urn:usf:readinessreason:>
# Replacement rule 2. Gate state uses the same universal blocking semantics and
# precedence, ensuring one non-conflicting state for release, artefact,
# enterprise, UI, and live-Stardog gates.
CONSTRUCT {
  ?result a usf:ReadinessGateResult ; usf:canonicalName ?name ; usf:gateResultOf ?gate ;
      usf:gateReadinessState ?state ; usf:gateReadinessReason ?reason ; usf:derivedFrom ?gate .
}
WHERE {
  ?gate a usf:ReadinessGate .
  FILTER NOT EXISTS {
    ?gate usf:semanticAdequacyDisposition ?disposition .
    FILTER(?disposition != <urn:usf:semanticadequacydisposition:independentlywarrantedretained>)
  }
  BIND(SHA256(STR(?gate)) AS ?digest)
  BIND(CONCAT("g", ?digest) AS ?name)
  BIND(IRI(CONCAT("urn:usf:readinessgateresult:", ?name)) AS ?result)
  BIND(EXISTS {
    ?criterion usf:requiredByGate ?gate .
    ?obligation a usf:AssuranceObligation ; usf:obligationFor ?criterion ; usf:obligationEffect oe:blocking .
  } AS ?evaluated)
  BIND(EXISTS {
    ?criterion usf:requiredByGate ?gate .
    ?obligation a usf:AssuranceObligation ; usf:obligationFor ?criterion ; usf:obligationEffect oe:blocking .
    VALUES (?obligationClass ?satisfaction) {
      (usf:ProofObligation usf:satisfiedByProofResult)
      (usf:TestObligation usf:satisfiedByTestResult)
      (usf:EvidenceRequirement usf:satisfiedByEvidence)
    }
    ?obligation a ?obligationClass .
    FILTER NOT EXISTS { ?obligation ?satisfaction ?observation }
  } AS ?missingBlocking)
  BIND(EXISTS {
    ?criterion usf:requiredByGate ?gate .
    ?requirement a usf:EvidenceRequirement ; usf:obligationFor ?criterion .
    ?evidence a usf:EvidenceResult ; usf:evidenceFor ?criterion ; usf:hasFreshness fresh:stale .
    FILTER NOT EXISTS { ?requirement usf:satisfiedByEvidence ?evidence }
  } AS ?stale)
  BIND(EXISTS {
    ?criterion usf:requiredByGate ?gate .
    ?requirement a usf:EvidenceRequirement ; usf:obligationFor ?criterion ; usf:requiresProviderMode ?requiredMode .
    ?evidence a usf:EvidenceResult ; usf:evidenceFor ?criterion ; usf:usesProviderMode ?actualMode .
    FILTER(?requiredMode != ?actualMode)
  } AS ?providerMismatch)
  BIND(EXISTS {
    ?criterion usf:requiredByGate ?gate .
    ?requirement a usf:EvidenceRequirement ; usf:obligationFor ?criterion ; usf:requiresEnvironmentClass ?requiredEnvironment .
    ?evidence a usf:EvidenceResult ; usf:evidenceFor ?criterion ; usf:inEnvironment/usf:hasEnvironmentClass ?actualEnvironment .
    FILTER(?requiredEnvironment != ?actualEnvironment)
  } AS ?environmentMismatch)
  BIND(EXISTS {
    ?criterion usf:requiredByGate ?gate .
    ?requirement a usf:EvidenceRequirement ; usf:obligationFor ?criterion .
    ?evidence a usf:EvidenceResult ; usf:evidenceFor ?criterion .
    FILTER NOT EXISTS { ?evidence usf:evidenceSignature ?signature }
  } AS ?unsignedEvidence)
  BIND(EXISTS {
    ?criterion usf:requiredByGate ?gate .
    ?requirement a usf:EvidenceRequirement ; usf:obligationFor ?criterion .
    ?evidence a usf:EvidenceResult ; usf:evidenceFor ?criterion .
    FILTER NOT EXISTS {
      ?evidence usf:integrityVerification ?verification .
      ?verification usf:verifiesEvidence ?evidence ; usf:verificationState <urn:usf:resultstate:passed> .
    }
  } AS ?integrityUnverified)
  BIND(EXISTS {
    ?criterion usf:requiredByGate ?gate .
    ?testObligation a usf:TestObligation ; usf:obligationFor ?criterion .
    ?test usf:testsSubject ?criterion .
    ?testResult a usf:TestResult ; usf:resultForTest ?test ; usf:resultState <urn:usf:resultstate:failed> .
  } AS ?failedTest)
  BIND(EXISTS {
    ?criterion usf:requiredByGate ?gate .
    ?obligation a usf:AssuranceObligation ; usf:obligationFor ?criterion ; usf:obligationEffect oe:advisory .
    VALUES (?obligationClass ?satisfaction) {
      (usf:ProofObligation usf:satisfiedByProofResult)
      (usf:TestObligation usf:satisfiedByTestResult)
      (usf:EvidenceRequirement usf:satisfiedByEvidence)
    }
    ?obligation a ?obligationClass .
    FILTER NOT EXISTS { ?obligation ?satisfaction ?observation }
  } AS ?missingAdvisory)
  BIND(IF(!?evaluated, rds:unknown,
       IF(?providerMismatch || ?environmentMismatch, rds:incompatible,
       IF(?stale, rds:stale,
       IF(?missingBlocking, rds:notready,
       IF(?missingAdvisory, rds:degraded, rds:ready))))) AS ?state)
  BIND(IF(!?evaluated, rr:unknownevaluation,
       IF(?providerMismatch, rr:incompatibleprovidermode,
       IF(?environmentMismatch, rr:incompatibleenvironment,
       IF(?stale, rr:staleevidence,
       IF(?failedTest, rr:failedtest,
       IF(?unsignedEvidence, rr:unsignedevidence,
       IF(?integrityUnverified, rr:integrityunverified,
       IF(?missingBlocking, rr:missingblockingobligation,
       IF(?missingAdvisory, rr:degradedadvisory, rr:satisfied))))))))) AS ?reason)
}
