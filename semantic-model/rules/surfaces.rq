PREFIX usf: <urn:usf:ontology:>
# Derive the contract surface of each semantic contract from its exposed interfaces.
CONSTRUCT {
  ?cs a usf:ContractSurface ;
      usf:canonicalName ?ln ;
      usf:surfaceOf ?c ;
      usf:derivedFrom ?c .
}
WHERE {
  ?c a usf:SemanticContract .
  FILTER NOT EXISTS {
    ?c usf:semanticAdequacyDisposition ?disposition .
    FILTER(?disposition != <urn:usf:semanticadequacydisposition:independentlywarrantedretained>)
  }
  BIND(REPLACE(STR(?c), "^.*:", "") AS ?ln)
  BIND(IRI(CONCAT("urn:usf:contractsurface:", ?ln)) AS ?cs)
}
