# Secrets — never commit real credentials
.env

# Python virtualenv (provisioned inside the chroot)
.venv/
__pycache__/
*.pyc

# Node dependencies (provisioned by bootstrap-chroot.sh / npm ci)
node_modules/

# Agent runtime state — the usf skill is tracked; local settings are not
.claude/settings.local.json

# Generated projections, materialisation plans and runtime payloads
.work/
.cas/
proof-output/
validation-output/
*.parquet
*.jsonl.zst
