# Secrets — never commit real credentials
.env

# Python virtualenv (provisioned inside the chroot)
.venv/
__pycache__/
*.pyc

# Node dependencies (provisioned by bootstrap-chroot.sh / npm ci)
node_modules/

# Agent runtime state — the usf skill is tracked; local settings are not
.claude/settings.local.json

# graph/ and census/ live in the parent usf repository and are used host-side
# only — never mounted or copied into the chroot (verify-chroot.sh asserts
# their absence); this repository is the graph workspace (compiler, MCP,
# Stardog tooling) only.
