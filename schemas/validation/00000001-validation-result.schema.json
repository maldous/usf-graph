{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:usf:schema:validation-result:00000001",
  "title": "USF validation result projection",
  "type": "object",
  "required": ["schemaVersion", "authorityDigest", "contract", "obligation", "environment", "providerMode", "evidenceSetDigest", "state", "checks", "nonclaims"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "authorityDigest": { "$ref": "#/$defs/digest" },
    "contract": { "type": "string", "pattern": "^urn:usf:semanticcontract:" },
    "obligation": { "type": "string", "pattern": "^urn:usf:validationobligation:" },
    "environment": { "type": "string", "pattern": "^urn:usf:environmentclass:" },
    "providerMode": { "type": "string", "pattern": "^urn:usf:providermode:" },
    "evidenceSetDigest": { "$ref": "#/$defs/digest" },
    "state": { "enum": ["passed", "failed"] },
    "checks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "required": ["id", "state", "code"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
          "state": { "enum": ["passed", "failed"] },
          "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" }
        },
        "additionalProperties": false
      }
    },
    "nonclaims": { "type": "array", "maxItems": 256, "uniqueItems": true, "items": { "type": "string", "pattern": "^urn:usf:nonclaim:" } }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  },
  "additionalProperties": false
}
