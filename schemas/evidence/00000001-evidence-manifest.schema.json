{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:usf:schema:evidence-manifest:00000001",
  "title": "USF evidence manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "authorityDigest",
    "evidenceSetDigest",
    "semanticIdentifiers",
    "cases",
    "measurements",
    "payloads"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "authorityDigest": { "$ref": "#/$defs/digest" },
    "evidenceSetDigest": { "$ref": "#/$defs/digest" },
    "semanticIdentifiers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^urn:usf:" }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "required": ["id", "expected", "observed", "passed"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
          "expected": { "type": "string", "minLength": 1 },
          "observed": { "type": "string", "minLength": 1 },
          "passed": { "type": "boolean" },
          "negative": { "type": "boolean" },
          "detail": { "type": "string", "maxLength": 4096 }
        },
        "additionalProperties": false
      }
    },
    "measurements": { "type": "object", "maxProperties": 256, "additionalProperties": { "type": ["integer", "number", "string", "boolean"] } },
    "payloads": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "#/$defs/payload" }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "payload": {
      "type": "object",
      "required": ["digest", "byteSize", "mediaType", "locator"],
      "properties": {
        "digest": { "$ref": "#/$defs/digest" },
        "byteSize": { "type": "integer", "minimum": 0 },
        "mediaType": { "type": "string", "pattern": "^[a-z0-9.+-]+/[A-Za-z0-9.+-]+$" },
        "locator": { "type": "string", "pattern": "^cas://sha256/[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
