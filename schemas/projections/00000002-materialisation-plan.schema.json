{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:usf:schema:materialisation-plan:00000002",
  "title": "USF authority-bound materialisation plan",
  "$comment": "planDigest is SHA-256 over the JCS-canonical document with planDigest omitted.",
  "type": "object",
  "required": ["schemaVersion", "authorityDigest", "contract", "operations", "planDigest"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "authorityDigest": { "$ref": "#/$defs/digest" },
    "contract": { "type": "string", "pattern": "^urn:usf:" },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": { "$ref": "#/$defs/operation" }
    },
    "planDigest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "path": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$" },
    "operation": {
      "type": "object",
      "required": ["index", "action", "path", "pathRole"],
      "properties": {
        "index": { "type": "integer", "minimum": 0, "maximum": 255 },
        "action": { "enum": ["create-directory", "write-file", "move-path", "delete-path"] },
        "path": { "$ref": "#/$defs/path" },
        "pathRole": { "type": "string", "pattern": "^urn:usf:pathrole:" },
        "sourcePath": { "$ref": "#/$defs/path" },
        "sourceDigest": { "$ref": "#/$defs/digest" },
        "content": { "type": "string" },
        "contentEncoding": { "enum": ["utf8", "base64"] },
        "contentLocator": { "type": "string", "pattern": "^cas://sha256/[0-9a-f]{64}$" },
        "contentDigest": { "$ref": "#/$defs/digest" },
        "fileMode": { "enum": ["0644", "0755"] },
        "artefactFamily": { "type": "string", "pattern": "^urn:usf:artefactfamily:" },
        "representationFormat": { "type": "string", "pattern": "^urn:usf:representationformat:" }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "write-file" } }, "required": ["action"] },
          "then": {
            "required": ["contentDigest", "artefactFamily", "representationFormat"],
            "oneOf": [
              { "required": ["content", "contentEncoding"], "not": { "required": ["contentLocator"] } },
              { "required": ["contentLocator"], "not": { "anyOf": [{ "required": ["content"] }, { "required": ["contentEncoding"] }] } }
            ]
          }
        },
        {
          "if": { "properties": { "action": { "const": "move-path" } }, "required": ["action"] },
          "then": { "required": ["sourcePath", "sourceDigest"] }
        },
        {
          "if": { "properties": { "action": { "const": "delete-path" } }, "required": ["action"] },
          "then": { "required": ["sourceDigest"] }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
