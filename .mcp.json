{
  "mcpServers": {
    "usf": {
      "command": "node",
      "args": ["processes/semantic-assurance/semantic-authority-mcp.mjs"],
      "env": {
        "STARDOG_SERVER": "${STARDOG_SERVER:-}",
        "STARDOG_DATABASE": "${STARDOG_DATABASE:-}",
        "STARDOG_TOKEN": "${STARDOG_TOKEN:-}",
        "STARDOG_USERNAME": "${STARDOG_USERNAME:-}",
        "STARDOG_PASSWORD": "${STARDOG_PASSWORD:-}",
        "USF_CAS_ROOT": "${USF_CAS_ROOT:-}"
      }
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN:-}"
      }
    }
  }
}
