@prefix usf: <urn:usf:ontology:> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix shp: <urn:usf:shacl:> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

shp:CapabilityShape a sh:NodeShape ;
    usf:canonicalName "capabilityshape" ;
    sh:targetClass usf:Capability ;
    sh:property [ sh:path usf:inDomain ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:CapabilityDomain ;
        sh:message "capabilitydomain: capability must have exactly one domain" ] ;
    sh:property [ sh:path usf:hasContract ; sh:minCount 1 ; sh:class usf:SemanticContract ;
        sh:message "capabilitycontract: capability must have at least one semantic contract" ] .

shp:SemanticContractShape a sh:NodeShape ;
    usf:canonicalName "semanticcontractshape" ;
    sh:targetObjectsOf usf:hasContract ;
    sh:property [ sh:path usf:semanticLifecycleState ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SemanticLifecycleState ;
        sh:message "contractlifecycle: contract must declare exactly one semantic lifecycle state" ] ;
    sh:property [ sh:path usf:declaresFacet ; sh:minCount 1 ; sh:class usf:ContractFacet ;
        sh:message "contractfacet: contract must declare facets" ] ;
    sh:property [ sh:path usf:supersededBy ; sh:maxCount 1 ; sh:class usf:SemanticContract ] ;
    sh:sparql [ sh:prefixes usf:prefixes ; sh:message "contractsupersession: a deprecated contract requires one distinct canonical successor" ;
      sh:select """SELECT $this WHERE {
        $this usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:deprecated> .
        FILTER NOT EXISTS { $this usf:supersededBy ?successor . FILTER(?successor != $this) }
      }""" ] .

shp:ContractFacetShape a sh:NodeShape ;
    usf:canonicalName "contractfacetshape" ;
    sh:targetClass usf:ContractFacet ;
    sh:property [ sh:path usf:facetKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:FacetKind ;
        sh:message "facetkind: facet must have exactly one facet kind" ] ;
    sh:property [ sh:path usf:facetStatus ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:FacetStatus ;
        sh:message "facetstatus: facet must declare exactly one completeness status" ] ;
    sh:property [ sh:path usf:facetStatement ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:minLength 1 ;
        sh:message "facetstatement: identity-only facets are forbidden" ] .

shp:UIContractFacetClosureShape a sh:NodeShape ;
    usf:canonicalName "uicontractfacetclosureshape" ;
    sh:target [ a sh:SPARQLTarget ; sh:prefixes usf:prefixes ;
        sh:select "SELECT ?this WHERE { ?this a usf:ContractFacet ; usf:facetKind <urn:usf:facetkind:uisemantics> . }" ] ;
    sh:sparql [ sh:prefixes usf:prefixes ;
        sh:message "UI facet status must agree with exact capability exposure and UI semantic-model authority" ;
        sh:select """SELECT $this WHERE {
          ?contract usf:declaresFacet $this . ?capability usf:hasContract ?contract ; usf:uiExposure ?exposure .
          $this usf:facetStatus ?status .
          BIND(EXISTS { ?capability usf:hasUISemanticModel ?model } AS ?hasModel)
          FILTER((?status = <urn:usf:facetstatus:complete> && (?exposure != <urn:usf:uiexposureclass:uiexposed> || !?hasModel)) ||
                 (?status = <urn:usf:facetstatus:notapplicable> && (?exposure = <urn:usf:uiexposureclass:uiexposed> || ?hasModel)) ||
                 ?status = <urn:usf:facetstatus:gap>)
        }""" ] ;
    sh:sparql [ sh:prefixes usf:prefixes ;
        sh:message "Every closed UI facet contract must preserve explicit product and acceptance nonclaims" ;
        sh:select """SELECT $this WHERE {
          ?contract usf:declaresFacet $this .
          VALUES ?required { <urn:usf:nonclaim:nohumanacceptance> <urn:usf:nonclaim:nouiproductparity> <urn:usf:nonclaim:noaccessibilitycompliance> <urn:usf:nonclaim:nolaunchi18n> }
          FILTER NOT EXISTS { ?contract usf:disclaims ?required }
        }""" ] .

shp:SourceSemanticBindingShape a sh:NodeShape ;
    usf:canonicalName "sourcesemanticbindingshape" ;
    sh:targetClass usf:SourceSemanticBinding ;
    sh:property [ sh:path usf:sourceBindingSource ; sh:minCount 1 ; sh:maxCount 1 ; sh:nodeKind sh:IRI ] ;
    sh:property [ sh:path usf:sourceBindingTarget ; sh:minCount 1 ; sh:nodeKind sh:IRI ] ;
    sh:property [ sh:path usf:sourceBindingContentDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
    sh:property [ sh:path usf:sourceBindingPath ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path usf:sourceBindingEquivalenceKind ; sh:minCount 1 ; sh:class usf:EquivalenceKind ] ;
    sh:property [ sh:path usf:sourceBindingArtefactPlan ; sh:maxCount 1 ; sh:class usf:ArtefactPlan ] ;
    sh:property [ sh:path usf:sourceBindingEquivalenceRule ; sh:maxCount 1 ; sh:class usf:EquivalenceRule ] ;
    sh:sparql [ sh:prefixes usf:prefixes ; sh:message "sourcebindingcurrent: bound path and content digest must match the source current observation" ;
      sh:select """SELECT $this WHERE {
        $this usf:sourceBindingSource ?source ; usf:sourceBindingPath ?path ; usf:sourceBindingContentDigest ?digest .
        FILTER EXISTS { ?anyObservation a usf:SourceArtefactObservation }
        FILTER NOT EXISTS {
          ?source a usf:SourceArtefact ; usf:hasCurrentSourceObservation ?observation .
          ?observation usf:observedSourcePath ?path ; usf:observedContentDigest ?digest .
        }
      }""" ] .

shp:PolicyShape a sh:NodeShape ;
    usf:canonicalName "policyshape" ;
    sh:targetClass usf:Policy ;
    sh:or (
        [ sh:property [ sh:path usf:policyConstrains ; sh:minCount 1 ] ]
        [ sh:property [ sh:path usf:appliesToCapability ; sh:minCount 1 ] ]
    ) ;
    sh:message "policyconnection: policy must constrain something or apply to a capability" .

shp:ConsentRequirementShape a sh:NodeShape ;
    usf:canonicalName "consentrequirementshape" ;
    sh:targetClass usf:ConsentRequirement ;
    sh:property [ sh:path usf:consentBasis ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ConsentBasis ;
        sh:message "consentbasis: consent requirement must state one lawful basis" ] .

shp:InterfaceShape a sh:NodeShape ;
    usf:canonicalName "interfaceshape" ;
    sh:targetClass usf:Interface ;
    sh:property [ sh:path usf:interfaceForContract ; sh:minCount 1 ; sh:class usf:SemanticContract ;
        sh:message "interfacecontract: interface must belong to a semantic contract" ] ;
    sh:property [ sh:path usf:hasOperation ; sh:minCount 1 ; sh:class usf:Operation ;
        sh:message "interfaceoperation: interface must expose at least one operation" ] .

shp:OperationShape a sh:NodeShape ;
    usf:canonicalName "operationshape" ;
    sh:targetObjectsOf usf:hasOperation ;
    sh:property [ sh:path usf:requiresPermission ; sh:minCount 1 ; sh:class usf:Permission ;
        sh:message "missingpermission: operation must require at least one permission" ] .

shp:CommandShape a sh:NodeShape ;
    usf:canonicalName "commandshape" ;
    sh:targetClass usf:Command ;
    sh:property [ sh:path usf:emitsAuditEvent ; sh:minCount 1 ; sh:class usf:AuditEvent ;
        sh:message "missingaudit: mutating command must emit at least one audit event" ] .

shp:TransitionShape a sh:NodeShape ;
    usf:canonicalName "transitionshape" ;
    sh:targetClass usf:Transition ;
    sh:property [ sh:path usf:fromState ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:State ;
        sh:message "transitionfrom: transition must have one source state" ] ;
    sh:property [ sh:path usf:toState ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:State ;
        sh:message "transitionto: transition must have one target state" ] .

shp:PermissionShape a sh:NodeShape ;
    usf:canonicalName "permissionshape" ;
    sh:targetClass usf:Permission ;
    sh:property [ sh:path usf:boundedBy ; sh:maxCount 1 ; sh:class usf:TenantBoundary ] .

shp:PortShape a sh:NodeShape ;
    usf:canonicalName "portshape" ;
    sh:targetClass usf:Port .

shp:EventShape a sh:NodeShape ;
    usf:canonicalName "eventshape" ;
    sh:targetClass usf:Event ;
    sh:property [ sh:path usf:hasDeliverySemantics ; sh:maxCount 1 ; sh:class usf:DeliverySemantics ] .

shp:DataModelShape a sh:NodeShape ;
    usf:canonicalName "datamodelshape" ;
    sh:targetClass usf:DataModel ;
    sh:property [ sh:path usf:enforcesTenancy ; sh:class usf:TenantBoundary ] ;
    sh:property [ sh:path usf:tenancyStrategy ; sh:maxCount 1 ; sh:class usf:TenancyStrategy ] .

shp:ProviderShape a sh:NodeShape ;
    usf:canonicalName "providershape" ;
    sh:targetClass usf:Provider ;
    sh:property [ sh:path usf:hasProviderMode ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ProviderMode ;
        sh:message "providermode: provider must declare exactly one provider mode" ] ;
    sh:property [ sh:path usf:fulfilsPort ; sh:minCount 1 ; sh:class usf:Port ;
        sh:message "providerport: provider must fulfil at least one port" ] .

shp:EnvironmentShape a sh:NodeShape ;
    usf:canonicalName "environmentshape" ;
    sh:targetClass usf:Environment ;
    sh:property [ sh:path usf:hasEnvironmentClass ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:EnvironmentClass ;
        sh:message "environmentclass: environment must declare exactly one class" ] .

shp:PromotionShape a sh:NodeShape ;
    usf:canonicalName "promotionshape" ;
    sh:targetClass usf:Promotion ;
    sh:property [ sh:path usf:promotesFrom ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Environment ] ;
    sh:property [ sh:path usf:promotesTo ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Environment ] .

shp:ConfigurationKeyShape a sh:NodeShape ;
    usf:canonicalName "configurationkeyshape" ;
    sh:targetClass usf:ConfigurationKey ;
    sh:property [ sh:path usf:hasSecretClassification ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SecretClassification ;
        sh:message "secretclassification: configuration key must declare a secret classification" ] .

shp:AuditEventShape a sh:NodeShape ;
    usf:canonicalName "auditeventshape" ;
    sh:targetClass usf:AuditEvent ;
    sh:property [ sh:path usf:auditCategory ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:AuditCategory ] ;
    sh:property [ sh:path usf:auditSeverity ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:AuditSeverity ] .

shp:ObservabilitySignalShape a sh:NodeShape ;
    usf:canonicalName "observabilitysignalshape" ;
    sh:targetClass usf:ObservabilitySignal ;
    sh:property [ sh:path usf:signalKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SignalKind ] .

shp:JourneyShape a sh:NodeShape ;
    usf:canonicalName "journeyshape" ;
    sh:targetClass usf:Journey ;
    sh:property [ sh:path usf:mapsToCapability ; sh:minCount 1 ; sh:class usf:Capability ;
        sh:message "journeycapability: journey must map to at least one capability" ] .
