@prefix usf: <urn:usf:ontology:> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shp: <urn:usf:shacl:> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Additive/replacement assurance shapes. Existing Proof, ProofResult,
# EvidenceResult, and Test shapes must be strengthened with these constraints.

shp:AssuranceMatrixShape a sh:NodeShape ; usf:canonicalName "assurancematrixshape" ;
    sh:targetClass usf:AssuranceMatrix ;
    sh:property [ sh:path usf:hasMatrixCell ; sh:minCount 1 ; sh:class usf:AssuranceMatrixCell ] .

shp:AssuranceMatrixCellShape a sh:NodeShape ; usf:canonicalName "assurancematrixcellshape" ;
    sh:targetClass usf:AssuranceMatrixCell ;
    sh:property [ sh:path usf:profileRung ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ProofRung ] ;
    sh:property [ sh:path usf:profileProviderMode ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ProviderMode ] ;
    sh:property [ sh:path usf:profileEnvironmentClass ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:EnvironmentClass ] .

shp:ReadinessGateShape a sh:NodeShape ; usf:canonicalName "readinessgateshape" ;
    sh:targetClass usf:ReadinessGate ;
    sh:property [ sh:path usf:gateKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ReadinessGateKind ] ;
    sh:property [ sh:path usf:hasCriterion ; sh:minCount 1 ; sh:class usf:GateCriterion ] .

shp:GateCriterionShape a sh:NodeShape ; usf:canonicalName "gatecriterionshape" ;
    sh:targetClass usf:GateCriterion ;
    sh:property [ sh:path usf:criterionCode ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path usf:requiredByGate ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ReadinessGate ] ;
    sh:property [ sh:path usf:obligationEffect ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ObligationEffect ] ;
    sh:property [ sh:path usf:usesAssuranceCell ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:AssuranceMatrixCell ] .

shp:AssuranceObligationShape a sh:NodeShape ; usf:canonicalName "assuranceobligationshape" ;
    sh:targetClass usf:AssuranceObligation, usf:ProofObligation, usf:TestObligation, usf:EvidenceRequirement ;
    sh:property [ sh:path usf:obligationFor ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path usf:obligationEffect ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ObligationEffect ] ;
    sh:property [ sh:path usf:usesAssuranceCell ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:AssuranceMatrixCell ] .

shp:ProofSubjectShape a sh:NodeShape ; usf:canonicalName "proofsubjectshape" ;
    sh:targetClass usf:Proof ;
    sh:property [ sh:path usf:provesSubject ; sh:minCount 1 ; sh:class usf:Entity ] .

shp:PassingProofResultShape a sh:NodeShape ; usf:canonicalName "passingproofresultshape" ;
    sh:targetClass usf:ProofResult ;
    sh:property [ sh:path usf:resultState ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ResultState ] ;
    sh:property [ sh:path usf:resultForProof ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Proof ] ;
    sh:property [ sh:path usf:usesProviderMode ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ProviderMode ] ;
    sh:property [ sh:path usf:inEnvironment ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Environment ] .

shp:TestExecutionShape a sh:NodeShape ; usf:canonicalName "testexecutionshape" ;
    sh:targetClass usf:TestExecution ;
    sh:property [ sh:path usf:executionOfTest ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Test ] ;
    sh:property [ sh:path usf:testProducesResult ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:TestResult ] .

shp:TestResultShape a sh:NodeShape ; usf:canonicalName "testresultshape" ;
    sh:targetClass usf:TestResult ;
    sh:property [ sh:path usf:resultForTest ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Test ] ;
    sh:property [ sh:path usf:resultState ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ResultState ] ;
    sh:sparql [ sh:message "detecteddefectwithoutdefect: detected-defect result must identify a planted defect" ;
        sh:prefixes usf:prefixes ;
        sh:select """SELECT $this WHERE {
          $this usf:resultState <urn:usf:resultstate:detecteddefect> .
          FILTER NOT EXISTS { $this usf:detectedDefect ?defect }
        }""" ] .

shp:EvidencePipelineShape a sh:NodeShape ; usf:canonicalName "evidencepipelineshape" ;
    sh:targetClass usf:EvidenceResult ;
    sh:property [ sh:path usf:evidenceFor ; sh:minCount 1 ] ;
    sh:sparql [ sh:message "freshevidencewithoutproofresult: fresh evidence must identify its passing proof result" ;
        sh:prefixes usf:prefixes ;
        sh:select """SELECT $this WHERE {
          $this usf:hasFreshness <urn:usf:freshness:fresh> .
          FILTER NOT EXISTS { $this usf:evidenceFromProofResult ?proofResult }
        }""" ] ;
    sh:sparql [ sh:message "admissibleevidencemissingpipeline: satisfying evidence lacks a required stage or pipeline operation" ;
        sh:prefixes usf:prefixes ;
        sh:select """SELECT $this WHERE {
          ?requirement usf:satisfiedByEvidence $this ; usf:requiresEvidenceStage ?stage .
          FILTER NOT EXISTS { $this usf:evidenceStage ?stage }
        }""" ] ;
    sh:sparql [ sh:message "admissibleevidenceunsigned: satisfying evidence lacks signature, checksum, or passing integrity verification" ;
        sh:prefixes usf:prefixes ;
        sh:select """SELECT $this WHERE {
          ?requirement usf:satisfiedByEvidence $this .
          FILTER(
            NOT EXISTS { $this usf:evidenceSignature ?signature } ||
            NOT EXISTS { $this usf:evidenceChecksum ?checksum } ||
            NOT EXISTS {
              $this usf:integrityVerification ?verification .
              ?verification usf:verifiesEvidence $this ;
                usf:verificationState <urn:usf:resultstate:passed> .
            }
          )
        }""" ] .

shp:EvidenceRequirementProfileShape a sh:NodeShape ; usf:canonicalName "evidencerequirementprofileshape" ;
    sh:targetClass usf:EvidenceRequirement ;
    sh:property [ sh:path usf:requiresProviderMode ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ProviderMode ] ;
    sh:property [ sh:path usf:requiresEnvironmentClass ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:EnvironmentClass ] ;
    sh:property [ sh:path usf:requiresFreshness ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Freshness ] ;
    sh:property [ sh:path usf:requiresEvidenceStage ; sh:minCount 6 ; sh:maxCount 6 ; sh:class usf:EvidenceStage ] .

shp:ReadinessStateShape a sh:NodeShape ; usf:canonicalName "readinessstateshape" ;
    sh:targetClass usf:Readiness ;
    sh:property [ sh:path usf:readinessState ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ReadinessState ] ;
    sh:property [ sh:path usf:readinessReason ; sh:minCount 1 ; sh:class usf:ReadinessReason ] .

shp:ReadinessGateResultShape a sh:NodeShape ; usf:canonicalName "readinessgateresultshape" ;
    sh:targetClass usf:ReadinessGateResult ;
    sh:property [ sh:path usf:gateResultOf ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ReadinessGate ] ;
    sh:property [ sh:path usf:gateReadinessState ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ReadinessState ] ;
    sh:property [ sh:path usf:gateReadinessReason ; sh:minCount 1 ; sh:class usf:ReadinessReason ] .

shp:IntegrityVerificationShape a sh:NodeShape ; usf:canonicalName "integrityverificationshape" ;
    sh:targetClass usf:IntegrityVerification ;
    sh:property [ sh:path usf:verifiesEvidence ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:EvidenceResult ] ;
    sh:property [ sh:path usf:verificationState ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ResultState ] .
