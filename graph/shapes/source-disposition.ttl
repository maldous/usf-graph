@prefix usf: <urn:usf:ontology:> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shp: <urn:usf:shacl:> .

shp:SourceArtefactShape a sh:NodeShape ;
  usf:canonicalName "sourceartefactshape" ;
  sh:targetClass usf:SourceArtefact ;
  sh:property [ sh:path usf:canonicalName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^s[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:sourceIdentityDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:hasCurrentSourceObservation ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceArtefactObservation ] ;
  sh:sparql [ sh:prefixes usf:prefixes ; sh:message "sourceidentity: IRI and canonical name must be s plus the source identity digest" ;
    sh:select """SELECT $this WHERE {
      $this usf:sourceIdentityDigest ?digest ; usf:canonicalName ?name .
      BIND(CONCAT("s", STR(?digest)) AS ?expected)
      FILTER(STR(?name) != ?expected || STR($this) != CONCAT("urn:usf:sourceartefact:", ?expected))
    }""" ] .

shp:SourceArtefactObservationShape a sh:NodeShape ;
  usf:canonicalName "sourceartefactobservationshape" ;
  sh:targetClass usf:SourceArtefactObservation ;
  sh:property [ sh:path usf:canonicalName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^o[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:observesSourceArtefact ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceArtefact ] ;
  sh:property [ sh:path usf:observedSourcePath ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$" ] ;
  sh:property [ sh:path usf:observedContentDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:observedFileMode ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^(100644|100755|120000|160000)$" ] ;
  sh:property [ sh:path usf:observedUniverse ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceUniverse ] ;
  sh:property [ sh:path usf:observedContentRole ; sh:minCount 1 ; sh:class usf:SourceContentRole ] ;
  sh:property [ sh:path usf:hasExactSemanticReference ; sh:nodeKind sh:IRI ] ;
  sh:property [ sh:path usf:observationSetDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] .

shp:SourceDispositionPolicyShape a sh:NodeShape ;
  usf:canonicalName "sourcedispositionpolicyshape" ;
  sh:targetClass usf:SourceDispositionPolicy ;
  sh:property [ sh:path usf:policyDispositionKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:DispositionKind ] ;
  sh:property [ sh:path usf:policyDispositionBasis ; sh:minCount 1 ; sh:class usf:DispositionBasis ] ;
  sh:property [ sh:path usf:policyDecisionState ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:DispositionDecisionState ] ;
  sh:property [ sh:path usf:policyOutputMode ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:DispositionOutputMode ] ;
  sh:property [ sh:path usf:policyPrecedence ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
  sh:property [ sh:path usf:policyArtefactPlan ; sh:maxCount 1 ; sh:class usf:ArtefactPlan ] ;
  sh:property [ sh:path usf:policyGenerationInputRole ; sh:class usf:GenerationInputRole ] ;
  sh:property [ sh:path usf:policyMatchesSourceIdentityDigest ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:policyMatchesUniverse ; sh:class usf:SourceUniverse ] ;
  sh:property [ sh:path usf:policyMatchesContentRole ; sh:class usf:SourceContentRole ] ;
  sh:property [ sh:path usf:policyMatchesExactSemanticReference ; sh:nodeKind sh:IRI ] ;
  sh:property [ sh:path usf:policyMatchesSourceBinding ; sh:class usf:SourceSemanticBinding ] ;
  sh:property [ sh:path usf:isDefaultDispositionPolicy ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:boolean ] ;
  sh:property [ sh:path usf:isActiveDispositionPolicy ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:boolean ] ;
  sh:property [ sh:path usf:decisionRationale ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:minLength 1 ] ;
  sh:sparql [ sh:prefixes usf:prefixes ; sh:message "policyselector: non-default policy requires a structural or exact selector; default policy forbids selectors" ;
    sh:select """SELECT $this WHERE {
      $this usf:isDefaultDispositionPolicy ?default .
      BIND(EXISTS { $this usf:policyMatchesSourceIdentityDigest|usf:policyMatchesUniverse|usf:policyMatchesContentRole|usf:policyMatchesExactSemanticReference|usf:policyMatchesSourceBinding ?selector } AS ?hasSelector)
      FILTER((?default = false && !?hasSelector) || (?default = true && ?hasSelector))
    }""" ] ;
  sh:sparql [ sh:prefixes usf:prefixes ; sh:message "policydefault: default policy must be reviewrequired and nooutput" ;
    sh:select """SELECT $this WHERE {
      $this usf:isDefaultDispositionPolicy true ; usf:policyDispositionKind ?kind ; usf:policyDecisionState ?state ; usf:policyOutputMode ?mode .
      FILTER(?kind != <urn:usf:dispositionkind:reviewrequired> ||
             ?state != <urn:usf:dispositiondecisionstate:reviewrequired> ||
             ?mode != <urn:usf:dispositionoutputmode:nooutput>)
    }""" ] ;
  sh:sparql [ sh:prefixes usf:prefixes ; sh:message "policyoutput: output mode must be permitted by kind" ;
    sh:select """SELECT $this WHERE {
      $this usf:policyDispositionKind ?kind ; usf:policyOutputMode ?mode .
      FILTER NOT EXISTS { ?kind usf:permitsDispositionOutputMode ?mode }
    }""" ] ;
  sh:sparql [ sh:prefixes usf:prefixes ; sh:message "policyplan: canonicaloutput requires exactly one distinct policy or binding plan; nooutput forbids every plan" ;
    sh:select """SELECT $this WHERE {
      $this usf:policyOutputMode ?mode .
      { FILTER(?mode = <urn:usf:dispositionoutputmode:canonicaloutput>)
        FILTER NOT EXISTS { $this usf:policyArtefactPlan ?plan }
        FILTER NOT EXISTS { $this usf:policyMatchesSourceBinding/usf:sourceBindingArtefactPlan ?plan }
      }
      UNION
      { FILTER(?mode = <urn:usf:dispositionoutputmode:canonicaloutput>)
        $this (usf:policyArtefactPlan|usf:policyMatchesSourceBinding/usf:sourceBindingArtefactPlan) ?left, ?right .
        FILTER(?left != ?right)
      }
      UNION
      { FILTER(?mode = <urn:usf:dispositionoutputmode:nooutput>)
        { FILTER EXISTS { $this usf:policyArtefactPlan ?plan } }
        UNION
        { FILTER EXISTS { $this usf:policyMatchesSourceBinding/usf:sourceBindingArtefactPlan ?plan } }
      }
    }""" ] .

shp:SourceArtefactDispositionShape a sh:NodeShape ;
  usf:canonicalName "sourceartefactdispositionshape" ;
  sh:targetClass usf:SourceArtefactDisposition ;
  sh:property [ sh:path usf:canonicalName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^d[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:dispositionOfSourceArtefact ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceArtefact ] ;
  sh:property [ sh:path usf:decidedAgainstObservation ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceArtefactObservation ] ;
  sh:property [ sh:path usf:derivedFromDispositionPolicy ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceDispositionPolicy ] ;
  sh:property [ sh:path usf:hasDispositionKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:DispositionKind ] ;
  sh:property [ sh:path usf:hasDispositionBasis ; sh:minCount 1 ; sh:class usf:DispositionBasis ] ;
  sh:property [ sh:path usf:hasDispositionDecisionState ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:DispositionDecisionState ] ;
  sh:property [ sh:path usf:hasDispositionOutputMode ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:DispositionOutputMode ] ;
  sh:property [ sh:path usf:assignedToArtefactPlan ; sh:maxCount 1 ; sh:class usf:ArtefactPlan ] ;
  sh:property [ sh:path usf:observationSetDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:decisionRationale ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:minLength 1 ] ;
  sh:sparql [ sh:prefixes usf:prefixes ; sh:message "dispositionplan: canonicaloutput requires exactly one plan IRI; nooutput forbids every plan" ;
    sh:select """SELECT $this WHERE {
      $this usf:hasDispositionOutputMode ?mode .
      { FILTER(?mode = <urn:usf:dispositionoutputmode:canonicaloutput>) FILTER NOT EXISTS { $this usf:assignedToArtefactPlan ?plan } }
      UNION
      { FILTER(?mode = <urn:usf:dispositionoutputmode:nooutput>) FILTER EXISTS { $this usf:assignedToArtefactPlan ?plan } }
    }""" ] ;
  sh:sparql [ sh:prefixes usf:prefixes ; sh:message "dispositionreview: reviewrequired kind and state must occur together" ;
    sh:select """SELECT $this WHERE {
      $this usf:hasDispositionKind ?kind ; usf:hasDispositionDecisionState ?state .
      FILTER((?kind = <urn:usf:dispositionkind:reviewrequired>) != (?state = <urn:usf:dispositiondecisionstate:reviewrequired>))
    }""" ] .

shp:SourceArtefactDispositionCurrentObservationShape a sh:NodeShape ;
  usf:canonicalName "sourceartefactdispositioncurrentobservationshape" ;
  sh:targetNode <urn:usf:ontology> ;
  sh:sparql [
    sh:prefixes usf:prefixes ;
    sh:message "dispositionobservation: disposition must use the source artefact current observation" ;
    sh:select """SELECT $this WHERE {
      FILTER EXISTS {
        ?disposition a usf:SourceArtefactDisposition ;
          usf:dispositionOfSourceArtefact ?source ;
          usf:decidedAgainstObservation ?observation .
        FILTER NOT EXISTS { ?source usf:hasCurrentSourceObservation ?observation }
      }
    }""" ;
  ] .
