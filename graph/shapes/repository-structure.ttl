@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix usf: <urn:usf:ontology:> .
@prefix shp: <urn:usf:shacl:> .

shp:CensusObservationRunShape a sh:NodeShape ; usf:canonicalName "censusobservationrunshape" ; sh:targetClass usf:CensusObservationRun ;
  sh:property [ sh:path usf:observationSetDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:observedRequiredPrerequisiteDependencyCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
  sh:property [ sh:path usf:observedResolvedPrerequisiteDependencyCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
  sh:property [ sh:path usf:observedSatisfiedPrerequisiteDependencyCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
  sh:property [ sh:path usf:observedActiveBlockingDependencyCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ; sh:maxInclusive 0 ] ;
  sh:property [ sh:path usf:hasCensusObservationInput ; sh:minCount 1 ; sh:class usf:CensusObservationInput ] ;
  sh:property [ sh:path usf:hasCensusParserShardObservation ; sh:minCount 1 ; sh:class usf:CensusParserShardObservation ] .

shp:CensusObservationInputShape a sh:NodeShape ; usf:canonicalName "censusobservationinputshape" ; sh:targetClass usf:CensusObservationInput ;
  sh:property [ sh:path usf:observedInputPath ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:minLength 1 ] ;
  sh:property [ sh:path usf:observedInputContentDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:observedInputByteCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
  sh:property [ sh:path usf:observedInCensusRun ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:CensusObservationRun ] .

shp:CensusParserShardObservationShape a sh:NodeShape ; usf:canonicalName "censusparsershardobservationshape" ; sh:targetClass usf:CensusParserShardObservation ;
  sh:property [ sh:path usf:observedParserShardPath ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path usf:observedParserUniverse ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceUniverse ] ;
  sh:property [ sh:path usf:observedCompressedContentDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:observedUncompressedContentDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:observedParserRecordCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
  sh:property [ sh:path usf:observedInCensusRun ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:CensusObservationRun ] .

shp:SourceObservationParserProvenanceShape a sh:NodeShape ; usf:canonicalName "sourceobservationparserprovenanceshape" ; sh:targetClass usf:SourceArtefactObservation ;
  sh:property [ sh:path usf:observedParserImplementation ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:minLength 1 ] ;
  sh:property [ sh:path usf:observedSyntaxKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:minLength 1 ] ;
  sh:property [ sh:path usf:observedFormatKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:minLength 1 ] ;
  sh:property [ sh:path usf:observedInCensusRun ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:CensusObservationRun ] .

shp:WorkPackageObservationShape a sh:NodeShape ; usf:canonicalName "workpackageobservationshape" ; sh:targetClass usf:WorkPackageObservation ;
  sh:property [ sh:path usf:canonicalName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^w[0-9a-f]{20}$" ] ;
  sh:property [ sh:path usf:workPackageKey ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^work-package-[0-9a-f]{20}$" ] ;
  sh:property [ sh:path usf:observedOwnedSourceArtefact ; sh:minCount 1 ; sh:class usf:SourceArtefact ] ;
  sh:property [ sh:path usf:observedOwnedCanonicalArtefact ; sh:class usf:Artefact ] ;
  sh:property [ sh:path usf:observedInCensusRun ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:CensusObservationRun ] .

shp:SourceRelationshipTargetObservationShape a sh:NodeShape ; usf:canonicalName "sourcerelationshiptargetobservationshape" ; sh:targetClass usf:SourceRelationshipTargetObservation ;
  sh:property [ sh:path usf:canonicalName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^t[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:observedRelationshipTarget ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:minLength 1 ] ;
  sh:property [ sh:path usf:observedRelationshipTargetDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:observedRelationshipTargetDisclosureStatus ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ObservationDisclosureStatus ] ;
  sh:property [ sh:path usf:observedRelationshipTargetKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceRelationshipTargetKind ] ;
  sh:property [ sh:path usf:resolvesToSourceArtefact ; sh:maxCount 1 ; sh:class usf:SourceArtefact ] ;
  sh:property [ sh:path usf:observedInCensusRun ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:CensusObservationRun ] ;
  sh:or (
    [ sh:property [ sh:path usf:observedRelationshipTargetDisclosureStatus ; sh:hasValue <urn:usf:observationdisclosurestatus:disclosed> ] ;
      sh:property [ sh:path usf:observedRelationshipTarget ; sh:minCount 1 ; sh:maxCount 1 ] ]
    [ sh:property [ sh:path usf:observedRelationshipTargetDisclosureStatus ; sh:hasValue <urn:usf:observationdisclosurestatus:withheldprohibitedmetadata> ] ;
      sh:property [ sh:path usf:observedRelationshipTarget ; sh:maxCount 0 ] ]
  ) .

shp:SourceRelationshipObservationShape a sh:NodeShape ; usf:canonicalName "sourcerelationshipobservationshape" ; sh:targetClass usf:SourceRelationshipObservation ;
  sh:property [ sh:path usf:canonicalName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^r[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:relationshipEvidenceDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:sourceRelationshipRecordDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:sourceRelationshipSource ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceArtefact ] ;
  sh:property [ sh:path usf:sourceRelationshipTarget ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceRelationshipTargetObservation ] ;
  sh:property [ sh:path usf:sourceRelationshipType ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceRelationshipType ] ;
  sh:property [ sh:path usf:sourceRelationshipEvidenceKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:SourceRelationshipEvidenceKind ] ;
  sh:property [ sh:path usf:sourceRelationshipAttributes ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path usf:sourceRelationshipAttributesDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:sourceRelationshipAttributesDisclosureStatus ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ObservationDisclosureStatus ] ;
  sh:property [ sh:path usf:sourceRelationshipResolved ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:boolean ; sh:hasValue true ] ;
  sh:property [ sh:path usf:observedInCensusRun ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:CensusObservationRun ] ;
  sh:or (
    [ sh:property [ sh:path usf:sourceRelationshipAttributesDisclosureStatus ; sh:hasValue <urn:usf:observationdisclosurestatus:disclosed> ] ;
      sh:property [ sh:path usf:sourceRelationshipAttributes ; sh:minCount 1 ; sh:maxCount 1 ] ]
    [ sh:property [ sh:path usf:sourceRelationshipAttributesDisclosureStatus ; sh:hasValue <urn:usf:observationdisclosurestatus:withheldprohibitedmetadata> ] ;
      sh:property [ sh:path usf:sourceRelationshipAttributes ; sh:maxCount 0 ] ]
  ) .

shp:WorkPackageDependencyObservationShape a sh:NodeShape ; usf:canonicalName "workpackagedependencyobservationshape" ; sh:targetClass usf:WorkPackageDependencyObservation ;
  sh:property [ sh:path usf:canonicalName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^d[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:workPackageDependencyKey ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^dependency-[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:workPackageDependencySource ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:WorkPackageObservation ; sh:disjoint usf:workPackageDependencyPrerequisite ] ;
  sh:property [ sh:path usf:workPackageDependencyPrerequisite ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:WorkPackageObservation ] ;
  sh:property [ sh:path usf:workPackageDependencyType ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:WorkPackageDependencyType ] ;
  sh:property [ sh:path usf:workPackageDependencyStatus ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:WorkPackageDependencyStatus ] ;
  sh:property [ sh:path usf:supportedBySourceRelationshipObservation ; sh:minCount 1 ; sh:class usf:SourceRelationshipObservation ] ;
  sh:property [ sh:path usf:workPackageDependencyEvidenceDigest ; sh:minCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:workPackageDependencyResolutionStatus ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue <urn:usf:workpackagedependencyresolutionstatus:resolvedretained> ] ;
  sh:property [ sh:path usf:observedInCensusRun ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:CensusObservationRun ] .

shp:RequiredPrerequisiteDependencySatisfactionObservationShape a sh:NodeShape ; usf:canonicalName "requiredprerequisitedependencysatisfactionobservationshape" ;
  sh:targetClass usf:WorkPackageDependencyObservation ;
  sh:or (
    [ sh:not [ sh:property [
      sh:path usf:workPackageDependencyStatus ;
      sh:hasValue <urn:usf:workpackagedependencystatus:requiredprerequisite>
    ] ] ]
    [
      sh:property [ sh:path usf:workPackageDependencySatisfactionSeed ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:DependencySatisfactionStatus ] ;
      sh:property [ sh:path usf:hasWorkPackageDependencySatisfactionBasis ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:WorkPackageDependencySatisfactionBasisObservation ]
    ]
  ) .

shp:WorkPackageDependencySatisfactionBasisObservationShape a sh:NodeShape ; usf:canonicalName "workpackagedependencysatisfactionbasisobservationshape" ; sh:targetClass usf:WorkPackageDependencySatisfactionBasisObservation ;
  sh:property [ sh:path usf:canonicalName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^s[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:satisfactionBasisForWorkPackageDependency ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:WorkPackageDependencyObservation ] ;
  sh:property [ sh:path usf:observedDependencySatisfactionStatus ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:DependencySatisfactionStatus ] ;
  sh:property [ sh:path usf:dependencySatisfactionBasisKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:DependencySatisfactionBasisKind ] ;
  sh:property [ sh:path usf:satisfactionBasisRelationshipObservation ; sh:minCount 1 ; sh:class usf:SourceRelationshipObservation ] ;
  sh:property [ sh:path usf:satisfactionBasisRecordDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:satisfactionBasisExactEvidenceHashCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 1 ] ;
  sh:property [ sh:path usf:satisfactionBasisCurrentRelationshipHashCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
  sh:property [ sh:path usf:satisfactionBasisStructurallyProvenRelationshipHashCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
  sh:property [ sh:path usf:satisfactionBasisDirectionMatchedRelationshipHashCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
  sh:property [ sh:path usf:satisfactionBasisCurrentPrerequisiteArtifactHashCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
  sh:property [ sh:path usf:satisfactionBasisCurrentPrerequisiteArtifactCount ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 1 ] ;
  sh:property [ sh:path usf:satisfactionBasisSourceEndpointExists ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] ;
  sh:property [ sh:path usf:satisfactionBasisPrerequisiteEndpointExists ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] ;
  sh:property [ sh:path usf:satisfactionBasisEdgeSurvivedTransitiveReduction ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] ;
  sh:property [ sh:path usf:satisfactionBasisRequiredPrerequisiteGraphAcyclic ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] ;
  sh:property [ sh:path usf:observedInCensusRun ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:CensusObservationRun ] .

shp:WorkPackageDependencyLineageObservationShape a sh:NodeShape ; usf:canonicalName "workpackagedependencylineageobservationshape" ; sh:targetClass usf:WorkPackageDependencyLineageObservation ;
  sh:property [ sh:path usf:successorDependencySource ; sh:minCount 1 ; sh:class usf:WorkPackageObservation ] ;
  sh:property [ sh:path usf:successorDependencyPrerequisite ; sh:minCount 1 ; sh:class usf:WorkPackageObservation ] ;
  sh:property [ sh:path usf:dependencyLineageDisposition ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue <urn:usf:dependencylineagedisposition:retainedwithevidence> ] ;
  sh:property [ sh:path usf:observedInCensusRun ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:CensusObservationRun ] .

shp:RepositoryDependencyResolutionPolicyShape a sh:NodeShape ; usf:canonicalName "repositorydependencyresolutionpolicyshape" ; sh:targetClass usf:RepositoryDependencyResolutionPolicy ;
  sh:property [ sh:path usf:requiredRelationshipEvidenceMinimum ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 1 ] ;
  sh:property [ sh:path usf:allowsWorkPackageDependencyType ; sh:minCount 1 ; sh:class usf:WorkPackageDependencyType ] ;
  sh:property [ sh:path usf:allowsWorkPackageDependencyStatus ; sh:minCount 1 ; sh:class usf:WorkPackageDependencyStatus ] ;
  sh:property [ sh:path usf:allowsSourceRelationshipType ; sh:minCount 1 ; sh:class usf:SourceRelationshipType ] ;
  sh:property [ sh:path usf:requiresRegisteredObservationRun ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] ;
  sh:property [ sh:path usf:requiresExactEvidenceEndpointOwnership ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] ;
  sh:property [ sh:path usf:requiresAcyclicRequiredPrerequisiteDependencies ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] .

shp:RepositoryDependencySatisfactionPolicyShape a sh:NodeShape ; usf:canonicalName "repositorydependencysatisfactionpolicyshape" ; sh:targetClass usf:RepositoryDependencySatisfactionPolicy ;
  sh:property [ sh:path usf:allowsDependencySatisfactionStatus ; sh:minCount 1 ; sh:class usf:DependencySatisfactionStatus ] ;
  sh:property [ sh:path usf:allowsDependencySatisfactionBasisKind ; sh:minCount 1 ; sh:class usf:DependencySatisfactionBasisKind ] ;
  sh:property [ sh:path usf:requiresResolvedRetainedDependency ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] ;
  sh:property [ sh:path usf:requiresRequiredPrerequisiteDependencyStatus ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] ;
  sh:property [ sh:path usf:requiresExactSatisfactionEvidenceClosure ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] ;
  sh:property [ sh:path usf:requiresSatisfactionEndpointOwnership ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] ;
  sh:property [ sh:path usf:requiresSameSatisfactionObservationRun ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] ;
  sh:property [ sh:path usf:requiresSatisfactionBasisDigest ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue true ] .

shp:RepositoryWorkPackageShape a sh:NodeShape ; usf:canonicalName "repositoryworkpackageshape" ; sh:targetClass usf:RepositoryWorkPackage ;
  sh:property [ sh:path usf:canonicalName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^w[0-9a-f]{20}$" ] ;
  sh:property [ sh:path usf:promotedFromWorkPackageObservation ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:WorkPackageObservation ] ;
  sh:property [ sh:path usf:ownsObservedSourceArtefact ; sh:minCount 1 ; sh:class usf:SourceArtefact ] ;
  sh:property [ sh:path usf:ownsCanonicalArtefact ; sh:class usf:Artefact ;
    sh:message "workpackagecanonicalartefact: an owned canonical artefact must be a declared artefact" ] ;
  sh:property [ sh:path usf:promotedByRepositoryStructurePolicy ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:RepositoryDependencyResolutionPolicy ] .

shp:RepositoryDependencyShape a sh:NodeShape ; usf:canonicalName "repositorydependencyshape" ; sh:targetClass usf:RepositoryDependency ;
  sh:property [ sh:path usf:canonicalName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^d[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:resolvedDependencySource ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:RepositoryWorkPackage ; sh:disjoint usf:resolvedDependencyPrerequisite ] ;
  sh:property [ sh:path usf:resolvedDependencyPrerequisite ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:RepositoryWorkPackage ] ;
  sh:property [ sh:path usf:derivedFromWorkPackageDependencyObservation ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:WorkPackageDependencyObservation ] ;
  sh:property [ sh:path usf:promotedByRepositoryStructurePolicy ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:RepositoryDependencyResolutionPolicy ] ;
  sh:property [ sh:path usf:supportedBySourceRelationshipObservation ; sh:minCount 1 ; sh:class usf:SourceRelationshipObservation ] .

shp:SatisfiedRequiredPrerequisiteResolvedWorkPackageDependencyShape a sh:NodeShape ; usf:canonicalName "satisfiedrequiredprerequisiteresolvedworkpackagedependencyshape" ;
  sh:targetClass usf:ResolvedWorkPackageDependency ;
  sh:or (
    [ sh:not [ sh:property [
      sh:path usf:resolvedDependencyStatus ;
      sh:hasValue <urn:usf:workpackagedependencystatus:requiredprerequisite>
    ] ] ]
    [
      sh:property [ sh:path usf:dependencySatisfactionStatus ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue <urn:usf:dependencysatisfactionstatus:satisfied> ] ;
      sh:property [ sh:path usf:derivedFromDependencySatisfactionBasis ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:WorkPackageDependencySatisfactionBasisObservation ] ;
      sh:property [ sh:path usf:promotedByDependencySatisfactionPolicy ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:RepositoryDependencySatisfactionPolicy ]
    ]
  ) .

shp:ActiveRepositoryDependencyBlockerShape a sh:NodeShape ; usf:canonicalName "activerepositorydependencyblockershape" ; sh:targetClass usf:ActiveRepositoryDependencyBlocker ;
  sh:property [ sh:path usf:canonicalName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^b[0-9a-f]{64}$" ] ;
  sh:property [ sh:path usf:activeBlockerForResolvedDependency ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ResolvedWorkPackageDependency ] ;
  sh:property [ sh:path usf:activeBlockerFromSatisfactionBasis ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:WorkPackageDependencySatisfactionBasisObservation ] .

shp:RetainedWorkPackageDependencyLineageShape a sh:NodeShape ; usf:canonicalName "retainedworkpackagedependencylineageshape" ; sh:targetClass usf:RetainedWorkPackageDependencyLineage ;
  sh:property [ sh:path usf:derivedFromWorkPackageDependencyLineageObservation ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:WorkPackageDependencyLineageObservation ] ;
  sh:property [ sh:path usf:retainedLineageSuccessorSource ; sh:minCount 1 ; sh:class usf:RepositoryWorkPackage ] ;
  sh:property [ sh:path usf:retainedLineageSuccessorPrerequisite ; sh:minCount 1 ; sh:class usf:RepositoryWorkPackage ] ;
  sh:property [ sh:path usf:promotedByRepositoryStructurePolicy ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:RepositoryDependencyResolutionPolicy ] .
