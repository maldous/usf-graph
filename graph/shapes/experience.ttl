@prefix usf: <urn:usf:ontology:> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <urn:usf:shape:> .

shape:CapabilityUIExposureShape a sh:NodeShape ;
    sh:targetClass usf:Capability ;
    sh:property [ sh:path usf:uiExposure ; sh:minCount 1 ; sh:maxCount 1 ; sh:in (
        <urn:usf:uiexposureclass:uiexposed>
        <urn:usf:uiexposureclass:apionly>
        <urn:usf:uiexposureclass:internal>
        <urn:usf:uiexposureclass:notexposed>
    ) ] ;
    sh:sparql [
        sh:message "ui-exposed capabilities require a UI semantic model; all other exposure classes forbid one." ;
        sh:prefixes usf:prefixes ;
        sh:select """
            SELECT $this WHERE {
              $this usf:uiExposure ?exposure .
              BIND(EXISTS { $this usf:hasUISemanticModel ?model } AS ?hasModel)
              FILTER((?exposure = <urn:usf:uiexposureclass:uiexposed> && !?hasModel) ||
                     (?exposure != <urn:usf:uiexposureclass:uiexposed> && ?hasModel))
            }
        """
    ] .

shape:JourneyMappingShape a sh:NodeShape ;
    sh:targetClass usf:Journey ;
    sh:property [ sh:path usf:mapsToCapability ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Capability ] ;
    sh:not [ sh:property [ sh:path usf:mapsToCapability ; sh:hasValue <urn:usf:capability:universalservicefoundationscopeandprinciples> ] ] .

shape:UISemanticModelShape a sh:NodeShape ;
    sh:targetClass usf:UISemanticModel ;
    sh:property [ sh:path usf:hasJourney ; sh:minCount 1 ; sh:class usf:Journey ] ;
    sh:property [ sh:path usf:hasViewModel ; sh:minCount 1 ; sh:class usf:ViewModel ] ;
    sh:property [ sh:path usf:hasSurface ; sh:minCount 1 ] ;
    sh:property [ sh:path usf:hasAccessibilityProfile ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:AccessibilityProfile ] ;
    sh:property [ sh:path usf:hasLocalisationProfile ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:LocalisationProfile ] ;
    sh:property [ sh:path usf:rendererContract ; sh:minCount 1 ; sh:class usf:RendererContract ] .

shape:ViewModelShape a sh:NodeShape ;
    sh:targetClass usf:ViewModel ;
    sh:property [ sh:path usf:viewDataModel ; sh:minCount 1 ; sh:class usf:DataModel ] ;
    sh:property [ sh:path usf:hasComponent ; sh:minCount 1 ; sh:class usf:Component ] .

shape:SurfaceShape a sh:NodeShape ;
    sh:targetSubjectsOf usf:surfaceKind ;
    sh:property [ sh:path usf:surfaceKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:in (
        <urn:usf:surfacekind:webroute> <urn:usf:surfacekind:mobilescreen> <urn:usf:surfacekind:form>
        <urn:usf:surfacekind:queryview> <urn:usf:surfacekind:notification> <urn:usf:surfacekind:preview>
        <urn:usf:surfacekind:e2ejourney> <urn:usf:surfacekind:documentation>
    ) ] ;
    sh:property [ sh:path usf:rendersViewModel ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ViewModel ] ;
    sh:property [ sh:path usf:uiRequiresPermission ; sh:minCount 1 ; sh:class usf:Permission ] ;
    sh:sparql [
        sh:message "Web-route and query-view surfaces require one route." ;
        sh:prefixes usf:prefixes ;
        sh:select """
            SELECT $this WHERE {
              $this usf:surfaceKind ?kind .
              FILTER(?kind IN (<urn:usf:surfacekind:webroute>, <urn:usf:surfacekind:queryview>))
              FILTER NOT EXISTS { $this usf:surfaceRoute ?route }
            }
        """
    ] ;
    sh:sparql [
        sh:message "Query-view surfaces require exact load-operation and interface bindings on their view model." ;
        sh:prefixes usf:prefixes ;
        sh:select """
            SELECT $this WHERE {
              $this usf:surfaceKind <urn:usf:surfacekind:queryview> ; usf:rendersViewModel ?model .
              FILTER NOT EXISTS { ?model usf:loadsOperation ?operation ; usf:bindsInterface ?interface . ?interface usf:hasOperation ?operation }
            }
        """
    ] .

shape:RouteShape a sh:NodeShape ;
    sh:targetClass usf:Route ;
    sh:property [ sh:path usf:routePattern ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^/" ] ;
    sh:property [ sh:path usf:routeKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:in (
        <urn:usf:routekind:public> <urn:usf:routekind:authenticated> <urn:usf:routekind:tenant>
        <urn:usf:routekind:administrator> <urn:usf:routekind:operator> <urn:usf:routekind:developer>
    ) ] ;
    sh:sparql [
        sh:message "Route patterns must be globally unique." ;
        sh:prefixes usf:prefixes ;
        sh:select """
            SELECT $this WHERE {
              $this usf:routePattern ?pattern .
              ?other usf:routePattern ?pattern .
              FILTER(STR($this) < STR(?other))
            }
        """
    ] .

shape:FormShape a sh:NodeShape ;
    sh:targetClass usf:Form ;
    sh:property [ sh:path usf:hasField ; sh:minCount 1 ; sh:class usf:FormField ] ;
    sh:property [ sh:path usf:submitsOperation ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Operation ] ;
    sh:sparql [
        sh:message "Field names and field order must be unique within a form." ;
        sh:prefixes usf:prefixes ;
        sh:select """
            SELECT $this WHERE {
              $this usf:hasField ?left, ?right .
              FILTER(STR(?left) < STR(?right))
              { ?left usf:fieldName ?v . ?right usf:fieldName ?v }
              UNION
              { ?left usf:fieldOrder ?v . ?right usf:fieldOrder ?v }
            }
        """
    ] ;
    sh:sparql [
        sh:message "Each form requires a framework-neutral action component in its rendered view model." ;
        sh:prefixes usf:prefixes ;
        sh:select """
            SELECT $this WHERE {
              $this usf:rendersViewModel ?model .
              FILTER NOT EXISTS { ?model usf:hasComponent ?component . ?component usf:componentKind <urn:usf:componentkind:action> }
            }
        """
    ] .

shape:FormFieldShape a sh:NodeShape ;
    sh:targetClass usf:FormField ;
    sh:property [ sh:path usf:fieldName ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path usf:fieldKind ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path usf:fieldOrder ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
    sh:property [ sh:path usf:hasValidationBinding ; sh:minCount 1 ; sh:class usf:ValidationBinding ] .

shape:ValidationBindingShape a sh:NodeShape ;
    sh:targetClass usf:ValidationBinding ;
    sh:property [ sh:path usf:validationConstraint ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Constraint ] ;
    sh:property [ sh:path usf:validationTiming ; sh:minCount 1 ; sh:maxCount 1 ; sh:in (
        <urn:usf:validationtiming:input> <urn:usf:validationtiming:blur>
        <urn:usf:validationtiming:submit> <urn:usf:validationtiming:serverresponse>
    ) ] .

shape:ErrorBindingShape a sh:NodeShape ;
    sh:targetClass usf:ErrorBinding ;
    sh:property [ sh:path usf:errorCode ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^[a-z0-9]+$" ] ;
    sh:property [ sh:path usf:errorState ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:InteractionState ] ;
    sh:property [ sh:path usf:errorPresentation ; sh:minCount 1 ; sh:maxCount 1 ] .

shape:ComponentShape a sh:NodeShape ;
    sh:targetClass usf:Component ;
    sh:property [ sh:path usf:componentKind ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path usf:componentOrder ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:integer ; sh:minInclusive 0 ] ;
    sh:sparql [
        sh:message "Component containment must be acyclic." ;
        sh:prefixes usf:prefixes ;
        sh:select "SELECT $this WHERE { $this usf:childComponent+ $this . }"
    ] .

shape:AccessibilityProfileShape a sh:NodeShape ;
    sh:targetClass usf:AccessibilityProfile ;
    sh:property [ sh:path usf:hasAccessibilityRequirement ; sh:minCount 1 ; sh:class usf:AccessibilityRequirement ] ;
    sh:property [ sh:path (usf:hasAccessibilityRequirement usf:accessibilityKind) ; sh:hasValue <urn:usf:accessibilityrequirementkind:keyboardoperable> ] ;
    sh:property [ sh:path (usf:hasAccessibilityRequirement usf:accessibilityKind) ; sh:hasValue <urn:usf:accessibilityrequirementkind:focusorder> ] ;
    sh:property [ sh:path (usf:hasAccessibilityRequirement usf:accessibilityKind) ; sh:hasValue <urn:usf:accessibilityrequirementkind:focusvisible> ] ;
    sh:property [ sh:path (usf:hasAccessibilityRequirement usf:accessibilityKind) ; sh:hasValue <urn:usf:accessibilityrequirementkind:accessiblename> ] ;
    sh:property [ sh:path (usf:hasAccessibilityRequirement usf:accessibilityKind) ; sh:hasValue <urn:usf:accessibilityrequirementkind:semanticrole> ] ;
    sh:property [ sh:path (usf:hasAccessibilityRequirement usf:accessibilityKind) ; sh:hasValue <urn:usf:accessibilityrequirementkind:statusannouncement> ] ;
    sh:property [ sh:path (usf:hasAccessibilityRequirement usf:accessibilityKind) ; sh:hasValue <urn:usf:accessibilityrequirementkind:contrast> ] ;
    sh:property [ sh:path (usf:hasAccessibilityRequirement usf:accessibilityKind) ; sh:hasValue <urn:usf:accessibilityrequirementkind:languagedeclaration> ] .

shape:AccessibilityRequirementShape a sh:NodeShape ;
    sh:targetObjectsOf usf:hasAccessibilityRequirement ;
    sh:property [ sh:path usf:accessibilityKind ; sh:minCount 1 ; sh:maxCount 1 ] .

shape:LocalisationProfileShape a sh:NodeShape ;
    sh:targetClass usf:LocalisationProfile ;
    sh:property [ sh:path usf:defaultLocale ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:language ] ;
    sh:property [ sh:path usf:supportedLocale ; sh:minCount 1 ; sh:datatype xsd:language ] ;
    sh:property [ sh:path usf:hasLocalisationRequirement ; sh:minCount 1 ; sh:class usf:LocalisationRequirement ] ;
    sh:sparql [
        sh:message "The default locale must be included among supported locales." ;
        sh:prefixes usf:prefixes ;
        sh:select """
            SELECT $this WHERE {
              $this usf:defaultLocale ?default .
              FILTER NOT EXISTS { $this usf:supportedLocale ?default }
            }
        """
    ] .

shape:LocalisationRequirementShape a sh:NodeShape ;
    sh:targetObjectsOf usf:hasLocalisationRequirement ;
    sh:property [ sh:path usf:localisationKind ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:sparql [
        sh:message "Message-key localisation requirements require at least one stable message key." ;
        sh:prefixes usf:prefixes ;
        sh:select """
            SELECT $this WHERE {
              $this usf:localisationKind <urn:usf:localisationrequirementkind:messagekey> .
              FILTER NOT EXISTS { $this usf:messageKey ?key }
            }
        """
    ] .

shape:RendererContractShape a sh:NodeShape ;
    sh:targetClass usf:RendererContract ;
    sh:property [ sh:path usf:rendererImplementation ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Renderer ] ;
    sh:property [ sh:path usf:rendererTarget ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:RendererTarget ] ;
    sh:property [ sh:path usf:rendererInputSchema ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Artefact ] ;
    sh:property [ sh:path usf:rendererOutputPlan ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:ArtefactPlan ] ;
    sh:property [ sh:path usf:supportsSurfaceKind ; sh:minCount 1 ] ;
    sh:sparql [
        sh:message "E2E renderer contracts require journeys; documentation renderer contracts require documentation models." ;
        sh:prefixes usf:prefixes ;
        sh:select """
            SELECT $this WHERE {
              $this usf:rendererTarget ?target .
              FILTER((?target = <urn:usf:renderertarget:e2e> && NOT EXISTS { $this usf:e2eJourney ?journey }) ||
                     (?target = <urn:usf:renderertarget:documentation> && NOT EXISTS { $this usf:documentationModel ?model }))
            }
        """
    ] .

shape:RendererOutputPlanOwnershipShape a sh:NodeShape ;
    sh:targetObjectsOf usf:rendererOutputPlan ;
    sh:property [
        sh:path [ sh:inversePath usf:rendererOutputPlan ] ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:RendererContract ;
        sh:message "Each renderer-output plan must be owned by exactly one renderer target contract."
    ] ;
    sh:property [
        sh:path usf:plansArtefact ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Artefact ;
        sh:message "Each renderer-output plan must own exactly one target-specific artefact."
    ] .

shape:RendererShape a sh:NodeShape ;
    sh:targetClass usf:Renderer ;
    sh:property [
        sh:path [ sh:inversePath usf:rendererImplementation ] ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:RendererContract ;
        sh:message "Each renderer implementation must be owned by exactly one renderer contract."
    ] .

shape:ArtefactPlanShape a sh:NodeShape ;
    sh:targetClass usf:ArtefactPlan ;
    sh:property [ sh:path usf:ownedByRepository ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:Repository ] ;
    sh:property [ sh:path usf:plansArtefact ; sh:minCount 1 ; sh:class usf:Artefact ] .

shape:RendererInputSchemaArtefactShape a sh:NodeShape ;
    sh:targetObjectsOf usf:rendererInputSchema ;
    sh:property [ sh:path usf:artefactKind ; sh:minCount 1 ; sh:maxCount 1 ; sh:hasValue <urn:usf:artefactkind:schema> ] ;
    sh:property [ sh:path usf:canonicalPath ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path usf:governedByPathRule ; sh:minCount 1 ; sh:maxCount 1 ; sh:class usf:PathRule ] .

shape:PathRuleShape a sh:NodeShape ;
    sh:targetClass usf:PathRule ;
    sh:property [ sh:path usf:pathPattern ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ; sh:pattern "^(?!/)(?!.*(?:^|/)(?:v2|legacy|old|new|temp|transitional|usf)(?:/|$))(?!.*(?:^|/)\\.\\.(?:/|$)).+$" ] .
