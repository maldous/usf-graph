# graph: urn:usf:graph:capabilities
# expect: capabilitydisconnected
@prefix usf: <urn:usf:ontology:> .
@prefix fixt: <urn:usf:fixturenode:> .
@prefix dom: <urn:usf:capabilitydomain:> .

fixt:disconnectedcapability a usf:Capability ;
    usf:canonicalName "disconnectedcapability" ;
    usf:inDomain dom:foundation ;
    usf:hasContract fixt:disconnectedcontract .
fixt:disconnectedcontract a usf:SemanticContract ;
    usf:canonicalName "disconnectedcontract" .
fixt:disconnectedrealisation a usf:Realisation ;
    usf:canonicalName "disconnectedrealisation" ;
    usf:realisationState <urn:usf:realisationstate:contractonly> ;
    usf:realisesContract fixt:disconnectedcontract .
