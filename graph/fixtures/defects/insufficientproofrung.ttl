@prefix usf: <urn:usf:ontology:> .
@prefix fixt: <urn:usf:fixturenode:> .
@prefix dom: <urn:usf:capabilitydomain:> .
@prefix facet: <urn:usf:facetkind:> .
@prefix rung: <urn:usf:proofrung:> .
@prefix pmode: <urn:usf:providermode:> .
@prefix envc: <urn:usf:environmentclass:> .
@prefix fresh: <urn:usf:freshness:> .

fixt:norungproof a usf:Proof ; usf:canonicalName "norungproof" ;
    usf:usesProviderMode pmode:hermeticmock ; usf:inEnvironment fixt:e1 ; usf:exercises fixt:c1 .
fixt:e1 a usf:Environment ; usf:canonicalName "e1" ; usf:hasEnvironmentClass envc:hermetic .
fixt:c1 a usf:SemanticContract ; usf:canonicalName "c1" .
