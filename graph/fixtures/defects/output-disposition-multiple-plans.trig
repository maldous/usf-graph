@prefix usf: <urn:usf:ontology:> .
@prefix fx: <urn:usf:fixture:outputdispositionmultipleplans:> .

GRAPH <urn:usf:graph:fixture:outputdispositionmultipleplans> {
  fx:disposition a usf:SourceArtefactDisposition ;
    usf:hasDispositionOutputMode <urn:usf:dispositionoutputmode:canonicaloutput> ;
    usf:assignedToArtefactPlan fx:leftplan, fx:rightplan .
  fx:leftplan a usf:ArtefactPlan .
  fx:rightplan a usf:ArtefactPlan .
}
