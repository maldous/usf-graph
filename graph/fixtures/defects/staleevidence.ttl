@prefix usf: <urn:usf:ontology:> .
@prefix fixt: <urn:usf:fixturenode:> .
@prefix dom: <urn:usf:capabilitydomain:> .
@prefix facet: <urn:usf:facetkind:> .
@prefix rung: <urn:usf:proofrung:> .
@prefix pmode: <urn:usf:providermode:> .
@prefix envc: <urn:usf:environmentclass:> .
@prefix fresh: <urn:usf:freshness:> .

fixt:staleev a usf:EvidenceResult ; usf:canonicalName "staleev" ;
    usf:evidenceKind <urn:usf:evidencekind:runtimeproofevidence> ;
    usf:usesProviderMode pmode:hermeticmock ; usf:inEnvironment fixt:seenv ;
    usf:hasFreshness fresh:stale ; usf:evidenceForContract fixt:sec ; usf:satisfies fixt:sereq .
fixt:sereq a usf:EvidenceRequirement ; usf:canonicalName "sereq" ;
    usf:requiresEvidenceKind <urn:usf:evidencekind:runtimeproofevidence> ;
    usf:requiresFreshness fresh:fresh ; usf:requiresProviderMode pmode:hermeticmock ; usf:derivedFrom fixt:sec .
fixt:seenv a usf:Environment ; usf:canonicalName "seenv" ; usf:hasEnvironmentClass envc:hermetic .
fixt:sec a usf:SemanticContract ; usf:canonicalName "sec" .
