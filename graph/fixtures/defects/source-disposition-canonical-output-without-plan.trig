@prefix usf: <urn:usf:ontology:> .
@prefix fx: <urn:usf:fixture:sourcedisposition:missingplan:> .

GRAPH <urn:usf:graph:fixture:sourcedispositionmissingplan> {
  fx:policy a usf:SourceDispositionPolicy ;
    usf:canonicalName "canonicaloutputpolicy" ;
    usf:policyDispositionKind <urn:usf:dispositionkind:retainasset> ;
    usf:policyDispositionBasis <urn:usf:dispositionbasis:explicitplanlink> ;
    usf:policyDecisionState <urn:usf:dispositiondecisionstate:accepted> ;
    usf:policyOutputMode <urn:usf:dispositionoutputmode:canonicaloutput> ;
    usf:policyPrecedence 10 ;
    usf:policyArtefactPlan <urn:usf:artefactplan:runtimecompose> ;
    usf:policyMatchesContentRole <urn:usf:sourcecontentrole:fixture> ;
    usf:isDefaultDispositionPolicy false ; usf:isActiveDispositionPolicy false ;
    usf:decisionRationale "The policy has a plan, while the planted disposition deliberately omits it." .
}

GRAPH <urn:usf:graph:observed:sourceartefacts> {
  <urn:usf:sourceartefact:s5555555555555555555555555555555555555555555555555555555555555555>
    a usf:SourceArtefact ;
    usf:canonicalName "s5555555555555555555555555555555555555555555555555555555555555555" ;
    usf:sourceIdentityDigest "5555555555555555555555555555555555555555555555555555555555555555" ;
    usf:hasCurrentSourceObservation fx:oeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee .
  fx:oeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee
    a usf:SourceArtefactObservation ;
    usf:canonicalName "oeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee" ;
    usf:observesSourceArtefact <urn:usf:sourceartefact:s5555555555555555555555555555555555555555555555555555555555555555> ;
    usf:observedSourcePath "fixtures/canonical-output.trig" ;
    usf:observedContentDigest "eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee" ;
    usf:observedFileMode "100644" ;
    usf:observedUniverse <urn:usf:sourceuniverse:graphauthority> ;
    usf:observedContentRole <urn:usf:sourcecontentrole:fixture> ;
    usf:observationSetDigest "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" .
}

GRAPH <urn:usf:graph:derived:sourcedispositions> {
  <urn:usf:sourceartefact:s5555555555555555555555555555555555555555555555555555555555555555>
    usf:hasSourceDisposition fx:deeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee .
  fx:deeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee
    a usf:SourceArtefactDisposition ;
    usf:canonicalName "deeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee" ;
    usf:dispositionOfSourceArtefact <urn:usf:sourceartefact:s5555555555555555555555555555555555555555555555555555555555555555> ;
    usf:decidedAgainstObservation fx:oeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee ;
    usf:derivedFromDispositionPolicy fx:policy ;
    usf:hasDispositionKind <urn:usf:dispositionkind:retainasset> ;
    usf:hasDispositionBasis <urn:usf:dispositionbasis:explicitplanlink> ;
    usf:hasDispositionDecisionState <urn:usf:dispositiondecisionstate:accepted> ;
    usf:hasDispositionOutputMode <urn:usf:dispositionoutputmode:canonicaloutput> ;
    usf:observationSetDigest "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" ;
    usf:decisionRationale "Canonical output deliberately lacks an assigned artefact plan." .
}
