@prefix usf: <urn:usf:ontology:> .
@prefix fx: <urn:usf:fixture:artefactplanmissingpath:> .

GRAPH <urn:usf:graph:fixture:artefactplanmissingpath> {
  fx:repository a usf:Repository .
  fx:plan a usf:ArtefactPlan ; usf:ownedByRepository fx:repository ; usf:plansArtefact fx:artefact .
  fx:artefact a usf:Artefact ; usf:artefactKind <urn:usf:artefactkind:contract> ;
    usf:governedByPathRule fx:pathrule ; usf:generatedByComponent fx:generator .
  fx:pathrule usf:pathPattern "generated/missing-path.json" .
  fx:generator a usf:CompilerComponent ; usf:semanticInputQuery "SELECT ?resource WHERE { ?resource a <urn:usf:ontology:SemanticContract> . }" ;
    usf:outputSchema fx:artefact ; usf:outputPathRule fx:pathrule ; usf:integrityPolicy fx:integritypolicy ;
    usf:normalisationPolicy fx:normalisationpolicy ; usf:missingSemanticsConstraint fx:missingconstraint ;
    usf:requiresEquivalenceKind <urn:usf:equivalencekind:semantic> .
}
