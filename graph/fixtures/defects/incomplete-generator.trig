@prefix usf: <urn:usf:ontology:> .
@prefix fx: <urn:usf:fixture:incompletegenerator:> .

GRAPH <urn:usf:graph:fixture:incompletegenerator> {
  fx:repository a usf:Repository .
  fx:plan a usf:ArtefactPlan ; usf:ownedByRepository fx:repository ; usf:plansArtefact fx:artefact .
  fx:artefact a usf:Artefact ; usf:canonicalPath "generated/incomplete-generator.json" ;
    usf:artefactKind <urn:usf:artefactkind:contract> ; usf:governedByPathRule fx:pathrule ; usf:generatedByComponent fx:generator .
  fx:pathrule usf:pathPattern "generated/incomplete-generator.json" .
  fx:generator a usf:CompilerComponent ;
    usf:outputSchema fx:artefact ; usf:outputPathRule fx:pathrule ;
    usf:integrityPolicy fx:integritypolicy ; usf:normalisationPolicy fx:normalisationpolicy ;
    usf:missingSemanticsConstraint fx:missingconstraint ;
    usf:requiresEquivalenceKind <urn:usf:equivalencekind:semantic> .
}
