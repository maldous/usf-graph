@prefix usf: <urn:usf:ontology:> .
@prefix fx: <urn:usf:fixture:sourcedispositionnonmaxprecedence:> .

GRAPH <urn:usf:graph:fixture:sourcedispositionnonmaxprecedence> {
  fx:lowpolicy a usf:SourceDispositionPolicy ;
    usf:canonicalName "lowprecedencepolicy" ;
    usf:policyDispositionKind <urn:usf:dispositionkind:retainasset> ;
    usf:policyDispositionBasis <urn:usf:dispositionbasis:structuralcontentrole> ;
    usf:policyDecisionState <urn:usf:dispositiondecisionstate:accepted> ;
    usf:policyOutputMode <urn:usf:dispositionoutputmode:nooutput> ;
    usf:policyPrecedence 10 ;
    usf:policyMatchesContentRole <urn:usf:sourcecontentrole:fixture> ;
    usf:isDefaultDispositionPolicy false ; usf:isActiveDispositionPolicy true ;
    usf:decisionRationale "Lower-precedence matching policy deliberately selected by the planted disposition." .
  fx:highpolicy a usf:SourceDispositionPolicy ;
    usf:canonicalName "highprecedencepolicy" ;
    usf:policyDispositionKind <urn:usf:dispositionkind:retainasset> ;
    usf:policyDispositionBasis <urn:usf:dispositionbasis:structuralcontentrole> ;
    usf:policyDecisionState <urn:usf:dispositiondecisionstate:accepted> ;
    usf:policyOutputMode <urn:usf:dispositionoutputmode:nooutput> ;
    usf:policyPrecedence 20 ;
    usf:policyMatchesContentRole <urn:usf:sourcecontentrole:fixture> ;
    usf:isDefaultDispositionPolicy false ; usf:isActiveDispositionPolicy true ;
    usf:decisionRationale "Higher-precedence matching policy that should have been selected." .
}

GRAPH <urn:usf:graph:observed:sourceartefacts> {
  <urn:usf:sourceartefact:saaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa> a usf:SourceArtefact ;
    usf:canonicalName "saaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" ;
    usf:sourceIdentityDigest "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" ;
    usf:hasCurrentSourceObservation fx:observation .
  fx:observation a usf:SourceArtefactObservation ;
    usf:canonicalName "obbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb" ;
    usf:observesSourceArtefact <urn:usf:sourceartefact:saaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa> ;
    usf:observedSourcePath "fixtures/non-max-precedence.trig" ;
    usf:observedContentDigest "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb" ;
    usf:observedFileMode "100644" ;
    usf:observedUniverse <urn:usf:sourceuniverse:graphauthority> ;
    usf:observedContentRole <urn:usf:sourcecontentrole:fixture> ;
    usf:observationSetDigest "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc" .
}

GRAPH <urn:usf:graph:derived:sourcedispositions> {
  <urn:usf:sourceartefact:saaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa> usf:hasSourceDisposition fx:disposition .
  fx:disposition a usf:SourceArtefactDisposition ;
    usf:canonicalName "ddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd" ;
    usf:dispositionOfSourceArtefact <urn:usf:sourceartefact:saaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa> ;
    usf:decidedAgainstObservation fx:observation ;
    usf:derivedFromDispositionPolicy fx:lowpolicy ;
    usf:hasDispositionKind <urn:usf:dispositionkind:retainasset> ;
    usf:hasDispositionBasis <urn:usf:dispositionbasis:structuralcontentrole> ;
    usf:hasDispositionDecisionState <urn:usf:dispositiondecisionstate:accepted> ;
    usf:hasDispositionOutputMode <urn:usf:dispositionoutputmode:nooutput> ;
    usf:observationSetDigest "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc" ;
    usf:decisionRationale "Planted defect selects the lower-precedence matching policy." .
}
