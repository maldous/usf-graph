@prefix usf: <urn:usf:ontology:> .
@prefix fx: <urn:usf:fixture:artefactplanmissingowner:> .

GRAPH <urn:usf:graph:fixture:artefactplanmissingowner> {
  fx:plan a usf:ArtefactPlan ; usf:plansArtefact fx:artefact .
  fx:artefact a usf:Artefact ; usf:canonicalPath "generated/missing-owner.json" ;
    usf:artefactKind <urn:usf:artefactkind:contract> ; usf:governedByPathRule fx:pathrule ; usf:generatedByComponent fx:generator .
  fx:pathrule usf:pathPattern "generated/missing-owner.json" .
  fx:generator a usf:CompilerComponent ; usf:semanticInputQuery "SELECT ?resource WHERE { ?resource a <urn:usf:ontology:SemanticContract> . }" ;
    usf:outputSchema fx:artefact ; usf:outputPathRule fx:pathrule ; usf:integrityPolicy fx:integritypolicy ;
    usf:normalisationPolicy fx:normalisationpolicy ; usf:missingSemanticsConstraint fx:missingconstraint ;
    usf:requiresEquivalenceKind <urn:usf:equivalencekind:semantic> .
}
