@prefix usf: <urn:usf:ontology:> .
@prefix bad: <urn:usf:fixture:ui:adversarial:> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<urn:usf:graph:fixture:ui:adversarial> {
    bad:canonicalname a usf:Component ; usf:canonicalName "canonical-name" ; usf:componentKind <urn:usf:componentkind:layout> ; usf:componentOrder 0 .

    bad:missingexposure a usf:Capability .
    bad:uiexposedwithoutmodel a usf:Capability ; usf:uiExposure <urn:usf:uiexposureclass:uiexposed> .
    bad:internalwithmodel a usf:Capability ; usf:uiExposure <urn:usf:uiexposureclass:internal> ; usf:hasUISemanticModel bad:emptymodel .
    bad:unknownexposure a usf:Capability ; usf:uiExposure bad:exposure .

    bad:genericjourney a usf:Journey ; usf:mapsToCapability <urn:usf:capability:universalservicefoundationscopeandprinciples> .
    bad:multijourney a usf:Journey ; usf:mapsToCapability bad:missingexposure , bad:uiexposedwithoutmodel .
    bad:unmappedjourney a usf:Journey .

    bad:emptymodel a usf:UISemanticModel .
    bad:emptyviewmodel a usf:ViewModel .

    bad:webroutesurface usf:surfaceKind <urn:usf:surfacekind:webroute> .
    bad:unknownsurface usf:surfaceKind bad:surfacekind ; usf:rendersViewModel bad:emptyviewmodel .

    bad:routeone a usf:Route ; usf:routePattern "duplicate" ; usf:routeKind <urn:usf:routekind:public> .
    bad:routetwo a usf:Route ; usf:routePattern "duplicate" ; usf:routeKind <urn:usf:routekind:public> .
    bad:routewithoutkind a usf:Route ; usf:routePattern "/missingkind" .

    bad:emptyform a usf:Form .
    bad:duplicatefieldform a usf:Form ; usf:hasField bad:leftfield , bad:rightfield .
    bad:leftfield a usf:FormField ; usf:fieldName "duplicate" ; usf:fieldKind <urn:usf:formfieldkind:text> ; usf:fieldOrder 0 .
    bad:rightfield a usf:FormField ; usf:fieldName "duplicate" ; usf:fieldKind <urn:usf:formfieldkind:text> ; usf:fieldOrder 0 .
    bad:emptyfield a usf:FormField .

    bad:emptyvalidation a usf:ValidationBinding .
    bad:unknownvalidation a usf:ValidationBinding ; usf:validationConstraint bad:constraint ; usf:validationTiming bad:timing .
    bad:constraint a usf:Constraint .

    bad:emptyerror a usf:ErrorBinding .
    bad:baderrorcode a usf:ErrorBinding ; usf:errorCode "bad-error" ; usf:errorState bad:state ; usf:errorPresentation <urn:usf:errorpresentationkind:inline> .
    bad:state a usf:InteractionState .

    bad:emptycomponent a usf:Component .
    bad:componentcycle a usf:Component ; usf:componentKind <urn:usf:componentkind:layout> ; usf:componentOrder 0 ; usf:childComponent bad:componentcycle .

    bad:incompleteaccessibility a usf:AccessibilityProfile ; usf:hasAccessibilityRequirement bad:requirementwithoutkind .
    bad:requirementwithoutkind a usf:AccessibilityRequirement .

    bad:localenotsupported a usf:LocalisationProfile ; usf:defaultLocale "en"^^xsd:language ; usf:supportedLocale "fr"^^xsd:language ; usf:hasLocalisationRequirement bad:messagewithoutkey .
    bad:messagewithoutkey a usf:LocalisationRequirement ; usf:localisationKind <urn:usf:localisationrequirementkind:messagekey> .
    bad:emptylocalisation a usf:LocalisationProfile .

    bad:emptyrenderer a usf:RendererContract .
    bad:e2ewithoutjourney a usf:RendererContract ; usf:rendererImplementation bad:renderer ; usf:rendererTarget <urn:usf:renderertarget:e2e> ; usf:rendererInputSchema bad:artefact ; usf:rendererOutputPlan bad:plan ; usf:supportsSurfaceKind <urn:usf:surfacekind:e2ejourney> .
    bad:documentationwithoutmodel a usf:RendererContract ; usf:rendererImplementation bad:renderer ; usf:rendererTarget <urn:usf:renderertarget:documentation> ; usf:rendererInputSchema bad:artefact ; usf:rendererOutputPlan bad:plan ; usf:supportsSurfaceKind <urn:usf:surfacekind:documentation> .
    bad:renderer a usf:Renderer .

    bad:missingtarget a usf:RendererContract ; usf:rendererImplementation bad:missingtargetrenderer ; usf:rendererInputSchema bad:artefact ; usf:rendererOutputPlan bad:missingtargetplan ; usf:supportsSurfaceKind <urn:usf:surfacekind:webroute> .
    bad:missingtargetrenderer a usf:Renderer .
    bad:missingtargetplan a usf:ArtefactPlan ; usf:ownedByRepository bad:repository ; usf:plansArtefact bad:missingtargetartefact .
    bad:missingtargetartefact a usf:Artefact .

    bad:unownedrenderer a usf:Renderer .

    bad:sharedwebcontract a usf:RendererContract ; usf:rendererImplementation bad:sharedwebrenderer ; usf:rendererTarget <urn:usf:renderertarget:web> ; usf:rendererInputSchema bad:artefact ; usf:rendererOutputPlan bad:sharedtargetplan ; usf:supportsSurfaceKind <urn:usf:surfacekind:webroute> .
    bad:sharedmobilecontract a usf:RendererContract ; usf:rendererImplementation bad:sharedmobilerenderer ; usf:rendererTarget <urn:usf:renderertarget:mobile> ; usf:rendererInputSchema bad:artefact ; usf:rendererOutputPlan bad:sharedtargetplan ; usf:supportsSurfaceKind <urn:usf:surfacekind:mobilescreen> .
    bad:sharedwebrenderer a usf:Renderer .
    bad:sharedmobilerenderer a usf:Renderer .
    bad:sharedtargetplan a usf:ArtefactPlan ; usf:ownedByRepository bad:repository ; usf:plansArtefact bad:sharedtargetartefact .
    bad:sharedtargetartefact a usf:Artefact .
    bad:repository a usf:Repository .

    bad:plan a usf:ArtefactPlan .
    bad:artefact a usf:Artefact .
    bad:pathrule a usf:PathRule .
