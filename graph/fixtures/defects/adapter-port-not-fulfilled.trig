# expect: adapterportnotfulfilled
@prefix usf: <urn:usf:ontology:> .
@prefix fixt: <urn:usf:fixturenode:> .
@prefix pmode: <urn:usf:providermode:> .

<urn:usf:graph:bindings> {
    fixt:mismatchedadapter a usf:Adapter ;
        usf:canonicalName "mismatchedadapter" ;
        usf:implementsPort fixt:portA ;
        usf:bindsProvider fixt:providerB .
    fixt:providerB a usf:Provider ;
        usf:canonicalName "providerb" ;
        usf:hasProviderMode pmode:hermeticmock ;
        usf:fulfilsPort fixt:portC .
    fixt:portA a usf:Port ; usf:canonicalName "porta" .
    fixt:portC a usf:Port ; usf:canonicalName "portc" .
}
