@prefix usf: <urn:usf:ontology:> .
@prefix fx: <urn:usf:fixture:ui:positive:> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<urn:usf:graph:fixture:ui:positive> {
    fx:uicapability a usf:Capability ; usf:canonicalName "uicapability" ; usf:uiExposure <urn:usf:uiexposureclass:uiexposed> ; usf:hasUISemanticModel fx:uimodel ; usf:hasContract fx:uicontract .
    fx:apicapability a usf:Capability ; usf:canonicalName "apicapability" ; usf:uiExposure <urn:usf:uiexposureclass:apionly> .
    fx:internalcapability a usf:Capability ; usf:canonicalName "internalcapability" ; usf:uiExposure <urn:usf:uiexposureclass:internal> .
    fx:notexposedcapability a usf:Capability ; usf:canonicalName "notexposedcapability" ; usf:uiExposure <urn:usf:uiexposureclass:notexposed> .

    fx:journey a usf:Journey ; usf:canonicalName "journey" ; usf:mapsToCapability fx:uicapability .
    fx:uicontract a usf:SemanticContract ; usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:draft> ; usf:declaresFacet fx:uifacet ; usf:disclaims <urn:usf:nonclaim:nohumanacceptance> , <urn:usf:nonclaim:nouiproductparity> , <urn:usf:nonclaim:noaccessibilitycompliance> , <urn:usf:nonclaim:nolaunchi18n> .
    fx:uifacet a usf:ContractFacet ; usf:facetKind <urn:usf:facetkind:uisemantics> ; usf:facetStatus <urn:usf:facetstatus:complete> ; usf:facetStatement "The fixture UI facet is complete." .
    fx:uimodel a usf:UISemanticModel ; usf:canonicalName "uimodel" ; usf:hasJourney fx:journey ; usf:hasViewModel fx:viewmodel ; usf:hasSurface fx:form ; usf:hasAccessibilityProfile fx:accessibilityprofile ; usf:hasLocalisationProfile fx:localisationprofile ; usf:rendererContract fx:webrenderercontract , fx:mobilerenderercontract .
    fx:viewmodel a usf:ViewModel ; usf:canonicalName "viewmodel" ; usf:viewDataModel fx:datamodel ; usf:hasComponent fx:component , fx:actioncomponent ; usf:hasForm fx:form ; usf:hasErrorBinding fx:errorbinding .
    fx:datamodel a usf:DataModel .
    fx:form a usf:Form ; usf:canonicalName "form" ; usf:surfaceKind <urn:usf:surfacekind:form> ; usf:rendersViewModel fx:viewmodel ; usf:hasField fx:field ; usf:submitsOperation fx:operation ; usf:uiRequiresPermission fx:permission .
    fx:operation a usf:Operation ; usf:requiresPermission fx:permission .
    fx:permission a usf:Permission .
    fx:field a usf:FormField ; usf:canonicalName "field" ; usf:fieldName "field" ; usf:fieldKind <urn:usf:formfieldkind:text> ; usf:fieldOrder 0 ; usf:hasValidationBinding fx:validationbinding .
    fx:validationbinding a usf:ValidationBinding ; usf:canonicalName "validationbinding" ; usf:validationConstraint fx:constraint ; usf:validationTiming <urn:usf:validationtiming:submit> .
    fx:constraint a usf:Constraint .
    fx:errorbinding a usf:ErrorBinding ; usf:canonicalName "errorbinding" ; usf:errorCode "errorbinding" ; usf:errorState fx:interactionstate ; usf:errorPresentation <urn:usf:errorpresentationkind:inline> .
    fx:interactionstate a usf:InteractionState .
    fx:component a usf:Component ; usf:canonicalName "component" ; usf:componentKind <urn:usf:componentkind:input> ; usf:componentOrder 0 .
    fx:actioncomponent a usf:Component ; usf:canonicalName "actioncomponent" ; usf:componentKind <urn:usf:componentkind:action> ; usf:componentOrder 1 .

    fx:accessibilityprofile a usf:AccessibilityProfile ; usf:canonicalName "accessibilityprofile" ; usf:hasAccessibilityRequirement fx:keyboardoperable , fx:focusorder , fx:focusvisible , fx:accessiblename , fx:semanticrole , fx:statusannouncement , fx:contrast , fx:languagedeclaration .
    fx:keyboardoperable a usf:AccessibilityRequirement ; usf:accessibilityKind <urn:usf:accessibilityrequirementkind:keyboardoperable> .
    fx:focusorder a usf:AccessibilityRequirement ; usf:accessibilityKind <urn:usf:accessibilityrequirementkind:focusorder> .
    fx:focusvisible a usf:AccessibilityRequirement ; usf:accessibilityKind <urn:usf:accessibilityrequirementkind:focusvisible> .
    fx:accessiblename a usf:AccessibilityRequirement ; usf:accessibilityKind <urn:usf:accessibilityrequirementkind:accessiblename> .
    fx:semanticrole a usf:AccessibilityRequirement ; usf:accessibilityKind <urn:usf:accessibilityrequirementkind:semanticrole> .
    fx:statusannouncement a usf:AccessibilityRequirement ; usf:accessibilityKind <urn:usf:accessibilityrequirementkind:statusannouncement> .
    fx:contrast a usf:AccessibilityRequirement ; usf:accessibilityKind <urn:usf:accessibilityrequirementkind:contrast> .
    fx:languagedeclaration a usf:AccessibilityRequirement ; usf:accessibilityKind <urn:usf:accessibilityrequirementkind:languagedeclaration> .

    fx:localisationprofile a usf:LocalisationProfile ; usf:canonicalName "localisationprofile" ; usf:defaultLocale "en"^^xsd:language ; usf:supportedLocale "en"^^xsd:language ; usf:hasLocalisationRequirement fx:messagerequirement .
    fx:messagerequirement a usf:LocalisationRequirement ; usf:localisationKind <urn:usf:localisationrequirementkind:messagekey> ; usf:messageKey "fixturemessage" .

    fx:webrenderercontract a usf:RendererContract ; usf:canonicalName "webrenderercontract" ; usf:rendererImplementation fx:webrenderer ; usf:rendererTarget <urn:usf:renderertarget:web> ; usf:rendererInputSchema fx:inputschema ; usf:rendererOutputPlan fx:webartefactplan ; usf:supportsSurfaceKind <urn:usf:surfacekind:form> .
    fx:mobilerenderercontract a usf:RendererContract ; usf:canonicalName "mobilerenderercontract" ; usf:rendererImplementation fx:mobilerenderer ; usf:rendererTarget <urn:usf:renderertarget:mobile> ; usf:rendererInputSchema fx:inputschema ; usf:rendererOutputPlan fx:mobileartefactplan ; usf:supportsSurfaceKind <urn:usf:surfacekind:form> .
    fx:webrenderer a usf:Renderer .
    fx:mobilerenderer a usf:Renderer .
    fx:repository a usf:Repository .
    fx:webartefactplan a usf:ArtefactPlan ; usf:canonicalName "webartefactplan" ; usf:ownedByRepository fx:repository ; usf:plansArtefact fx:webinput .
    fx:mobileartefactplan a usf:ArtefactPlan ; usf:canonicalName "mobileartefactplan" ; usf:ownedByRepository fx:repository ; usf:plansArtefact fx:mobileinput .
    fx:inputschema a usf:Artefact ; usf:canonicalName "inputschema" ; usf:artefactKind <urn:usf:artefactkind:schema> ; usf:canonicalPath "ui/inputschema.json" ; usf:governedByPathRule fx:pathrule .
    fx:webinput a usf:Artefact ; usf:canonicalName "webinput" ; usf:artefactKind <urn:usf:artefactkind:manifest> ; usf:canonicalPath "ui/renderinputs/web/index.json" ; usf:governedByPathRule fx:webpathrule .
    fx:mobileinput a usf:Artefact ; usf:canonicalName "mobileinput" ; usf:artefactKind <urn:usf:artefactkind:manifest> ; usf:canonicalPath "ui/renderinputs/mobile/index.json" ; usf:governedByPathRule fx:mobilepathrule .
    fx:pathrule a usf:PathRule ; usf:canonicalName "pathrule" ; usf:pathPattern "ui/{modelid}.json" .
    fx:webpathrule a usf:PathRule ; usf:canonicalName "webpathrule" ; usf:pathPattern "ui/renderinputs/web/{modelid}.json" .
    fx:mobilepathrule a usf:PathRule ; usf:canonicalName "mobilepathrule" ; usf:pathPattern "ui/renderinputs/mobile/{modelid}.json" .
}
