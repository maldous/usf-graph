# conforming
@prefix usf: <urn:usf:ontology:> .
<urn:usf:fixture:wave5kernelvalidationobligation> a usf:ValidationObligation ; usf:canonicalName "fixturewave5kernelvalidationobligation" ; usf:validationForContract <urn:usf:fixture:wave5kernelcontract> .
