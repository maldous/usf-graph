<urn:usf:fixture:wave5kernelvalidationresult> a usf:ValidationResult ; usf:canonicalName "fixturewave5kernelvalidationresult" ; usf:resultState <urn:usf:resultstate:passed> ; usf:entersEvidenceLifecycleAs <urn:usf:fixture:wave5kernelvalidationevidence> .
