@prefix usf: <urn:usf:ontology:> .
@prefix fixt: <urn:usf:fixturenode:> .
@prefix dom: <urn:usf:capabilitydomain:> .
@prefix facet: <urn:usf:facetkind:> .
@prefix rung: <urn:usf:proofrung:> .
@prefix pmode: <urn:usf:providermode:> .
@prefix envc: <urn:usf:environmentclass:> .
@prefix fresh: <urn:usf:freshness:> .

fixt:conformingcommand a usf:Command ; usf:canonicalName "conformingcommand" ;
    usf:requiresPermission fixt:cperm2 ; usf:emitsAuditEvent fixt:caudit .
fixt:cperm2 a usf:Permission ; usf:canonicalName "cperm2" .
fixt:caudit a usf:AuditEvent ; usf:canonicalName "caudit" ;
    usf:auditCategory <urn:usf:auditcategory:datamutation> ; usf:auditSeverity <urn:usf:auditseverity:notice> .
