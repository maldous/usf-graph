  <urn:usf:nonclaim:localenginenotsemanticauthority> a usf:NonClaim ; usf:canonicalName "localenginenotsemanticauthority" .
  <urn:usf:nonclaim:nochrootjavaruntime> a usf:NonClaim ; usf:canonicalName "nochrootjavaruntime" .
  <urn:usf:nonclaim:nolivepublicationfromlocalevidencealone> a usf:NonClaim ; usf:canonicalName "nolivepublicationfromlocalevidencealone" .

  <urn:usf:feature:indexedlocalrdfvalidation> a usf:Feature ; usf:canonicalName "indexedlocalrdfvalidation" .
  <urn:usf:feature:independentengineparity> a usf:Feature ; usf:canonicalName "independentengineparity" .

  <urn:usf:validationobligation:localsemanticvalidationtoolchain> a usf:ValidationObligation ;
      usf:canonicalName "localsemanticvalidationtoolchain" ;
      usf:validationForContract <urn:usf:semanticcontract:localsemanticvalidationtoolchain> .
  <urn:usf:validationenvironment:hostlocalvalidation> a usf:ValidationEnvironment ;
      usf:canonicalName "hostlocalvalidation" ;
      usf:hasEnvironmentClass <urn:usf:environmentclass:hermetic> .

  <urn:usf:realisationoption:rdf4jnativestoreshaclsail> a usf:RealisationOption ;
      usf:canonicalName "rdf4jnativestoreshaclsail" .
  <urn:usf:realisationoption:jenatdbjenashacl> a usf:RealisationOption ;
      usf:canonicalName "jenatdbjenashacl" .
  <urn:usf:realisationoption:dualenginelocalvalidation> a usf:RealisationOption ;
      usf:canonicalName "dualenginelocalvalidation" .
  <urn:usf:realisationoption:hostsidefullcorpusvalidation> a usf:RealisationOption ;
      usf:canonicalName "hostsidefullcorpusvalidation" .
  <urn:usf:realisationoption:chrootfullcorpusvalidation> a usf:RealisationOption ;
