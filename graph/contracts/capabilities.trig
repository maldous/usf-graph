<urn:usf:graph:capabilities> {
 <urn:usf:realisation:compilersemanticenforcementcontractonly> usf:canonicalName "compilersemanticenforcementcontractonly" .
 <urn:usf:realisation:bootstrappacketcontractonly> usf:canonicalName "bootstrappacketcontractonly" .
}

@prefix usf: <urn:usf:ontology:> .
@prefix contractstate: <urn:usf:contractactivationstate:> .
<urn:usf:graph:capabilities> {
 <urn:usf:semanticcontract:compilersemanticenforcement> a usf:SemanticContract ; usf:canonicalName "compilersemanticenforcement" ; usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:active> ; usf:hasActivationState contractstate:active ; usf:activationReason "Superseding admitted digest-bound compiler validation and runtime-proof evidence proves active and model-incomplete contract projection, rejection of unknown contracts, transactional rollback, 114 compiler tests, 45 annotated fixtures, 20 proof cases, eight negative cases, and authority-bound hermetic release signing." ; usf:mandatoryProofObligation <urn:usf:proofobligation:compilersemantics>, <urn:usf:proofobligation:p10cc239b81b3890d5714e8996d369bd08394965220eae7c34aa7c3ccbfc2467b> ; usf:reliesOnProofResult <urn:usf:proofresult:compilersemanticenforcementmodelprojection>, <urn:usf:proofresult:compilersemanticenforcementmodelprojectionderived> ; usf:requiredValidation <urn:usf:validationobligation:compilersemanticenforcement> ; usf:permittedRealisationType usf:Implementation ; usf:asserts <urn:usf:claim:semanticfirstlifecycle> ; usf:disclaims <urn:usf:nonclaim:bootstrapexceptionisimplementationauthority>, <urn:usf:nonclaim:hermeticevaluationsignatureprovidesproductionauthenticity> ; usf:contractConstraint "The compiler validates registered semantic sources, derivation, SHACL, integrity, contamination, and source observations transactionally and fails closed with rollback." ; usf:contractConstraint "Source-equivalence evaluation enforces the exact predicates selected by the bound equivalence rule; exact source digests, canonical capability identity and facet structure remain mandatory, while historical source lifecycle metadata never overrides current semantic lifecycle authority." ; usf:contractConstraint "A digest-bound model-incomplete or proof-blocked contract projection preserves claims, nonclaims, and obligations while granting no action, path, format, proof, or decision authority." ; usf:contractConstraint "The foundation release signing identity derives from the public hermetic label usf-foundation-release-hermetic-evaluation-key-v1 and provides deterministic integrity and tamper evidence only; it is not a production authenticity credential." .
 <urn:usf:semanticcontract:bootstrappacket> a usf:SemanticContract ; usf:canonicalName "bootstrappacket" ; usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:active> ; usf:hasActivationState contractstate:active ; usf:activationReason "Admitted digest-bound bootstrap validation and runtime-proof evidence, two exact evidence-set proofs covering explicit and derived behavior obligations, 21 proof cases including six negative cases, 23 annotated fixtures, and 17 focused unit tests warrant activation." ; usf:mandatoryProofObligation <urn:usf:proofobligation:bootstrappacketsemantics>, <urn:usf:proofobligation:pfe4063321882c4c97f6c8d64ac09f2750b9237fca833fb353ac4ad1124512978> ; usf:reliesOnProofResult <urn:usf:proofresult:bootstrappacket>, <urn:usf:proofresult:bootstrappacketderived> ; usf:requiredValidation <urn:usf:validationobligation:bootstrappacket> ; usf:permittedRealisationType usf:Implementation ; usf:asserts <urn:usf:claim:semanticfirstlifecycle> ; usf:disclaims <urn:usf:nonclaim:bootstrapexceptionisimplementationauthority> ; usf:contractConstraint "The bootstrap packet traces model to evidence to proof to contract to realisation to validation, preserves claims and nonclaims, and is bound to a verified live authority digest." ; usf:contractConstraint "Packets are bounded to 8192 canonical JSON bytes, 50 semantic bindings, and traversal depth three; deterministic continuations are invalid after authority drift." ; usf:contractConstraint "A bootstrap packet is a non-authoritative projection and never grants implementation authority or bypasses current contract projection checks." .
 <urn:usf:claim:semanticfirstlifecycle> a usf:Claim ; usf:canonicalName "semanticfirstlifecycle" .
 <urn:usf:nonclaim:bootstrapexceptionisimplementationauthority> a usf:NonClaim ; usf:canonicalName "bootstrapexceptionisimplementationauthority" .
 <urn:usf:nonclaim:hermeticevaluationsignatureprovidesproductionauthenticity> a usf:NonClaim ; usf:canonicalName "hermeticevaluationsignatureprovidesproductionauthenticity" .
 <urn:usf:realisation:compilersemanticenforcementcontractonly> a usf:Realisation ; usf:realisesContract <urn:usf:semanticcontract:compilersemanticenforcement> ; usf:realisationState <urn:usf:realisationstate:deprecated> .
 <urn:usf:realisation:bootstrappacketcontractonly> a usf:Realisation ; usf:realisesContract <urn:usf:semanticcontract:bootstrappacket> ; usf:realisationState <urn:usf:realisationstate:deprecated> .
}
