    <urn:usf:ontology:sourceBindingPath> "spec/instances/semantic-contract/tenant-isolation-proof.json";
    <urn:usf:ontology:sourceBindingEquivalenceKind> <urn:usf:equivalencekind:structural>.
<urn:usf:semanticcontract:tenantisolationproof> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
<urn:usf:repository:foundation> <urn:usf:ontology:hasArtefactPlan> <urn:usf:artefactplan:semanticcontracttenantisolationproof>.
<urn:usf:artefactplan:semanticcontracttenantisolationproof> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontracttenantisolationproof";
    <urn:usf:ontology:ownedByRepository> <urn:usf:repository:foundation>;
