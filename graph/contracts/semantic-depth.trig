<urn:usf:artefactplan:semanticcontractnotificationdeliveryandpreferencesandchannels> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractnotificationdeliveryandpreferencesandchannels";
    <urn:usf:ontology:ownedByRepository> <urn:usf:repository:foundation>;
    <urn:usf:ontology:plansArtefact> <urn:usf:artefact:semanticcontractnotificationdeliveryandpreferencesandchannels>;
