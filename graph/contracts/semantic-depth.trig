    <urn:usf:ontology:sourceBindingPath> "spec/instances/semantic-contract/environment-specific-vs-shared-service-model.json";
    <urn:usf:ontology:sourceBindingEquivalenceKind> <urn:usf:equivalencekind:structural>.
<urn:usf:semanticcontract:environmentspecificvssharedservicemodel> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
