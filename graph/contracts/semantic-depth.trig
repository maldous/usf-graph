    <urn:usf:ontology:sourceBindingTarget> <urn:usf:semanticcontract:ratelimitingapi>;
    <urn:usf:ontology:sourceBindingContentDigest> "7fc925b3760c95c3a917cd3c964cdb1f7a0bf0d677801b82bd6ea42a825bc379";
    <urn:usf:ontology:sourceBindingPath> "spec/instances/semantic-contract/rate-limiting-api.json";
    <urn:usf:ontology:sourceBindingEquivalenceKind> <urn:usf:equivalencekind:structural>.
<urn:usf:semanticcontract:ratelimitingapi> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
<urn:usf:repository:foundation> <urn:usf:ontology:hasArtefactPlan> <urn:usf:artefactplan:semanticcontractratelimitingapi>.
<urn:usf:artefactplan:semanticcontractratelimitingapi> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractratelimitingapi";
    <urn:usf:ontology:ownedByRepository> <urn:usf:repository:foundation>;
    <urn:usf:ontology:plansArtefact> <urn:usf:artefact:semanticcontractratelimitingapi>;
    <urn:usf:ontology:plansSemanticResource> <urn:usf:semanticcontract:ratelimitingapi>.
<urn:usf:artefact:semanticcontractratelimitingapi> a <urn:usf:ontology:Artefact>;
    <urn:usf:ontology:canonicalName> "semanticcontractratelimitingapi";
    <urn:usf:ontology:artefactKind> <urn:usf:artefactkind:contract>;
    <urn:usf:ontology:canonicalPath> "contracts/semantic/ratelimitingapi.json";
    <urn:usf:ontology:governedByPathRule> <urn:usf:pathrule:semanticcontractratelimitingapi>;
    <urn:usf:ontology:generatedByComponent> <urn:usf:generator:semanticcontract>.
<urn:usf:pathrule:semanticcontractratelimitingapi> a <urn:usf:ontology:PathRule>;
    <urn:usf:ontology:canonicalName> "semanticcontractratelimitingapi";
    <urn:usf:ontology:pathPattern> "contracts/semantic/ratelimitingapi.json".
<urn:usf:sourcesemanticbinding:ratelimitingapisemanticsource> <urn:usf:ontology:sourceBindingArtefactPlan> <urn:usf:artefactplan:semanticcontractratelimitingapi>;
    <urn:usf:ontology:sourceBindingEquivalenceRule> <urn:usf:equivalencerule:semanticcontractprojection>;
    <urn:usf:ontology:sourceBindingTarget> <urn:usf:artefactplan:semanticcontractratelimitingapi>, <urn:usf:artefact:semanticcontractratelimitingapi>, <urn:usf:contractfacet:ratelimitingapilifecycle>.
<urn:usf:contractfacet:ratelimitingapilifecycle> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The rate-limit lifecycle is explicit: an operator sets a per-tenant policy, evaluation checks entitlement before counting, requests move within a fixed window from allowed below or at the limit to denied above the limit, and live counts reset in a new window bucket. No configured policy means opt-in allow.".
<urn:usf:sourcesemanticbinding:ratelimitingapisemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:ratelimitingapistatemodel>.
<urn:usf:contractfacet:ratelimitingapistatemodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Policy state consists of policy key, entitlement key, limit, window seconds, action, and updated-at/updated-by; counter state is per tenant, policy, and window with a used count and an exceeded state once the used count passes the limit. Counters are bucketed by window and reset on a new bucket rather than being decremented.".
<urn:usf:sourcesemanticbinding:ratelimitingapisemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:ratelimitingapipermissions>.
<urn:usf:contractfacet:ratelimitingapipermissions> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Tenant developer reads use a tenant developer-read permission, operator policy read/write use platform rate-limit permissions, and policy evaluation additionally requires the configured entitlement. Operator routes validate the tenant identifier and policy mutation is operator-only.".
<urn:usf:sourcesemanticbinding:ratelimitingapisemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:ratelimitingapicontracts>.
<urn:usf:contractfacet:ratelimitingapicontracts> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "API contracts are a tenant rate-limit read, an operator per-tenant rate-limit read, and an operator per-tenant rate-limit update, with developer-portal exposure of rate-limit summaries. The interface is a rate-limit port with both a cache adapter and a relational adapter behind it.".
<urn:usf:sourcesemanticbinding:ratelimitingapisemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:ratelimitingapivalidation>.
<urn:usf:contractfacet:ratelimitingapivalidation> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Validation proves that no policy is opt-in allow, a missing entitlement denies before counting, configured limits allow below/at the limit and deny above it, and an invalid tenant identifier fails the operator operation. Entitlement is evaluated before the counter is consulted.".
<urn:usf:sourcesemanticbinding:ratelimitingapisemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:ratelimitingapierrormodel>.
<urn:usf:contractfacet:ratelimitingapierrormodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "An assert operation throws once the limit is exceeded while an evaluate operation returns denied decisions distinguishing entitlement denial from exceeded state; when the cache provider is unavailable it reports degraded and falls back to relational counting. Decisions fail closed on ambiguous provider state.".
<urn:usf:sourcesemanticbinding:ratelimitingapisemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:ratelimitingapiauditmodel>.
<urn:usf:contractfacet:ratelimitingapiauditmodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Setting a rate-limit policy emits an audit record before the mutation (audit-before-change) with the rate-limit resource identified, so policy changes are attributable. Evaluation decisions are observable for enforcement.".
<urn:usf:sourcesemanticbinding:ratelimitingapisemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:ratelimitingapireadinessmodel>.
<urn:usf:contractfacet:ratelimitingapireadinessmodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The relational proof skips honestly when the database is unavailable; the cache provider reports ready on a successful ping and degraded on failure, with relational fallback still valid for counting. Readiness never claims availability beyond what the substrate proves.".
<urn:usf:sourcesemanticbinding:ratelimitingapisemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:ratelimitingapiproof>.
<urn:usf:contractfacet:ratelimitingapiproof> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Behaviour is exercised by rate-limit unit tests and runtime proofs validating live relational and cache counting plus operator route behaviour and degraded fallback. Proof is hermetic/runtime lineage; current activation evidence is recorded by the contract proof result and remains subject to freshness and invalidation.".
<urn:usf:sourcesemanticbinding:ratelimitingapisemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:ratelimitingapiuisemantics>.
<urn:usf:contractfacet:ratelimitingapiuisemantics> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:notapplicable>;
    <urn:usf:ontology:facetStatement> "The ratelimitingapi capability is explicitly API-only; no human-rendered surface, component, action, journey, consent prompt, or renderer input is authorised. Any UI requires a deliberate exposure amendment.".
<urn:usf:semanticcontract:ratelimitingapi> <urn:usf:ontology:disclaims> <urn:usf:nonclaim:nohumanacceptance>, <urn:usf:nonclaim:nouiproductparity>, <urn:usf:nonclaim:noaccessibilitycompliance>, <urn:usf:nonclaim:nolaunchi18n>.
<urn:usf:sourcesemanticbinding:rbacrolesandpermissionssemanticsource> a <urn:usf:ontology:SourceSemanticBinding>;
    <urn:usf:ontology:canonicalName> "rbacrolesandpermissionssemanticsource";
