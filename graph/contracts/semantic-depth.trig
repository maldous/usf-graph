<urn:usf:repository:foundation> <urn:usf:ontology:hasArtefactPlan> <urn:usf:artefactplan:semanticcontractenvironmentregistryandbootstrap>.
<urn:usf:artefactplan:semanticcontractenvironmentregistryandbootstrap> a <urn:usf:ontology:ArtefactPlan>;
