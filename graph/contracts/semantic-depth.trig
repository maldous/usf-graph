<urn:usf:semanticcontract:servicecatalogandproviderintegrationmodel> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
<urn:usf:repository:foundation> <urn:usf:ontology:hasArtefactPlan> <urn:usf:artefactplan:semanticcontractservicecatalogandproviderintegrationmodel>.
<urn:usf:artefactplan:semanticcontractservicecatalogandproviderintegrationmodel> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractservicecatalogandproviderintegrationmodel";
    <urn:usf:ontology:ownedByRepository> <urn:usf:repository:foundation>;
    <urn:usf:ontology:plansArtefact> <urn:usf:artefact:semanticcontractservicecatalogandproviderintegrationmodel>;
