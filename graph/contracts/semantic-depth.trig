<urn:usf:semanticcontract:datagovernancecataloglineageclassificationpiidsrgdpr> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
<urn:usf:repository:foundation> <urn:usf:ontology:hasArtefactPlan> <urn:usf:artefactplan:semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr>.
<urn:usf:artefactplan:semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr";
    <urn:usf:ontology:ownedByRepository> <urn:usf:repository:foundation>;
    <urn:usf:ontology:plansArtefact> <urn:usf:artefact:semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr>;
    <urn:usf:ontology:plansSemanticResource> <urn:usf:semanticcontract:datagovernancecataloglineageclassificationpiidsrgdpr>.
<urn:usf:artefact:semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr> a <urn:usf:ontology:Artefact>;
    <urn:usf:ontology:canonicalName> "semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr";
    <urn:usf:ontology:artefactKind> <urn:usf:artefactkind:contract>;
    <urn:usf:ontology:canonicalPath> "contracts/semantic/datagovernancecataloglineageclassificationpiidsrgdpr.json";
    <urn:usf:ontology:governedByPathRule> <urn:usf:pathrule:semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr>;
    <urn:usf:ontology:generatedByComponent> <urn:usf:generator:semanticcontract>.
<urn:usf:pathrule:semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr> a <urn:usf:ontology:PathRule>;
    <urn:usf:ontology:canonicalName> "semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr";
    <urn:usf:ontology:pathPattern> "contracts/semantic/datagovernancecataloglineageclassificationpiidsrgdpr.json".
<urn:usf:sourcesemanticbinding:datagovernancecataloglineageclassificationpiidsrgdprsemanticsource> <urn:usf:ontology:sourceBindingArtefactPlan> <urn:usf:artefactplan:semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr>;
    <urn:usf:ontology:sourceBindingEquivalenceRule> <urn:usf:equivalencerule:semanticcontractprojection>;
    <urn:usf:ontology:sourceBindingTarget> <urn:usf:artefactplan:semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr>, <urn:usf:artefact:semanticcontractdatagovernancecataloglineageclassificationpiidsrgdpr>, <urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprlifecycle>.
<urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprlifecycle> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Maintains a data catalog with lineage, rules-based PII/sensitivity classification of datasets, and a data-subject-request workflow for privacy/GDPR fulfilment, composed from tenant foundation signals with audit. Classifications and request records progress through defined states, and request fulfilment captures durable evidence of what was done. The capability fails closed where source data or configuration is unavailable rather than inventing classifications or marking requests fulfilled without evidence.".
<urn:usf:sourcesemanticbinding:datagovernancecataloglineageclassificationpiidsrgdprsemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprstatemodel>.
<urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprstatemodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "State comprises catalog entries with lineage, dataset classifications constrained to none, PII, or sensitive, and data-subject-request records constrained to open or fulfilled, with a fulfilment-evidence payload attached on completion. The classification and request constraints are defined by a governance migration and the evidence payload was added by a later forward migration to preserve checksum stability of the original. Lineage and catalog metadata describe datasets without copying their sensitive contents.".
<urn:usf:sourcesemanticbinding:datagovernancecataloglineageclassificationpiidsrgdprsemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprpermissions>.
<urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprpermissions> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Catalog and classification are read broadly within governance scope with operator-controlled writes, while data-subject-request handling is a privileged, audited workflow. Access is constrained so that classification and request operations preserve tenant boundary and isolation, and request fulfilment is attributable to the operator who performed it. PII handling follows least-exposure so that catalog metadata never surfaces secret fields.".
<urn:usf:sourcesemanticbinding:datagovernancecataloglineageclassificationpiidsrgdprsemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprcontracts>.
<urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprcontracts> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The capability exposes a governance catalog with lineage plus data-subject-request routes, and interacts with other capabilities (cross-capability interactions are recorded) because lineage and classification draw on tenant foundation signals. The contract requires that a request transition to fulfilled only with captured fulfilment evidence, and that classification values stay within the constrained vocabulary enforced by check constraints. New behaviour must update the semantic artefacts.".
<urn:usf:sourcesemanticbinding:datagovernancecataloglineageclassificationpiidsrgdprsemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprvalidation>.
<urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprvalidation> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Classification values are validated against the constrained set (none, PII, sensitive) and request states against open or fulfilled by database check constraints, so out-of-vocabulary values are rejected. Fulfilment requires the evidence payload to be present before a request is considered fulfilled. Missing or invalid configuration fails closed rather than defaulting.".
<urn:usf:sourcesemanticbinding:datagovernancecataloglineageclassificationpiidsrgdprsemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprerrormodel>.
<urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprerrormodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Failures are deterministic and fail-closed: a request cannot be marked fulfilled without evidence, invalid classifications are rejected, and provider failure returns a typed degraded or readiness error while keeping mutation boundaries closed and not fabricating provider success. Tenant data is never silently dropped or remapped, and the incident class is tenant-data-or-security because mishandling carries privacy exposure risk.".
<urn:usf:sourcesemanticbinding:datagovernancecataloglineageclassificationpiidsrgdprsemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprauditmodel>.
<urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprauditmodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Data-subject-request fulfilment records durable evidence, and classification and catalog changes are tenant-scoped and traceable through typed logs carrying the tenant/organisation identifier and through route/use-case/provider spans that preserve tenant context. The audit trail supports compliance and evidence-pack production, and recovery must preserve the data-subject evidence alongside the records.".
<urn:usf:sourcesemanticbinding:datagovernancecataloglineageclassificationpiidsrgdprsemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprreadinessmodel>.
<urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprreadinessmodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Readiness depends on the governance adapter and its store being reachable; the capability degrades explicitly when the adapter is unavailable, disabling mutating governance paths while keeping read-only readiness and audit visible. Readiness being blocked, a failed governance proof during promotion, or a missing isolation or audit signal raise alerts and block promotion.".
<urn:usf:sourcesemanticbinding:datagovernancecataloglineageclassificationpiidsrgdprsemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprproof>.
<urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdprproof> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Behaviour is exercised by the data-governance proof and governance unit tests covering classification constraints and data-subject-request fulfilment evidence. Proof is hermetic/runtime lineage; current activation evidence is recorded by the contract proof result and remains subject to freshness and invalidation.".
<urn:usf:sourcesemanticbinding:datagovernancecataloglineageclassificationpiidsrgdprsemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdpruisemantics>.
<urn:usf:contractfacet:datagovernancecataloglineageclassificationpiidsrgdpruisemantics> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:notapplicable>;
    <urn:usf:ontology:facetStatement> "The datagovernancecataloglineageclassificationpiidsrgdpr capability is explicitly not exposed; no product or operator UI is authorised. Any UI requires a deliberate exposure amendment.".
<urn:usf:semanticcontract:datagovernancecataloglineageclassificationpiidsrgdpr> <urn:usf:ontology:disclaims> <urn:usf:nonclaim:nohumanacceptance>, <urn:usf:nonclaim:nouiproductparity>, <urn:usf:nonclaim:noaccessibilitycompliance>, <urn:usf:nonclaim:nolaunchi18n>.
