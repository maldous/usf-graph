    <urn:usf:ontology:sourceBindingTarget> <urn:usf:semanticcontract:servicecatalogandproviderintegrationmodel>;
    <urn:usf:ontology:sourceBindingContentDigest> "8fd09a45b22427dfbebac359f268893fc2a4bd1d5870a2aa745dcf6bd45e5a7e";
    <urn:usf:ontology:sourceBindingPath> "spec/instances/semantic-contract/service-catalog-and-provider-integration-model.json";
