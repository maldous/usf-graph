    <urn:usf:ontology:sourceBindingEquivalenceKind> <urn:usf:equivalencekind:structural>.
<urn:usf:semanticcontract:e2econfidenceladderstageaware> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
