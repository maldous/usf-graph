    <urn:usf:ontology:sourceBindingPath> "spec/instances/semantic-contract/code-quality-and-secret-and-dependency-scanning.json";
    <urn:usf:ontology:sourceBindingEquivalenceKind> <urn:usf:equivalencekind:structural>.
<urn:usf:semanticcontract:codequalityandsecretanddependencyscanning> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
