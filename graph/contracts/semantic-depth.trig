<urn:usf:artefactplan:semanticcontractenvironmentspecificvssharedservicemodel> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractenvironmentspecificvssharedservicemodel";
    <urn:usf:ontology:ownedByRepository> <urn:usf:repository:foundation>;
    <urn:usf:ontology:plansArtefact> <urn:usf:artefact:semanticcontractenvironmentspecificvssharedservicemodel>;
