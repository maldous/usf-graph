    <urn:usf:ontology:sourceBindingTarget> <urn:usf:semanticcontract:accessibilitya11ygate>;
    <urn:usf:ontology:sourceBindingContentDigest> "0b294ceea849993bc1d39950ae316bc934a65fd27eb7a664b0c4b68aa2591bbc";
    <urn:usf:ontology:sourceBindingPath> "spec/instances/semantic-contract/accessibility-a11y-gate.json";
    <urn:usf:ontology:sourceBindingEquivalenceKind> <urn:usf:equivalencekind:structural>.
<urn:usf:semanticcontract:accessibilitya11ygate> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
<urn:usf:repository:foundation> <urn:usf:ontology:hasArtefactPlan> <urn:usf:artefactplan:semanticcontractaccessibilitya11ygate>.
<urn:usf:artefactplan:semanticcontractaccessibilitya11ygate> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractaccessibilitya11ygate";
    <urn:usf:ontology:ownedByRepository> <urn:usf:repository:foundation>;
    <urn:usf:ontology:plansArtefact> <urn:usf:artefact:semanticcontractaccessibilitya11ygate>;
    <urn:usf:ontology:plansSemanticResource> <urn:usf:semanticcontract:accessibilitya11ygate>.
<urn:usf:artefact:semanticcontractaccessibilitya11ygate> a <urn:usf:ontology:Artefact>;
    <urn:usf:ontology:canonicalName> "semanticcontractaccessibilitya11ygate";
    <urn:usf:ontology:artefactKind> <urn:usf:artefactkind:contract>;
    <urn:usf:ontology:canonicalPath> "contracts/semantic/accessibilitya11ygate.json";
    <urn:usf:ontology:governedByPathRule> <urn:usf:pathrule:semanticcontractaccessibilitya11ygate>;
    <urn:usf:ontology:generatedByComponent> <urn:usf:generator:semanticcontract>.
<urn:usf:pathrule:semanticcontractaccessibilitya11ygate> a <urn:usf:ontology:PathRule>;
    <urn:usf:ontology:canonicalName> "semanticcontractaccessibilitya11ygate";
    <urn:usf:ontology:pathPattern> "contracts/semantic/accessibilitya11ygate.json".
<urn:usf:sourcesemanticbinding:accessibilitya11ygatesemanticsource> <urn:usf:ontology:sourceBindingArtefactPlan> <urn:usf:artefactplan:semanticcontractaccessibilitya11ygate>;
    <urn:usf:ontology:sourceBindingEquivalenceRule> <urn:usf:equivalencerule:semanticcontractprojection>;
    <urn:usf:ontology:sourceBindingTarget> <urn:usf:artefactplan:semanticcontractaccessibilitya11ygate>, <urn:usf:artefact:semanticcontractaccessibilitya11ygate>, <urn:usf:contractfacet:accessibilitya11ygatelifecycle>.
<urn:usf:contractfacet:accessibilitya11ygatelifecycle> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Gate capability that asserts landmark, role, ARIA, and axe expectations as a contract over UI capabilities and gates promotion on them; it is neither provider-backed nor database-backed and owns no tenant records. It deploys the V1-proven e2e accessibility spec contract and must keep its lifecycle/readiness model unchanged during extraction, with migrations limited to contract/config references. Recovery re-runs the e2e accessibility spec before promotion continues.".
<urn:usf:sourcesemanticbinding:accessibilitya11ygatesemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:accessibilitya11ygatestatemodel>.
<urn:usf:contractfacet:accessibilitya11ygatestatemodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The state is the set of accessibility expectations and the latest gate results rather than owned tenant rows: the required landmarks, roles, ARIA attributes, and axe rule outcomes per audited surface, held as configuration and evidence. It has no owned database schema, so backup scope is configuration/evidence only and restore cannot create tenant data. Results are per-run evidence reconciled against the expected accessibility contract.".
<urn:usf:sourcesemanticbinding:accessibilitya11ygatesemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:accessibilitya11ygatepermissions>.
<urn:usf:contractfacet:accessibilitya11ygatepermissions> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The a11y gate owns no tenant data and exposes no tenant-mutating routes, so standard platform security controls apply; the gate is an operator/CI concern rather than an end-user permission. Accessibility expectations apply to UI surfaces for all users and are not tenant-gated. Configuring exceptions is a governance authority, not an end-user role.".
<urn:usf:sourcesemanticbinding:accessibilitya11ygatesemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:accessibilitya11ygatecontracts>.
<urn:usf:contractfacet:accessibilitya11ygatecontracts> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The contract is the accessibility expectation set (landmarks, roles, ARIA, and axe rules) that audited UI capabilities must satisfy, exercised by the e2e accessibility spec. Configuration is read from the declared provider/config plane and missing or invalid configuration fails closed instead of inventing defaults. The gate verdict is the contract that promotion decisions consume.".
<urn:usf:sourcesemanticbinding:accessibilitya11ygatesemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:accessibilitya11ygatevalidation>.
<urn:usf:contractfacet:accessibilitya11ygatevalidation> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Validation runs the accessibility checks (landmark/role/ARIA assertions plus axe scans) against the audited surfaces and fails when expectations are unmet. Inputs are the rendered UI surfaces and the expectation set, which must both be present. Missing or unknown results are treated as not-pass rather than assumed accessible.".
<urn:usf:sourcesemanticbinding:accessibilitya11ygatesemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:accessibilitya11ygateerrormodel>.
<urn:usf:contractfacet:accessibilitya11ygateerrormodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Local failure returns a typed platform error or a readiness-degraded state without changing tenant-visible semantics; unavailable local dependencies fail closed through the readiness model. An accessibility violation produces a failing gate verdict rather than a silent pass. The risk class is semantic drift or configuration loss, not tenant data loss.".
<urn:usf:sourcesemanticbinding:accessibilitya11ygatesemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:accessibilitya11ygateauditmodel>.
<urn:usf:contractfacet:accessibilitya11ygateauditmodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Because it performs no tenant mutation, its audit concern is the accessibility evidence record: the per-surface landmark/role/ARIA/axe results form the reviewable proof of conformance. These results remain visible so accessibility posture is inspectable. Recovery re-runs the e2e accessibility spec so the conformance claim stays evidence-backed.".
<urn:usf:sourcesemanticbinding:accessibilitya11ygatesemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:accessibilitya11ygatereadinessmodel>.
<urn:usf:contractfacet:accessibilitya11ygatereadinessmodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Readiness means the audited UI surfaces meet the accessibility expectations and the e2e accessibility spec passes; unavailable dependencies fail closed through the readiness model. Readiness is demonstrated by re-running the accessibility spec rather than by a live heartbeat. Missing, stale, or unknown results do not count as ready.".
<urn:usf:sourcesemanticbinding:accessibilitya11ygatesemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:accessibilitya11ygateproof>.
<urn:usf:contractfacet:accessibilitya11ygateproof> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Behaviour is exercised by the e2e accessibility spec, demonstrating the landmark, role, ARIA, and axe expectations as a gate over UI capabilities. Proof is hermetic/runtime lineage; current activation evidence is recorded by the contract proof result and remains subject to freshness and invalidation.".
<urn:usf:sourcesemanticbinding:accessibilitya11ygatesemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:accessibilitya11ygateuisemantics>.
<urn:usf:contractfacet:accessibilitya11ygateuisemantics> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:notapplicable>;
    <urn:usf:ontology:facetStatement> "The accessibilitya11ygate capability is explicitly internal; no product or operator UI is authorised. Any UI requires a deliberate exposure amendment.".
<urn:usf:semanticcontract:accessibilitya11ygate> <urn:usf:ontology:disclaims> <urn:usf:nonclaim:nohumanacceptance>, <urn:usf:nonclaim:nouiproductparity>, <urn:usf:nonclaim:noaccessibilitycompliance>, <urn:usf:nonclaim:nolaunchi18n>.
