<urn:usf:artefact:semanticcontracttenantlifecycleprovisionsuspenddeleteexport> a <urn:usf:ontology:Artefact>;
    <urn:usf:ontology:canonicalName> "semanticcontracttenantlifecycleprovisionsuspenddeleteexport";
    <urn:usf:ontology:artefactKind> <urn:usf:artefactkind:contract>;
