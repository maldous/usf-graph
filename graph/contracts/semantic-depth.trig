<urn:usf:semanticcontract:suborganisations> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
<urn:usf:repository:foundation> <urn:usf:ontology:hasArtefactPlan> <urn:usf:artefactplan:semanticcontractsuborganisations>.
<urn:usf:artefactplan:semanticcontractsuborganisations> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractsuborganisations";
    <urn:usf:ontology:ownedByRepository> <urn:usf:repository:foundation>;
