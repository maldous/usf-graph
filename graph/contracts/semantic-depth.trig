<urn:usf:artefact:semanticcontractcustomdomainsdnsownershiptlscanonical> a <urn:usf:ontology:Artefact>;
    <urn:usf:ontology:canonicalName> "semanticcontractcustomdomainsdnsownershiptlscanonical";
