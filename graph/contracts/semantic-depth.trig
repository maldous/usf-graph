<urn:usf:semanticcontract:providerenvironmentclassification> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
<urn:usf:repository:foundation> <urn:usf:ontology:hasArtefactPlan> <urn:usf:artefactplan:semanticcontractproviderenvironmentclassification>.
<urn:usf:artefactplan:semanticcontractproviderenvironmentclassification> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractproviderenvironmentclassification";
