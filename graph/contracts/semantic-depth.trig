<urn:usf:artefact:semanticcontractapidocsdeveloperportalsdksratelimits> a <urn:usf:ontology:Artefact>;
    <urn:usf:ontology:canonicalName> "semanticcontractapidocsdeveloperportalsdksratelimits";
