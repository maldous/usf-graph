    <urn:usf:ontology:sourceBindingContentDigest> "b7777ff9c0945f93fef4ba2ce37447b9f8cbcc6089662de7932ed2a5b3ec836b";
    <urn:usf:ontology:sourceBindingPath> "spec/instances/semantic-contract/authentication-platform.json";
    <urn:usf:ontology:sourceBindingEquivalenceKind> <urn:usf:equivalencekind:structural>.
<urn:usf:semanticcontract:authenticationplatform> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
<urn:usf:repository:foundation> <urn:usf:ontology:hasArtefactPlan> <urn:usf:artefactplan:semanticcontractauthenticationplatform>.
<urn:usf:artefactplan:semanticcontractauthenticationplatform> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractauthenticationplatform";
