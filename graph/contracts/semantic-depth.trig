<urn:usf:artefactplan:semanticcontracte2econfidenceladderstageaware> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontracte2econfidenceladderstageaware";
    <urn:usf:ontology:ownedByRepository> <urn:usf:repository:foundation>;
    <urn:usf:ontology:plansArtefact> <urn:usf:artefact:semanticcontracte2econfidenceladderstageaware>;
