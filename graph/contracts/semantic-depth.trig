<urn:usf:artefactplan:semanticcontractworkflowenginescheduledjobsapprovals> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractworkflowenginescheduledjobsapprovals";
