    <urn:usf:ontology:sourceBindingTarget> <urn:usf:semanticcontract:auditofprivilegedaccess>;
    <urn:usf:ontology:sourceBindingContentDigest> "535ca0ba9ce5aeae053082fb3820f9ea024f4fb455aebcb0a0a26dc60ad3f6a3";
    <urn:usf:ontology:sourceBindingPath> "spec/instances/semantic-contract/audit-of-privileged-access.json";
    <urn:usf:ontology:sourceBindingEquivalenceKind> <urn:usf:equivalencekind:structural>.
<urn:usf:semanticcontract:auditofprivilegedaccess> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
<urn:usf:repository:foundation> <urn:usf:ontology:hasArtefactPlan> <urn:usf:artefactplan:semanticcontractauditofprivilegedaccess>.
<urn:usf:artefactplan:semanticcontractauditofprivilegedaccess> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractauditofprivilegedaccess";
    <urn:usf:ontology:ownedByRepository> <urn:usf:repository:foundation>;
    <urn:usf:ontology:plansArtefact> <urn:usf:artefact:semanticcontractauditofprivilegedaccess>;
    <urn:usf:ontology:plansSemanticResource> <urn:usf:semanticcontract:auditofprivilegedaccess>.
<urn:usf:artefact:semanticcontractauditofprivilegedaccess> a <urn:usf:ontology:Artefact>;
    <urn:usf:ontology:canonicalName> "semanticcontractauditofprivilegedaccess";
    <urn:usf:ontology:artefactKind> <urn:usf:artefactkind:contract>;
    <urn:usf:ontology:canonicalPath> "contracts/semantic/auditofprivilegedaccess.json";
    <urn:usf:ontology:governedByPathRule> <urn:usf:pathrule:semanticcontractauditofprivilegedaccess>;
    <urn:usf:ontology:generatedByComponent> <urn:usf:generator:semanticcontract>.
<urn:usf:pathrule:semanticcontractauditofprivilegedaccess> a <urn:usf:ontology:PathRule>;
    <urn:usf:ontology:canonicalName> "semanticcontractauditofprivilegedaccess";
    <urn:usf:ontology:pathPattern> "contracts/semantic/auditofprivilegedaccess.json".
<urn:usf:sourcesemanticbinding:auditofprivilegedaccesssemanticsource> <urn:usf:ontology:sourceBindingArtefactPlan> <urn:usf:artefactplan:semanticcontractauditofprivilegedaccess>;
    <urn:usf:ontology:sourceBindingEquivalenceRule> <urn:usf:equivalencerule:semanticcontractprojection>;
    <urn:usf:ontology:sourceBindingTarget> <urn:usf:artefactplan:semanticcontractauditofprivilegedaccess>, <urn:usf:artefact:semanticcontractauditofprivilegedaccess>, <urn:usf:contractfacet:auditofprivilegedaccesslifecycle>.
<urn:usf:contractfacet:auditofprivilegedaccesslifecycle> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The privileged-audit lifecycle is a read-only contextual query over durable audit rows: choose a logical resource, map it to the stored resource and per-context permission, query tenant-scoped audit events, redact secret metadata, and return a bounded result. It consumes the audit evidence produced by privileged operations such as support/break-glass access.".
<urn:usf:sourcesemanticbinding:auditofprivilegedaccesssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:auditofprivilegedaccessstatemodel>.
<urn:usf:contractfacet:auditofprivilegedaccessstatemodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "State is an audit-event projection carrying id, action, actor id, resource, resource id, timestamp, and redacted metadata, where logical resources map to member, config, feature, and auth-settings contexts. The capability projects existing durable rows rather than owning new mutable state.".
<urn:usf:sourcesemanticbinding:auditofprivilegedaccesssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:auditofprivilegedaccesspermissions>.
<urn:usf:contractfacet:auditofprivilegedaccesspermissions> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The route requires a coarse tenant audit-read permission and the usecase additionally enforces a per-context permission such as member, config, feature, or auth-settings read. The tenant id comes from the resolved session, never from the client, preserving tenant isolation.".
<urn:usf:sourcesemanticbinding:auditofprivilegedaccesssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:auditofprivilegedaccesscontracts>.
<urn:usf:contractfacet:auditofprivilegedaccesscontracts> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The operation surface is a single tenant-scoped audit query accepting resource, resource id, action, actor, from/to, and limit parameters. It returns a bounded, redacted projection.".
<urn:usf:sourcesemanticbinding:auditofprivilegedaccesssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:auditofprivilegedaccessvalidation>.
<urn:usf:contractfacet:auditofprivilegedaccessvalidation> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Unknown logical resources are invalid, a missing per-context permission is forbidden, the limit is clamped to a bounded range, and resource-id, action, actor, and date filters are optional. Invalid queries return no rows.".
<urn:usf:sourcesemanticbinding:auditofprivilegedaccesssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:auditofprivilegedaccesserrormodel>.
<urn:usf:contractfacet:auditofprivilegedaccesserrormodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Typed outcomes are ok, forbidden, and invalid, mapped fail-closed to 200, 403, and 400; provider failure returns a typed degraded result. The query never returns cross-tenant or unauthorised rows.".
<urn:usf:sourcesemanticbinding:auditofprivilegedaccesssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:auditofprivilegedaccessauditmodel>.
<urn:usf:contractfacet:auditofprivilegedaccessauditmodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The capability reads existing audit events and is not itself a mutation audit, redacting secret-like metadata keys and not exposing client IP or user agent. It is the consumer side of the privileged-access audit dependency, failing closed when producer evidence is unavailable.".
<urn:usf:sourcesemanticbinding:auditofprivilegedaccesssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:auditofprivilegedaccessreadinessmodel>.
<urn:usf:contractfacet:auditofprivilegedaccessreadinessmodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Readiness is invariant-ready for contextual audit reads, and degraded mode keeps read-only projection visible while disabling any dependent mutation. A broader live history proof validates read-only projection, source isolation, secret exclusion, pagination, and absence of mutation against the live data substrate.".
<urn:usf:sourcesemanticbinding:auditofprivilegedaccesssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:auditofprivilegedaccessproof>.
<urn:usf:contractfacet:auditofprivilegedaccessproof> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "A unit proof covers the contextual audit semantics and an adjacent runtime history proof validates live read-only audit/history projection, demonstrated in source lineage via hermetic/runtime validation. Proof is hermetic/runtime lineage; current activation evidence is recorded by the contract proof result and remains subject to freshness and invalidation.".
<urn:usf:sourcesemanticbinding:auditofprivilegedaccesssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:auditofprivilegedaccessuisemantics>.
<urn:usf:contractfacet:auditofprivilegedaccessuisemantics> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:notapplicable>;
    <urn:usf:ontology:facetStatement> "The auditofprivilegedaccess capability is explicitly not exposed; no product or operator UI is authorised. Any UI requires a deliberate exposure amendment.".
<urn:usf:semanticcontract:auditofprivilegedaccess> <urn:usf:ontology:disclaims> <urn:usf:nonclaim:nohumanacceptance>, <urn:usf:nonclaim:nouiproductparity>, <urn:usf:nonclaim:noaccessibilitycompliance>, <urn:usf:nonclaim:nolaunchi18n>.
<urn:usf:sourcesemanticbinding:authenticationplatformsemanticsource> a <urn:usf:ontology:SourceSemanticBinding>;
