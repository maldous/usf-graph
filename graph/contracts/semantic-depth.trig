    <urn:usf:ontology:sourceBindingPath> "spec/instances/semantic-contract/object-storage-and-tenant-prefixes-and-signed-urls.json";
    <urn:usf:ontology:sourceBindingEquivalenceKind> <urn:usf:equivalencekind:structural>.
<urn:usf:semanticcontract:objectstorageandtenantprefixesandsignedurls> <urn:usf:ontology:semanticLifecycleState> <urn:usf:semanticlifecyclestate:active>.
<urn:usf:repository:foundation> <urn:usf:ontology:hasArtefactPlan> <urn:usf:artefactplan:semanticcontractobjectstorageandtenantprefixesandsignedurls>.
<urn:usf:artefactplan:semanticcontractobjectstorageandtenantprefixesandsignedurls> a <urn:usf:ontology:ArtefactPlan>;
    <urn:usf:ontology:canonicalName> "semanticcontractobjectstorageandtenantprefixesandsignedurls";
    <urn:usf:ontology:ownedByRepository> <urn:usf:repository:foundation>;
    <urn:usf:ontology:plansArtefact> <urn:usf:artefact:semanticcontractobjectstorageandtenantprefixesandsignedurls>;
    <urn:usf:ontology:plansSemanticResource> <urn:usf:semanticcontract:objectstorageandtenantprefixesandsignedurls>.
<urn:usf:artefact:semanticcontractobjectstorageandtenantprefixesandsignedurls> a <urn:usf:ontology:Artefact>;
    <urn:usf:ontology:canonicalName> "semanticcontractobjectstorageandtenantprefixesandsignedurls";
    <urn:usf:ontology:artefactKind> <urn:usf:artefactkind:contract>;
    <urn:usf:ontology:canonicalPath> "contracts/semantic/objectstorageandtenantprefixesandsignedurls.json";
    <urn:usf:ontology:governedByPathRule> <urn:usf:pathrule:semanticcontractobjectstorageandtenantprefixesandsignedurls>;
    <urn:usf:ontology:generatedByComponent> <urn:usf:generator:semanticcontract>.
<urn:usf:pathrule:semanticcontractobjectstorageandtenantprefixesandsignedurls> a <urn:usf:ontology:PathRule>;
    <urn:usf:ontology:canonicalName> "semanticcontractobjectstorageandtenantprefixesandsignedurls";
    <urn:usf:ontology:pathPattern> "contracts/semantic/objectstorageandtenantprefixesandsignedurls.json".
<urn:usf:sourcesemanticbinding:objectstorageandtenantprefixesandsignedurlssemanticsource> <urn:usf:ontology:sourceBindingArtefactPlan> <urn:usf:artefactplan:semanticcontractobjectstorageandtenantprefixesandsignedurls>;
    <urn:usf:ontology:sourceBindingEquivalenceRule> <urn:usf:equivalencerule:semanticcontractprojection>;
    <urn:usf:ontology:sourceBindingTarget> <urn:usf:artefactplan:semanticcontractobjectstorageandtenantprefixesandsignedurls>, <urn:usf:artefact:semanticcontractobjectstorageandtenantprefixesandsignedurls>, <urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlslifecycle>.
<urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlslifecycle> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Provides tenant object storage with per-tenant key prefixes, signed-URL access, and an upload-scan lifecycle, exposed through object, readiness, and probe operations; object bytes live in the object-storage provider while a per-object registry row tracks lifecycle in the relational store. An object moves through scan states from uploaded to clean, quarantined, or rejected, and storage usage is metered. The capability composes an object-storage adapter with a relational object-registry repository.".
<urn:usf:sourcesemanticbinding:objectstorageandtenantprefixesandsignedurlssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsstatemodel>.
<urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsstatemodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Each object is represented by a registry record carrying an object id, tenant/organisation id, object key, content type, size in bytes, scan state (uploaded, quarantined, clean, or rejected), timestamps, and the tenant prefix, with storage usage tracked against a storage-bytes quota meter. Object bytes are held under a tenant-scoped key prefix in the object-storage provider, while the registry row is the relational source of truth for lifecycle and quota. The registry table is tenant-scoped under row-level security.".
<urn:usf:sourcesemanticbinding:objectstorageandtenantprefixesandsignedurlssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlspermissions>.
<urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlspermissions> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Objects are isolated by tenant prefix and by tenant-scoped registry access, so one tenant cannot enumerate or read another tenant's objects, and access to bytes is mediated by short-lived signed URLs rather than open buckets. The provider is identity-integrated so claim-to-policy mapping governs bucket access, and tenant-scoped registry rows enforce isolation in the database layer. Object operations are security-sensitive and must preserve permission and isolation.".
<urn:usf:sourcesemanticbinding:objectstorageandtenantprefixesandsignedurlssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlscontracts>.
<urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlscontracts> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The contract exposes object operations plus storage readiness and a probe, mediating all access through the storage adapter and the object-registry repository behind ports. Reads and writes of bytes occur via signed URLs scoped to the tenant prefix, and registry mutations record scan state and size for quota. There is a recorded cross-capability interaction with quota enforcement via the storage-bytes meter.".
<urn:usf:sourcesemanticbinding:objectstorageandtenantprefixesandsignedurlssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsvalidation>.
<urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsvalidation> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Uploads validate content type and size against quota and place the object under the correct tenant prefix; the scan lifecycle validates an object as clean before it is treated as usable, quarantining or rejecting otherwise. Tenant context is required so registry access and prefixes are correctly scoped. Missing or invalid configuration fails closed rather than defaulting to an open bucket.".
<urn:usf:sourcesemanticbinding:objectstorageandtenantprefixesandsignedurlssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlserrormodel>.
<urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlserrormodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "The model is fail-closed and security-sensitive: an unscanned or quarantined object is not served as clean, provider failure returns a typed degraded or readiness error with mutation boundaries closed, and the capability never fabricates a successful upload or a valid signed URL. Tenant data cannot be silently dropped or remapped, and cross-tenant access is denied by prefix and registry isolation. Incident class is tenant-data-or-security.".
<urn:usf:sourcesemanticbinding:objectstorageandtenantprefixesandsignedurlssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsauditmodel>.
<urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsauditmodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Object lifecycle transitions (upload, scan outcome, quarantine, rejection) are recorded in the tenant-scoped registry, and operations preserve tenant context through spans with typed logs carrying the tenant/organisation identifier. Signed-URL issuance is bounded and attributable, and recovery must preserve tenant boundary, audit, and data-subject evidence. Quota changes are observable through the storage-bytes meter.".
<urn:usf:sourcesemanticbinding:objectstorageandtenantprefixesandsignedurlssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsreadinessmodel>.
<urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsreadinessmodel> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Readiness depends on both the object-storage adapter and the relational object-registry repository being reachable; a probe verifies the provider, and the capability degrades explicitly when either is unavailable, disabling mutating storage paths while keeping read-only readiness and audit visible. Readiness being blocked, a failed tenant-storage-objects proof during promotion, or a missing isolation or audit signal raise alerts and block promotion.".
<urn:usf:sourcesemanticbinding:objectstorageandtenantprefixesandsignedurlssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsproof>.
<urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsproof> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:complete>;
    <urn:usf:ontology:facetStatement> "Behaviour is exercised by the tenant-storage-objects proof plus object-storage adapter and storage-runtime contract tests covering prefix isolation and the scan lifecycle. Proof is hermetic/runtime lineage; current activation evidence is recorded by the contract proof result and remains subject to freshness and invalidation.".
<urn:usf:sourcesemanticbinding:objectstorageandtenantprefixesandsignedurlssemanticsource> <urn:usf:ontology:sourceBindingTarget> <urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsuisemantics>.
<urn:usf:contractfacet:objectstorageandtenantprefixesandsignedurlsuisemantics> <urn:usf:ontology:facetStatus> <urn:usf:facetstatus:notapplicable>;
    <urn:usf:ontology:facetStatement> "The objectstorageandtenantprefixesandsignedurls capability is explicitly not exposed; no product or operator UI is authorised. Any UI requires a deliberate exposure amendment.".
<urn:usf:semanticcontract:objectstorageandtenantprefixesandsignedurls> <urn:usf:ontology:disclaims> <urn:usf:nonclaim:nohumanacceptance>, <urn:usf:nonclaim:nouiproductparity>, <urn:usf:nonclaim:noaccessibilitycompliance>, <urn:usf:nonclaim:nolaunchi18n>.
<urn:usf:sourcesemanticbinding:observabilitybuiltinalertingandincidentssemanticsource> a <urn:usf:ontology:SourceSemanticBinding>;
    <urn:usf:ontology:canonicalName> "observabilitybuiltinalertingandincidentssemanticsource";
