@prefix usf: <urn:usf:ontology:> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix fam: <urn:usf:artefactfamily:> .
@prefix storage: <urn:usf:storageclass:> .
@prefix format: <urn:usf:representationformat:> .
@prefix authority: <urn:usf:authorityclass:> .
@prefix mode: <urn:usf:generationmode:> .
@prefix retention: <urn:usf:retentionclass:> .
@prefix supersession: <urn:usf:supersessionrule:> .
@prefix naming: <urn:usf:namingrule:> .
@prefix numbering: <urn:usf:numberingscope:> .
@prefix projection: <urn:usf:projectiontype:> .
@prefix path: <urn:usf:pathrole:> .
@prefix rule: <urn:usf:materialisationrule:> .
@prefix actor: <urn:usf:materialisationactor:> .
@prefix facet: <urn:usf:facetkind:> .
@prefix cf: <urn:usf:contractfacet:> .

<urn:usf:graph:materialisation> {
  ######################################################################
  # Candidate authority. No path or implementation is authorised until
  # the mandatory proof succeeds and this contract is activated.
  ######################################################################

  <urn:usf:capability:repositoryexternalartefactmaterialisation> a usf:Capability ;
      usf:canonicalName "repositoryexternalartefactmaterialisation" ;
      usf:inDomain <urn:usf:capabilitydomain:foundation> ;
      usf:uiExposure <urn:usf:uiexposureclass:notexposed> ;
      usf:hasContract <urn:usf:semanticcontract:repositoryexternalartefactmaterialisation> .

  <urn:usf:claim:standalonesemanticgraphrepository> a usf:Claim ; usf:canonicalName "standalonesemanticgraphrepository" .
  <urn:usf:claim:semanticcontrolpayloadseparation> a usf:Claim ; usf:canonicalName "semanticcontrolpayloadseparation" .
  <urn:usf:claim:authorityboundmaterialisation> a usf:Claim ; usf:canonicalName "authorityboundmaterialisation" .
  <urn:usf:claim:deterministicmaterialisation> a usf:Claim ; usf:canonicalName "deterministicmaterialisation" .
  <urn:usf:claim:boundedagentconsumption> a usf:Claim ; usf:canonicalName "boundedagentconsumption" .
  <urn:usf:claim:transactionalsemanticmodelevolution> a usf:Claim ; usf:canonicalName "transactionalsemanticmodelevolution" .

  <urn:usf:nonclaim:externalpayloadissemanticauthority> a usf:NonClaim ; usf:canonicalName "externalpayloadissemanticauthority" .
  <urn:usf:nonclaim:projectionissemanticauthority> a usf:NonClaim ; usf:canonicalName "projectionissemanticauthority" .
  <urn:usf:nonclaim:ticketauthorisesmaterialisation> a usf:NonClaim ; usf:canonicalName "ticketauthorisesmaterialisation" .
  <urn:usf:nonclaim:runtimeresultsbelongingit> a usf:NonClaim ; usf:canonicalName "runtimeresultsbelongingit" .
  <urn:usf:nonclaim:parentrepositorydependency> a usf:NonClaim ; usf:canonicalName "parentrepositorydependency" .
  <urn:usf:nonclaim:proofcockpitcompletion> a usf:NonClaim ; usf:canonicalName "proofcockpitcompletion" .
  <urn:usf:nonclaim:javacrossengineparity> a usf:NonClaim ; usf:canonicalName "javacrossengineparity" .
  <urn:usf:nonclaim:paidobjectstorageselected> a usf:NonClaim ; usf:canonicalName "paidobjectstorageselected" .

  <urn:usf:feature:standalonesemanticgraph> a usf:Feature ; usf:canonicalName "standalonesemanticgraph" .
  <urn:usf:feature:repositorymaterialisation> a usf:Feature ; usf:canonicalName "repositorymaterialisation" .
  <urn:usf:feature:externalpayloadverification> a usf:Feature ; usf:canonicalName "externalpayloadverification" .
  <urn:usf:feature:transactionalmodelupdate> a usf:Feature ; usf:canonicalName "transactionalmodelupdate" .

  <urn:usf:semanticcontract:repositoryexternalartefactmaterialisation> a usf:SemanticContract ;
      usf:canonicalName "repositoryexternalartefactmaterialisation" ;
      usf:semanticLifecycleState <urn:usf:semanticlifecyclestate:active> ;
      usf:hasActivationState <urn:usf:contractactivationstate:active> ;
      usf:activationReason "Admitted final deterministic evidence, an exact-evidence-set proof repeated with identical digests inside the standalone chroot, and passing validation warrant the independently usable authority-bound materialisation foundation." ;
      usf:mandatoryProofObligation <urn:usf:proofobligation:repositoryexternalartefactmaterialisation> ;
      usf:reliesOnProofResult <urn:usf:proofresult:repositoryexternalartefactmaterialisationfinal> ;
      usf:asserts <urn:usf:claim:standalonesemanticgraphrepository>, <urn:usf:claim:semanticcontrolpayloadseparation>, <urn:usf:claim:authorityboundmaterialisation>, <urn:usf:claim:deterministicmaterialisation>, <urn:usf:claim:boundedagentconsumption>, <urn:usf:claim:transactionalsemanticmodelevolution> ;
      usf:disclaims <urn:usf:nonclaim:externalpayloadissemanticauthority>, <urn:usf:nonclaim:projectionissemanticauthority>, <urn:usf:nonclaim:ticketauthorisesmaterialisation>, <urn:usf:nonclaim:runtimeresultsbelongingit>, <urn:usf:nonclaim:parentrepositorydependency>, <urn:usf:nonclaim:proofcockpitcompletion>, <urn:usf:nonclaim:javacrossengineparity>, <urn:usf:nonclaim:paidobjectstorageselected>, <urn:usf:nonclaim:noaccessibilitycompliance>, <urn:usf:nonclaim:nohumanacceptance>, <urn:usf:nonclaim:nolaunchi18n>, <urn:usf:nonclaim:nouiproductparity> ;
      usf:warrantsFeature <urn:usf:feature:standalonesemanticgraph>, <urn:usf:feature:repositorymaterialisation>, <urn:usf:feature:externalpayloadverification>, <urn:usf:feature:transactionalmodelupdate> ;
      usf:permittedRealisationType usf:Implementation ;
      usf:requiredValidation <urn:usf:validationobligation:repositoryexternalartefactmaterialisation> ;
      usf:declaresFacet cf:repositoryexternalartefactmaterialisationlifecycle, cf:repositoryexternalartefactmaterialisationstatemodel, cf:repositoryexternalartefactmaterialisationpermissions, cf:repositoryexternalartefactmaterialisationcontracts, cf:repositoryexternalartefactmaterialisationvalidation, cf:repositoryexternalartefactmaterialisationerrormodel, cf:repositoryexternalartefactmaterialisationauditmodel, cf:repositoryexternalartefactmaterialisationreadinessmodel, cf:repositoryexternalartefactmaterialisationproof, cf:repositoryexternalartefactmaterialisationuisemantics ;
      usf:contractConstraint "Stardog validated state is the sole semantic control plane; Git, object storage, Parquet, OCI and JSON-LD only materialise authorised decisions." ;
      usf:contractConstraint "The maldous/usf-graph repository owns its graph source, compiler, credentials boundary, agent directives, skills, proofs and tests and must operate without any parent repository." ;
      usf:contractConstraint "The compiler may update registered Stardog named graphs only in a validated transaction and must roll back all targeted graphs on any parse, SHACL, integrity, derivation, contamination or publication failure." ;
      usf:contractConstraint "Only a coordinator may mutate semantic authority; workers and ordinary agents receive bounded digest-bound projections and query current authority before acting." ;
      usf:contractConstraint "Every AI-agent realisation or validation packet contains semantic identifiers, the current authority digest, contract state, objective, claims, nonclaims, authorised actions, paths and formats, acceptance obligations, validation obligations, result requirements and fail-closed stop conditions; missing or stale fields prohibit action." ;
      usf:contractConstraint "Materialisation plans remain bounded: write bytes are either inline or referenced from the configured operator-local CAS by a locator whose digest equals the exact operation content digest; remote and unverified plan content is forbidden." ;
      usf:contractConstraint "Agent packets are at most 65536 canonical JSON bytes and 256 items, contain no credentials or unbounded evidence payloads, and are regenerated whenever their authority digest no longer matches live Stardog state." ;
      usf:contractConstraint "No tracked path, format, storage class, directory or realisation may be created before an active contract and accepted decision authorise it." ;
      usf:contractConstraint "External payloads are immutable and content-addressed; their small digest, media type, byte size, artifact type and locator envelopes remain in Stardog." ;
      usf:contractConstraint "The default external payload store is an operator-local content-addressed filesystem outside Git. No GCS bucket, cloud billing linkage, or paid managed object-storage realisation is selected; any such backend requires a separate active decision and proof." ;
      usf:contractConstraint "Runtime evidence, proof output, validation output, logs, screenshots, binaries, archives, Parquet data, NativeStore databases and generated contract caches are not Git source." ;
      usf:contractConstraint "Only latest stable standard editions are selected. Draft standards and superseded selected editions are not retained as active representation choices." ;
      usf:contractConstraint "Ordinals are eight-digit and family-scoped only for individually referenceable authored governance artifacts; ordinals are never reused or renumbered, language-native source files are not prefixed, and content-addressed payloads use digests." ;
      usf:contractConstraint "No empty anticipated directory is created. The realisations path exists only when an accepted decision selects a local-code realisation." ;
      usf:contractConstraint "SQLite is permitted only as an ephemeral task ledger, queue, cache, offline index or test fixture and never as shared semantic authority." .

  cf:repositoryexternalartefactmaterialisationlifecycle a usf:ContractFacet ; usf:canonicalName "repositoryexternalartefactmaterialisationlifecycle" ; usf:facetKind facet:lifecycle ; usf:facetStatus <urn:usf:facetstatus:complete> ; usf:facetStatement "Proof-blocked, eligible, active, superseded and retired materialisation states remain distinct." .
  cf:repositoryexternalartefactmaterialisationstatemodel a usf:ContractFacet ; usf:canonicalName "repositoryexternalartefactmaterialisationstatemodel" ; usf:facetKind facet:statemodel ; usf:facetStatus <urn:usf:facetstatus:complete> ; usf:facetStatement "Artifact rules, descriptors, plans and operations have explicit validator-checkable state." .
  cf:repositoryexternalartefactmaterialisationpermissions a usf:ContractFacet ; usf:canonicalName "repositoryexternalartefactmaterialisationpermissions" ; usf:facetKind facet:permissions ; usf:facetStatus <urn:usf:facetstatus:complete> ; usf:facetStatement "Semantic mutation is coordinator-only and filesystem mutation requires an active digest-bound plan." .
  cf:repositoryexternalartefactmaterialisationcontracts a usf:ContractFacet ; usf:canonicalName "repositoryexternalartefactmaterialisationcontracts" ; usf:facetKind facet:contracts ; usf:facetStatus <urn:usf:facetstatus:complete> ; usf:facetStatement "Storage, format, path, naming, retention, supersession and projection decisions are semantic contracts." .
  cf:repositoryexternalartefactmaterialisationvalidation a usf:ContractFacet ; usf:canonicalName "repositoryexternalartefactmaterialisationvalidation" ; usf:facetKind facet:validation ; usf:facetStatus <urn:usf:facetstatus:complete> ; usf:facetStatement "Every plan, descriptor, projection and realisation is validated and failures close the gate." .
  cf:repositoryexternalartefactmaterialisationerrormodel a usf:ContractFacet ; usf:canonicalName "repositoryexternalartefactmaterialisationerrormodel" ; usf:facetKind facet:errormodel ; usf:facetStatus <urn:usf:facetstatus:complete> ; usf:facetStatement "Stable failure codes identify rule, path, digest, signature, size, isolation and transaction violations." .
  cf:repositoryexternalartefactmaterialisationauditmodel a usf:ContractFacet ; usf:canonicalName "repositoryexternalartefactmaterialisationauditmodel" ; usf:facetKind facet:auditmodel ; usf:facetStatus <urn:usf:facetstatus:complete> ; usf:facetStatement "Authority digests, exact evidence-set digests, operation keys and immutable payload digests make mutations auditable." .
  cf:repositoryexternalartefactmaterialisationreadinessmodel a usf:ContractFacet ; usf:canonicalName "repositoryexternalartefactmaterialisationreadinessmodel" ; usf:facetKind facet:readinessmodel ; usf:facetStatus <urn:usf:facetstatus:complete> ; usf:facetStatement "Readiness requires passing representative proof, standalone chroot isolation and deterministic two-pass materialisation." .
  cf:repositoryexternalartefactmaterialisationproof a usf:ContractFacet ; usf:canonicalName "repositoryexternalartefactmaterialisationproof" ; usf:facetKind facet:proof ; usf:facetStatus <urn:usf:facetstatus:complete> ; usf:facetStatement "The mandatory proof evaluates an exact admitted evidence set with negative cases and explicit nonclaims." .
  cf:repositoryexternalartefactmaterialisationuisemantics a usf:ContractFacet ; usf:canonicalName "repositoryexternalartefactmaterialisationuisemantics" ; usf:facetKind facet:uisemantics ; usf:facetStatus <urn:usf:facetstatus:notapplicable> ; usf:facetStatement "No user-interface semantic surface is introduced by this foundation." .

  <urn:usf:validationobligation:repositoryexternalartefactmaterialisation> a usf:ValidationObligation ;
      usf:canonicalName "repositoryexternalartefactmaterialisation" ;
      usf:validationForContract <urn:usf:semanticcontract:repositoryexternalartefactmaterialisation> .
  <urn:usf:validationenvironment:standalonechroot> a usf:ValidationEnvironment ;
      usf:canonicalName "standalonechroot" ;
      usf:hasEnvironmentClass <urn:usf:environmentclass:hermetic> .

  <urn:usf:realisationoption:stageorientedlayout> a usf:RealisationOption ; usf:canonicalName "stageorientedlayout" .
  <urn:usf:realisationoption:ownerorientedlayout> a usf:RealisationOption ; usf:canonicalName "ownerorientedlayout" .
  <urn:usf:realisationoption:globalordinal> a usf:RealisationOption ; usf:canonicalName "globalordinal" .
  <urn:usf:realisationoption:familyordinal> a usf:RealisationOption ; usf:canonicalName "familyordinal" .
  <urn:usf:realisationdecision:repositoryexternalartefactmaterialisation> a usf:RealisationDecision ;
      usf:canonicalName "repositoryexternalartefactmaterialisation" ;
      usf:decisionState <urn:usf:decisionstate:accepted> ;
      usf:considersOption <urn:usf:realisationoption:stageorientedlayout>, <urn:usf:realisationoption:ownerorientedlayout>, <urn:usf:realisationoption:globalordinal>, <urn:usf:realisationoption:familyordinal> ;
      usf:authorisesRepository "maldous/usf-graph" ;
      usf:authorisesSourcePath ".", "graph", "tools/compiler", "tools/collectors", "tools/proof", "tools/validation", "schemas/evidence", "schemas/projections", "schemas/validation", "decisions", ".claude/skills/usf", ".codex/skills/usf", "tools/chroot", ".work/materialisation" ;
      usf:authorisesRealisationType usf:Implementation ;
      usf:requiresADR <urn:usf:adrrequirement:repositoryexternalartefactmaterialisation> ;
      usf:supersedesDecision <urn:usf:realisationdecision:localvalidationtoolchain> .
  <urn:usf:adrrequirement:repositoryexternalartefactmaterialisation> a usf:ADRRequirement ;
