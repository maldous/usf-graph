  fam:evidencepayload usf:usesMaterialisationRule rule:evidencepayload .
  rule:evidencepayload a usf:MaterialisationRule ; usf:canonicalName "evidencepayload" ; usf:governedArtefactFamily fam:evidencepayload ; usf:usesStorageClass storage:contentaddressedobjectstorage ; usf:usesRepresentationFormat format:jcsjson, format:jsonld11, format:jsonlineszstandard, format:parquet2130, format:nativebinary ; usf:usesNamingRule naming:digestidentity ; usf:usesNumberingScope numbering:digestonly ; usf:usesGenerationMode mode:runtime ; usf:usesAuthorityClass authority:externalpayload ; usf:usesRetentionClass retention:policybounded ; usf:usesSupersessionRule supersession:appendonlylink ; usf:localRepresentation false ; usf:trackedRepresentation false ; usf:contentAddressingRequired true ; usf:signatureRequired false ; usf:maximumInlineBytes 4096 ; usf:materialisationGenerator actor:externalservice ; usf:materialisationValidator actor:materialisationvalidator ; usf:materialisationConsumer actor:semanticcompiler .
  fam:evidencemanifest usf:usesMaterialisationRule rule:evidencemanifest .
  rule:evidencemanifest a usf:MaterialisationRule ; usf:canonicalName "evidencemanifest" ; usf:governedArtefactFamily fam:evidencemanifest ; usf:usesStorageClass storage:contentaddressedobjectstorage ; usf:usesRepresentationFormat format:jcsjson ; usf:usesNamingRule naming:digestidentity ; usf:usesNumberingScope numbering:digestonly ; usf:usesGenerationMode mode:generated ; usf:usesAuthorityClass authority:externalpayload ; usf:usesRetentionClass retention:policybounded ; usf:usesSupersessionRule supersession:appendonlylink ; usf:usesProjectionType projection:boundedjcsjson ; usf:localRepresentation false ; usf:trackedRepresentation false ; usf:contentAddressingRequired true ; usf:signatureRequired false ; usf:maximumInlineBytes 65536 ; usf:materialisationGenerator actor:semanticcompiler ; usf:materialisationValidator actor:materialisationvalidator ; usf:materialisationConsumer actor:semanticcompiler, actor:agent .
