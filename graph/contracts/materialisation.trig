  # Complete rules for every selected artifact family.
  ######################################################################

  fam:semanticsource usf:usesMaterialisationRule rule:semanticsource .
  rule:semanticsource a usf:MaterialisationRule ; usf:canonicalName "semanticsource" ; usf:governedArtefactFamily fam:semanticsource ; usf:usesStorageClass storage:gittrackedsource ; usf:usesRepresentationFormat format:turtlerdf11, format:trigrdf11 ; usf:usesPathRole path:semanticsource ; usf:usesNamingRule naming:languagenative ; usf:usesNumberingScope numbering:languagenative ; usf:usesGenerationMode mode:authored ; usf:usesAuthorityClass authority:authoreddefinition ; usf:usesRetentionClass retention:permanenthistory ; usf:usesSupersessionRule supersession:versionedreplacement ; usf:localRepresentation true ; usf:trackedRepresentation true ; usf:contentAddressingRequired false ; usf:signatureRequired false ; usf:maximumInlineBytes 0 ; usf:materialisationGenerator actor:coordinator ; usf:materialisationValidator actor:semanticcompiler ; usf:materialisationConsumer actor:semanticcompiler, actor:agent .
  fam:semanticdigestprojection usf:usesMaterialisationRule rule:semanticdigestprojection .
