      usf:realisesContract <urn:usf:semanticcontract:repositoryexternalartefactmaterialisation> ;
      usf:realisationState <urn:usf:realisationstate:deprecated> ;
      usf:authorisedByDecision <urn:usf:realisationdecision:repositoryexternalartefactmaterialisation> ;
      usf:authorisedSourcePath "tools/compiler" .

  <urn:usf:implementation:repositoryexternalartefactmaterialisation> a usf:Implementation ;
      usf:canonicalName "repositoryexternalartefactmaterialisation" .

  <urn:usf:realisation:repositoryexternalartefactmaterialisation> a usf:Realisation ;
      usf:canonicalName "repositoryexternalartefactmaterialisation" ;
      usf:realisesContract <urn:usf:semanticcontract:repositoryexternalartefactmaterialisation> ;
      usf:realisingImplementation <urn:usf:implementation:repositoryexternalartefactmaterialisation> ;
      usf:realisationState <urn:usf:realisationstate:internal> ;
      usf:authorisedByDecision <urn:usf:realisationdecision:repositoryexternalartefactmaterialisation> ;
      usf:authorisedSourcePath "tools/compiler", "tools/collectors", "tools/proof", "tools/validation", "tools/chroot" .

  ######################################################################
  # Candidate path roles. They become authorisations only on activation.
  ######################################################################

  path:repositoryroot a usf:PathRole ; usf:canonicalName "repositoryroot" ; usf:authorisedParentPath "." ; usf:materialisesOnDemand true .
