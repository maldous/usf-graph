  path:generatedwork a usf:PathRole ; usf:canonicalName "generatedwork" ; usf:authorisedParentPath ".work/materialisation" ; usf:materialisesOnDemand true .

  actor:coordinator a usf:Entity ; usf:canonicalName "coordinator" .
  actor:semanticcompiler a usf:Entity ; usf:canonicalName "semanticcompiler" .
  actor:materialisationvalidator a usf:Entity ; usf:canonicalName "materialisationvalidator" .
  actor:agent a usf:Entity ; usf:canonicalName "agent" .
  actor:humanreviewer a usf:Entity ; usf:canonicalName "humanreviewer" .
  actor:externalservice a usf:Entity ; usf:canonicalName "externalservice" .

