@prefix usf: <urn:usf:ontology:> .
@prefix cfg: <urn:usf:configurationkey:> .
@prefix pers: <urn:usf:persistencecontract:> .
@prefix seck: <urn:usf:secretclassification:> .

<urn:usf:graph:platform> {
    cfg:apppublicname a usf:ConfigurationKey ;
        usf:canonicalName "apppublicname" ;
        usf:hasSecretClassification seck:nonsecret .
    cfg:auditretrievalui a usf:ConfigurationKey ;
        usf:canonicalName "auditretrievalui" ;
        usf:hasSecretClassification seck:nonsecret .
    cfg:configurationprovidermodeselector a usf:ConfigurationKey ;
        usf:canonicalName "configurationprovidermodeselector" ;
        usf:hasSecretClassification seck:nonsecret .
    cfg:environmentname a usf:ConfigurationKey ;
        usf:canonicalName "environmentname" ;
        usf:hasSecretClassification seck:nonsecret .
    cfg:experimentalconfigeditor a usf:ConfigurationKey ;
        usf:canonicalName "experimentalconfigeditor" ;
        usf:hasSecretClassification seck:nonsecret .
    cfg:providermailapikeyref a usf:ConfigurationKey ;
        usf:canonicalName "providermailapikeyref" ;
        usf:hasSecretClassification seck:secret .
    cfg:providermode a usf:ConfigurationKey ;
        usf:canonicalName "providermode" ;
        usf:hasSecretClassification seck:nonsecret .
    cfg:providernotificationmailcredentialref a usf:ConfigurationKey ;
        usf:canonicalName "providernotificationmailcredentialref" ;
        usf:hasSecretClassification seck:secret .
    cfg:providernotificationmode a usf:ConfigurationKey ;
        usf:canonicalName "providernotificationmode" ;
        usf:hasSecretClassification seck:nonsecret .
    cfg:securityauditrequired a usf:ConfigurationKey ;
        usf:canonicalName "securityauditrequired" ;
        usf:hasSecretClassification seck:nonsecret .
    cfg:securitysessionttlseconds a usf:ConfigurationKey ;
        usf:canonicalName "securitysessionttlseconds" ;
        usf:hasSecretClassification seck:nonsecret .
    cfg:tenantlocale a usf:ConfigurationKey ;
        usf:canonicalName "tenantlocale" ;
        usf:hasSecretClassification seck:nonsecret .
    pers:adaptersdbmigrationsmanifest a usf:PersistenceContract ;
        usf:canonicalName "adaptersdbmigrationsmanifest" .
    pers:composebackuprestorepostures a usf:PersistenceContract ;
        usf:canonicalName "composebackuprestorepostures" .
    pers:composedataboundaries a usf:PersistenceContract ;
        usf:canonicalName "composedataboundaries" .
    pers:composelifecycles a usf:PersistenceContract ;
        usf:canonicalName "composelifecycles" .
    pers:composeretentionpostures a usf:PersistenceContract ;
        usf:canonicalName "composeretentionpostures" .
    pers:datamigrationkinds a usf:PersistenceContract ;
        usf:canonicalName "datamigrationkinds" .
    pers:migrationimmutability a usf:PersistenceContract ;
        usf:canonicalName "migrationimmutability" .
    pers:persistentobjectclassificationregistry a usf:PersistenceContract ;
        usf:canonicalName "persistentobjectclassificationregistry" .
    pers:seedresetpolicy a usf:PersistenceContract ;
        usf:canonicalName "seedresetpolicy" .
}
