PREFIX usf: <urn:usf:ontology:>
PREFIX direction: <urn:usf:repositorydependencydirection:>
PREFIX resolution: <urn:usf:workpackagedependencyresolutionstatus:>

CONSTRUCT {
  ?workPackage a usf:RepositoryWorkPackage ;
    usf:canonicalName ?workPackageName ;
    usf:promotedFromWorkPackageObservation ?workPackageObservation ;
    usf:ownsObservedSourceArtefact ?ownedSourceArtefact ;
    usf:ownsCanonicalArtefact ?ownedCanonicalArtefact ;
    usf:promotedByRepositoryStructurePolicy ?policy .
}
WHERE {
  ?policy a usf:RepositoryDependencyResolutionPolicy ; usf:requiresRegisteredObservationRun true .
  ?workPackageObservation a usf:WorkPackageObservation ; usf:canonicalName ?workPackageName ; usf:observedInCensusRun ?run .
  ?run a usf:CensusObservationRun ; usf:observationSetDigest ?runDigest ; usf:hasCensusParserShardObservation ?parserProvenance .
  ?parserProvenance a usf:CensusParserShardObservation ; usf:observedCompressedContentDigest ?parserDigest .
  OPTIONAL { ?workPackageObservation usf:observedOwnedSourceArtefact ?ownedSourceArtefact }
  OPTIONAL { ?workPackageObservation usf:observedOwnedCanonicalArtefact ?ownedCanonicalArtefact }
  FILTER(STRLEN(?runDigest) = 64 && STRLEN(?parserDigest) = 64)
  BIND(IRI(REPLACE(STR(?workPackageObservation), "workpackageobservation:", "repositoryworkpackage:")) AS ?workPackage)
}

#---NEXT---#

PREFIX usf: <urn:usf:ontology:>
PREFIX direction: <urn:usf:repositorydependencydirection:>
PREFIX resolution: <urn:usf:workpackagedependencyresolutionstatus:>

CONSTRUCT {
  ?dependency a usf:RepositoryDependency, usf:ResolvedWorkPackageDependency ;
    usf:canonicalName ?canonicalName ;
    usf:resolvedDependencySource ?resolvedSource ;
    usf:resolvedDependencyPrerequisite ?resolvedPrerequisite ;
    usf:resolvedDependencyType ?kind ;
    usf:resolvedDependencyStatus ?status ;
    usf:dependencyDirection direction:sourcerequiresprerequisite ;
    usf:dependencyResolutionState resolution:resolvedretained ;
    usf:derivedFromWorkPackageDependencyObservation ?candidate ;
    usf:promotedByRepositoryStructurePolicy ?policy ;
    usf:supportedBySourceRelationshipObservation ?relationship .
}
WHERE {
  ?policy a usf:RepositoryDependencyResolutionPolicy ;
    usf:allowsWorkPackageDependencyType ?kind ; usf:allowsWorkPackageDependencyStatus ?status ;
    usf:allowsRepositoryDependencyDirection direction:sourcerequiresprerequisite ;
    usf:allowsWorkPackageDependencyResolutionStatus resolution:resolvedretained ;
    usf:allowsSourceRelationshipType ?relationshipKind ;
    usf:requiresRegisteredObservationRun true ; usf:requiresExactEvidenceEndpointOwnership true .
  ?candidate a usf:WorkPackageDependencyObservation ;
    usf:workPackageDependencySource ?sourceObservation ; usf:workPackageDependencyPrerequisite ?prerequisiteObservation ;
    usf:workPackageDependencyType ?kind ; usf:workPackageDependencyStatus ?status ;
    usf:workPackageDependencyResolutionStatus resolution:resolvedretained ;
    usf:supportedBySourceRelationshipObservation ?relationship ; usf:observedInCensusRun ?run .
  ?run a usf:CensusObservationRun ; usf:observationSetDigest ?runDigest ; usf:hasCensusParserShardObservation ?parserProvenance .
  ?parserProvenance a usf:CensusParserShardObservation ; usf:observedCompressedContentDigest ?parserDigest .
  ?relationship a usf:SourceRelationshipObservation ; usf:sourceRelationshipType ?relationshipKind ;
    usf:sourceRelationshipSource ?sourceArtefact ; usf:sourceRelationshipTarget ?targetObservation ;
    usf:sourceRelationshipResolved true ; usf:observedInCensusRun ?run .
  ?targetObservation a usf:SourceRelationshipTargetObservation ; usf:resolvesToSourceArtefact ?targetArtefact .
  ?sourceObservation usf:observedOwnedSourceArtefact ?sourceArtefact ; usf:observedInCensusRun ?run .
  ?prerequisiteObservation usf:observedOwnedSourceArtefact ?targetArtefact ; usf:observedInCensusRun ?run .
  FILTER(?sourceObservation != ?prerequisiteObservation && STRLEN(?runDigest) = 64 && STRLEN(?parserDigest) = 64)
  FILTER NOT EXISTS {
    ?candidate usf:supportedBySourceRelationshipObservation ?invalidRelationship .
    FILTER NOT EXISTS {
      ?invalidRelationship a usf:SourceRelationshipObservation ; usf:sourceRelationshipType ?invalidRelationshipKind ;
        usf:sourceRelationshipSource ?invalidSourceArtefact ; usf:sourceRelationshipTarget ?invalidTargetObservation ;
        usf:sourceRelationshipResolved true ; usf:observedInCensusRun ?run .
      ?policy usf:allowsSourceRelationshipType ?invalidRelationshipKind .
      ?invalidTargetObservation a usf:SourceRelationshipTargetObservation ; usf:resolvesToSourceArtefact ?invalidTargetArtefact ; usf:observedInCensusRun ?run .
      ?sourceObservation usf:observedOwnedSourceArtefact ?invalidSourceArtefact .
      ?prerequisiteObservation usf:observedOwnedSourceArtefact ?invalidTargetArtefact .
    }
  }
  FILTER NOT EXISTS {
    ?candidate usf:workPackageDependencyEvidenceDigest ?evidenceDigest .
    FILTER NOT EXISTS { ?candidate usf:supportedBySourceRelationshipObservation ?evidenceRelationship . ?evidenceRelationship usf:relationshipEvidenceDigest ?evidenceDigest }
  }
  FILTER NOT EXISTS {
    ?candidate usf:supportedBySourceRelationshipObservation ?evidenceRelationship . ?evidenceRelationship usf:relationshipEvidenceDigest ?evidenceDigest .
    FILTER NOT EXISTS { ?candidate usf:workPackageDependencyEvidenceDigest ?evidenceDigest }
  }
  BIND(IRI(REPLACE(STR(?sourceObservation), "workpackageobservation:", "repositoryworkpackage:")) AS ?resolvedSource)
  BIND(IRI(REPLACE(STR(?prerequisiteObservation), "workpackageobservation:", "repositoryworkpackage:")) AS ?resolvedPrerequisite)
  BIND(IRI(REPLACE(STR(?candidate), "workpackagedependencyobservation:", "resolvedworkpackagedependency:")) AS ?dependency)
  BIND(STRAFTER(STR(?candidate), "workpackagedependencyobservation:") AS ?canonicalName)
}

#---NEXT---#

PREFIX usf: <urn:usf:ontology:>
PREFIX depstatus: <urn:usf:workpackagedependencystatus:>
PREFIX resolution: <urn:usf:workpackagedependencyresolutionstatus:>
PREFIX satisfaction: <urn:usf:dependencysatisfactionstatus:>

CONSTRUCT {
  ?dependency usf:dependencySatisfactionStatus satisfaction:satisfied ;
    usf:derivedFromDependencySatisfactionBasis ?basis ;
    usf:promotedByDependencySatisfactionPolicy ?satisfactionPolicy .
}
WHERE {
  ?dependency a usf:ResolvedWorkPackageDependency ;
    usf:resolvedDependencyStatus depstatus:requiredprerequisite ;
    usf:dependencyResolutionState resolution:resolvedretained ;
    usf:derivedFromWorkPackageDependencyObservation ?observation ;
    usf:resolvedDependencySource ?resolvedSource ;
    usf:resolvedDependencyPrerequisite ?resolvedPrerequisite .
  ?observation a usf:WorkPackageDependencyObservation ;
    usf:workPackageDependencyStatus depstatus:requiredprerequisite ;
    usf:workPackageDependencyResolutionStatus resolution:resolvedretained ;
    usf:workPackageDependencySource ?sourceObservation ;
    usf:workPackageDependencyPrerequisite ?prerequisiteObservation ;
    usf:workPackageDependencySatisfactionSeed satisfaction:satisfied ;
    usf:hasWorkPackageDependencySatisfactionBasis ?basis ;
    usf:observedInCensusRun ?run .
  ?basis a usf:WorkPackageDependencySatisfactionBasisObservation ;
    usf:satisfactionBasisForWorkPackageDependency ?observation ;
    usf:observedDependencySatisfactionStatus satisfaction:satisfied ;
    usf:dependencySatisfactionBasisKind ?basisKind ;
    usf:satisfactionBasisRecordDigest ?basisDigest ;
    usf:satisfactionBasisExactEvidenceHashCount ?exactEvidenceCount ;
    usf:satisfactionBasisCurrentRelationshipHashCount ?exactEvidenceCount ;
    usf:satisfactionBasisStructurallyProvenRelationshipHashCount ?exactEvidenceCount ;
    usf:satisfactionBasisDirectionMatchedRelationshipHashCount ?exactEvidenceCount ;
    usf:satisfactionBasisCurrentPrerequisiteArtifactHashCount ?exactEvidenceCount ;
    usf:satisfactionBasisCurrentPrerequisiteArtifactCount ?prerequisiteArtifactCount ;
    usf:satisfactionBasisSourceEndpointExists true ;
    usf:satisfactionBasisPrerequisiteEndpointExists true ;
    usf:satisfactionBasisEdgeSurvivedTransitiveReduction true ;
    usf:satisfactionBasisRequiredPrerequisiteGraphAcyclic true ;
    usf:observedInCensusRun ?run .
  ?satisfactionPolicy a usf:RepositoryDependencySatisfactionPolicy ;
    usf:allowsDependencySatisfactionStatus satisfaction:satisfied ;
    usf:allowsDependencySatisfactionBasisKind ?basisKind ;
    usf:requiresResolvedRetainedDependency true ;
    usf:requiresRequiredPrerequisiteDependencyStatus true ;
    usf:requiresExactSatisfactionEvidenceClosure true ;
    usf:requiresSatisfactionEndpointOwnership true ;
    usf:requiresSameSatisfactionObservationRun true ;
    usf:requiresSatisfactionBasisDigest true .
  ?run a usf:CensusObservationRun ;
    usf:observationSetDigest ?runDigest ;
    usf:hasCensusParserShardObservation ?parser .
  ?parser a usf:CensusParserShardObservation ; usf:observedCompressedContentDigest ?parserDigest .
  {
    SELECT ?basis (COUNT(DISTINCT ?basisRelationship) AS ?observedRelationshipCount)
      (COUNT(DISTINCT ?observedPrerequisiteArtefact) AS ?observedPrerequisiteArtefactCount)
    WHERE {
      ?basis usf:satisfactionBasisRelationshipObservation ?basisRelationship .
      ?basisRelationship usf:sourceRelationshipTarget ?basisTarget .
      ?basisTarget usf:resolvesToSourceArtefact ?observedPrerequisiteArtefact .
    }
    GROUP BY ?basis
  }
  FILTER(?exactEvidenceCount > 0 && ?prerequisiteArtifactCount > 0)
  FILTER(?observedRelationshipCount = ?exactEvidenceCount && ?observedPrerequisiteArtefactCount = ?prerequisiteArtifactCount)
  FILTER(STRLEN(?basisDigest) = 64 && STRLEN(?runDigest) = 64 && STRLEN(?parserDigest) = 64)
  FILTER(?sourceObservation != ?prerequisiteObservation)
  FILTER NOT EXISTS {
    ?observation usf:supportedBySourceRelationshipObservation ?relationship .
    FILTER NOT EXISTS {
      ?basis usf:satisfactionBasisRelationshipObservation ?relationship .
      ?relationship a usf:SourceRelationshipObservation ;
        usf:sourceRelationshipSource ?sourceArtefact ;
        usf:sourceRelationshipTarget ?targetObservation ;
        usf:sourceRelationshipResolved true ;
        usf:observedInCensusRun ?run .
      ?targetObservation a usf:SourceRelationshipTargetObservation ;
        usf:resolvesToSourceArtefact ?targetArtefact ;
        usf:observedInCensusRun ?run .
      ?sourceObservation usf:observedOwnedSourceArtefact ?sourceArtefact .
      ?prerequisiteObservation usf:observedOwnedSourceArtefact ?targetArtefact .
    }
  }
  FILTER NOT EXISTS {
    ?basis usf:satisfactionBasisRelationshipObservation ?relationship .
    FILTER NOT EXISTS { ?observation usf:supportedBySourceRelationshipObservation ?relationship }
  }
  BIND(IRI(REPLACE(STR(?sourceObservation), "workpackageobservation:", "repositoryworkpackage:")) AS ?expectedSource)
  BIND(IRI(REPLACE(STR(?prerequisiteObservation), "workpackageobservation:", "repositoryworkpackage:")) AS ?expectedPrerequisite)
  FILTER(?resolvedSource = ?expectedSource && ?resolvedPrerequisite = ?expectedPrerequisite)
}

#---NEXT---#

PREFIX usf: <urn:usf:ontology:>
PREFIX depstatus: <urn:usf:workpackagedependencystatus:>
PREFIX resolution: <urn:usf:workpackagedependencyresolutionstatus:>
PREFIX satisfaction: <urn:usf:dependencysatisfactionstatus:>

CONSTRUCT {
  ?dependency usf:dependencySatisfactionStatus satisfaction:unsatisfied ;
    usf:derivedFromDependencySatisfactionBasis ?basis .
  ?blocker a usf:ActiveRepositoryDependencyBlocker ;
    usf:canonicalName ?blockerName ;
    usf:activeBlockerForResolvedDependency ?dependency ;
    usf:activeBlockerFromSatisfactionBasis ?basis .
}
WHERE {
  ?dependency a usf:ResolvedWorkPackageDependency ;
    usf:resolvedDependencyStatus depstatus:requiredprerequisite ;
    usf:dependencyResolutionState resolution:resolvedretained ;
    usf:derivedFromWorkPackageDependencyObservation ?observation .
  ?observation usf:workPackageDependencySatisfactionSeed satisfaction:unsatisfied ;
    usf:hasWorkPackageDependencySatisfactionBasis ?basis .
  ?basis a usf:WorkPackageDependencySatisfactionBasisObservation ;
    usf:satisfactionBasisForWorkPackageDependency ?observation ;
    usf:observedDependencySatisfactionStatus satisfaction:unsatisfied .
  BIND(IRI(REPLACE(STR(?dependency), "resolvedworkpackagedependency:", "activerepositorydependencyblocker:")) AS ?blocker)
  BIND(STRAFTER(STR(?dependency), "resolvedworkpackagedependency:") AS ?suffix)
  BIND(CONCAT("b", SUBSTR(?suffix, 2)) AS ?blockerName)
}

#---NEXT---#

PREFIX usf: <urn:usf:ontology:>

CONSTRUCT {
  ?retained a usf:RetainedWorkPackageDependencyLineage ;
    usf:canonicalName ?canonicalName ;
    usf:derivedFromWorkPackageDependencyLineageObservation ?lineage ;
    usf:retainedLineageSuccessorSource ?resolvedSource ;
    usf:retainedLineageSuccessorPrerequisite ?resolvedPrerequisite ;
    usf:promotedByRepositoryStructurePolicy ?policy .
}
WHERE {
  ?policy a usf:RepositoryDependencyResolutionPolicy ; usf:allowsDependencyLineageDisposition <urn:usf:dependencylineagedisposition:retainedwithevidence> ; usf:requiresRegisteredObservationRun true .
  ?lineage a usf:WorkPackageDependencyLineageObservation ; usf:dependencyLineageDisposition <urn:usf:dependencylineagedisposition:retainedwithevidence> ;
    usf:successorDependencySource ?source ; usf:successorDependencyPrerequisite ?prerequisite ; usf:observedInCensusRun ?run .
  ?source a usf:WorkPackageObservation ; usf:observedInCensusRun ?run .
  ?prerequisite a usf:WorkPackageObservation ; usf:observedInCensusRun ?run .
  ?run a usf:CensusObservationRun ; usf:observationSetDigest ?runDigest .
  FILTER(STRLEN(?runDigest) = 64)
  BIND(IRI(REPLACE(STR(?source), "workpackageobservation:", "repositoryworkpackage:")) AS ?resolvedSource)
  BIND(IRI(REPLACE(STR(?prerequisite), "workpackageobservation:", "repositoryworkpackage:")) AS ?resolvedPrerequisite)
  BIND(IRI(REPLACE(STR(?lineage), "workpackagedependencylineageobservation:", "retainedworkpackagedependencylineage:")) AS ?retained)
  BIND(STRAFTER(STR(?lineage), "workpackagedependencylineageobservation:") AS ?canonicalName)
}
