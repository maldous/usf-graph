PREFIX usf: <urn:usf:ontology:>
PREFIX oe: <urn:usf:obligationeffect:>
# Replacement for obligations.rq. Every governed contract, control, and gate
# criterion receives both proof and executed-test obligations. IRI construction
# uses the full subject digest, never a local-name approximation.
CONSTRUCT {
  ?po a usf:ProofObligation, usf:AssuranceObligation ; usf:canonicalName ?pn ; usf:obligationFor ?subject ;
      usf:requiresRung ?rung ; usf:obligationEffect ?effect ;
      usf:usesAssuranceCell ?cell ; usf:requiredByGate ?authoredGate ; usf:derivedFrom ?subject .
  ?to a usf:TestObligation, usf:AssuranceObligation ; usf:canonicalName ?tn ; usf:obligationFor ?subject ;
      usf:obligationEffect ?effect ; usf:usesAssuranceCell ?cell ;
      usf:requiredByGate ?authoredGate ; usf:derivedFrom ?subject .
}
WHERE {
  VALUES ?class { usf:SemanticContract usf:Control usf:GateCriterion }
  ?subject a ?class .
  OPTIONAL { ?subject usf:obligationEffect ?authoredEffect }
  OPTIONAL { ?subject usf:usesAssuranceCell ?authoredCell }
  OPTIONAL { ?subject usf:requiredByGate ?authoredGate }
  BIND(COALESCE(?authoredEffect, oe:blocking) AS ?effect)
  BIND(COALESCE(?authoredCell, <urn:usf:assurancecell:behaviourhermetichermetic>) AS ?cell)
  ?cell usf:profileRung ?rung .
  BIND(SHA256(STR(?subject)) AS ?digest)
  BIND(CONCAT("p", ?digest) AS ?pn)
  BIND(CONCAT("t", ?digest) AS ?tn)
  BIND(IRI(CONCAT("urn:usf:proofobligation:", ?pn)) AS ?po)
  BIND(IRI(CONCAT("urn:usf:testobligation:", ?tn)) AS ?to)
}
