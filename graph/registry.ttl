@prefix usf: <urn:usf:ontology:> .
@prefix ng:  <urn:usf:namedgraph:> .
@prefix gcl: <urn:usf:graphclass:> .
@prefix rl:  <urn:usf:rule:> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Registry of every named graph, its authority class, its stable graph IRI, and its
# deterministic load and validation order. Derivation and integrity rule modules are
# registered here and bound to the graphs they read and write.

# ---- Definition graphs ----
ng:ontology    a usf:NamedGraph ; usf:canonicalName "ontology"    ; usf:graphClass gcl:definitiongraph ; usf:graphIri "urn:usf:graph:ontology"^^xsd:anyURI    ; usf:loadOrder 1  ; usf:graphValidationOrder 1 .
ng:taxonomy    a usf:NamedGraph ; usf:canonicalName "taxonomy"    ; usf:graphClass gcl:definitiongraph ; usf:graphIri "urn:usf:graph:taxonomy"^^xsd:anyURI    ; usf:loadOrder 2  ; usf:graphValidationOrder 2 .
ng:vocabulary  a usf:NamedGraph ; usf:canonicalName "vocabulary"  ; usf:graphClass gcl:definitiongraph ; usf:graphIri "urn:usf:graph:vocabulary"^^xsd:anyURI  ; usf:loadOrder 3  ; usf:graphValidationOrder 3 .
ng:authority   a usf:NamedGraph ; usf:canonicalName "authority"   ; usf:graphClass gcl:definitiongraph ; usf:graphIri "urn:usf:graph:authority"^^xsd:anyURI   ; usf:loadOrder 4  ; usf:graphValidationOrder 4 .
ng:registry    a usf:NamedGraph ; usf:canonicalName "registry"    ; usf:graphClass gcl:definitiongraph ; usf:graphIri "urn:usf:graph:registry"^^xsd:anyURI    ; usf:loadOrder 5  ; usf:graphValidationOrder 5 .

# ---- Authored graphs ----
ng:providers      a usf:NamedGraph ; usf:canonicalName "providers"      ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:providers"^^xsd:anyURI      ; usf:loadOrder 6  ; usf:graphValidationOrder 10 .
ng:environments   a usf:NamedGraph ; usf:canonicalName "environments"   ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:environments"^^xsd:anyURI   ; usf:loadOrder 7  ; usf:graphValidationOrder 11 .
ng:claims         a usf:NamedGraph ; usf:canonicalName "claims"         ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:claims"^^xsd:anyURI         ; usf:loadOrder 8  ; usf:graphValidationOrder 12 .
ng:capabilities   a usf:NamedGraph ; usf:canonicalName "capabilities"   ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:capabilities"^^xsd:anyURI   ; usf:loadOrder 9  ; usf:graphValidationOrder 13 .
ng:policies       a usf:NamedGraph ; usf:canonicalName "policies"       ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:policies"^^xsd:anyURI       ; usf:loadOrder 10 ; usf:graphValidationOrder 14 .
ng:interfaces     a usf:NamedGraph ; usf:canonicalName "interfaces"     ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:interfaces"^^xsd:anyURI     ; usf:loadOrder 11 ; usf:graphValidationOrder 15 .
ng:interactions   a usf:NamedGraph ; usf:canonicalName "interactions"   ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:interactions"^^xsd:anyURI   ; usf:loadOrder 12 ; usf:graphValidationOrder 16 .
ng:platform       a usf:NamedGraph ; usf:canonicalName "platform"       ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:platform"^^xsd:anyURI       ; usf:loadOrder 13 ; usf:graphValidationOrder 17 .
ng:data           a usf:NamedGraph ; usf:canonicalName "data"           ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:data"^^xsd:anyURI           ; usf:loadOrder 14 ; usf:graphValidationOrder 18 .
ng:signals        a usf:NamedGraph ; usf:canonicalName "signals"        ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:signals"^^xsd:anyURI        ; usf:loadOrder 15 ; usf:graphValidationOrder 19 .
ng:experience     a usf:NamedGraph ; usf:canonicalName "experience"     ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:experience"^^xsd:anyURI     ; usf:loadOrder 16 ; usf:graphValidationOrder 20 .
ng:proofs         a usf:NamedGraph ; usf:canonicalName "proofs"         ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:proofs"^^xsd:anyURI         ; usf:loadOrder 17 ; usf:graphValidationOrder 21 .
ng:evidence       a usf:NamedGraph ; usf:canonicalName "evidence"       ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:evidence"^^xsd:anyURI       ; usf:loadOrder 18 ; usf:graphValidationOrder 22 .
ng:controls       a usf:NamedGraph ; usf:canonicalName "controls"       ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:controls"^^xsd:anyURI       ; usf:loadOrder 19 ; usf:graphValidationOrder 23 .
ng:tests          a usf:NamedGraph ; usf:canonicalName "tests"          ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:tests"^^xsd:anyURI          ; usf:loadOrder 20 ; usf:graphValidationOrder 24 .
ng:services       a usf:NamedGraph ; usf:canonicalName "services"       ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:services"^^xsd:anyURI       ; usf:loadOrder 21 ; usf:graphValidationOrder 25 .
ng:implementations a usf:NamedGraph ; usf:canonicalName "implementations" ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:implementations"^^xsd:anyURI ; usf:loadOrder 22 ; usf:graphValidationOrder 26 .
ng:bindings       a usf:NamedGraph ; usf:canonicalName "bindings"       ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:bindings"^^xsd:anyURI       ; usf:loadOrder 23 ; usf:graphValidationOrder 27 .
ng:agents         a usf:NamedGraph ; usf:canonicalName "agents"         ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:agents"^^xsd:anyURI         ; usf:loadOrder 24 ; usf:graphValidationOrder 28 .
ng:validators     a usf:NamedGraph ; usf:canonicalName "validators"     ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:validators"^^xsd:anyURI     ; usf:loadOrder 25 ; usf:graphValidationOrder 29 .
ng:enterprise     a usf:NamedGraph ; usf:canonicalName "enterprise"     ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:enterprise"^^xsd:anyURI     ; usf:loadOrder 26 ; usf:graphValidationOrder 30 .
ng:assuranceprofiles a usf:NamedGraph ; usf:canonicalName "assuranceprofiles" ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:assurance-profiles"^^xsd:anyURI ; usf:loadOrder 27 ; usf:graphValidationOrder 31 .
ng:readinessgates a usf:NamedGraph ; usf:canonicalName "readinessgates" ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:readiness-gates"^^xsd:anyURI ; usf:loadOrder 28 ; usf:graphValidationOrder 32 .
ng:ui a usf:NamedGraph ; usf:canonicalName "ui" ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:ui"^^xsd:anyURI ; usf:loadOrder 29 ; usf:graphValidationOrder 33 .
ng:renderers a usf:NamedGraph ; usf:canonicalName "renderers" ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:renderers"^^xsd:anyURI ; usf:loadOrder 30 ; usf:graphValidationOrder 34 .
ng:generation a usf:NamedGraph ; usf:canonicalName "generation" ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:generation"^^xsd:anyURI ; usf:loadOrder 31 ; usf:graphValidationOrder 35 .
ng:semanticdepth a usf:NamedGraph ; usf:canonicalName "semanticdepth" ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:semanticdepth"^^xsd:anyURI ; usf:loadOrder 32 ; usf:graphValidationOrder 36 .
ng:sourcedispositionpolicies a usf:NamedGraph ; usf:canonicalName "sourcedispositionpolicies" ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:sourcedispositionpolicies"^^xsd:anyURI ; usf:loadOrder 33 ; usf:graphValidationOrder 37 .
ng:repositorystructurepolicy a usf:NamedGraph ; usf:canonicalName "repositorystructurepolicy" ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:repositorystructurepolicy"^^xsd:anyURI ; usf:loadOrder 34 ; usf:graphValidationOrder 38 .
ng:materialisation a usf:NamedGraph ; usf:canonicalName "materialisation" ; usf:graphClass gcl:authoredgraph ; usf:graphIri "urn:usf:graph:materialisation"^^xsd:anyURI ; usf:loadOrder 35 ; usf:graphValidationOrder 39 .

# ---- Observed graphs (non-authoritative external/repository evidence) ----
ng:sourceobservations a usf:NamedGraph ; usf:canonicalName "sourceobservations" ; usf:graphClass gcl:observedgraph ; usf:graphIri "urn:usf:graph:observed:sourceartefacts"^^xsd:anyURI ; usf:loadOrder 37 ; usf:graphValidationOrder 40 .

# ---- Shape graph ----
ng:shapes a usf:NamedGraph ; usf:canonicalName "shapes" ; usf:graphClass gcl:shapegraph ; usf:graphIri "urn:usf:graph:shapes"^^xsd:anyURI ; usf:loadOrder 36 ; usf:graphValidationOrder 6 .

# ---- Derived graphs ----
ng:derivedrepositorystructure a usf:NamedGraph ; usf:canonicalName "derivedrepositorystructure" ; usf:graphClass gcl:derivedgraph ; usf:graphIri "urn:usf:graph:derived:repositorystructure"^^xsd:anyURI ; usf:loadOrder 40 ; usf:graphValidationOrder 41 .
ng:derivedsourcedispositions a usf:NamedGraph ; usf:canonicalName "derivedsourcedispositions" ; usf:graphClass gcl:derivedgraph ; usf:graphIri "urn:usf:graph:derived:sourcedispositions"^^xsd:anyURI ; usf:loadOrder 41 ; usf:graphValidationOrder 42 .
ng:derivedobligations a usf:NamedGraph ; usf:canonicalName "derivedobligations" ; usf:graphClass gcl:derivedgraph ; usf:graphIri "urn:usf:graph:derived:obligations"^^xsd:anyURI ; usf:loadOrder 42 ; usf:graphValidationOrder 43 .
ng:derivedevidence    a usf:NamedGraph ; usf:canonicalName "derivedevidence"    ; usf:graphClass gcl:derivedgraph ; usf:graphIri "urn:usf:graph:derived:evidence"^^xsd:anyURI    ; usf:loadOrder 43 ; usf:graphValidationOrder 44 .
ng:derivedsurfaces    a usf:NamedGraph ; usf:canonicalName "derivedsurfaces"    ; usf:graphClass gcl:derivedgraph ; usf:graphIri "urn:usf:graph:derived:surfaces"^^xsd:anyURI    ; usf:loadOrder 44 ; usf:graphValidationOrder 45 .
ng:derivedcoverage    a usf:NamedGraph ; usf:canonicalName "derivedcoverage"    ; usf:graphClass gcl:derivedgraph ; usf:graphIri "urn:usf:graph:derived:coverage"^^xsd:anyURI    ; usf:loadOrder 45 ; usf:graphValidationOrder 46 .
ng:derivedreadiness   a usf:NamedGraph ; usf:canonicalName "derivedreadiness"   ; usf:graphClass gcl:derivedgraph ; usf:graphIri "urn:usf:graph:derived:readiness"^^xsd:anyURI   ; usf:loadOrder 46 ; usf:graphValidationOrder 47 .

# ---- Derivation rule modules (produce the derived graphs) ----
rl:obligations a usf:DerivationRule ; usf:canonicalName "obligations" ; usf:inNamedGraph ng:derivedobligations .
rl:evidence    a usf:DerivationRule ; usf:canonicalName "evidence"    ; usf:inNamedGraph ng:derivedevidence .
rl:surfaces    a usf:DerivationRule ; usf:canonicalName "surfaces"    ; usf:inNamedGraph ng:derivedsurfaces .
rl:coverage    a usf:DerivationRule ; usf:canonicalName "coverage"    ; usf:inNamedGraph ng:derivedcoverage .
rl:readiness   a usf:DerivationRule ; usf:canonicalName "readiness"   ; usf:inNamedGraph ng:derivedreadiness .
rl:sourcedispositions a usf:DerivationRule ; usf:canonicalName "sourcedispositions" ; usf:inNamedGraph ng:derivedsourcedispositions .
rl:repositorystructure a usf:DerivationRule ; usf:canonicalName "repositorystructure" ; usf:inNamedGraph ng:derivedrepositorystructure .

# ---- Integrity rule module (whole-dataset invariants; returns no violations) ----
rl:integrity a usf:IntegrityRule ; usf:canonicalName "integrity" .
