# --- term usage governance
usf:TermUsageState a owl:Class ; rdfs:subClassOf usf:ControlledValue ;
    rdfs:label "TermUsageState" ;
    rdfs:comment "Controlled usage disposition for a declared ontology term that currently has no instance level usage." .
usf:termUsageState a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:range usf:TermUsageState ; rdfs:label "termUsageState" ;
    rdfs:comment "Declares the deliberate usage disposition of a declared but currently uninstantiated term." .
usf:termUsageRationale a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:range xsd:string ; rdfs:label "termUsageRationale" ;
    rdfs:comment "Human readable rationale for a term usage disposition." .
usf:intentionallyStandalone a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:range xsd:boolean ; rdfs:label "intentionallyStandalone" ;
    rdfs:comment "Marks a resource whose lack of architectural connection is a deliberate, reviewed decision; requires a decision rationale." .

# --- term usage dispositions (declared terms without current instance usage)
usf:Importer usf:termUsageState <urn:usf:termusagestate:reservedfuturescope> ;
    usf:termUsageRationale "Reserved for the clean room generation and release lifecycle; instances are produced by compiler generation runs, not authored in the semantic graph." .
