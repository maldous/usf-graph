@prefix usf:  <urn:usf:ontology:> .
@prefix tax:  <urn:usf:taxonomy:> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

# The taxonomy classifies ontology classes into semantic families and records the
# authored/derived split. It adds classification only; it declares no new terms.

usf:SemanticFamily a owl:Class ; rdfs:subClassOf usf:ControlledValue ;
    rdfs:label "SemanticFamily" ;
    rdfs:comment "A top-level grouping of ontology classes into one coherent concern." .

usf:classifiedAs a owl:ObjectProperty ;
    rdfs:range usf:SemanticFamily ; rdfs:label "classifiedAs" ;
    rdfs:comment "Classifies an ontology class under one semantic family." .

tax:contract    a usf:SemanticFamily ; usf:canonicalName "contract" .
tax:interaction a usf:SemanticFamily ; usf:canonicalName "interaction" .
tax:platform    a usf:SemanticFamily ; usf:canonicalName "platform" .
tax:experience  a usf:SemanticFamily ; usf:canonicalName "experience" .
tax:assurance   a usf:SemanticFamily ; usf:canonicalName "assurance" .
tax:realisation a usf:SemanticFamily ; usf:canonicalName "realisation" .
tax:execution   a usf:SemanticFamily ; usf:canonicalName "execution" .
tax:derivation  a usf:SemanticFamily ; usf:canonicalName "derivation" .
tax:authority   a usf:SemanticFamily ; usf:canonicalName "authority" .

# Contract family
usf:Capability            usf:classifiedAs tax:contract .
usf:SemanticContract      usf:classifiedAs tax:contract .
usf:ContractFacet         usf:classifiedAs tax:contract .
usf:Policy                usf:classifiedAs tax:contract .
usf:Constraint            usf:classifiedAs tax:contract .
usf:Claim                 usf:classifiedAs tax:contract .
usf:NonClaim              usf:classifiedAs tax:contract .
usf:Permission            usf:classifiedAs tax:contract .
usf:Role                  usf:classifiedAs tax:contract .
usf:TenantBoundary        usf:classifiedAs tax:contract .
usf:PrivacyClassification usf:classifiedAs tax:contract .
usf:RetentionPolicy       usf:classifiedAs tax:contract .
usf:ConsentRequirement    usf:classifiedAs tax:contract .

# Interaction family
usf:Port       usf:classifiedAs tax:interaction .
usf:Interface  usf:classifiedAs tax:interaction .
usf:Operation  usf:classifiedAs tax:interaction .
usf:Command    usf:classifiedAs tax:interaction .
usf:Query      usf:classifiedAs tax:interaction .
usf:Event      usf:classifiedAs tax:interaction .
usf:Message    usf:classifiedAs tax:interaction .
usf:Workflow   usf:classifiedAs tax:interaction .
usf:State      usf:classifiedAs tax:interaction .
usf:Transition usf:classifiedAs tax:interaction .

# Platform family
usf:Provider            usf:classifiedAs tax:platform .
usf:Environment         usf:classifiedAs tax:platform .
usf:Promotion           usf:classifiedAs tax:platform .
usf:ConfigurationKey    usf:classifiedAs tax:platform .
usf:DataModel           usf:classifiedAs tax:platform .
usf:PersistenceContract usf:classifiedAs tax:platform .
usf:Migration           usf:classifiedAs tax:platform .
usf:BackupRestore       usf:classifiedAs tax:platform .

# Experience family
usf:AuditEvent               usf:classifiedAs tax:experience .
usf:ObservabilitySignal      usf:classifiedAs tax:experience .
usf:Alert                    usf:classifiedAs tax:experience .
usf:Journey                  usf:classifiedAs tax:experience .
usf:InteractionState         usf:classifiedAs tax:experience .
usf:AccessibilityRequirement usf:classifiedAs tax:experience .
usf:LocalisationRequirement  usf:classifiedAs tax:experience .

# Assurance family (authored + derived)
usf:Proof               usf:classifiedAs tax:assurance .
usf:ProofExecution      usf:classifiedAs tax:assurance .
usf:ProofResult         usf:classifiedAs tax:assurance .
usf:EvidenceResult      usf:classifiedAs tax:assurance .
usf:Control             usf:classifiedAs tax:assurance .
usf:ControlObjective    usf:classifiedAs tax:assurance .
usf:Risk                usf:classifiedAs tax:assurance .
usf:Test                usf:classifiedAs tax:assurance .
usf:Fixture             usf:classifiedAs tax:assurance .
usf:Defect              usf:classifiedAs tax:assurance .

# Realisation family
usf:Service        usf:classifiedAs tax:realisation .
usf:Implementation usf:classifiedAs tax:realisation .
usf:Adapter        usf:classifiedAs tax:realisation .
usf:Binding        usf:classifiedAs tax:realisation .
usf:Realisation    usf:classifiedAs tax:realisation .

# Execution family
usf:Agent           usf:classifiedAs tax:execution .
usf:AgentConstraint usf:classifiedAs tax:execution .
usf:ValidatorRule   usf:classifiedAs tax:execution .
usf:IntegrityRule   usf:classifiedAs tax:execution .
usf:DerivationRule  usf:classifiedAs tax:execution .
usf:Shape           usf:classifiedAs tax:execution .

# Derivation family (derived-only classes)
usf:ProofObligation     usf:classifiedAs tax:derivation .
usf:TestObligation      usf:classifiedAs tax:derivation .
usf:EvidenceRequirement usf:classifiedAs tax:derivation .
usf:DerivedSurface      usf:classifiedAs tax:derivation .
usf:ContractSurface     usf:classifiedAs tax:derivation .
usf:Coverage            usf:classifiedAs tax:derivation .
usf:Readiness           usf:classifiedAs tax:derivation .

# Authority family
usf:NamedGraph usf:classifiedAs tax:authority .

@prefix usf: <urn:usf:ontology:> .

# Merge target: urn:usf:graph:taxonomy.
# Reuse the nine existing semantic families; no new family is necessary.

# Contract terms.
usf:ArtefactPlan usf:classifiedAs <urn:usf:taxonomy:contract> .
usf:PathRule usf:classifiedAs <urn:usf:taxonomy:contract> .
usf:CompatibilityContract usf:classifiedAs <urn:usf:taxonomy:contract> .
usf:MigrationPolicy usf:classifiedAs <urn:usf:taxonomy:contract> .

# Realisation terms.
usf:ArtefactContainer usf:classifiedAs <urn:usf:taxonomy:realisation> .
usf:Artefact usf:classifiedAs <urn:usf:taxonomy:realisation> .
usf:Repository usf:classifiedAs <urn:usf:taxonomy:realisation> .
usf:Workspace usf:classifiedAs <urn:usf:taxonomy:realisation> .
usf:Package usf:classifiedAs <urn:usf:taxonomy:realisation> .
usf:Module usf:classifiedAs <urn:usf:taxonomy:realisation> .
usf:Template usf:classifiedAs <urn:usf:taxonomy:realisation> .

# Execution terms.
usf:Compiler usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:CompilerComponent usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:Generator usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:Renderer usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:Transform usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:Importer usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:ArtefactMaterialisation usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:EvidenceCollection usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:EvidenceNormalisation usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:EvidenceIngestion usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:CompilerPhase usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:CompilerRun usf:classifiedAs <urn:usf:taxonomy:execution> .
usf:CleanRoomGeneration usf:classifiedAs <urn:usf:taxonomy:execution> .

# Platform and release terms.
usf:Build usf:classifiedAs <urn:usf:taxonomy:platform> .
usf:Release usf:classifiedAs <urn:usf:taxonomy:platform> .
usf:Version usf:classifiedAs <urn:usf:taxonomy:platform> .
usf:DependencyLock usf:classifiedAs <urn:usf:taxonomy:platform> .
usf:Bundle usf:classifiedAs <urn:usf:taxonomy:platform> .

# Assurance and integrity terms.
usf:Signature usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:SigningIdentity usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:Attestation usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:ProvenanceRecord usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:SoftwareBillOfMaterials usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:Checksum usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:EquivalenceClaim usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:EquivalenceRule usf:classifiedAs <urn:usf:taxonomy:assurance> .

# Enterprise assurance terms. Controlled-value subclasses remain exempt under
# the closed-vocabulary rule below.
usf:AssuranceFramework usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:FrameworkEdition usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:FrameworkClause usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:FrameworkControl usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:ControlImplementation usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:ControlScopeMapping usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:StatementOfApplicability usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:ApplicabilityDecision usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:AssuranceOwnerRole usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:ControlException usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:CompensatingControl usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:RiskAssessment usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:RiskTreatment usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:RiskAcceptance usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:ControlAssessment usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:AssuranceFinding usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:CorrectiveAction usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:ControlReview usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:EvidenceReview usf:classifiedAs <urn:usf:taxonomy:assurance> .

# Taxonomy exemptions (enforced as rules rather than RDF assertions):
# Merge target: urn:usf:graph:taxonomy. Existing semantic families suffice.
usf:UISemanticModel usf:classifiedAs <urn:usf:taxonomy:experience> .
usf:ViewModel usf:classifiedAs <urn:usf:taxonomy:experience> .
usf:Surface usf:classifiedAs <urn:usf:taxonomy:experience> .
usf:Form usf:classifiedAs <urn:usf:taxonomy:experience> .
usf:FormField usf:classifiedAs <urn:usf:taxonomy:experience> .
usf:ValidationBinding usf:classifiedAs <urn:usf:taxonomy:experience> .
usf:ErrorBinding usf:classifiedAs <urn:usf:taxonomy:experience> .
usf:Component usf:classifiedAs <urn:usf:taxonomy:experience> .
usf:AccessibilityProfile usf:classifiedAs <urn:usf:taxonomy:experience> .
usf:LocalisationProfile usf:classifiedAs <urn:usf:taxonomy:experience> .
usf:Preview usf:classifiedAs <urn:usf:taxonomy:experience> .
usf:Route usf:classifiedAs <urn:usf:taxonomy:interaction> .
usf:RendererContract usf:classifiedAs <urn:usf:taxonomy:contract> .

# Universal assurance and readiness terms. The five new controlled-value
# classes remain exempt and are not assigned to a nonexistent vocabulary family.
usf:AssuranceObligation usf:classifiedAs <urn:usf:taxonomy:derivation> .
usf:ReadinessGateResult usf:classifiedAs <urn:usf:taxonomy:derivation> .
usf:AssuranceMatrix usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:AssuranceMatrixCell usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:ReadinessGate usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:GateCriterion usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:TestExecution usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:TestResult usf:classifiedAs <urn:usf:taxonomy:assurance> .
usf:IntegrityVerification usf:classifiedAs <urn:usf:taxonomy:assurance> .

# Repository source observation and disposition.
usf:ObservedEntity usf:classifiedAs <urn:usf:taxonomy:derivation> .
usf:SourceArtefact usf:classifiedAs <urn:usf:taxonomy:realisation> .
usf:SourceArtefactObservation usf:classifiedAs <urn:usf:taxonomy:derivation> .
usf:SourceArtefactDisposition usf:classifiedAs <urn:usf:taxonomy:derivation> .
usf:SourceDispositionPolicy usf:classifiedAs <urn:usf:taxonomy:contract> .
usf:SourceSemanticBinding usf:classifiedAs <urn:usf:taxonomy:contract> .
usf:AutomationWorkflowContract usf:classifiedAs <urn:usf:taxonomy:contract> .

# ControlledValue subclasses retain the existing controlled-value exemption;
# properties are closed by declaration/domain/range rather than classifiedAs.

# - subclasses of usf:ControlledValue are closed-vocabulary dimensions and do
#   not receive semantic-family assignments;
# - the existing abstract bases usf:Entity, usf:DerivedEntity, and
#   usf:ControlledValue retain their current abstract-base exemption;
# - properties are classified by domain/range and graph ownership, not with
#   usf:classifiedAs.
