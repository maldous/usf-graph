<urn:usf:representationformat:turtlerdf11> a usf:RepresentationFormat ; usf:canonicalName "turtlerdf11" ; usf:canonicalMediaType "text/turtle" ; usf:canonicalExtension ".ttl" ; usf:definedByStandard <urn:usf:standard:rdf11> .
