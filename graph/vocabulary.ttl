<urn:usf:representationformat:jsonld11> a usf:RepresentationFormat ; usf:canonicalName "jsonld11" ; usf:canonicalMediaType "application/ld+json" ; usf:canonicalExtension ".jsonld" ; usf:definedByStandard <urn:usf:standard:jsonld11> .
<urn:usf:representationformat:jcsjson> a usf:RepresentationFormat ; usf:canonicalName "jcsjson" ; usf:canonicalMediaType "application/json" ; usf:canonicalExtension ".json" ; usf:definedByStandard <urn:usf:standard:rfc8785> .
