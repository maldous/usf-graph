# Proof, test, evidence-pipeline, and readiness values.

fresh:unknown a usf:Freshness ; usf:canonicalName "unknown" .

rds:stale        a usf:ReadinessState ; usf:canonicalName "stale" .
rds:incompatible a usf:ReadinessState ; usf:canonicalName "incompatible" .
rds:degraded     a usf:ReadinessState ; usf:canonicalName "degraded" .
rds:unknown      a usf:ReadinessState ; usf:canonicalName "unknown" .

oe:blocking a usf:ObligationEffect ; usf:canonicalName "blocking" .
oe:advisory a usf:ObligationEffect ; usf:canonicalName "advisory" .

rs:passed         a usf:ResultState ; usf:canonicalName "passed" .
rs:failed         a usf:ResultState ; usf:canonicalName "failed" .
rs:detecteddefect a usf:ResultState ; usf:canonicalName "detecteddefect" .
rs:notrun         a usf:ResultState ; usf:canonicalName "notrun" .
rs:unknown        a usf:ResultState ; usf:canonicalName "unknown" .

es:emitted           a usf:EvidenceStage ; usf:canonicalName "emitted" .
es:collected         a usf:EvidenceStage ; usf:canonicalName "collected" .
es:normalised        a usf:EvidenceStage ; usf:canonicalName "normalised" .
es:ingested          a usf:EvidenceStage ; usf:canonicalName "ingested" .
es:signed            a usf:EvidenceStage ; usf:canonicalName "signed" .
es:integrityverified a usf:EvidenceStage ; usf:canonicalName "integrityverified" .

gk:release     a usf:ReadinessGateKind ; usf:canonicalName "release" .
gk:artefact    a usf:ReadinessGateKind ; usf:canonicalName "artefact" .
gk:enterprise  a usf:ReadinessGateKind ; usf:canonicalName "enterprise" .
gk:ui          a usf:ReadinessGateKind ; usf:canonicalName "ui" .
gk:livestardog a usf:ReadinessGateKind ; usf:canonicalName "livestardog" .

rr:satisfied                 a usf:ReadinessReason ; usf:canonicalName "satisfied" .
rr:missingblockingobligation a usf:ReadinessReason ; usf:canonicalName "missingblockingobligation" .
rr:staleevidence             a usf:ReadinessReason ; usf:canonicalName "staleevidence" .
rr:incompatibleprovidermode  a usf:ReadinessReason ; usf:canonicalName "incompatibleprovidermode" .
rr:incompatibleenvironment   a usf:ReadinessReason ; usf:canonicalName "incompatibleenvironment" .
rr:degradedadvisory          a usf:ReadinessReason ; usf:canonicalName "degradedadvisory" .
rr:unknownevaluation         a usf:ReadinessReason ; usf:canonicalName "unknownevaluation" .
rr:failedtest                a usf:ReadinessReason ; usf:canonicalName "failedtest" .
rr:unsignedevidence          a usf:ReadinessReason ; usf:canonicalName "unsignedevidence" .

