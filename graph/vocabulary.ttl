# Naming and numbering.
<urn:usf:namingrule:eightdigitfamilyslug> a usf:NamingRule ; usf:canonicalName "eightdigitfamilyslug" ; usf:filenamePattern "^[0-9]{8}-[a-z0-9]+(?:-[a-z0-9]+)*(?:\\.[a-z0-9]+)+$" .
<urn:usf:namingrule:languagenative> a usf:NamingRule ; usf:canonicalName "languagenative" ; usf:filenamePattern "^[A-Za-z0-9._-]+$" .
<urn:usf:namingrule:digestidentity> a usf:NamingRule ; usf:canonicalName "digestidentity" ; usf:filenamePattern "^sha256:[0-9a-f]{64}$" .
<urn:usf:namingrule:canonicalfixed> a usf:NamingRule ; usf:canonicalName "canonicalfixed" ; usf:filenamePattern "^[A-Za-z0-9._-]+$" .
<urn:usf:namingrule:providernative> a usf:NamingRule ; usf:canonicalName "providernative" ; usf:filenamePattern "^[^\\x00]+$" .
<urn:usf:numberingscope:familyeightdigit> a usf:NumberingScope ; usf:canonicalName "familyeightdigit" ; usf:ordinalWidth 8 ; usf:ordinalReuseProhibited true ; usf:renumberingProhibited true .
<urn:usf:numberingscope:languagenative> a usf:NumberingScope ; usf:canonicalName "languagenative" ; usf:ordinalReuseProhibited true ; usf:renumberingProhibited true .
<urn:usf:numberingscope:digestonly> a usf:NumberingScope ; usf:canonicalName "digestonly" ; usf:ordinalReuseProhibited true ; usf:renumberingProhibited true .
<urn:usf:numberingscope:none> a usf:NumberingScope ; usf:canonicalName "none" ; usf:ordinalReuseProhibited true ; usf:renumberingProhibited true .

