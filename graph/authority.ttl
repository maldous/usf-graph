@prefix usf: <urn:usf:ontology:> .
@prefix gcl: <urn:usf:graphclass:> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Graph authority model. Each graph class declares what it may do; the mayConstrain /
# mayReference / mayDerive relations bound cross-graph authority. Integrity rules and shapes
# reject any graph acting outside its class.

gcl:definitiongraph
    usf:mayDeclareTerms true ;
    usf:mayAssertInstances true ;
    usf:authoritative true ;
    usf:loadedAsAuthority true ;
    usf:mayReference gcl:definitiongraph .

gcl:authoredgraph
    usf:mayDeclareTerms false ;
    usf:mayAssertInstances true ;
    usf:authoritative true ;
    usf:loadedAsAuthority true ;
    usf:mayReference gcl:definitiongraph , gcl:authoredgraph .

gcl:shapegraph
    usf:mayDeclareTerms false ;
    usf:mayAssertInstances false ;
    usf:authoritative true ;
    usf:loadedAsAuthority true ;
    usf:mayConstrain gcl:definitiongraph , gcl:authoredgraph , gcl:derivedgraph ;
    usf:mayReference gcl:definitiongraph , gcl:authoredgraph , gcl:derivedgraph .

gcl:rulegraph
    usf:mayDeclareTerms false ;
    usf:mayAssertInstances false ;
    usf:authoritative true ;
    usf:loadedAsAuthority true ;
    usf:mayDerive gcl:derivedgraph ;
    usf:mayReference gcl:definitiongraph , gcl:authoredgraph , gcl:derivedgraph .

gcl:derivedgraph
    usf:mayDeclareTerms false ;
    usf:mayAssertInstances true ;
    usf:authoritative false ;
    usf:loadedAsAuthority true ;
    usf:mayReference gcl:definitiongraph , gcl:authoredgraph , gcl:derivedgraph .

gcl:fixturegraph
    usf:mayDeclareTerms false ;
    usf:mayAssertInstances true ;
    usf:authoritative false ;
    usf:loadedAsAuthority false ;
    usf:mayReference gcl:definitiongraph .

gcl:observedgraph
    usf:mayDeclareTerms false ;
    usf:mayAssertInstances true ;
    usf:authoritative false ;
    usf:loadedAsAuthority false ;
    usf:loadedForValidation true ;
    usf:loadedForDerivation true ;
    usf:mayReference gcl:definitiongraph , gcl:authoredgraph , gcl:observedgraph .

gcl:shapegraph usf:mayConstrain gcl:observedgraph ; usf:mayReference gcl:observedgraph .
gcl:rulegraph usf:mayReference gcl:observedgraph .
gcl:derivedgraph usf:mayReference gcl:observedgraph .
