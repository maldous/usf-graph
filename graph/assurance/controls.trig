@prefix usf: <urn:usf:ontology:> .
@prefix ctl: <urn:usf:control:> .
@prefix cob: <urn:usf:controlobjective:> .
@prefix rsk: <urn:usf:risk:> .

<urn:usf:graph:controls> {
    cob:accessibilitygateevidence a usf:ControlObjective ;
        usf:canonicalName "accessibilitygateevidence" .
    cob:accessreviewprivilegedoperationposture a usf:ControlObjective ;
        usf:canonicalName "accessreviewprivilegedoperationposture" .
    cob:backuprestoreresilienceposture a usf:ControlObjective ;
        usf:canonicalName "backuprestoreresilienceposture" .
    cob:donestategovernance a usf:ControlObjective ;
        usf:canonicalName "donestategovernance" .
    cob:enterpriseevidencepolicy a usf:ControlObjective ;
        usf:canonicalName "enterpriseevidencepolicy" .
    cob:enterpriseproofdepthmatrices a usf:ControlObjective ;
        usf:canonicalName "enterpriseproofdepthmatrices" .
    cob:incidentvulnerabilitymanagementevidence a usf:ControlObjective ;
        usf:canonicalName "incidentvulnerabilitymanagementevidence" .
    cob:iso27001alignedauditcontrolmap a usf:ControlObjective ;
        usf:canonicalName "iso27001alignedauditcontrolmap" .
    cob:observabilityevidencestandard a usf:ControlObjective ;
        usf:canonicalName "observabilityevidencestandard" .
    cob:privacydataminimisationposture a usf:ControlObjective ;
        usf:canonicalName "privacydataminimisationposture" .
    cob:sdkdependencygovernance a usf:ControlObjective ;
        usf:canonicalName "sdkdependencygovernance" .
    cob:soasupportmappings a usf:ControlObjective ;
        usf:canonicalName "soasupportmappings" .
    cob:sonarqubezeroissuequalitygateassurance a usf:ControlObjective ;
        usf:canonicalName "sonarqubezeroissuequalitygateassurance" .
    cob:testcoveragegate a usf:ControlObjective ;
        usf:canonicalName "testcoveragegate" .
    ctl:accessibilitygateevidence a usf:Control ;
        usf:achievesObjective cob:accessibilitygateevidence ;
        usf:canonicalName "accessibilitygateevidence" ;
        usf:mitigates rsk:evidenceintegrityandfreshnessfailure .
    ctl:accessreviewprivilegedoperationposture a usf:Control ;
        usf:achievesObjective cob:accessreviewprivilegedoperationposture ;
        usf:canonicalName "accessreviewprivilegedoperationposture" ;
        usf:mitigates rsk:privilegedaccessreviewfailure .
    ctl:backuprestoreresilienceposture a usf:Control ;
        usf:achievesObjective cob:backuprestoreresilienceposture ;
        usf:canonicalName "backuprestoreresilienceposture" ;
        usf:mitigates rsk:recoveryevidencegap .
    ctl:donestategovernance a usf:Control ;
        usf:achievesObjective cob:donestategovernance ;
        usf:canonicalName "donestategovernance" ;
        usf:mitigates rsk:uncontrolledsemanticchange .
    ctl:enterpriseevidencepolicy a usf:Control ;
        usf:achievesObjective cob:enterpriseevidencepolicy ;
        usf:canonicalName "enterpriseevidencepolicy" ;
        usf:mitigates rsk:evidenceintegrityandfreshnessfailure .
    ctl:enterpriseproofdepthmatrices a usf:Control ;
        usf:achievesObjective cob:enterpriseproofdepthmatrices ;
        usf:canonicalName "enterpriseproofdepthmatrices" ;
        usf:mitigates rsk:assuranceoverclaim .
    ctl:incidentvulnerabilitymanagementevidence a usf:Control ;
        usf:achievesObjective cob:incidentvulnerabilitymanagementevidence ;
        usf:canonicalName "incidentvulnerabilitymanagementevidence" ;
        usf:mitigates rsk:incidentandvulnerabilityblindspot .
    ctl:iso27001alignedauditcontrolmap a usf:Control ;
        usf:achievesObjective cob:iso27001alignedauditcontrolmap ;
        usf:canonicalName "iso27001alignedauditcontrolmap" ;
        usf:mitigates rsk:assuranceoverclaim .
    ctl:observabilityevidencestandard a usf:Control ;
        usf:achievesObjective cob:observabilityevidencestandard ;
        usf:canonicalName "observabilityevidencestandard" ;
        usf:mitigates rsk:incidentandvulnerabilityblindspot .
    ctl:privacydataminimisationposture a usf:Control ;
        usf:achievesObjective cob:privacydataminimisationposture ;
        usf:canonicalName "privacydataminimisationposture" ;
        usf:mitigates rsk:privacyretentionandminimisationfailure .
    ctl:sdkdependencygovernance a usf:Control ;
        usf:achievesObjective cob:sdkdependencygovernance ;
        usf:canonicalName "sdkdependencygovernance" ;
        usf:mitigates rsk:softwareandprovidersupplychainfailure .
    ctl:soasupportmappings a usf:Control ;
        usf:achievesObjective cob:soasupportmappings ;
        usf:canonicalName "soasupportmappings" ;
        usf:mitigates rsk:assuranceoverclaim .
    ctl:sonarqubezeroissuequalitygateassurance a usf:Control ;
        usf:achievesObjective cob:sonarqubezeroissuequalitygateassurance ;
        usf:canonicalName "sonarqubezeroissuequalitygateassurance" ;
        usf:mitigates rsk:softwareandprovidersupplychainfailure .
    ctl:testcoveragegate a usf:Control ;
        usf:achievesObjective cob:testcoveragegate ;
        usf:canonicalName "testcoveragegate" ;
        usf:mitigates rsk:assuranceoverclaim .
}
