@prefix usf:   <urn:usf:ontology:> .
@prefix matrix:<urn:usf:assurancematrix:> .
@prefix cell:  <urn:usf:assurancecell:> .
@prefix gate:  <urn:usf:readinessgate:> .
@prefix crit:  <urn:usf:gatecriterion:> .
@prefix rung:  <urn:usf:proofrung:> .
@prefix pmode: <urn:usf:providermode:> .
@prefix envc:  <urn:usf:environmentclass:> .
@prefix gk:    <urn:usf:readinessgatekind:> .
@prefix oe:    <urn:usf:obligationeffect:> .

<urn:usf:graph:readiness-gates> {
  gate:release a usf:ReadinessGate ; usf:canonicalName "release" ; usf:gateKind gk:release ;
      usf:hasCriterion crit:releasebuild, crit:releasedeterminism, crit:releaseversion,
          crit:releasechecksum, crit:releasesbom, crit:releaseprovenance,
          crit:releasesignature, crit:releasesignatureverification .
  crit:releasebuild a usf:GateCriterion ; usf:canonicalName "releasebuild" ; usf:criterionCode "release.build.passed" ; usf:requiredByGate gate:release ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:releasedeterminism a usf:GateCriterion ; usf:canonicalName "releasedeterminism" ; usf:criterionCode "release.full-incremental.parity" ; usf:requiredByGate gate:release ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:releaseversion a usf:GateCriterion ; usf:canonicalName "releaseversion" ; usf:criterionCode "release.bundle.versioned" ; usf:requiredByGate gate:release ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:releasechecksum a usf:GateCriterion ; usf:canonicalName "releasechecksum" ; usf:criterionCode "release.bundle.checksummed" ; usf:requiredByGate gate:release ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:releasesbom a usf:GateCriterion ; usf:canonicalName "releasesbom" ; usf:criterionCode "release.sbom.valid" ; usf:requiredByGate gate:release ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:releaseprovenance a usf:GateCriterion ; usf:canonicalName "releaseprovenance" ; usf:criterionCode "release.provenance.valid" ; usf:requiredByGate gate:release ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:releasesignature a usf:GateCriterion ; usf:canonicalName "releasesignature" ; usf:criterionCode "release.signature.present" ; usf:requiredByGate gate:release ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:releasesignatureverification a usf:GateCriterion ; usf:canonicalName "releasesignatureverification" ; usf:criterionCode "release.signature.independently-verified" ; usf:requiredByGate gate:release ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .

  gate:artefact a usf:ReadinessGate ; usf:canonicalName "artefact" ; usf:gateKind gk:artefact ;
      usf:hasCriterion crit:artefactplan, crit:artefactownership, crit:artefactschema,
          crit:artefactpath, crit:artefactintegrity, crit:artefactequivalence,
          crit:artefactmissingsemantics .
  crit:artefactplan a usf:GateCriterion ; usf:canonicalName "artefactplan" ; usf:criterionCode "artefact.plan.complete" ; usf:requiredByGate gate:artefact ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:contracthermetichermetic .
  crit:artefactownership a usf:GateCriterion ; usf:canonicalName "artefactownership" ; usf:criterionCode "artefact.output.owned" ; usf:requiredByGate gate:artefact ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:contracthermetichermetic .
  crit:artefactschema a usf:GateCriterion ; usf:canonicalName "artefactschema" ; usf:criterionCode "artefact.output-schema.valid" ; usf:requiredByGate gate:artefact ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:contracthermetichermetic .
  crit:artefactpath a usf:GateCriterion ; usf:canonicalName "artefactpath" ; usf:criterionCode "artefact.path.deterministic" ; usf:requiredByGate gate:artefact ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:contracthermetichermetic .
  crit:artefactintegrity a usf:GateCriterion ; usf:canonicalName "artefactintegrity" ; usf:criterionCode "artefact.integrity.valid" ; usf:requiredByGate gate:artefact ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:artefactequivalence a usf:GateCriterion ; usf:canonicalName "artefactequivalence" ; usf:criterionCode "artefact.equivalence.passed" ; usf:requiredByGate gate:artefact ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:artefactmissingsemantics a usf:GateCriterion ; usf:canonicalName "artefactmissingsemantics" ; usf:criterionCode "artefact.missing-semantics.fail-closed" ; usf:requiredByGate gate:artefact ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .

  gate:enterprise a usf:ReadinessGate ; usf:canonicalName "enterprise" ; usf:gateKind gk:enterprise ;
      usf:hasCriterion crit:enterprisecontrols, crit:enterpriserisks,
          crit:enterpriseframeworkversions, crit:enterprisesoa,
          crit:enterpriseevidence .
  crit:enterprisecontrols a usf:GateCriterion ; usf:canonicalName "enterprisecontrols" ; usf:criterionCode "enterprise.controls.complete" ; usf:requiredByGate gate:enterprise ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:contracthermetichermetic .
  crit:enterpriserisks a usf:GateCriterion ; usf:canonicalName "enterpriserisks" ; usf:criterionCode "enterprise.risks.complete" ; usf:requiredByGate gate:enterprise ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:contracthermetichermetic .
  crit:enterpriseframeworkversions a usf:GateCriterion ; usf:canonicalName "enterpriseframeworkversions" ; usf:criterionCode "enterprise.framework-versions.explicit" ; usf:requiredByGate gate:enterprise ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:contracthermetichermetic .
  crit:enterprisesoa a usf:GateCriterion ; usf:canonicalName "enterprisesoa" ; usf:criterionCode "enterprise.soa.applicability-complete" ; usf:requiredByGate gate:enterprise ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:enterpriseevidence a usf:GateCriterion ; usf:canonicalName "enterpriseevidence" ; usf:criterionCode "enterprise.evidence.collected-signed" ; usf:requiredByGate gate:enterprise ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .

  gate:ui a usf:ReadinessGate ; usf:canonicalName "ui" ; usf:gateKind gk:ui ;
      usf:hasCriterion crit:uiviewmodel, crit:uiprimitives, crit:uirenderer,
          crit:uiaccessibility, crit:uievidence .
  crit:uiviewmodel a usf:GateCriterion ; usf:canonicalName "uiviewmodel" ; usf:criterionCode "ui.viewmodel.complete" ; usf:requiredByGate gate:ui ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:contracthermetichermetic .
  crit:uiprimitives a usf:GateCriterion ; usf:canonicalName "uiprimitives" ; usf:criterionCode "ui.route-form-table.complete" ; usf:requiredByGate gate:ui ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:contracthermetichermetic .
  crit:uirenderer a usf:GateCriterion ; usf:canonicalName "uirenderer" ; usf:criterionCode "ui.renderer-contract.complete" ; usf:requiredByGate gate:ui ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:uiaccessibility a usf:GateCriterion ; usf:canonicalName "uiaccessibility" ; usf:criterionCode "ui.accessibility.passed" ; usf:requiredByGate gate:ui ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .
  crit:uievidence a usf:GateCriterion ; usf:canonicalName "uievidence" ; usf:criterionCode "ui.execution-evidence.admissible" ; usf:requiredByGate gate:ui ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:behaviourhermetichermetic .

  gate:livestardog a usf:ReadinessGate ; usf:canonicalName "livestardog" ; usf:gateKind gk:livestardog ;
      usf:hasCriterion crit:stardogofficialsdk, crit:stardogonetransaction,
          crit:stardogregisteredgraphs, crit:stardogpergraphclear,
          crit:stardogauthoredvalidation, crit:stardogorderedderivation,
          crit:stardogderivedvalidation, crit:stardogintegrityvalidation,
          crit:stardogcontaminationvalidation, crit:stardogrollback,
          crit:stardogdigests, crit:stardogattestation, crit:stardogdrift .
  crit:stardogofficialsdk a usf:GateCriterion ; usf:canonicalName "stardogofficialsdk" ; usf:criterionCode "stardog.official-sdk.only" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
  crit:stardogonetransaction a usf:GateCriterion ; usf:canonicalName "stardogonetransaction" ; usf:criterionCode "stardog.write.single-transaction" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
  crit:stardogregisteredgraphs a usf:GateCriterion ; usf:canonicalName "stardogregisteredgraphs" ; usf:criterionCode "stardog.graphs.registered-only" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
  crit:stardogpergraphclear a usf:GateCriterion ; usf:canonicalName "stardogpergraphclear" ; usf:criterionCode "stardog.clear.per-graph-only" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
  crit:stardogauthoredvalidation a usf:GateCriterion ; usf:canonicalName "stardogauthoredvalidation" ; usf:criterionCode "stardog.authored.validation-passed" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
  crit:stardogorderedderivation a usf:GateCriterion ; usf:canonicalName "stardogorderedderivation" ; usf:criterionCode "stardog.derivation.ordered" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
  crit:stardogderivedvalidation a usf:GateCriterion ; usf:canonicalName "stardogderivedvalidation" ; usf:criterionCode "stardog.derived.validation-passed" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
  crit:stardogintegrityvalidation a usf:GateCriterion ; usf:canonicalName "stardogintegrityvalidation" ; usf:criterionCode "stardog.integrity.validation-passed" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
  crit:stardogcontaminationvalidation a usf:GateCriterion ; usf:canonicalName "stardogcontaminationvalidation" ; usf:criterionCode "stardog.contamination.validation-passed" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
  crit:stardogrollback a usf:GateCriterion ; usf:canonicalName "stardogrollback" ; usf:criterionCode "stardog.rollback.faults-proven" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:resiliencecomposedintegration .
  crit:stardogdigests a usf:GateCriterion ; usf:canonicalName "stardogdigests" ; usf:criterionCode "stardog.per-graph-digests.canonical" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
  crit:stardogattestation a usf:GateCriterion ; usf:canonicalName "stardogattestation" ; usf:criterionCode "stardog.external-attestation.signed-verified" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
  crit:stardogdrift a usf:GateCriterion ; usf:canonicalName "stardogdrift" ; usf:criterionCode "stardog.readonly-drift.zero" ; usf:requiredByGate gate:livestardog ; usf:obligationEffect oe:blocking ; usf:usesAssuranceCell cell:substratecomposedintegration .
}
