@prefix usf:   <urn:usf:ontology:> .
@prefix matrix:<urn:usf:assurancematrix:> .
@prefix cell:  <urn:usf:assurancecell:> .
@prefix gate:  <urn:usf:readinessgate:> .
@prefix crit:  <urn:usf:gatecriterion:> .
@prefix rung:  <urn:usf:proofrung:> .
@prefix pmode: <urn:usf:providermode:> .
@prefix envc:  <urn:usf:environmentclass:> .
@prefix gk:    <urn:usf:readinessgatekind:> .
@prefix oe:    <urn:usf:obligationeffect:> .

<urn:usf:graph:assurance-profiles> {
  matrix:canonical a usf:AssuranceMatrix ;
      usf:canonicalName "canonical" ;
      usf:hasMatrixCell cell:discoveryhermeticlocal,
          cell:executablehermetichermetic, cell:contracthermetichermetic,
          cell:behaviourhermetichermetic, cell:substratecomposedintegration,
          cell:resiliencecomposedintegration, cell:substratesandboxstaging,
          cell:foundationsandboxproductionshaped,
          cell:foundationliveproductionlive .

  cell:discoveryhermeticlocal a usf:AssuranceMatrixCell ; usf:canonicalName "discoveryhermeticlocal" ; usf:profileRung rung:discovery ; usf:profileProviderMode pmode:hermeticmock ; usf:profileEnvironmentClass envc:local .
  cell:executablehermetichermetic a usf:AssuranceMatrixCell ; usf:canonicalName "executablehermetichermetic" ; usf:profileRung rung:executable ; usf:profileProviderMode pmode:hermeticmock ; usf:profileEnvironmentClass envc:hermetic .
  cell:contracthermetichermetic a usf:AssuranceMatrixCell ; usf:canonicalName "contracthermetichermetic" ; usf:profileRung rung:contract ; usf:profileProviderMode pmode:hermeticmock ; usf:profileEnvironmentClass envc:hermetic .
  cell:behaviourhermetichermetic a usf:AssuranceMatrixCell ; usf:canonicalName "behaviourhermetichermetic" ; usf:profileRung rung:behaviour ; usf:profileProviderMode pmode:hermeticmock ; usf:profileEnvironmentClass envc:hermetic .
  cell:substratecomposedintegration a usf:AssuranceMatrixCell ; usf:canonicalName "substratecomposedintegration" ; usf:profileRung rung:substrate ; usf:profileProviderMode pmode:composedreal ; usf:profileEnvironmentClass envc:integration .
  cell:resiliencecomposedintegration a usf:AssuranceMatrixCell ; usf:canonicalName "resiliencecomposedintegration" ; usf:profileRung rung:resilience ; usf:profileProviderMode pmode:composedreal ; usf:profileEnvironmentClass envc:integration .
  cell:substratesandboxstaging a usf:AssuranceMatrixCell ; usf:canonicalName "substratesandboxstaging" ; usf:profileRung rung:substrate ; usf:profileProviderMode pmode:externalsandbox ; usf:profileEnvironmentClass envc:staging .
  cell:foundationsandboxproductionshaped a usf:AssuranceMatrixCell ; usf:canonicalName "foundationsandboxproductionshaped" ; usf:profileRung rung:foundation ; usf:profileProviderMode pmode:externalsandbox ; usf:profileEnvironmentClass envc:productionshaped .
  cell:foundationliveproductionlive a usf:AssuranceMatrixCell ; usf:canonicalName "foundationliveproductionlive" ; usf:profileRung rung:foundation ; usf:profileProviderMode pmode:liveexternal ; usf:profileEnvironmentClass envc:productionlive .
}
