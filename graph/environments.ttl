@prefix usf: <urn:usf:ontology:> .
@prefix env: <urn:usf:environment:> .
@prefix envc: <urn:usf:environmentclass:> .
@prefix pmode: <urn:usf:providermode:> .
@prefix prom: <urn:usf:promotion:> .

env:ci a usf:Environment ;
    usf:canonicalName "ci" ;
    usf:hasEnvironmentClass envc:integration .
env:hermetic a usf:Environment ;
    usf:canonicalName "hermetic" ;
    usf:hasEnvironmentClass envc:hermetic ;
    usf:permitsProviderMode pmode:hermeticmock .
env:integrationtest a usf:Environment ;
    usf:canonicalName "integrationtest" ;
    usf:hasEnvironmentClass envc:integration ;
    usf:permitsProviderMode pmode:composedreal .
env:localdev a usf:Environment ;
    usf:canonicalName "localdev" ;
    usf:hasEnvironmentClass envc:local ;
    usf:permitsProviderMode pmode:hermeticmock .
env:productionlive a usf:Environment ;
    usf:canonicalName "productionlive" ;
    usf:hasEnvironmentClass envc:productionlive ;
    usf:permitsProviderMode pmode:liveexternal .
env:productionshaped a usf:Environment ;
    usf:canonicalName "productionshaped" ;
    usf:hasEnvironmentClass envc:productionshaped ;
    usf:permitsProviderMode pmode:externalsandbox .
env:staging a usf:Environment ;
    usf:canonicalName "staging" ;
    usf:hasEnvironmentClass envc:staging ;
    usf:permitsProviderMode pmode:externalsandbox .
prom:claimrules a usf:Promotion ;
    usf:canonicalName "claimrules" ;
    usf:promotesFrom env:localdev ;
    usf:promotesTo env:localdev .
prom:promotedevtotest a usf:Promotion ;
    usf:canonicalName "promotedevtotest" ;
    usf:promotesFrom env:localdev ;
    usf:promotesTo env:integrationtest .
prom:promotestagingtoproduction a usf:Promotion ;
    usf:canonicalName "promotestagingtoproduction" ;
    usf:promotesFrom env:staging ;
    usf:promotesTo env:productionlive .
prom:promotetesttostaging a usf:Promotion ;
    usf:canonicalName "promotetesttostaging" ;
    usf:promotesFrom env:integrationtest ;
    usf:promotesTo env:staging .
prom:repositoryenvironmentladdergovernance a usf:Promotion ;
    usf:canonicalName "repositoryenvironmentladdergovernance" ;
    usf:promotesFrom env:localdev ;
    usf:promotesTo env:localdev .
prom:usfdevteststagingartifactpromotioncontract a usf:Promotion ;
    usf:canonicalName "usfdevteststagingartifactpromotioncontract" ;
    usf:promotesFrom env:localdev ;
    usf:promotesTo env:localdev .
